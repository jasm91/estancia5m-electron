var _alCharts = {};      // referencias a Chart.js para destruirlas al cambiar lote
var _alAnimalesData = []; // animales del lote actual con cálculos

function initAnalisisLote() {
  // Llenar selector de lotes
  var sel = document.getElementById('al-lot-select');
  if (!sel) return;

  // Preservar selección actual si la hay
  var currentVal = sel.value;
  sel.innerHTML = '<option value="">Seleccionar lote...</option>';

  var lots = (db.lots || []).filter(function(l) {
    var st = (l.status || '').toLowerCase();
    return st !== 'sold' && st !== 'vendido' && (l.animal_count || 0) > 0;
  }).sort(function(a, b) { return (a.code || '').localeCompare(b.code || ''); });

  lots.forEach(function(l) {
    var opt = document.createElement('option');
    opt.value = l.code;
    var statusLabel = (l.status || '').toLowerCase() === 'cuarentena' ? ' [CUARENTENA]' : '';
    opt.textContent = l.code + ' — ' + (l.category || '') + statusLabel + ' (' + l.animal_count + ' cab)';
    sel.appendChild(opt);
  });

  if (currentVal) sel.value = currentVal;

  if (sel.value) renderAnalisisLote();
}

function _alDestroyCharts() {
  Object.keys(_alCharts).forEach(function(k) {
    try { if (_alCharts[k]) _alCharts[k].destroy(); } catch(e) {}
  });
  _alCharts = {};
}

// Calcular GMD individual: peso final - peso inicial / días
function _alCalcAnimalStats(anim, fallbackEntryDate) {
  var pesajes = (anim.pesajes || []).filter(function(p) { return p && p.peso && p.fecha; });
  pesajes.sort(function(a, b) { return String(a.fecha).localeCompare(String(b.fecha)); });

  var pesoActual = pesajes.length ? pesajes[pesajes.length - 1].peso : null;
  var pesoIngreso = pesajes.length ? pesajes[0].peso : null;
  var fechaIngreso = pesajes.length ? pesajes[0].fecha : fallbackEntryDate;
  var fechaUltima = pesajes.length ? pesajes[pesajes.length - 1].fecha : null;

  var gmd = null;
  var deltaTotal = null;
  var dias = null;
  if (pesajes.length >= 2 && pesoActual && pesoIngreso) {
    deltaTotal = pesoActual - pesoIngreso;
    var t1 = new Date(fechaIngreso).getTime();
    var t2 = new Date(fechaUltima).getTime();
    dias = Math.max(1, Math.round((t2 - t1) / (1000 * 60 * 60 * 24)));
    gmd = deltaTotal / dias;
  }

  return {
    id: String(anim.animal_id || anim.id || '?'),
    raza: anim.raza || anim.breed || '-',
    pesoActual: pesoActual,
    pesoIngreso: pesoIngreso,
    deltaTotal: deltaTotal,
    gmd: gmd,
    pesajes: pesajes,
    fechaIngreso: fechaIngreso,
    fechaUltima: fechaUltima,
    nPesajes: pesajes.length
  };
}

function _alFmtNum(n, decimals) {
  if (n === null || n === undefined || isNaN(n)) return '-';
  return Number(n).toFixed(decimals != null ? decimals : 0);
}

function renderAnalisisLote() {
  var sel = document.getElementById('al-lot-select');
  if (!sel || !sel.value) {
    document.getElementById('al-empty-state').style.display = 'block';
    document.getElementById('al-content').style.display = 'none';
    document.getElementById('al-export-btn').style.display = 'none';
    return;
  }

  var lotCode = sel.value;
  var lot = (db.lots || []).find(function(l) { return l.code === lotCode; });
  if (!lot) {
    toast('Lote no encontrado', 'error');
    return;
  }

  // Cargar animales
  var animDB = {};
  try { animDB = JSON.parse(localStorage.getItem('e5m_animals') || '{}'); } catch(e) {}
  var animales = (animDB[lotCode] || []).map(function(a) {
    return _alCalcAnimalStats(a, lot.entry_date);
  });
  _alAnimalesData = animales;

  if (!animales.length) {
    // v1.8.5: en vez de cortar TODO, mostrar lo que sí hay (timeline, sanidad, datos de lote).
    // Muchos lotes se registran solo por conteo (sin marcar individual) — igual tienen historial.
    var nCab = lot.animal_count || 0;
    document.getElementById('al-empty-state').innerHTML =
      '<div style="font-size:40px;margin-bottom:12px">📊</div>' +
      '<div style="font-size:15px;margin-bottom:6px;color:var(--text)">El lote ' + escH(lotCode) + ' tiene ' + nCab + ' animales registrados por conteo</div>' +
      '<div style="font-size:13px;margin-bottom:6px">No hay pesos individuales, así que no se puede mostrar el análisis de peso/GMD por animal.</div>' +
      '<div style="font-size:12px;color:var(--muted)">Para ver gráficos individuales, registrá pesajes en Lotes › Pesajes, o marcá el lote individualmente.</div>';
    document.getElementById('al-empty-state').style.display = 'block';
    document.getElementById('al-content').style.display = 'none';
    document.getElementById('al-export-btn').style.display = 'none';
    return;
  }

  document.getElementById('al-empty-state').style.display = 'none';
  document.getElementById('al-content').style.display = 'block';
  document.getElementById('al-export-btn').style.display = 'inline-block';

  _alDestroyCharts();
  // Envolver cada renderer en try/catch para que un error en uno no rompa los demás
  function _alSafeRender(name, fn) {
    try { fn(); } catch(err) { console.error('[Análisis Lote] Error en ' + name + ':', err); }
  }
  _alSafeRender('Header',     function() { _alRenderHeader(lot, animales); });
  _alSafeRender('KPIs',       function() { _alRenderKPIs(lot, animales); });
  _alSafeRender('Alerts',     function() { _alRenderAlerts(lot, animales); });
  _alSafeRender('Histograma', function() { _alRenderHistograma(animales); });
  _alSafeRender('Curva',      function() { _alRenderCurva(animales); });
  _alSafeRender('Proyección', function() { _alRenderProyeccion(lot, animales); });
  _alSafeRender('GMD',        function() { _alRenderGMD(animales); });
  _alSafeRender('Insights',   function() { _alRenderInsights(lot, animales); });
  _alSafeRender('Distribución', function() { _alRenderDistribucion(animales); });
  _alSafeRender('Comparativo',function() { _alRenderComparativo(lot, animales); });
  _alSafeRender('Sanidad',    function() { _alRenderSanidad(lot); });
  _alSafeRender('Timeline',   function() { _alRenderTimeline(lot); });
  _alSafeRender('Tabla',      function() { _alRenderTabla(animales, 'todos'); });
}

function _alRenderHeader(lot, animales) {
  document.getElementById('al-lot-code').textContent = lot.code;

  var statusEl = document.getElementById('al-lot-status');
  var status = (lot.status || '').toLowerCase();
  if (status === 'cuarentena') {
    statusEl.textContent = '● Cuarentena';
    statusEl.style.background = 'rgba(255, 149, 0, 0.12)';
    statusEl.style.color = 'var(--orange, #FF9500)';
    statusEl.style.borderColor = 'rgba(255, 149, 0, 0.3)';
  } else {
    statusEl.textContent = '● Activo';
    statusEl.style.background = 'rgba(57, 211, 83, 0.12)';
    statusEl.style.color = 'var(--green)';
    statusEl.style.borderColor = 'rgba(57, 211, 83, 0.3)';
  }

  var meta = '';
  if (lot.category) meta += '<span><span style="color:var(--amber)">🐂</span> <strong style="color:var(--text)">' + escH(lot.category) + '</strong></span>';
  if (lot.breed) meta += '<span><span style="color:var(--amber)">🧬</span> ' + escH(lot.breed) + '</span>';
  if (lot.paddock) meta += '<span><span style="color:var(--amber)">🌾</span> ' + escH(lot.paddock) + '</span>';
  if (lot.supplier) meta += '<span><span style="color:var(--amber)">🏷️</span> ' + escH(lot.supplier) + '</span>';

  // Días desde ingreso
  if (lot.entry_date) {
    var dias = Math.round((new Date().getTime() - new Date(lot.entry_date).getTime()) / (1000 * 60 * 60 * 24));
    meta += '<span><span style="color:var(--amber)">📅</span> Ingreso: ' + escH(lot.entry_date) + ' <strong style="color:var(--text)">(' + dias + ' días)</strong></span>';
  }

  document.getElementById('al-lot-meta').innerHTML = meta;

  // Última fecha de pesaje
  var lastDates = animales.filter(function(a) { return a.fechaUltima; }).map(function(a) { return a.fechaUltima; }).sort();
  document.getElementById('al-last-weight').textContent = lastDates.length ? lastDates[lastDates.length - 1] : '-';
}

function _alRenderKPIs(lot, animales) {
  var pesoActuales = animales.filter(function(a) { return a.pesoActual; }).map(function(a) { return a.pesoActual; });
  var gmds = animales.filter(function(a) { return a.gmd != null; }).map(function(a) { return a.gmd; });

  var promPeso = pesoActuales.length ? (pesoActuales.reduce(function(s, x) { return s + x; }, 0) / pesoActuales.length) : 0;
  var pesoTotal = pesoActuales.reduce(function(s, x) { return s + x; }, 0);
  var promGmd = gmds.length ? (gmds.reduce(function(s, x) { return s + x; }, 0) / gmds.length) : 0;

  // CV (coeficiente de variación)
  var cv = 0;
  if (pesoActuales.length > 1) {
    var variance = pesoActuales.reduce(function(s, x) { return s + Math.pow(x - promPeso, 2); }, 0) / pesoActuales.length;
    var sigma = Math.sqrt(variance);
    cv = promPeso > 0 ? (sigma / promPeso) * 100 : 0;
  }

  // Rezagados (GMD < 0.5)
  var rezagados = gmds.filter(function(g) { return g < 0.5; }).length;

  var kpis = [
    { label: 'Cabezas', value: animales.length, unit: '', color: 'amber', trend: '' },
    { label: 'Peso promedio', value: _alFmtNum(promPeso, 0), unit: 'kg', color: 'green', trend: '' },
    { label: 'GMD promedio', value: _alFmtNum(promGmd, 2), unit: 'kg/d', color: 'blue', trend: gmds.length ? '▲ ' + gmds.length + ' animales con datos' : 'sin datos' },
    { label: 'Uniformidad (CV)', value: _alFmtNum(cv, 1), unit: '%', color: 'purple', trend: cv < 10 ? '▲ uniforme' : (cv < 15 ? '~ aceptable' : '▼ disperso') },
    { label: 'Peso total', value: _alFmtNum(pesoTotal, 0).replace(/\B(?=(\d{3})+(?!\d))/g, ','), unit: 'kg', color: 'orange', trend: '' },
    { label: 'Rezagados', value: rezagados, unit: '', color: 'red', trend: rezagados ? 'GMD < 0.5 kg/d' : 'sin rezagos' }
  ];

  var html = kpis.map(function(k) {
    var trendClass = k.trend.indexOf('▲') >= 0 ? 'up' : (k.trend.indexOf('▼') >= 0 ? 'down' : 'flat');
    var trendColor = trendClass === 'up' ? 'var(--green)' : (trendClass === 'down' ? 'var(--red)' : 'var(--muted)');
    var bg = {
      amber: 'var(--amber)',
      green: 'var(--green)',
      blue: 'var(--blue, #58A6FF)',
      purple: 'var(--purple, #A371F7)',
      orange: 'var(--orange, #FF9500)',
      red: 'var(--red)'
    }[k.color] || 'var(--amber)';
    return '<div style="background:var(--sur);border:1px solid var(--bor);border-radius:8px;padding:14px 16px;position:relative;overflow:hidden">' +
      '<div style="position:absolute;left:0;top:0;bottom:0;width:3px;background:' + bg + '"></div>' +
      '<div style="font-family:\'DM Mono\',monospace;font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:6px">' + k.label + '</div>' +
      '<div style="font-size:22px;font-weight:700;color:var(--text);font-family:\'DM Mono\',monospace;letter-spacing:-0.01em">' +
        k.value + (k.unit ? '<span style="font-size:12px;color:var(--muted);font-weight:400;margin-left:3px">' + k.unit + '</span>' : '') +
      '</div>' +
      (k.trend ? '<div style="font-size:11px;margin-top:4px;font-family:\'DM Mono\',monospace;color:' + trendColor + '">' + k.trend + '</div>' : '') +
    '</div>';
  }).join('');

  document.getElementById('al-kpis').innerHTML = html;
}

function _alRenderAlerts(lot, animales) {
  var html = '';
  // Listos para faena (peso target >= 450 kg para novillos, configurable)
  var pesoFaena = (lot.category || '').toLowerCase().indexOf('novillo') >= 0 ? 450 : 0;
  if (pesoFaena > 0) {
    var listosFaena = animales.filter(function(a) { return a.pesoActual && a.pesoActual >= pesoFaena; }).length;
    if (listosFaena > 0) {
      var pct = ((listosFaena / animales.length) * 100).toFixed(0);
      html += '<div style="background:rgba(57,211,83,0.06);border:1px solid rgba(57,211,83,0.25);border-radius:8px;padding:12px 14px;margin-bottom:10px;display:flex;align-items:flex-start;gap:12px;font-size:13px">' +
        '<div style="font-size:18px">✅</div><div>' +
        '<div style="font-weight:700;margin-bottom:2px">' + listosFaena + ' animales superaron el peso de faena (≥' + pesoFaena + ' kg)</div>' +
        '<div style="color:var(--muted);font-size:12px">' + pct + '% del lote listo para venta. Considerá venta parcial o seguir engorde.</div>' +
        '</div></div>';
    }
  }
  // Rezagados con detalles
  var rezagados = animales.filter(function(a) { return a.gmd != null && a.gmd < 0.5; });
  if (rezagados.length > 0) {
    var ids = rezagados.slice(0, 6).map(function(a) { return a.id; }).join(', ') + (rezagados.length > 6 ? '...' : '');
    html += '<div style="background:rgba(255,149,0,0.06);border:1px solid rgba(255,149,0,0.25);border-radius:8px;padding:12px 14px;margin-bottom:10px;display:flex;align-items:flex-start;gap:12px;font-size:13px">' +
      '<div style="font-size:18px">⚠️</div><div>' +
      '<div style="font-weight:700;margin-bottom:2px">' + rezagados.length + ' animales con GMD bajo (< 0.5 kg/día)</div>' +
      '<div style="color:var(--muted);font-size:12px">IDs: ' + escH(ids) + '. Revisar sanidad o separar a lote especial.</div>' +
      '</div></div>';
  }
  // Sin pesajes recientes
  var sinPesaje = animales.filter(function(a) { return a.nPesajes < 2; }).length;
  if (sinPesaje > animales.length * 0.5) {
    html += '<div style="background:rgba(88,166,255,0.06);border:1px solid rgba(88,166,255,0.25);border-radius:8px;padding:12px 14px;margin-bottom:10px;display:flex;align-items:flex-start;gap:12px;font-size:13px">' +
      '<div style="font-size:18px">ℹ️</div><div>' +
      '<div style="font-weight:700;margin-bottom:2px">' + sinPesaje + ' animales con menos de 2 pesajes</div>' +
      '<div style="color:var(--muted);font-size:12px">No se puede calcular GMD individual sin al menos 2 pesajes. Programá un pesaje del lote.</div>' +
      '</div></div>';
  }
  document.getElementById('al-alerts').innerHTML = html;
}

function _alRenderHistograma(animales) {
  var pesoActuales = animales.filter(function(a) { return a.pesoActual; }).map(function(a) { return a.pesoActual; });
  if (!pesoActuales.length) {
    document.getElementById('al-hist-subtitle').textContent = 'Sin datos de pesaje';
    return;
  }

  // Calcular buckets dinámicos
  var minP = Math.min.apply(null, pesoActuales);
  var maxP = Math.max.apply(null, pesoActuales);
  var rango = maxP - minP;
  var bucketSize = rango > 100 ? 20 : (rango > 50 ? 10 : 5);
  // Redondear el min hacia abajo al múltiplo de bucketSize
  var startP = Math.floor(minP / bucketSize) * bucketSize;
  var endP = Math.ceil(maxP / bucketSize) * bucketSize;

  var labels = [];
  var counts = [];
  for (var b = startP; b < endP; b += bucketSize) {
    labels.push(b + '-' + (b + bucketSize));
    counts.push(0);
  }
  pesoActuales.forEach(function(p) {
    var idx = Math.min(labels.length - 1, Math.floor((p - startP) / bucketSize));
    if (idx >= 0) counts[idx]++;
  });

  // Colores por gradient (rojo bajo → verde medio → azul alto)
  var colors = labels.map(function(_, i) {
    var pct = i / Math.max(1, labels.length - 1);
    if (pct < 0.2) return '#E74C3C';
    if (pct < 0.4) return '#FF9500';
    if (pct < 0.6) return '#C9A84C';
    if (pct < 0.8) return '#39D353';
    return '#58A6FF';
  });

  document.getElementById('al-hist-subtitle').textContent = pesoActuales.length + ' animales · buckets de ' + bucketSize + ' kg';

  // Stats boxplot
  var sorted = pesoActuales.slice().sort(function(a, b) { return a - b; });
  var median = sorted[Math.floor(sorted.length / 2)];
  var q1 = sorted[Math.floor(sorted.length * 0.25)];
  var q3 = sorted[Math.floor(sorted.length * 0.75)];

  var statsHtml =
    _alStatCell('Mín', minP + ' kg') +
    _alStatCell('Q1', q1 + ' kg') +
    _alStatCell('Mediana', median + ' kg') +
    _alStatCell('Q3', q3 + ' kg') +
    _alStatCell('Máx', maxP + ' kg');
  document.getElementById('al-boxplot-stats').innerHTML = statsHtml;

  var ctx = document.getElementById('al-chart-histograma');
  if (ctx) {
    _alCharts.hist = new Chart(ctx, {
      type: 'bar',
      data: {
        labels: labels,
        datasets: [{ label: 'Animales', data: counts, backgroundColor: colors, borderRadius: 4, borderSkipped: false }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: { label: function(c) { return c.parsed.y + ' animales (' + ((c.parsed.y / animales.length) * 100).toFixed(1) + '%)'; } }
          }
        },
        scales: {
          x: { grid: { display: false }, ticks: { font: { size: 10 } } },
          y: { beginAtZero: true, grid: { color: '#2A2A2A' }, ticks: { stepSize: 1, font: { size: 10 } } }
        }
      }
    });
  }
}

function _alStatCell(label, val) {
  return '<div style="background:var(--bg2,#161616);border:1px solid var(--bor);border-radius:6px;padding:10px;text-align:center">' +
    '<div style="font-family:\'DM Mono\',monospace;font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:3px">' + label + '</div>' +
    '<div style="font-family:\'DM Mono\',monospace;font-size:14px;font-weight:700;color:var(--text)">' + val + '</div>' +
  '</div>';
}

function _alRenderCurva(animales) {
  // Agrupar pesajes por fecha y calcular promedio/min/max del lote
  var fechasMap = {};
  animales.forEach(function(a) {
    a.pesajes.forEach(function(p) {
      if (!fechasMap[p.fecha]) fechasMap[p.fecha] = [];
      fechasMap[p.fecha].push(p.peso);
    });
  });
  var fechas = Object.keys(fechasMap).sort();

  if (fechas.length < 2) {
    document.getElementById('al-curva-subtitle').textContent = 'Insuficientes pesajes para graficar curva';
    return;
  }

  var prom = fechas.map(function(f) {
    var arr = fechasMap[f];
    return arr.reduce(function(s, x) { return s + x; }, 0) / arr.length;
  });
  var minArr = fechas.map(function(f) { return Math.min.apply(null, fechasMap[f]); });
  var maxArr = fechas.map(function(f) { return Math.max.apply(null, fechasMap[f]); });

  document.getElementById('al-curva-subtitle').textContent = fechas.length + ' fechas de pesaje';

  var ctx = document.getElementById('al-chart-curva');
  if (ctx) {
    _alCharts.curva = new Chart(ctx, {
      type: 'line',
