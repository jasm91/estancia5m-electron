// ─────────────────────────────────────────────────────────────

// Normaliza un string de tipo de sal: lower, trim, sin acentos, sin "sal" inicial.
// "Sal Mineral" / "sal mineral " / "SAL MINERAL" → "mineral"
// "Proteinada" / "sal proteinada" → "proteinada"
// "" / null / "sal" → "sin clasificar"
function _salNormalizeTipo(raw) {
  if (raw == null) return 'sin clasificar';
  var s = String(raw).toLowerCase().trim();
  if (!s) return 'sin clasificar';
  // Quitar acentos comunes
  s = s.replace(/[áàä]/g,'a').replace(/[éèë]/g,'e').replace(/[íìï]/g,'i').replace(/[óòö]/g,'o').replace(/[úùü]/g,'u');
  // Quitar prefijo "sal " si lo hay
  s = s.replace(/^sal\s+/, '').trim();
  if (!s || s === 'sal') return 'sin clasificar';
  return s;
}

// Label legible para mostrar (capitalize primera palabra)
function _salTipoLabel(normalized) {
  if (!normalized) return 'Sin clasificar';
  return normalized.charAt(0).toUpperCase() + normalized.slice(1);
}

// Paleta consistente para tipos. Hash determinista por nombre normalizado.
var _SAL_TIPO_COLORS = ['#7F77DD','#1D9E75','#D85A30','#378ADD','#BA7517','#993556','#5DCAA5','#F0997B','#97C459','#EF9F27'];
function _salTipoColor(normalized) {
  if (!normalized || normalized === 'sin clasificar') return '#888780';
  var h = 0;
  for (var i = 0; i < normalized.length; i++) h = (h * 31 + normalized.charCodeAt(i)) >>> 0;
  return _SAL_TIPO_COLORS[h % _SAL_TIPO_COLORS.length];
}

// Devuelve [{normalized, label, count, kg}] ordenado por kg desc, contando todos los registros de db.sal.
function _salGetTipos() {
  var byTipo = {};
  (db.sal || []).forEach(function(r){
    if (!r) return;
    var n = _salNormalizeTipo(r.tipo);
    if (!byTipo[n]) byTipo[n] = { normalized: n, label: _salTipoLabel(n), count: 0, kg: 0 };
    byTipo[n].count++;
    byTipo[n].kg += parseFloat(r.qty || r.total || r.kg || 0) || 0;
  });
  return Object.keys(byTipo).map(function(k){ return byTipo[k]; })
    .sort(function(a,b){ return b.kg - a.kg; });
}

// Filtra una lista de registros por tipo normalizado. '' = todas.
function _salFilterByTipo(records, tipoNorm) {
  if (!tipoNorm) return records;
  return records.filter(function(r){ return _salNormalizeTipo(r && r.tipo) === tipoNorm; });
}

