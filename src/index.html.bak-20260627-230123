function searchPreciosOnline() {
  var el = document.getElementById('int-tab-precios');
  if (!el) return;
  var searchDiv = document.getElementById('precios-search-result');
  if (!searchDiv) {
    searchDiv = document.createElement('div');
    searchDiv.id = 'precios-search-result';
    searchDiv.style.cssText = 'margin-bottom:14px';
    var firstCard = el.querySelector('.card');
    if (firstCard) firstCard.insertBefore(searchDiv, firstCard.children[1]);
  }
  searchDiv.innerHTML = '<div style="padding:12px;background:var(--sur2);border-radius:8px;font-size:12px"><div class="spinner" style="width:20px;height:20px;display:inline-block;vertical-align:middle;margin-right:8px"></div> Buscando precios actuales en Bolivia...</div>';

  var apiUrl = getApiUrl();
  var token = localStorage.getItem('e5m_api_token') || '';
  fetch(apiUrl + '/market-prices-search', {
    method: 'POST',
    headers: {'Content-Type':'application/json', 'Authorization':'Bearer '+token},
    body: JSON.stringify({query: 'precios ganado bovino Santa Cruz Bolivia'})
  }).then(function(r){return r.json();})
  .then(function(d){
    if (d.error) throw new Error(d.error);
    var text = d.text || 'No se encontraron resultados.';
    var sources = '';
    if (d.sources && d.sources.length) {
      sources = '<div style="margin-top:8px;font-size:10px;color:var(--muted)">Fuentes: ';
      d.sources.forEach(function(s){
        sources += '<a href="'+s.url+'" target="_blank" style="color:var(--amber2);margin-right:8px">'+escH(s.title)+'</a>';
      });
      sources += '</div>';
    }
    searchDiv.innerHTML = '<div style="padding:14px;background:rgba(245,166,35,.06);border:1px solid rgba(245,166,35,.15);border-radius:8px">' +
      '<div style="font-size:12px;font-weight:700;color:var(--amber2);margin-bottom:6px">🔍 Referencia de mercado (IA + Google Search)</div>' +
      '<div style="font-size:12px;color:var(--text);line-height:1.6;white-space:pre-wrap">' + escH(text).replace(/\n/g,'<br>').replace(/\*\*([^*]+)\*\*/g,'<b>$1</b>') + '</div>' +
      sources +
      '<div style="margin-top:8px;font-size:10px;color:var(--muted)">Consultado: '+new Date().toLocaleString()+' — Los precios son referenciales</div></div>';
  }).catch(function(e){
    searchDiv.innerHTML = '<div style="padding:12px;background:rgba(239,68,68,.1);border-radius:8px;font-size:12px;color:var(--red)">Error buscando precios: '+e.message+'</div>';
  });
}

function renderPrecios() {
  var el = document.getElementById('int-tab-precios');
  if (!el) return;
  var precios = JSON.parse(localStorage.getItem('e5m_market_prices') || '[]');

  var html = '<div class="card" style="padding:20px">';
  html += '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px">';
  html += '<div style="font-size:15px;font-weight:700">📊 Precios de Mercado</div>';
  html += '<button class="btn btn-ghost btn-sm" onclick="searchPreciosOnline()" style="margin-right:6px;font-size:11px">🔍 Buscar precios</button><button class="btn btn-primary btn-sm" onclick="openAddPrecio()">+ Registrar precio</button></div>';

  // Reference info
  html += '<div style="padding:10px 14px;background:rgba(245,166,35,.08);border:1px solid rgba(245,166,35,.2);border-radius:8px;margin-bottom:14px;font-size:11px;color:var(--muted);line-height:1.6">';
  html += '📡 <b>Fuentes de referencia Bolivia:</b><br>';
  html += '• <a href="https://fegasacruz.org" target="_blank" style="color:var(--amber2)">FEGASACRUZ</a> — Precios semanales de remate (El Marucho, FERCOGAN)<br>';
  html += '• <a href="https://siip.produccion.gob.bo" target="_blank" style="color:var(--amber2)">SIIP</a> — Sistema de Info del Min. de Produccion<br>';
  html += '• Registra los precios que escuches de frigorificos, remates y vecinos para llevar tu propio historico.';
  html += '</div>';

  if (precios.length) {
    // Summary
    var latest = precios[precios.length - 1];
    var avg30 = precios.filter(function(p){return Date.now() - new Date(p.fecha).getTime() < 2592000000;});
    var avg30Val = avg30.length ? Math.round(avg30.reduce(function(s,p){return s+p.precio;},0)/avg30.length*100)/100 : 0;
    var trend = precios.length >= 2 ? precios[precios.length-1].precio - precios[precios.length-2].precio : 0;

    html += '<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:14px">';
    html += '<div class="kpi-card"><div class="kpi-val" style="color:var(--amber2)">'+latest.precio+' Bs/kg</div><div class="kpi-lbl">Ultimo registrado ('+latest.fecha+')</div></div>';
    html += '<div class="kpi-card"><div class="kpi-val">'+avg30Val+' Bs/kg</div><div class="kpi-lbl">Promedio 30 dias</div></div>';
    html += '<div class="kpi-card"><div class="kpi-val" style="color:'+(trend>=0?'var(--green)':'var(--red)')+'">'+
      (trend>=0?'↑':'↓')+' '+Math.abs(trend).toFixed(1)+' Bs/kg</div><div class="kpi-lbl">Tendencia</div></div>';
    html += '</div>';

    // Price chart (simple SVG)
    var maxP = Math.max.apply(null, precios.map(function(p){return p.precio;}));
    var minP = Math.min.apply(null, precios.map(function(p){return p.precio;}));
    var range = maxP - minP || 1;
    var chartW = 500, chartH = 120;
    var path = '';
    precios.forEach(function(p, i) {
      var x = i * (chartW / Math.max(1,precios.length-1)) + 10;
      var y = chartH - ((p.precio - minP) / range * (chartH - 30)) + 15;
      path += (i===0?'M':'L')+x+','+y;
    });
    html += '<div style="margin-bottom:14px"><svg viewBox="0 0 '+(chartW+20)+' '+(chartH+25)+'" style="width:100%;height:160px">';
    html += '<text x="4" y="12" fill="var(--muted)" font-size="10">Historial de precios (Bs/kg)</text>';
    html += '<path d="'+path+'" fill="none" stroke="var(--amber2)" stroke-width="2"/>';
    precios.forEach(function(p, i) {
      var x = i * (chartW / Math.max(1,precios.length-1)) + 10;
      var y = chartH - ((p.precio - minP) / range * (chartH - 30)) + 15;
      html += '<circle cx="'+x+'" cy="'+y+'" r="3" fill="var(--amber2)"/>';
      if (i % Math.ceil(precios.length/8) === 0) {
        html += '<text x="'+x+'" y="'+(chartH+22)+'" fill="var(--muted)" font-size="8" text-anchor="middle">'+p.fecha.slice(5)+'</text>';
      }
    });
    html += '<text x="2" y="20" fill="var(--green)" font-size="9">'+maxP+'</text>';
    html += '<text x="2" y="'+chartH+'" fill="var(--red)" font-size="9">'+minP+'</text>';
    html += '</svg></div>';

    // Table
    html += '<table class="tbl" style="font-size:12px"><thead><tr><th>Fecha</th><th>Precio Bs/kg</th><th>Fuente</th><th>Tipo</th><th>Notas</th><th></th></tr></thead><tbody>';
    precios.slice().reverse().slice(0,20).forEach(function(p) {
      html += '<tr><td>'+p.fecha+'</td><td style="font-weight:700;color:var(--amber2)">'+p.precio+' Bs/kg</td><td>'+escH(p.fuente||'-')+'</td><td>'+escH(p.tipo||'gancho')+'</td><td style="font-size:11px;color:var(--muted)">'+escH(p.notas||'-')+'</td>';
      html += '<td><button class="btn btn-ghost btn-sm" style="color:var(--red)" onclick="deletePrecio(\''+p.id+'\')">✕</button></td></tr>';
    });
    html += '</tbody></table>';
  } else {
    html += '<div style="text-align:center;padding:30px;color:var(--muted)"><div style="font-size:28px;margin-bottom:8px">📊</div>Sin precios registrados. Agrega el primer precio de referencia.</div>';
  }
  html += '</div>';
  el.innerHTML = html;
}

