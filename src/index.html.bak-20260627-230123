function saveTankConfig() {
  var listEl = document.getElementById('tank-config-list');
  if (!listEl) return;
  var oldTanks = getDieselTanks();
  var newTanks = [];
  var rows = listEl.querySelectorAll('[id^="tank-row-"]');
  rows.forEach(function(row, i) {
    var nameEl = row.querySelector('[id^="tc-name-"]');
    var capEl = row.querySelector('[id^="tc-cap-"]');
    var lvlEl = row.querySelector('[id^="tc-lvl-"]');
    var name = (nameEl ? nameEl.value : '').trim() || ('Tanque ' + (i + 1));
    var cap = parseFloat(capEl ? capEl.value : 1000) || 1000;
    var lvl = parseFloat(lvlEl ? lvlEl.value : 0) || 0;
    var oldTank = oldTanks[i];
    newTanks.push({id:(oldTank&&oldTank.id)?oldTank.id:'tank_'+Date.now()+'_'+i, name:name, capacity:cap, current_level:Math.min(lvl,cap)});
  });
  if (!newTanks.length) { toast('Agrega al menos un tanque','error'); return; }
  saveDieselTanks(newTanks);
  closeModal('modal-tank-config');
  renderDieselDesktop();
  toast('Tanques: ' + newTanks.map(function(t){return t.name;}).join(', '),'success');
}

