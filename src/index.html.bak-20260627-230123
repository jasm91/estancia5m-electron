    else if (a.gmd >= 0.7) estado = '<span style="display:inline-block;padding:2px 8px;border-radius:10px;font-family:\'DM Mono\',monospace;font-size:10px;background:rgba(88,166,255,0.12);color:var(--blue,#58A6FF)">Normal</span>';
    else if (a.gmd >= 0.5) estado = '<span style="display:inline-block;padding:2px 8px;border-radius:10px;font-family:\'DM Mono\',monospace;font-size:10px;background:rgba(201,168,76,0.12);color:var(--amber)">GMD bajo</span>';
    else estado = '<span style="display:inline-block;padding:2px 8px;border-radius:10px;font-family:\'DM Mono\',monospace;font-size:10px;background:rgba(231,76,60,0.12);color:var(--red)">⚠ Atención</span>';

    var deltaColor = '';
    if (a.deltaTotal != null) {
      if (a.deltaTotal < 0) deltaColor = 'color:var(--red)';
      else if (a.deltaTotal >= 100) deltaColor = 'color:var(--green)';
    }

    html += '<tr style="border-bottom:1px solid var(--bor)">' +
      '<td style="padding:9px 10px;font-family:\'DM Mono\',monospace"><strong>' + escH(a.id) + '</strong></td>' +
      '<td style="padding:9px 10px;color:var(--text);font-size:12px">' + escH(a.raza) + '</td>' +
      '<td style="padding:9px 10px;text-align:right;font-family:\'DM Mono\',monospace">' + (a.pesoIngreso ? a.pesoIngreso + ' kg' : '-') + '</td>' +
      '<td style="padding:9px 10px;text-align:right;font-family:\'DM Mono\',monospace"><strong>' + (a.pesoActual ? a.pesoActual + ' kg' : '-') + '</strong></td>' +
      '<td style="padding:9px 10px;text-align:right;font-family:\'DM Mono\',monospace;' + deltaColor + '">' + (a.deltaTotal != null ? (a.deltaTotal >= 0 ? '+' : '') + a.deltaTotal + ' kg' : '-') + '</td>' +
      '<td style="padding:9px 10px;text-align:right;font-family:\'DM Mono\',monospace"><strong>' + (a.gmd != null ? a.gmd.toFixed(2) : '-') + '</strong></td>' +
      '<td style="padding:9px 10px;text-align:right;font-family:\'DM Mono\',monospace;color:var(--muted)">' + a.nPesajes + '</td>' +
      '<td style="padding:9px 10px">' + estado + '</td>' +
    '</tr>';
  });
  document.getElementById('al-tbody-animales').innerHTML = html;
}

