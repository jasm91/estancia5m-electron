function calcDieselTotal() {
  var l=parseFloat((document.getElementById('diesel-litros')||{}).value)||0;
  var p=parseFloat((document.getElementById('diesel-precio')||{}).value)||0;
  var t=document.getElementById('diesel-total');
  if(t) t.value=l&&p?'Bs. '+(l*p).toFixed(2):'';
  // Warn if despacho exceeds tank
  var type=(document.getElementById('diesel-tx-type')||{}).value;
  var warn=document.getElementById('diesel-stock-warn');
  if(warn && l>0) {
    var tankId2=(document.getElementById('diesel-tank-sel')||{}).value;
    var tanks2=getDieselTanks();
    var tank=getTankById(tanks2,tankId2);
    if(type==='recarga' && (tank.current_level+l)>tank.capacity) {
      var espacio=Math.round((tank.capacity-tank.current_level)*10)/10;
      warn.style.display='block'; warn.textContent='⚠️ Excede capacidad: '+tank.name+' tiene '+tank.current_level+'/'+tank.capacity+' L. Espacio: '+espacio+' L';
    } else if(type!=='recarga' && l>tank.current_level) {
      warn.style.display='block'; warn.textContent='⚠️ Stock insuficiente: '+tank.current_level+' L disponibles';
    } else { warn.style.display='none'; }
  } else if(warn) { warn.style.display='none'; }
}

function saveDiesel() {
  var type=(document.getElementById('diesel-tx-type')||{}).value||'despacho';
  var fecha=(document.getElementById('diesel-fecha')||{}).value||'';
  // FIX v1.4.34: no permitir fechas futuras
  if(!validateNotFuture(fecha, 'fecha del despacho')) return;
  var litros=parseFloat((document.getElementById('diesel-litros')||{}).value)||0;
  var obs=((document.getElementById('diesel-obs')||{}).value||'').trim();
  if(!fecha||!litros){toast('Completa fecha y litros','error');return;}
  if(!obs){toast('Ingresa observaciones','error');return;}
  var tankId=(document.getElementById('diesel-tank-sel')||{}).value;
  var tanks=getDieselTanks();
  var tank=getTankById(tanks,tankId);

  // ── TRASPASO: dos registros (egreso en origen + ingreso en destino) ──
  if (type === 'traspaso') {
    var tankDestId = (document.getElementById('diesel-tank-dest-sel')||{}).value;
    if (!tankDestId) { toast('Seleccioná el tanque destino', 'error'); return; }
    if (tankDestId === tankId) { toast('Origen y destino deben ser distintos', 'error'); return; }
    var tankDest = getTankById(tanks, tankDestId);
    if (litros > tank.current_level) {
      toast('Stock insuficiente en ' + tank.name + ': ' + tank.current_level + ' L disponibles', 'error');
      return;
    }
    if ((tankDest.current_level + litros) > tankDest.capacity) {
      var espacio = Math.round((tankDest.capacity - tankDest.current_level)*10)/10;
      toast('Excede capacidad de ' + tankDest.name + ' (' + tankDest.capacity + ' L). Espacio: ' + espacio + ' L', 'error');
      return;
    }
    if(!db.diesel) db.diesel=[];
    if(!db.next_ids) db.next_ids={};
    if(!db.next_ids.diesel) db.next_ids.diesel=1;
    var nowIso = new Date().toISOString();
    // Egreso (origen)
    var recOut = {
      id: db.next_ids.diesel++,
      type: 'traspaso',
      direction: 'out',
      tank_id: tankId,
      tank_dest_id: tankDestId,
      fecha: fecha,
      litros: litros,
      obs: obs,
      vehiculo: 'Traspaso → ' + tankDest.name,
      by: 'Desktop',
      created_at: nowIso,
      traspaso_pair: nowIso // para vincular ambos
    };
    // Ingreso (destino)
    var recIn = {
      id: db.next_ids.diesel++,
      type: 'traspaso',
      direction: 'in',
      tank_id: tankDestId,
      tank_origen_id: tankId,
      fecha: fecha,
      litros: litros,
      obs: obs,
      vehiculo: 'Traspaso ← ' + tank.name,
      by: 'Desktop',
      created_at: nowIso,
      traspaso_pair: nowIso
    };
    tank.current_level = Math.round((tank.current_level - litros) * 10) / 10;
    if (tank.current_level < 0) tank.current_level = 0;
    tankDest.current_level = Math.round((tankDest.current_level + litros) * 10) / 10;
    if (tankDest.current_level > tankDest.capacity) tankDest.current_level = tankDest.capacity;
    db.diesel.push(recOut);
    db.diesel.push(recIn);
    saveDieselTanks(tanks);
    saveDB();
    closeModal('modal-diesel');
    renderDieselDesktop();
    toast('Traspaso: ' + litros + ' L de ' + tank.name + ' → ' + tankDest.name, 'success');
    try { auditLog('create', 'diesel', recOut.id, 'Traspaso ' + litros + ' L: ' + tank.name + ' → ' + tankDest.name); } catch(e){}
    if (db.diesel) try { replaceTableInRailway('diesel', db.diesel); } catch(e){}
    return;
  }

  // ── RECARGA / DESPACHO (lógica original) ──
  if(type!=='recarga' && litros>tank.current_level){toast('Stock insuficiente: '+tank.current_level+' L disponibles','error');return;}
  if(type==='recarga' && (tank.current_level+litros)>tank.capacity){
    var espacioDisp = Math.round((tank.capacity - tank.current_level)*10)/10;
    toast('Excede capacidad del tanque '+tank.name+' ('+tank.capacity+' L). Espacio disponible: '+espacioDisp+' L','error');return;
  }
  if(!db.diesel) db.diesel=[];
  if(!db.next_ids) db.next_ids={};
  if(!db.next_ids.diesel) db.next_ids.diesel=1;
  var rec={id:db.next_ids.diesel++,type:type,tank_id:tankId,fecha:fecha,litros:litros,obs:obs,by:'Desktop',created_at:new Date().toISOString()};
  if(type==='recarga'){
    rec.precio=parseFloat((document.getElementById('diesel-precio')||{}).value)||0;
    rec.total=Math.round(litros*rec.precio*100)/100;
    rec.proveedor=((document.getElementById('diesel-proveedor')||{}).value||'').trim();
    tank.current_level=Math.round((tank.current_level+litros)*10)/10;
    if(tank.current_level>tank.capacity) tank.current_level=tank.capacity;
  } else {
    var _vOtro=document.getElementById('diesel-vehiculo-otro');
    rec.vehiculo=(_vOtro&&_vOtro.style.display!=='none')?(_vOtro.value||'').trim():((document.getElementById('diesel-vehiculo')||{}).value||'').trim();
    if(!rec.vehiculo){toast('Ingresa el vehiculo/equipo','error');return;}
    tank.current_level=Math.round((tank.current_level-litros)*10)/10;
    if(tank.current_level<0) tank.current_level=0;
  }
  db.diesel.push(rec);
  saveDieselTanks(tanks);
  saveDB(); closeModal('modal-diesel'); renderDieselDesktop();
  var msgs={recarga:'Recarga: +'+litros+' L ('+tank.current_level+' L en tanque)',despacho:'Despacho: -'+litros+' L a '+rec.vehiculo+' ('+tank.current_level+' L restantes)'};
  toast(msgs[type]||'Registrado','success');
}

function deleteDiesel(id) {
