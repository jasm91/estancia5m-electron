function savePrecio() {
  var fecha = (document.getElementById('precio-fecha')||{}).value || today();
  // FIX v1.4.34: no permitir fechas futuras
  if(!validateNotFuture(fecha, 'fecha del precio')) return;
  var valor = parseFloat((document.getElementById('precio-valor')||{}).value) || 0;
  if (!valor) { toast('Ingresa el precio','error'); return; }
  var precios = JSON.parse(localStorage.getItem('e5m_market_prices') || '[]');
  precios.push({
    id: 'p_'+Date.now(), fecha: fecha, precio: valor,
    tipo: (document.getElementById('precio-tipo')||{}).value || 'gancho',
    fuente: ((document.getElementById('precio-fuente')||{}).value||'').trim(),
    notas: ((document.getElementById('precio-notas')||{}).value||'').trim()
  });
  precios.sort(function(a,b){return a.fecha.localeCompare(b.fecha);});
  localStorage.setItem('e5m_market_prices', JSON.stringify(precios));
  replaceTableInRailway('market_prices', precios);
  document.getElementById('precio-overlay').remove();
  renderPrecios();
  toast('Precio registrado: '+valor+' Bs/kg','success');
}

function deletePrecio(id) {
  if (!confirm('Eliminar este registro de precio?')) return;
  var precios = JSON.parse(localStorage.getItem('e5m_market_prices') || '[]');
  // FIX v1.4.35: capturar el record antes de borrar para audit log
  var _delPrecio = precios.find(function(p){ return p.id === id; });
  precios = precios.filter(function(p){return p.id !== id;});
  localStorage.setItem('e5m_market_prices', JSON.stringify(precios));
  replaceTableInRailway('market_prices', precios);
  renderPrecios();
  toast('Precio eliminado','success');
  // FIX v1.4.35: audit log
  try { auditLog('delete', 'market_prices', id, _delPrecio ? ('Precio ' + (_delPrecio.fecha||'?') + ' · Bs ' + (_delPrecio.precio||0) + '/kg') : ('Precio #' + id)); } catch(e){}
}


