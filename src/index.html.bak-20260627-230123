function saveLluviaDesktop() {
  var fecha=(document.getElementById('lluvia-d-fecha')||{}).value||'';
  // FIX v1.4.34: no permitir fechas futuras
  if(!validateNotFuture(fecha, 'fecha de lluvia')) return;
  var obs=((document.getElementById('lluvia-d-obs')||{}).value||'').trim();
  if(!fecha){toast('Ingresa la fecha','error');return;}
  // Read all pluvio values dynamically
  var pluvios = getPluvios();
  var values = {};
  var hasAny = false;
  pluvios.forEach(function(p) {
    var v = parseFloat((document.getElementById('lluvia-inp-'+p.key)||{}).value) || 0;
    values[p.key] = v;
    if (v > 0) hasAny = true;
  });
  if(!hasAny){toast('Ingresa al menos una lectura','error');return;}
  if(!db.lluvias) db.lluvias=[];
  var existing=db.lluvias.find(function(r){return r.fecha===fecha;});
  if(existing){
    pluvios.forEach(function(p){ existing[p.key] = values[p.key]; });
    existing.obs=obs; existing.updated_at=new Date().toISOString();
    toast('Lectura actualizada: '+fecha,'success');
  } else {
    var rec = {id:Date.now(),fecha:fecha,obs:obs,by:'Desktop',created_at:new Date().toISOString()};
    pluvios.forEach(function(p){ rec[p.key] = values[p.key]; });
    db.lluvias.push(rec);
    var resumen = pluvios.map(function(p){ return p.label+' '+values[p.key]; }).join(' / ');
    toast(resumen+' mm','success');
  }
  saveDB();
  // FIX v1.4.31: sync-push usa mergeById que no actualiza registros existentes,
  // por lo que al EDITAR una lluvia el cambio se perdía tras el próximo pull.
  // replaceTableInRailway hace REPLACE total y persiste correctamente.
  replaceTableInRailway('lluvias', db.lluvias || []);
  // FIX v1.4.35: audit log para lluvia
  try {
    var lluviaSummary = 'Lluvia ' + fecha + ': ' + pluvios.map(function(p){ return p.label+' '+values[p.key]+'mm'; }).join(' · ');
    auditLog(existing ? 'update' : 'create', 'lluvias', (existing ? existing.id : (db.lluvias[db.lluvias.length-1]||{}).id), lluviaSummary);
  } catch(e){}
  closeModal('modal-lluvia-desktop'); renderLluviasDesktop();
}

function deleteLluvia(id) {
  if(!confirm('Eliminar este registro?')) return;
  
  // FIX v1.4.35: audit log para deleteLluvia
  var _delRec_deleteLluvia = (db.lluvias || []).find(function(r){ return String(r.id) === String(id); });
  var _delSummary_deleteLluvia = _delRec_deleteLluvia ? _summarizeRecord('lluvias', _delRec_deleteLluvia) : 'Lluvia #' + id;
  try { auditLog('delete', 'lluvias', id, _delSummary_deleteLluvia); } catch(e){}
  trackDeletion(id, 'lluvias');
  db.lluvias=db.lluvias.filter(function(r){return String(r.id)!==String(id);});
  saveDB(); renderLluviasDesktop();
  replaceTableInRailway('lluvias', db.lluvias || []);
  toast('Eliminado','success');
}

