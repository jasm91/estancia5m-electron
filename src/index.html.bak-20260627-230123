function showPersonalTab(tabName, btn) {
  var tabs = ['adelantos', 'sueldos', 'bonos', 'bajas', 'contrataciones'];
  tabs.forEach(function(t) {
    var el = document.getElementById('pers-tab-' + t);
    if (el) el.style.display = t === tabName ? 'block' : 'none';
  });
  document.querySelectorAll('[id^="pers-tab-"][id$="-btn"]').forEach(function(b) { b.classList.remove('active'); });
  if (btn) btn.classList.add('active');
  // Render data on demand
  if (tabName === 'sueldos' && typeof renderHistorialSueldos === 'function') {
    try { renderHistorialSueldos(); } catch(e){}
  }
  if (tabName === 'adelantos' && typeof renderAdvances === 'function') {
    try { renderAdvances(); } catch(e){}
  }
  if (tabName === 'bonos' && typeof renderBonos === 'function') { try { renderBonos(); } catch(e){} }
  if (tabName === 'bajas' && typeof renderBajasPersonal === 'function') { try { renderBajasPersonal(); } catch(e){} }
  if (tabName === 'contrataciones' && typeof renderContrataciones === 'function') { try { renderContrataciones(); } catch(e){} }
  // Persistir última tab usada
  try { localStorage.setItem('e5m_personal_tab', tabName); } catch(e){}
}

// v1.4.74: acceso rápido a Rotación desde el sidebar (atajo a sub-pestaña dentro de Lotes)
function goToRotacion(navBtn) {
  // 1. Ir a la página Lotes
  showPage('lotes', null);
  // 2. Marcar como activo el botón del sidebar de Rotación (no el de Lotes)
