function setUpdateStatus(html, color) {
  var el = document.getElementById('update-status');
  if (el) { el.innerHTML = html; el.style.borderColor = color || 'var(--bor)'; }
}

function checkForAppUpdate() {
  var btn = document.getElementById('btn-check-update');
  if (btn) btn.disabled = true;
  setUpdateStatus('🔍 Verificando...', 'var(--blue)');

  if (window.estancia && window.estancia.app && window.estancia.app.checkUpdate) {
    window.estancia.app.checkUpdate().then(function(res) {
      if (btn) btn.disabled = false;
      if (res.status === 'available') {
        setUpdateStatus('✅ <strong>Nueva versión disponible:</strong> v' + res.version + ' (actual: v' + res.currentVersion + ')<br><span style="font-size:10px;color:var(--muted)">Haz click en "Actualizar ahora" para descargar</span>' + renderChangelogHTML(res.version), 'var(--green)');
        var forceBtn = document.getElementById('btn-force-update');
        if (forceBtn) forceBtn.style.animation = 'pulse 1.5s infinite';
      } else if (res.status === 'current') {
        setUpdateStatus('✅ Estás en la versión más reciente: <strong>v' + res.version + '</strong>', 'var(--green)');
      } else if (res.status === 'dev') {
        setUpdateStatus('🔧 ' + res.message, 'var(--amber)');
      } else {
        setUpdateStatus('❌ Error: ' + (res.message || 'No se pudo verificar'), 'var(--red)');
      }
    }).catch(function(e) {
      if (btn) btn.disabled = false;
      setUpdateStatus('❌ Error: ' + e.message, 'var(--red)');
    });
  } else {
    // Fallback: verificar via GitHub API (usa getGhToken para leer de settings/localStorage/input)
    getGhToken().then(function(ghToken){
      var headers = {};
      if (ghToken) headers['Authorization'] = 'token ' + ghToken;
      fetch('https://api.github.com/repos/jasm91/estancia5m-electron/releases/latest', { headers: headers })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (btn) btn.disabled = false;
        if (data.tag_name) {
          var latestVersion = data.tag_name.replace('v','');
          var currentVersion = _APP_VERSION || '0.0.0';
          if (latestVersion !== currentVersion) {
            setUpdateStatus('✅ <strong>Nueva versión:</strong> v' + latestVersion + ' (actual: v' + currentVersion + ')<br><span style="font-size:10px;color:var(--muted)">Haz click en "Actualizar ahora" para descargar</span>' + renderChangelogHTML(latestVersion), 'var(--green)');
          } else {
            setUpdateStatus('✅ Versión actual: <strong>v' + currentVersion + '</strong> (la más reciente)', 'var(--green)');
          }
        } else {
          setUpdateStatus('⚠️ No se pudo obtener la versión más reciente', 'var(--amber)');
        }
      }).catch(function(e) {
        if (btn) btn.disabled = false;
        setUpdateStatus('❌ Error verificando: ' + e.message, 'var(--red)');
      });
    });
  }
}

// Set up update listeners ONCE at init
(function initUpdateListeners() {
  if (!window.estancia || !window.estancia.app) return;
  if (window.estancia.app.onUpdateProgress) {
    window.estancia.app.onUpdateProgress(function(p) {
      setUpdateStatus('⬇️ Descargando: <strong>' + p.percent + '%</strong> (' + Math.round(p.transferred/1024/1024*10)/10 + ' / ' + Math.round(p.total/1024/1024*10)/10 + ' MB) · ' + Math.round(p.speed/1024) + ' KB/s', 'var(--blue)');
      window._updateReceived = true;
    });
  }
  if (window.estancia.app.onUpdateDownloaded) {
    window.estancia.app.onUpdateDownloaded(function(info) {
      window._updateReceived = true;
      if (window._updateTimer) clearInterval(window._updateTimer);
      setUpdateStatus('✅ <strong>v' + info.version + ' descargada.</strong> La app se actualizará al cerrar, o click "Instalar y reiniciar".' + renderChangelogHTML(info.version), 'var(--green)');
      var btn = document.getElementById('btn-force-update');
      if (btn) { btn.disabled = false; btn.textContent = '⬇️ Actualizar ahora'; btn.style.animation = ''; }
      var installBtn = document.getElementById('btn-install-update');
      if (installBtn) { installBtn.style.display = 'inline-block'; installBtn.style.animation = 'pulse 1.5s infinite'; }
      // Actualizar el badge del header al estado "lista para instalar"
      try { showUpdateBadge(info.version, true); showUpdateNotification(info.version, true); } catch(e){}
    });
  }
  if (window.estancia.app.onUpdateError) {
    window.estancia.app.onUpdateError(function(err) {
      if (window._updateTimer) clearInterval(window._updateTimer);
      setUpdateStatus('❌ Error: ' + err.message, 'var(--red)');
      var btn = document.getElementById('btn-force-update');
      if (btn) { btn.disabled = false; btn.textContent = '⬇️ Actualizar ahora'; }
    });
  }
})();

function forceAppUpdate() {
  var btn = document.getElementById('btn-force-update');
  if (btn) { btn.disabled = true; btn.textContent = '⏳ Descargando...'; }
  window._updateReceived = false;

  // Timer animado como fallback si no llegan eventos de progreso
  var dots = 0;
  var elapsed = 0;
  if (window._updateTimer) clearInterval(window._updateTimer);
  window._updateTimer = setInterval(function() {
    if (window._updateReceived) { clearInterval(window._updateTimer); return; }
    dots = (dots + 1) % 4;
    elapsed++;
    var dotStr = '.'.repeat(dots + 1);
    setUpdateStatus('⬇️ Descargando actualización' + dotStr + ' <span style="color:var(--muted)">(' + elapsed + 's)</span>', 'var(--blue)');
  }, 1000);

  if (window.estancia && window.estancia.app && window.estancia.app.forceUpdate) {
    window.estancia.app.forceUpdate().then(function(res) {
      if (res.status === 'current') {
        clearInterval(window._updateTimer);
        setUpdateStatus('✅ ' + res.message, 'var(--green)');
        if (btn) { btn.disabled = false; btn.textContent = '⬇️ Actualizar ahora'; }
      } else if (res.status === 'error') {
        clearInterval(window._updateTimer);
        setUpdateStatus('❌ Error: ' + res.message, 'var(--red)');
        if (btn) { btn.disabled = false; btn.textContent = '⬇️ Actualizar ahora'; }
      }
      // status 'downloading' → timer + listeners handle the UI
    }).catch(function(e) {
      clearInterval(window._updateTimer);
      setUpdateStatus('❌ Error: ' + e.message, 'var(--red)');
      if (btn) { btn.disabled = false; btn.textContent = '⬇️ Actualizar ahora'; }
    });
  } else {
    clearInterval(window._updateTimer);
    var url = 'https://github.com/jasm91/estancia5m-electron/releases/latest';
    if (window.estancia && window.estancia.app) {
      window.estancia.app.openExternal(url);
    } else {
      window.open(url, '_blank');
    }
    setUpdateStatus('🌐 Se abrió la página de descargas en el navegador', 'var(--amber)');
    if (btn) { btn.disabled = false; btn.textContent = '⬇️ Actualizar ahora'; }
  }
}

function quitAndInstallUpdate() {
  if (window.estancia && window.estancia.app) {
    // Check if update is actually downloaded
    window.estancia.app.updateStatus().then(function(s) {
      if (s.downloaded) {
        setUpdateStatus('🚀 Instalando v' + s.version + '... La app se reiniciará.', 'var(--green)');
        setTimeout(function() { window.estancia.app.quitAndInstall(); }, 1000);
      } else {
        setUpdateStatus('⚠️ La actualización no se descargó completamente. Haz click en "Actualizar ahora" primero.', 'var(--amber)');
      }
    });
  } else {
    toast('Función no disponible', 'error');
  }
}

