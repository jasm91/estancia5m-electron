function calcAjusteDiesel() {
  var tankId = (document.getElementById('ajuste-tank-sel')||{}).value;
  var tanks = getDieselTanks();
  var tank = getTankById(tanks, tankId);
  var fisico = parseFloat((document.getElementById('ajuste-fisico')||{}).value) || 0;
  var diff = Math.round((fisico - tank.current_level) * 10) / 10;
  var diffBox = document.getElementById('ajuste-diff-box');
  var diffEl = document.getElementById('ajuste-diff');
  var pctEl = document.getElementById('ajuste-merma-pct');
  if (!diffBox) return;
  if (!fisico && fisico !== 0) { diffBox.style.display = 'none'; return; }
  diffBox.style.display = 'block';
  var isLoss = diff < 0;
  diffBox.style.background = isLoss ? 'rgba(248,81,73,.08)' : diff > 0 ? 'rgba(52,211,153,.08)' : 'var(--sur2)';
  diffBox.style.border = '1px solid ' + (isLoss ? 'rgba(248,81,73,.2)' : diff > 0 ? 'rgba(52,211,153,.2)' : 'var(--bor)');
  if (diffEl) { diffEl.textContent = (diff > 0 ? '+' : '') + diff + ' L'; diffEl.style.color = isLoss ? 'var(--red)' : diff > 0 ? 'var(--green)' : 'var(--muted)'; }
  var mermaPct = tank.current_level > 0 ? Math.abs(Math.round((diff / tank.current_level) * 1000) / 10) : 0;
  if (pctEl) { pctEl.textContent = (isLoss ? '-' : '+') + mermaPct + '%'; pctEl.style.color = isLoss ? 'var(--red)' : 'var(--green)'; }
}

function saveAjusteDiesel() {
  var tankId = (document.getElementById('ajuste-tank-sel')||{}).value;
  var tanks = getDieselTanks();
  var tank = getTankById(tanks, tankId);
  var fisico = parseFloat((document.getElementById('ajuste-fisico')||{}).value);
  var motivo = (document.getElementById('ajuste-motivo')||{}).value || 'otro';
  var obs = ((document.getElementById('ajuste-obs')||{}).value || '').trim();
  if (isNaN(fisico) || fisico < 0) { toast('Ingresa el nivel físico','error'); return; }
  if (!obs) { toast('Ingresa observaciones','error'); return; }
  var diff = Math.round((fisico - tank.current_level) * 10) / 10;
  if (diff === 0) { toast('Sin diferencia — no se registra ajuste','info'); closeModal('modal-diesel-ajuste'); return; }
  if (!db.diesel) db.diesel = [];
  if (!db.next_ids) db.next_ids = {};
  if (!db.next_ids.diesel) db.next_ids.diesel = 1;
  var rec = {
    id: db.next_ids.diesel++,
    type: 'ajuste',
    tank_id: tankId,
    fecha: localDate(),
    litros: Math.abs(diff),
    ajuste_direccion: diff > 0 ? 'sobrante' : 'merma',
    nivel_teorico: tank.current_level,
    nivel_fisico: fisico,
    merma_pct: tank.current_level > 0 ? Math.round(Math.abs(diff / tank.current_level) * 1000) / 10 : 0,
    motivo: motivo,
    obs: obs,
    by: 'Desktop',
    created_at: new Date().toISOString()
  };
  // Calcular costo de merma basado en precio promedio de recargas
  if (diff < 0) {
    var _recargas = (db.diesel||[]).filter(function(r){return r.type==='recarga'&&r.precio;});
    var _precioPromL = _recargas.length ? _recargas.reduce(function(s,r){return s+(r.precio||0);},0)/_recargas.length : 0;
    rec.costo_merma = Math.round(Math.abs(diff) * _precioPromL * 100) / 100;
  }
  db.diesel.push(rec);
  tank.current_level = fisico;
  saveDieselTanks(tanks);
  saveDB();
  closeModal('modal-diesel-ajuste');
  renderDieselDesktop();
  var msg = diff < 0
    ? 'Merma: ' + Math.abs(diff) + ' L (' + rec.merma_pct + '%)' + (rec.costo_merma ? ' — Costo estimado: Bs. ' + rec.costo_merma : '') + ' — Nivel ajustado a ' + fisico + ' L'
    : 'Sobrante: +' + diff + ' L — Nivel ajustado a ' + fisico + ' L';
  toast(msg, diff < 0 ? 'error' : 'success');
}

