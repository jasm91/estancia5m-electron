    antiparasitario:'veterinario', vacuna:'veterinario', antibiotico:'veterinario',
    antiinflamatorio:'veterinario', vitamina_mineral:'veterinario', vitamina:'veterinario', hormona:'veterinario',
    sal_mineral:'sal', alimento_balanceado:'sal', alimento:'sal',
    lubricante:'aceite', aceite:'aceite', combustible:'aceite',
    herramienta:'herramienta', repuesto:'herramienta',
    otro:'otros'
  };
  if (byType[type]) return CAT[byType[type]];
  // 2) Sin tipo claro -> adivinar por nombre (tokens seguros con limites de palabra)
  var search = name + ' ' + type;
  if (/vacuna|vaccin|antibi|antiparasit|ivermec|pour.?on|clostr|aftosa|rabia|jeringa|aguja|sanidad|medicament|\bvet\b|dosis|ampoll|estreptomi|penicil|biotic|tetra|oxitetra|fenbenda|albenda|\bcura|sulfat|hierro|vitamin|complej.?b|fipronil|cypermet|piretroide|tatuad|caravan/.test(search)) return CAT.veterinario;
  if (/\bsal\b|mineral|calcimin|calcio|fosfor|magnesi|suplement|premix|sodio/.test(search)) return CAT.sal;
  if (/aceit|lubricant|grasa|hidr[áa]ulic|refrigerant|anticongel/.test(search)) return CAT.aceite;
  if (/tornill|clav|alambre|martillo|llave|destornill|repuest|tuerca|perno|broca|disco|cuerda|piol[íi]n|herramient|infraest|filtro|manguera|correa|rodamiento/.test(search)) return CAT.herramienta;
  return CAT.otros;
}

// Estado de salud del producto (prioridad: 1=crítico, 2=advertencia, 5=ok)
// Maneja "Sin vencimiento" (null/string vacío/fecha inválida) como producto no perecedero
function _stockGetHealth(p) {
  var today = new Date();
  var qty = parseFloat(p.stock_qty) || 0;
  var min = parseFloat(p.stock_min) || 0;
  var ratio = min > 0 ? qty/min : (qty > 0 ? 999 : 0);

  var expDays = null;
  if (p.expiry_date && typeof p.expiry_date === 'string' && p.expiry_date.length >= 8) {
    var d = new Date(p.expiry_date);
    if (!isNaN(d.getTime())) expDays = Math.round((d - today) / 86400000);
  }

  if (qty <= 0) return { status:'sin-stock', label:'Sin stock', color:'#A32D2D', bgFill:'#F7C1C1', barColor:'#A32D2D', priority:1, expDays:expDays };
  if (expDays !== null && expDays < 0) return { status:'vencido', label:'Vencido', color:'#A32D2D', bgFill:'#F7C1C1', barColor:'#A32D2D', priority:1, expDays:expDays };
  if (ratio < 1) return { status:'bajo', label:'Bajo', color:'#854F0B', bgFill:'#FAC775', barColor:'#EF9F27', priority:2, expDays:expDays };
  if (expDays !== null && expDays <= 30) return { status:'por-vencer', label:'Vence pronto', color:'#854F0B', bgFill:'#FAC775', barColor:'#BA7517', priority:3, expDays:expDays };
  return { status:'ok', label:'OK', color:'#27500A', bgFill:'#C0DD97', barColor:'#639922', priority:5, expDays:expDays };
}

// Cambia el filtro activo (chips)
function _stockSetFilter(filter) {
  _stockSelectedFilter = filter;
  renderStock();
}

// Cambia la categoría activa (hub)
function _stockSetCategory(cat) {
  _stockSelectedCategory = (_stockSelectedCategory === cat) ? 'all' : cat;
  renderStock();
}

// Renderiza el hub de 5 categorías
function _stockRenderHub() {
  var hub = document.getElementById('stock-hub');
  if (!hub) return;

  var products = db.products || [];

  // Agrupar y resumir
  var cats = {
    veterinario: { count:0, value:0, unitsByUnit:{}, alerts:0 },
    sal:         { count:0, value:0, unitsByUnit:{}, alerts:0 },
    aceite:      { count:0, value:0, unitsByUnit:{}, alerts:0 },
    herramienta: { count:0, value:0, unitsByUnit:{}, alerts:0 },
    otros:       { count:0, value:0, unitsByUnit:{}, alerts:0 }
  };
  var totalCount = 0, totalValue = 0, totalAlerts = 0;

  products.forEach(function(p){
    var cat = _stockGetCategory(p);
    var bucket = cats[cat.type];
    if (!bucket) return;
    bucket.count++;
    totalCount++;
    var qty = parseFloat(p.stock_qty) || 0;
    var cost = parseFloat(p.cost) || 0;
    var v = qty * cost;
    bucket.value += v;
    totalValue += v;
    var u = (p.unit || 'u').toLowerCase();
    bucket.unitsByUnit[u] = (bucket.unitsByUnit[u]||0) + qty;
    var h = _stockGetHealth(p);
    if (h.priority <= 3) { bucket.alerts++; totalAlerts++; }
  });

  // Formato unidades: muestra hasta 2 unidades distintas, "1,250 ml · 320 dosis"
  function fmtUnits(unitsByUnit) {
    var parts = Object.keys(unitsByUnit).map(function(u){ return { u:u, q:unitsByUnit[u] }; })
      .filter(function(x){ return x.q > 0; })
      .sort(function(a,b){ return b.q - a.q; })
      .slice(0,2)
      .map(function(x){ return _fmtNum(x.q) + ' ' + x.u; });
    return parts.join(' · ') || '—';
  }

  // Cards
  var hubHtml = '';
  var allActive = _stockSelectedCategory === 'all';
  // v1.4.63: paleta de colores adaptada al dark theme (antes pastel chocaban con el resto de la app)
  // Cada categoría: fondo oscuro sutil + acento de color en icono y valor
  hubHtml += _stockHubCard('all', '📦', 'Todos', totalCount + ' productos', 'Bs. ' + _fmtNum(Math.round(totalValue)) + ' total', totalAlerts, allActive, 'rgba(48,54,61,.5)', '#c9d1d9', '#8b949e');

  [
    { type:'veterinario', icon:'💉', label:'Veterinario',        bg:'rgba(248,113,113,.10)', fg:'#fca5a5', fgMuted:'#8b949e' },
    { type:'sal',         icon:'🧂', label:'Sal y suplem.',      bg:'rgba(251,191,36,.10)',  fg:'#fcd34d', fgMuted:'#8b949e' },
    { type:'aceite',      icon:'🛢️', label:'Aceites y lubric.',  bg:'rgba(96,165,250,.10)',  fg:'#93c5fd', fgMuted:'#8b949e' },
    { type:'herramienta', icon:'🔧', label:'Herramientas',       bg:'rgba(167,139,250,.10)', fg:'#c4b5fd', fgMuted:'#8b949e' }
  ].forEach(function(c){
    var b = cats[c.type];
    hubHtml += _stockHubCard(c.type, c.icon, c.label, b.count + ' producto'+(b.count!==1?'s':''), 'Bs. ' + _fmtNum(Math.round(b.value)) + ' · ' + fmtUnits(b.unitsByUnit), b.alerts, _stockSelectedCategory === c.type, c.bg, c.fg, c.fgMuted);
  });

  // Si hay productos en "Otros", agregar una sexta card chica
  if (cats.otros.count > 0) {
    hub.style.gridTemplateColumns = 'repeat(6, 1fr)';
    hubHtml += _stockHubCard('otros', '📦', 'Otros', cats.otros.count + ' productos', 'Bs. ' + _fmtNum(Math.round(cats.otros.value)) + ' · ' + fmtUnits(cats.otros.unitsByUnit), cats.otros.alerts, _stockSelectedCategory === 'otros', 'rgba(48,54,61,.5)', '#c9d1d9', '#8b949e');
  } else {
    hub.style.gridTemplateColumns = 'repeat(5, 1fr)';
  }

  hub.innerHTML = hubHtml;
}

function _stockHubCard(catKey, icon, label, line1, line2, alerts, isActive, bg, fg, fgMuted) {
  // v1.4.63: borde sutil para que las cards se integren con el dark theme
  var border = isActive ? '1px solid ' + fg : '1px solid rgba(48,54,61,.4)';
  var outline = isActive ? ';box-shadow:0 0 0 1px '+fg+' inset' : '';
  var badge = alerts > 0 ? '<div style="position:absolute;top:6px;right:8px;background:#A32D2D;color:#fff;font-size:9px;font-weight:600;min-width:16px;height:16px;padding:0 4px;border-radius:8px;display:flex;align-items:center;justify-content:center">'+alerts+'</div>' : '';
  return '<div onclick="_stockSetCategory(\''+catKey+'\')" style="position:relative;padding:12px 10px;border:'+border+';border-radius:10px;cursor:pointer;background:'+bg+';color:'+fg+';transition:transform .1s,border-color .1s'+outline+'" onmouseover="this.style.transform=\'translateY(-1px)\'" onmouseout="this.style.transform=\'translateY(0)\'">' +
    badge +
    '<div style="font-size:18px;margin-bottom:4px">'+icon+'</div>' +
    '<div style="font-size:12px;font-weight:600;line-height:1.2">'+escH(label)+'</div>' +
    '<div style="font-size:10px;line-height:1.4;margin-top:6px;color:'+fgMuted+'">' +
      '<div>'+escH(line1)+'</div>' +
      '<div style="opacity:.85">'+escH(line2)+'</div>' +
    '</div>' +
  '</div>';
}

// Renderiza los chips de filtros
function _stockRenderChips() {
  var chips = document.getElementById('stock-chips');
  if (!chips) return;
  var products = db.products || [];

  // Contar productos por filtro (sin aplicar categoría)
  var counts = { all:0, active:0, alertas:0, 'sin-stock':0, bajo:0, 'por-vencer':0 };
  products.forEach(function(p){
    counts.all++;
    if (p.active !== false) counts.active++;
    var h = _stockGetHealth(p);
    if (h.priority <= 3) counts.alertas++;
    if (h.status === 'sin-stock') counts['sin-stock']++;
    if (h.status === 'bajo') counts.bajo++;
    if (h.status === 'por-vencer' || h.status === 'vencido') counts['por-vencer']++;
  });

  var filters = [
    { key:'active',     label:'Activos',     count:counts.active },
    { key:'alertas',    label:'Con alertas', count:counts.alertas },
    { key:'sin-stock',  label:'Sin stock',   count:counts['sin-stock'] },
    { key:'bajo',       label:'Bajos',       count:counts.bajo },
    { key:'por-vencer', label:'Por vencer',  count:counts['por-vencer'] },
    { key:'all',        label:'Todos',       count:counts.all }
  ];

  var html = '<span style="font-size:11px;color:var(--muted);margin-right:4px">Mostrar:</span>';
  html += filters.map(function(f){
    var active = _stockSelectedFilter === f.key;
    var bg = active ? 'var(--text)' : 'transparent';
    var color = active ? 'var(--sur)' : 'var(--text)';
    var border = active ? 'var(--text)' : 'var(--border)';
    var lbl = f.label + (f.count > 0 ? ' ('+f.count+')' : '');
    return '<button onclick="_stockSetFilter(\''+f.key+'\')" style="font-size:11px;padding:4px 10px;border-radius:999px;border:1px solid '+border+';cursor:pointer;background:'+bg+';color:'+color+';font-weight:'+(active?500:400)+'">'+escH(lbl)+'</button>';
  }).join('');

  chips.innerHTML = html;
}

// Aplica filtros y ordenamiento a la lista
function _stockGetFilteredList() {
  var products = (db.products || []).slice();
  var search = (document.getElementById('stock-search') || {}).value || '';
  search = search.toLowerCase().trim();
  var sort = (document.getElementById('stock-sort') || {}).value || 'critical';

  return products.filter(function(p){
    // Filtro de categoría
    if (_stockSelectedCategory !== 'all') {
      var cat = _stockGetCategory(p);
      if (cat.type !== _stockSelectedCategory) return false;
    }
    // Filtro de estado
    var h = _stockGetHealth(p);
    if (_stockSelectedFilter === 'active' && p.active === false) return false;
    if (_stockSelectedFilter === 'alertas' && h.priority > 3) return false;
    if (_stockSelectedFilter === 'sin-stock' && h.status !== 'sin-stock') return false;
    if (_stockSelectedFilter === 'bajo' && h.status !== 'bajo') return false;
    if (_stockSelectedFilter === 'por-vencer' && h.status !== 'por-vencer' && h.status !== 'vencido') return false;
    // Búsqueda
    if (search && (p.name||'').toLowerCase().indexOf(search) === -1) return false;
    return true;
  }).sort(function(a,b){
    var ha = _stockGetHealth(a), hb = _stockGetHealth(b);
    if (sort === 'critical') return ha.priority - hb.priority || (a.name||'').localeCompare(b.name||'');
    if (sort === 'az') return (a.name||'').localeCompare(b.name||'');
    if (sort === 'low') {
      var ra = (parseFloat(a.stock_min)||0) > 0 ? (parseFloat(a.stock_qty)||0) / parseFloat(a.stock_min) : 999;
      var rb = (parseFloat(b.stock_min)||0) > 0 ? (parseFloat(b.stock_qty)||0) / parseFloat(b.stock_min) : 999;
      return ra - rb;
    }
    if (sort === 'exp') {
      var da = ha.expDays === null ? 99999 : ha.expDays;
      var db_ = hb.expDays === null ? 99999 : hb.expDays;
      return da - db_;
    }
    if (sort === 'usage') {
      // Sin datos confiables de uso, fallback a stock más bajo
      return ha.priority - hb.priority;
    }
    return 0;
  });
}

// Renderiza una fila individual
function _stockRenderRow(p) {
  var cat = _stockGetCategory(p);
  var h = _stockGetHealth(p);
  var qty = parseFloat(p.stock_qty)||0;
  var min = parseFloat(p.stock_min)||0;
  var pct = min > 0 ? Math.min(100, Math.round(qty/min*100)) : (qty>0?100:0);
  var unit = p.unit || 'u';

  // FIX v1.4.41: bajar intensidad de fondos para no saturar en dark mode
  // Antes: rgba(247,193,193,.2) y rgba(250,199,117,.18) saturaban en dark
  // Ahora: solo border-left de color, fila sin tinte de fondo
  var borderColor = h.priority === 1 ? '#A32D2D' : h.priority <= 3 ? '#BA7517' : '#639922';
  var rowBg = 'transparent'; // sin tinte — el border-left ya comunica el estado

  // Stock display
  var stockColor = h.priority === 1 ? '#E24B4A' : h.priority === 2 ? '#EF9F27' : 'var(--text)';
  var stockHtml = '<div style="font-weight:500;color:'+stockColor+';font-size:12px">'+_fmtNum(qty)+' / '+_fmtNum(min)+' '+escH(unit)+'</div>' +
    '<div style="height:3px;background:var(--border);border-radius:2px;margin-top:3px;overflow:hidden">' +
      '<div style="height:100%;width:'+pct+'%;background:'+h.barColor+';border-radius:2px"></div>' +
    '</div>';

  // FIX v1.4.44: removidos botones contextuales redundantes (Comprar→/+Stock)
  // La urgencia se comunica con border-left de color + texto en rojo/amber
  // Los 3 botones de acción (Editar/+Stock/Eliminar) van siempre visibles a la derecha
  var rightHtml = '';
  if (h.status === 'vencido') {
    rightHtml = '<div style="text-align:right;line-height:1.3">' +
      '<div style="color:var(--red);font-size:10px">Vencido</div>' +
      '<div style="font-weight:500;color:var(--red);font-size:11px">'+(h.expDays !== null ? 'hace '+Math.abs(h.expDays)+' día'+(Math.abs(h.expDays)!==1?'s':'') : '')+'</div>' +
    '</div>';
  } else if (h.status === 'sin-stock') {
    rightHtml = '<div style="text-align:right;line-height:1.3">' +
      '<div style="color:var(--red);font-size:10px">Sin stock</div>' +
      '<div style="font-weight:500;color:var(--red);font-size:11px">comprar</div>' +
    '</div>';
  } else if (h.status === 'bajo') {
    rightHtml = '<div style="text-align:right;line-height:1.3">' +
      '<div style="color:var(--amber2);font-size:10px">Stock bajo</div>' +
      '<div style="font-weight:500;color:var(--amber2);font-size:11px">'+_fmtNum(qty)+' de '+_fmtNum(min)+'</div>' +
    '</div>';
  } else if (h.status === 'por-vencer') {
    rightHtml = '<div style="text-align:right;line-height:1.3">' +
      '<div style="color:var(--amber2);font-size:10px">Vence en</div>' +
      '<div style="font-weight:500;color:var(--amber2);font-size:11px">'+h.expDays+' día'+(h.expDays!==1?'s':'')+'</div>' +
    '</div>';
  } else {
    if (h.expDays === null) {
      rightHtml = '<div style="text-align:right;color:var(--muted);font-size:10px;font-style:italic">Sin vencimiento</div>';
    } else {
      rightHtml = '<div style="text-align:right;line-height:1.3">' +
        '<div style="color:var(--muted);font-size:10px">Vence</div>' +
        '<div style="font-weight:500;font-size:11px">'+escH(p.expiry_date)+'</div>' +
      '</div>';
    }
  }

  var subText = cat.label.toLowerCase() + (p.type ? ' · '+escH(p.type) : '');

  // FIX v1.4.44: 3 botones de acción VISIBLES en la fila (no ocultos en submenu)
  // - ✎ Editar (texto neutro)
  // - + Stock (verde, primario porque es el más usado)
  // - ✕ Eliminar (rojo)
  // Click en cualquier otra parte de la fila sigue disparando toggle de actividad
  var actionButtons =
    '<button title="Editar producto" onclick="event.stopPropagation();openEditProduct('+p.id+')" style="background:transparent;border:1px solid var(--border);cursor:pointer;color:var(--muted);font-size:11px;padding:4px 8px;border-radius:6px;transition:all .12s" onmouseover="this.style.background=\'var(--sur2)\';this.style.color=\'var(--text)\'" onmouseout="this.style.background=\'transparent\';this.style.color=\'var(--muted)\'">✎</button>' +
    '<button title="Ingreso de stock" onclick="event.stopPropagation();quickAddStock('+p.id+')" style="background:transparent;border:1px solid var(--green);cursor:pointer;color:var(--green);font-size:11px;padding:4px 8px;border-radius:6px;font-weight:600;transition:all .12s" onmouseover="this.style.background=\'var(--green)\';this.style.color=\'#fff\'" onmouseout="this.style.background=\'transparent\';this.style.color=\'var(--green)\'">+ Stock</button>' +
    '<button title="Eliminar producto" onclick="event.stopPropagation();deleteProduct('+p.id+')" style="background:transparent;border:1px solid var(--border);cursor:pointer;color:var(--red);font-size:11px;padding:4px 8px;border-radius:6px;transition:all .12s" onmouseover="this.style.background=\'rgba(231,75,74,.1)\';this.style.borderColor=\'var(--red)\'" onmouseout="this.style.background=\'transparent\';this.style.borderColor=\'var(--border)\'">✕</button>';

  // FIX v1.4.43: click en fila → toggle de panel inline expandible (NO modal)
  return '<div data-stock-row="'+p.id+'">' +
    '<div onclick="_stockToggleActivity(\''+p.id+'\')" title="Click para expandir actividad" style="display:grid;grid-template-columns:32px 1fr 130px 100px auto;align-items:center;gap:10px;padding:10px 12px 10px 9px;border-top:1px solid var(--border);border-left:3px solid '+borderColor+';background:'+rowBg+';cursor:pointer;transition:background .12s" onmouseover="this.style.background=\'var(--sur2)\'" onmouseout="this.style.background=\''+rowBg+'\'">' +
      '<div style="font-size:16px;text-align:center">'+cat.icon+'</div>' +
      '<div>' +
        '<div style="font-size:13px;font-weight:500;margin:0">'+escH(p.name||'(sin nombre)')+'</div>' +
        '<div style="font-size:10px;color:var(--muted);margin:2px 0 0">'+escH(subText)+'</div>' +
      '</div>' +
      '<div style="text-align:right">'+stockHtml+'</div>' +
      '<div>'+rightHtml+'</div>' +
      '<div style="display:flex;gap:4px;align-items:center">'+actionButtons+'</div>' +
    '</div>' +
    '<div id="_stock-activity-'+p.id+'" style="display:none;background:var(--sur2);border-left:3px solid '+borderColor+';padding:0"></div>' +
  '</div>';
}

// FIX v1.4.41: menú dropdown DOM (antes usaba prompt() que no funcionaba bien en Electron)
// Actividad ya tiene su propio botón en la fila, así que el menú solo lleva Editar y Eliminar
function _stockShowMenu(ev, prodId) {
  if (ev) { ev.stopPropagation(); }
  // Si ya hay un menú abierto, cerrarlo
  var existing = document.getElementById('_stock-row-menu');
  if (existing && existing.parentNode) existing.parentNode.removeChild(existing);

  var p = (db.products||[]).find(function(x){ return String(x.id) === String(prodId); });
  if (!p) return;

  var trigger = ev && ev.target ? ev.target : null;
  var rect = trigger && trigger.getBoundingClientRect ? trigger.getBoundingClientRect() : { right: window.innerWidth/2, bottom: window.innerHeight/2 };

  var menu = document.createElement('div');
  menu.id = '_stock-row-menu';
  menu.style.cssText = 'position:fixed;z-index:9500;background:var(--sur);border:1px solid var(--border);border-radius:8px;box-shadow:0 4px 12px rgba(0,0,0,.25);padding:4px;min-width:160px;font-family:var(--font-sans,system-ui)';
  // Posicionar a la izquierda del icono (para no salirse de pantalla derecha)
  menu.style.top = Math.min(rect.bottom + 4, window.innerHeight - 120) + 'px';
  menu.style.left = Math.max(8, rect.right - 160) + 'px';

  function mkItem(label, color, onClickFn) {
    var item = document.createElement('div');
    item.style.cssText = 'padding:8px 12px;font-size:12px;color:'+(color||'var(--text)')+';cursor:pointer;border-radius:4px;display:flex;align-items:center;gap:8px';
    item.innerHTML = label;
    item.addEventListener('mouseover', function(){ item.style.background = 'var(--sur2)'; });
    item.addEventListener('mouseout',  function(){ item.style.background = 'transparent'; });
    item.addEventListener('click', function(e){
      e.stopPropagation();
      closeMenu();
      onClickFn();
    });
    return item;
  }

  menu.appendChild(mkItem('✎ Editar producto', null, function(){ try { openEditProduct(prodId); } catch(e){ console.error(e); } }));
  menu.appendChild(mkItem('+ Ingreso de stock', null, function(){ try { quickAddStock(prodId); } catch(e){ console.error(e); } }));

  var divider = document.createElement('div');
  divider.style.cssText = 'height:1px;background:var(--border);margin:4px 0';
  menu.appendChild(divider);

  menu.appendChild(mkItem('✕ Eliminar producto', 'var(--red)', function(){ try { deleteProduct(prodId); } catch(e){ console.error(e); } }));

  document.body.appendChild(menu);

  // Cerrar al hacer click afuera o tocar Escape
  function closeMenu() {
    if (menu.parentNode) menu.parentNode.removeChild(menu);
    document.removeEventListener('click', onDocClick, true);
    document.removeEventListener('keydown', onKey);
  }
  function onDocClick(e) {
    if (!menu.contains(e.target)) closeMenu();
  }
  function onKey(e) {
    if (e.key === 'Escape') closeMenu();
  }
  // Delay para no capturar el click que abrió el menú
  setTimeout(function(){
    document.addEventListener('click', onDocClick, true);
    document.addEventListener('keydown', onKey);
  }, 0);
}

// v1.4.43: Toggle de panel de actividad INLINE (se despliega debajo de la fila, sin modal popup)
// Reemplaza la versión modal que perdía contexto del resto de productos.
function _stockToggleActivity(prodId) {
  var panel = document.getElementById('_stock-activity-' + prodId);
  if (!panel) return;

  // Si ya está abierto, cerrarlo
  var isOpen = panel.style.display !== 'none' && panel.innerHTML !== '';
  if (isOpen) {
    panel.style.display = 'none';
    panel.innerHTML = '';
    return;
  }

  // Cerrar TODOS los otros paneles abiertos (uno a la vez para no saturar)
  document.querySelectorAll('[id^="_stock-activity-"]').forEach(function(el){
    if (el.id !== ('_stock-activity-' + prodId)) {
      el.style.display = 'none';
      el.innerHTML = '';
    }
  });

  // Recolectar entries del producto desde TODAS las fuentes
  var prod = (db.products||[]).find(function(p){ return String(p.id) === String(prodId); });
  if (!prod) return;
  var entries = [];
  var prodName = prod.name || '';
  var unit = prod.unit || '';

  // Curaciones
  (db.treatments||[]).forEach(function(t){
    if (t.product_id == prodId || (t.product_name && t.product_name === prodName)) {
      var qty = parseFloat(t.total) || (parseFloat(t.dose||0) * parseFloat(t.count||0)) || 0;
      var scope = t.scope === 'individual' ? ('Animal '+(t.animal_id||'?')) : ('Lote '+(t.lot_code||'?'));
      entries.push({ date: t.applied_at || t.created_at || '', type: 'Curación', sign: '-', qty: qty, desc: scope + ' · ' + (t.count||1) + ' cab' + (t.diagnosis?' ('+t.diagnosis+')':''), by: t.by || '' });
    }
  });
  // Compras
  (db.purchases||[]).forEach(function(p){
    if (p.product_id == prodId || (p.product_name && p.product_name === prodName)) {
      var qty = parseFloat(p.qty)||0;
      if (qty) entries.push({ date: p.date || p.created_at || '', type: 'Compra', sign: '+', qty: qty, desc: (p.supplier ? 'a ' + p.supplier : 'Compra'), by: p.by || '' });
    }
    if (p.items && p.items.length) {
      p.items.forEach(function(it){
        if (it.product_id == prodId || (it.product_name && it.product_name === prodName)) {
          entries.push({ date: p.date || p.created_at || '', type: 'Compra', sign: '+', qty: parseFloat(it.qty)||0, desc: (p.supplier ? 'a ' + p.supplier : 'Compra') + ' (multi-item)', by: p.by || '' });
        }
      });
    }
  });
  // Sal
  (db.sal||[]).forEach(function(s){
    if (s.stock_product === prodName && s.stock_descontado) {
      entries.push({ date: s.date || s.created_at || '', type: 'Sal', sign: '-', qty: parseFloat(s.stock_descontado)||0, desc: 'Lote ' + (s.lot_code||'?') + (s.tipo?' ('+s.tipo+')':'') + (s.obs?' · '+s.obs:''), by: s.by || '' });
    }
  });
  // Alimento
  (db.alimento||[]).forEach(function(a){
    if (a.stock_product === prodName && a.stock_descontado) {
      entries.push({ date: a.date || a.created_at || '', type: 'Alimento', sign: '-', qty: parseFloat(a.stock_descontado)||0, desc: 'Lote ' + (a.lot_code||'?') + (a.obs?' · '+a.obs:''), by: a.by || '' });
    }
  });
  // Conteos manuales (ajustes de inventario)
  (db.inventory_counts||[]).forEach(function(c){
    if (!c.ajustado) return;
    (c.items || []).forEach(function(item){
      var matchById = item.product_id == prodId;
      var matchByName = item.product_name && item.product_name === prodName;
      if (!matchById && !matchByName) return;
      var diff = parseFloat(item.diferencia) || 0;
      if (diff === 0) return;
      entries.push({ date: c.date || c.created_at || '', type: (c.tipo==='ingreso'?'Ingreso':'Conteo'), sign: diff > 0 ? '+' : '-', qty: Math.abs(diff), desc: (c.tipo==='ingreso' ? '📥 Ingreso de stock' + (item.motivo?' · '+item.motivo:'') : 'Ajuste por conteo físico (sistema: ' + (item.stock_teorico||item.stock_sistema||0) + ', físico: ' + (item.stock_fisico||0) + ')' + (item.motivo?' · '+item.motivo:'')), by: c.by || '' });
    });
  });
  // Mantenimiento
  (db.maintenance||[]).forEach(function(m){
    // v1.4.55: nuevo formato multi-item — stock_items[]
    if (Array.isArray(m.stock_items) && m.stock_items.length) {
      m.stock_items.forEach(function(it){
        var matchById = it.product_id == prodId;
        var matchByName = it.product_name && it.product_name === prodName;
        if ((matchById || matchByName) && it.qty) {
          entries.push({ date: m.date || m.created_at || '', type: 'Mantenim.', sign: '-', qty: parseFloat(it.qty)||0, desc: (m.equipo ? m.equipo + ' · ' : '') + (m.desc || 'Mantenimiento').slice(0,50), by: m.who || m.by || '' });
        }
      });
    } else {
      // Formato viejo single-item (back-compat)
      var matchById = m.stock_product_id == prodId;
      var matchByName = m.stock_product && m.stock_product === prodName;
      if ((matchById || matchByName) && m.stock_descontado) {
        entries.push({ date: m.date || m.created_at || '', type: 'Mantenim.', sign: '-', qty: parseFloat(m.stock_descontado)||0, desc: (m.equipo ? m.equipo + ' · ' : '') + (m.desc || 'Mantenimiento').slice(0,50), by: m.who || m.by || '' });
      }
    }
  });
  // Aceite
  (db.aceite||[]).forEach(function(a){
    var matchById = a.stock_product_id == prodId;
    var matchByName = a.stock_product && a.stock_product === prodName;
    if ((matchById || matchByName) && a.stock_descontado) {
      entries.push({ date: a.fecha || a.created_at || '', type: 'Aceite', sign: '-', qty: parseFloat(a.stock_descontado)||0, desc: (a.vehiculo || '?') + (a.tipo ? ' (' + a.tipo + ')' : ''), by: a.by || '' });
    }
  });

  entries.sort(function(a,b){ return (b.date||'').localeCompare(a.date||''); });

  var totalIn  = entries.filter(function(e){return e.sign==='+';}).reduce(function(s,e){return s+e.qty;},0);
  var totalOut = entries.filter(function(e){return e.sign==='-';}).reduce(function(s,e){return s+e.qty;},0);

  var rowsHtml = entries.length ? entries.map(function(e){
    var typeColors = { 'Compra':'#27500A', 'Curación':'#854F0B', 'Sal':'#7F77DD', 'Alimento':'#1D9E75', 'Conteo':'#185FA5', 'Mantenim.':'#5F5E5A', 'Aceite':'#BA7517' };
    var typeColor = typeColors[e.type] || 'var(--muted)';
    var qtyColor = e.sign==='+'?'var(--green)':'var(--red)';
    return '<div style="display:grid;grid-template-columns:90px 80px 90px 1fr;gap:8px;padding:6px 16px;border-bottom:1px solid var(--border);font-size:11px;align-items:center">' +
      '<span style="color:var(--muted);font-family:DM Mono,monospace">'+(e.date||'').slice(0,10)+'</span>' +
      '<span style="font-size:10px;padding:2px 6px;background:rgba(0,0,0,.06);color:'+typeColor+';font-weight:600;border-radius:6px;text-align:center">'+escH(e.type)+'</span>' +
      '<span style="font-family:DM Mono,monospace;color:'+qtyColor+';font-weight:600;text-align:right">'+e.sign+_fmtNum(e.qty)+' '+escH(unit)+'</span>' +
      '<span style="color:var(--text)">'+escH(e.desc)+(e.by?' · <span style="color:var(--muted);font-size:10px">'+escH(e.by)+'</span>':'')+'</span>' +
    '</div>';
  }).join('') : '<div style="padding:14px;text-align:center;color:var(--muted);font-size:12px">Sin movimientos registrados</div>';

  // Header del panel inline con resumen
  panel.innerHTML =
    '<div style="display:flex;gap:14px;padding:10px 16px;background:rgba(0,0,0,.04);border-bottom:1px solid var(--border);font-size:11px;align-items:center">' +
      '<span style="font-size:10px;color:var(--muted);text-transform:uppercase;font-weight:600">📊 Actividad</span>' +
      '<span><span style="color:var(--muted);text-transform:uppercase;font-size:10px">↗ Entradas</span> <span style="color:var(--green);font-weight:600;font-family:DM Mono,monospace">+'+_fmtNum(totalIn)+' '+escH(unit)+'</span></span>' +
      '<span><span style="color:var(--muted);text-transform:uppercase;font-size:10px">↘ Salidas</span> <span style="color:var(--red);font-weight:600;font-family:DM Mono,monospace">-'+_fmtNum(totalOut)+' '+escH(unit)+'</span></span>' +
      '<span style="margin-left:auto;color:var(--muted);font-size:10px">'+entries.length+' movimiento'+(entries.length!==1?'s':'')+'</span>' +
    '</div>' +
    rowsHtml;
  panel.style.display = 'block';
}

