  ['filter-status','filter-assignee','filter-priority'].forEach(function(id){
    var el = document.getElementById(id);
    if (el) el.onchange = renderTaskList;
  });

  // Populate assignee filter
  var fa = document.getElementById('filter-assignee');
  if (fa) {
    var cur = fa.value;
    var assignees = [];
    getTaskDB().forEach(function(t){ if(t.assignee && assignees.indexOf(t.assignee)<0) assignees.push(t.assignee); });
    fa.innerHTML = '<option value="">Todos los responsables</option>';
    assignees.forEach(function(a){
      var o = document.createElement('option');
      o.value = a; o.textContent = a;
      if (a === cur) o.selected = true;
      fa.appendChild(o);
    });
