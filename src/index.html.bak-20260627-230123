function openVentaCarne(bajaId) {
  var baja = (db.bajas||[]).find(function(b){ return String(b.id) === String(bajaId); });
  if (!baja) { toast('Baja no encontrada','error'); return; }
  document.getElementById('vc-baja-id').value = bajaId;
  document.getElementById('vc-animal-info').innerHTML =
    'Animal <b style="color:var(--amber2)">#' + escH(baja.animal_id) + '</b> · Lote: ' + escH(baja.lot_code) +
    (baja.raza ? ' · ' + escH(baja.raza) : '') +
    (baja.ultimo_peso ? ' · Último peso: <b>' + baja.ultimo_peso + ' kg</b>' : '') +
    ' · Causa: ' + escH(baja.causa) + ' (' + escH(baja.fecha) + ')';
  var f = document.getElementById('vc-fecha'); if (f) f.value = localDate();
  ['vc-comprador','vc-kg','vc-precio','vc-total','vc-obs'].forEach(function(id){ var e=document.getElementById(id); if(e) e.value=''; });
  // Pre-fill kg estimate (rendimiento carne ~50% del peso vivo)
