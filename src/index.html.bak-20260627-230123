        labels: fechas,
        datasets: [
          { label: 'Máximo', data: maxArr, borderColor: 'rgba(57,211,83,0.4)', backgroundColor: 'rgba(57,211,83,0.05)', borderDash: [4, 4], tension: 0.35, pointRadius: 3, fill: false },
          { label: 'Promedio', data: prom, borderColor: '#C9A84C', backgroundColor: 'rgba(201,168,76,0.1)', borderWidth: 3, tension: 0.35, pointRadius: 5, pointBackgroundColor: '#C9A84C', fill: false },
          { label: 'Mínimo', data: minArr, borderColor: 'rgba(231,76,60,0.4)', backgroundColor: 'transparent', borderDash: [4, 4], tension: 0.35, pointRadius: 3, fill: false }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { position: 'bottom', labels: { font: { size: 11 }, padding: 12, usePointStyle: true } } },
        scales: {
          y: { beginAtZero: false, grid: { color: '#2A2A2A' }, title: { display: true, text: 'Peso (kg)', color: '#666', font: { size: 11 } } },
          x: { grid: { display: false } }
        }
      }
    });
  }
}

function _alRenderProyeccion(lot, animales) {
  try {
    // Determinar peso target (default según categoría)
    var defaultTarget = 480;
    var cat = (lot.category || '').toLowerCase();
    if (cat.indexOf('vaca') >= 0) defaultTarget = 420;
    else if (cat.indexOf('toro') >= 0) defaultTarget = 600;
    else if (cat.indexOf('vaquill') >= 0 || cat.indexOf('ternero') >= 0) defaultTarget = 380;
    // Usar valor del input si ya existe, sino default
    var inputEl = document.getElementById('al-faena-target');
    var targetWeight = inputEl && inputEl.value ? parseFloat(inputEl.value) : defaultTarget;
    if (!targetWeight || targetWeight < 200) targetWeight = defaultTarget;
    if (inputEl && !inputEl.value) inputEl.value = targetWeight;

    // Animales con suficiente data para proyectar
    var conGmd = animales.filter(function(a) { return a.gmd != null && a.gmd > 0 && a.pesoActual; });
    var subtitle = document.getElementById('al-proy-subtitle');
    var summaryEl = document.getElementById('al-proy-summary');
    var gmdInfoEl = document.getElementById('al-gmd-real-info');
    if (!subtitle || !summaryEl) return;

    if (!conGmd.length) {
      subtitle.textContent = 'Sin datos suficientes (se requieren ≥2 pesajes)';
      summaryEl.innerHTML = '';
      if (gmdInfoEl) gmdInfoEl.style.display = 'none';
      return;
    }

    // Calcular GMD promedio REAL y peso promedio actual
    var gmds = conGmd.map(function(a) { return a.gmd; });
    var pesos = conGmd.map(function(a) { return a.pesoActual; });
    var gmdReal = gmds.reduce(function(s, x) { return s + x; }, 0) / gmds.length;
    var pesoProm = pesos.reduce(function(s, x) { return s + x; }, 0) / pesos.length;

    // ── GMD: capear automáticamente si es absurda + permitir override manual ─────
    // GMDs >3.0 kg/d son físicamente imposibles para bovinos en pastoreo
    // (incluso en feedlot intensivo el máximo realista es ~2.0 kg/d)
    var GMD_MAX_REALISTA = 2.0;
    var gmdInputEl = document.getElementById('al-faena-gmd');
    var gmdInputValue = gmdInputEl && gmdInputEl.value ? parseFloat(gmdInputEl.value) : NaN;

    var gmdRealEsAbsurda = gmdReal > 3.0 || gmdReal < 0.01;
    var gmdParaUsar;
    var gmdSource;

    if (!isNaN(gmdInputValue) && gmdInputValue >= 0.05 && gmdInputValue <= 3.0) {
      // Usuario fijó manualmente un GMD
      gmdParaUsar = gmdInputValue;
      gmdSource = (Math.abs(gmdInputValue - gmdReal) < 0.01) ? 'real' : 'simulada';
    } else if (gmdRealEsAbsurda) {
      // GMD calculada es absurda → usar default seguro
      gmdParaUsar = 0.75;
      gmdSource = 'fallback';
    } else {
      gmdParaUsar = gmdReal;
      gmdSource = 'real';
    }

    // Pre-llenar el input si está vacío
    if (gmdInputEl && !gmdInputEl.value) {
      // Si la GMD real es absurda, sugerir el fallback; sino la real
      var initVal = gmdRealEsAbsurda ? 0.75 : gmdReal;
      gmdInputEl.value = initVal.toFixed(2);
    }

    // Mostrar info de GMD real calculada (especialmente si fue capeada)
    if (gmdInfoEl) {
      if (gmdRealEsAbsurda) {
        gmdInfoEl.style.display = 'block';
        gmdInfoEl.innerHTML = '<span style="color:var(--red)">⚠ GMD real calculada: ' + gmdReal.toFixed(2) + ' kg/d (atípica — pesajes muy cercanos o valores inconsistentes)</span> · usando ' + gmdParaUsar.toFixed(2) + ' kg/d para proyectar';
      } else if (gmdSource === 'simulada') {
        gmdInfoEl.style.display = 'block';
        gmdInfoEl.innerHTML = '<span style="color:var(--blue,#58A6FF)">▶ Simulación con GMD ' + gmdParaUsar.toFixed(2) + ' kg/d</span> · GMD real del lote: ' + gmdReal.toFixed(2) + ' kg/d';
      } else {
        gmdInfoEl.style.display = 'block';
        gmdInfoEl.innerHTML = '<span style="color:var(--muted)">GMD real del lote: <strong style="color:var(--text)">' + gmdReal.toFixed(2) + ' kg/d</strong> (calculado de pesajes individuales)</span>';
      }
    }

    // Si el lote ya supera el target, mostrar diferente
    if (pesoProm >= targetWeight) {
      subtitle.innerHTML = '<span style="color:var(--green)">✓ Promedio del lote ya superó el target</span>';
    } else {
      var diasAFaena = Math.round((targetWeight - pesoProm) / gmdParaUsar);
      var fechaFaena = new Date(Date.now() + diasAFaena * 24 * 60 * 60 * 1000);
      var fechaStr = fechaFaena.toLocaleDateString('es-BO', { day: '2-digit', month: 'short', year: 'numeric' });
      subtitle.innerHTML = '<strong style="color:var(--text)">~' + diasAFaena + ' días</strong> · <span style="color:var(--amber)">' + fechaStr + '</span>';
    }

    // ── Construir el dataset del gráfico ──────────────────────────
    // 1. Curva histórica: agrupar pesajes por fecha y promediar
    var fechasMap = {};
    animales.forEach(function(a) {
      (a.pesajes || []).forEach(function(p) {
        if (!p || !p.fecha || !p.peso) return;
        if (!fechasMap[p.fecha]) fechasMap[p.fecha] = [];
        fechasMap[p.fecha].push(p.peso);
      });
    });
    var fechasHist = Object.keys(fechasMap).sort();

    // Si hay <2 fechas históricas, no podemos graficar curva — pero sí KPIs
    if (fechasHist.length < 2) {
      // Solo renderizar KPIs sin gráfico
      _alProyRenderKPIs(animales, conGmd, pesoProm, gmdParaUsar, targetWeight);
      return;
    }

    var historicoPromedio = fechasHist.map(function(f) {
      var arr = fechasMap[f];
      return arr.reduce(function(s, x) { return s + x; }, 0) / arr.length;
    });

    // 2. Proyección: desde la última fecha histórica
    var ultimaFechaHist = new Date(fechasHist[fechasHist.length - 1]);
    var ultimoPeso = historicoPromedio[historicoPromedio.length - 1];
    var diasProy = pesoProm < targetWeight
      ? Math.min(540, Math.ceil((targetWeight - ultimoPeso) / gmdParaUsar) + 30)
      : 90;
    if (diasProy < 60) diasProy = 60;

    // Generar puntos cada N días (~30 puntos total)
    var stepDays = Math.max(7, Math.floor(diasProy / 30));
    var labelsProy = [];
    var valoresProy = [];
    for (var d = stepDays; d <= diasProy; d += stepDays) {  // empezar en stepDays (no 0)
      var fecha = new Date(ultimaFechaHist.getTime() + d * 24 * 60 * 60 * 1000);
      labelsProy.push(fecha.toISOString().slice(0, 10));
      valoresProy.push(Math.round(ultimoPeso + d * gmdParaUsar));
    }

    // 3. Combinar histórico + proyección
    // Eje X: todas las fechas (históricas + proyectadas)
    var labelsCombo = fechasHist.concat(labelsProy);

    // Dataset histórico: valores reales en los puntos históricos, null en los proyectados
    var dataHist = historicoPromedio.concat(labelsProy.map(function() { return null; }));

    // Dataset proyectado: null en históricos (excepto el último para conectar), valores en proyectados
    var dataProy = fechasHist.map(function(_, i) {
      return i === fechasHist.length - 1 ? ultimoPeso : null;  // solo el último histórico
    }).concat(valoresProy);

    // Dataset target (línea horizontal)
    var dataTarget = labelsCombo.map(function() { return targetWeight; });

    var ctx = document.getElementById('al-chart-proyeccion');
    if (ctx) {
      _alCharts.proy = new Chart(ctx, {
        type: 'line',
        data: {
          labels: labelsCombo,
          datasets: [
            {
              label: 'Histórico',
              data: dataHist,
              borderColor: '#C9A84C',
              backgroundColor: 'rgba(201,168,76,0.1)',
              borderWidth: 3,
              tension: 0.35,
              pointRadius: 4,
              pointBackgroundColor: '#C9A84C',
              fill: false,
              spanGaps: false
            },
            {
              label: 'Proyectado (GMD ' + gmdParaUsar.toFixed(2) + ')',
              data: dataProy,
              borderColor: '#58A6FF',
              backgroundColor: 'rgba(88,166,255,0.06)',
              borderWidth: 2.5,
              borderDash: [6, 4],
              tension: 0.1,
              pointRadius: 2,
              pointBackgroundColor: '#58A6FF',
              fill: false,
              spanGaps: true
            },
            {
              label: 'Target faena (' + targetWeight + ' kg)',
              data: dataTarget,
              borderColor: '#39D353',
              backgroundColor: 'transparent',
              borderWidth: 2,
              borderDash: [4, 4],
              tension: 0,
              pointRadius: 0,
              fill: false
            }
          ]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              position: 'bottom',
              labels: { font: { size: 10 }, padding: 10, usePointStyle: true, pointStyle: 'line' }
            },
            tooltip: {
              callbacks: {
                label: function(c) {
                  var ds = c.dataset.label || '';
                  if (c.parsed.y == null) return null;
                  return ds + ': ' + Math.round(c.parsed.y) + ' kg';
                }
              }
            }
          },
          scales: {
            y: {
              beginAtZero: false,
              grid: { color: '#2A2A2A' },
              title: { display: true, text: 'Peso (kg)', color: '#666', font: { size: 11 } }
            },
            x: {
              grid: { display: false },
              ticks: { maxTicksLimit: 8, font: { size: 9 } }
            }
          }
        }
      });
    }

    _alProyRenderKPIs(animales, conGmd, pesoProm, gmdParaUsar, targetWeight);
  } catch(err) {
    console.error('[Proyección] Error renderizando:', err);
    var subtitle = document.getElementById('al-proy-subtitle');
    var summaryEl = document.getElementById('al-proy-summary');
    if (subtitle) subtitle.textContent = 'Error generando proyección';
    if (summaryEl) summaryEl.innerHTML = '';
  }
}

// Botón ↺ — vuelve la GMD del input a la real calculada
function resetGmdToReal() {
  var gmdInputEl = document.getElementById('al-faena-gmd');
  if (!gmdInputEl) return;
  // Limpiar el input — al renderear de nuevo, se va a auto-completar con la GMD real
  gmdInputEl.value = '';
  if (typeof renderAnalisisLote === 'function') renderAnalisisLote();
}

function _alProyRenderKPIs(animales, conGmd, pesoProm, gmdProm, targetWeight) {
  var summaryEl = document.getElementById('al-proy-summary');
  if (!summaryEl) return;

  var precioKg = (typeof rp !== 'undefined' && rp && rp.precio_kg_carne) ? parseFloat(rp.precio_kg_carne) : 18;
  var moneda = (typeof rp !== 'undefined' && rp && rp.moneda) || 'Bs';

  var diasA = pesoProm < targetWeight ? Math.round((targetWeight - pesoProm) / gmdProm) : 0;
  var yaListos = conGmd.filter(function(a) { return a.pesoActual >= targetWeight; }).length;
  var pctListos = conGmd.length ? Math.round(yaListos / conGmd.length * 100) : 0;
  var horizon = 180;
  var noLlegan = conGmd.filter(function(a) {
    var pesoFuturo = a.pesoActual + a.gmd * horizon;
    return pesoFuturo < targetWeight;
  }).length;
  var pctNoLlegan = conGmd.length ? Math.round(noLlegan / conGmd.length * 100) : 0;
  var totalAnimales = animales.length;
  var pesoTotalProyectado = totalAnimales * targetWeight;
  var valorEstimado = pesoTotalProyectado * precioKg;

  function _proyKpi(label, value, sub, color) {
    var bg = color || 'var(--amber)';
    return '<div style="background:var(--bg2,#161616);border:1px solid var(--bor);border-radius:6px;padding:10px 12px;position:relative;overflow:hidden">' +
      '<div style="position:absolute;left:0;top:0;bottom:0;width:3px;background:' + bg + '"></div>' +
      '<div style="font-family:\'DM Mono\',monospace;font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:4px">' + label + '</div>' +
      '<div style="font-size:16px;font-weight:700;color:var(--text);font-family:\'DM Mono\',monospace">' + value + '</div>' +
      (sub ? '<div style="font-size:10px;color:var(--muted);margin-top:2px">' + sub + '</div>' : '') +
    '</div>';
  }

  var diasLabel = diasA > 0 ? diasA + ' días' : '✓ Ya listos';
  var diasSub = '';
  if (diasA > 0) {
    var meses = (diasA / 30).toFixed(1);
    var fechaFin = new Date(Date.now() + diasA * 24 * 60 * 60 * 1000);
    diasSub = '~' + meses + ' meses · ' + fechaFin.toLocaleDateString('es-BO', { month: 'short', year: '2-digit' });
  }

  summaryEl.innerHTML =
    _proyKpi('Días a faena', diasLabel, diasSub, 'var(--amber)') +
    _proyKpi('Ya superaron', yaListos + ' / ' + conGmd.length, pctListos + '% del lote', 'var(--green)') +
    _proyKpi('No llegan en 6m', noLlegan + ' / ' + conGmd.length, pctNoLlegan + '% rezagados', noLlegan > 0 ? 'var(--red)' : 'var(--muted)') +
    _proyKpi('Valor estimado', moneda + ' ' + valorEstimado.toLocaleString('es-BO', { maximumFractionDigits: 0 }), 'a ' + moneda + ' ' + precioKg + '/kg', 'var(--blue, #58A6FF)');
}

function _alRenderGMD(animales) {
  var conGmd = animales.filter(function(a) { return a.gmd != null; });
  if (!conGmd.length) {
    document.getElementById('al-gmd-subtitle').textContent = 'Sin datos suficientes (se requieren ≥2 pesajes)';
    return;
  }
  conGmd.sort(function(a, b) { return b.gmd - a.gmd; });
  var labels = conGmd.map(function(a) { return a.id; });
  var values = conGmd.map(function(a) { return a.gmd; });
  var colors = values.map(function(v) {
    if (v >= 1.0) return '#39D353';
    if (v >= 0.7) return '#C9A84C';
    if (v >= 0.5) return '#FF9500';
    return '#E74C3C';
  });

  document.getElementById('al-gmd-subtitle').textContent = conGmd.length + ' animales · ordenados de mejor a peor';

  var ctx = document.getElementById('al-chart-gmd');
  if (ctx) {
    _alCharts.gmd = new Chart(ctx, {
      type: 'bar',
      data: { labels: labels, datasets: [{ label: 'GMD', data: values, backgroundColor: colors, borderRadius: 2 }] },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: { callbacks: { label: function(c) { return 'GMD: ' + c.parsed.y.toFixed(2) + ' kg/día'; } } }
        },
        scales: {
          x: { grid: { display: false }, ticks: { font: { size: 9 }, maxRotation: 90 } },
          y: { beginAtZero: true, grid: { color: '#2A2A2A' }, title: { display: true, text: 'GMD (kg/día)', color: '#666', font: { size: 11 } } }
        }
      }
    });
  }
}

function _alRenderInsights(lot, animales) {
  var html = '';
  var conGmd = animales.filter(function(a) { return a.gmd != null; });
  var gmds = conGmd.map(function(a) { return a.gmd; });
  var promGmd = gmds.length ? (gmds.reduce(function(s, x) { return s + x; }, 0) / gmds.length) : 0;
  var pesoActuales = animales.filter(function(a) { return a.pesoActual; }).map(function(a) { return a.pesoActual; });
  var promPeso = pesoActuales.length ? (pesoActuales.reduce(function(s, x) { return s + x; }, 0) / pesoActuales.length) : 0;

  // Meta GMD configurable (asumir 0.75 si no está)
  var metaGmd = 0.75;
  if (typeof rp !== 'undefined' && rp && rp.meta_gmd) metaGmd = parseFloat(rp.meta_gmd) || 0.75;

  if (promGmd > 0) {
    var diff = ((promGmd / metaGmd - 1) * 100);
    var diffStr = (diff >= 0 ? '+' : '') + diff.toFixed(1) + '%';
    html += _alInsight('Performance', 'GMD del lote (<strong>' + promGmd.toFixed(2) + ' kg/d</strong>) está <strong>' + diffStr + '</strong> respecto a la meta de ' + metaGmd + ' kg/d.');
  }

  // CV
  if (pesoActuales.length > 1) {
    var variance = pesoActuales.reduce(function(s, x) { return s + Math.pow(x - promPeso, 2); }, 0) / pesoActuales.length;
    var sigma = Math.sqrt(variance);
    var cv = (sigma / promPeso) * 100;
    var cvDesc = cv < 10 ? 'muy uniforme' : (cv < 15 ? 'aceptable' : 'disperso');
    html += _alInsight('Uniformidad', 'CV de <strong>' + cv.toFixed(1) + '%</strong> indica un lote <strong>' + cvDesc + '</strong>.' + (cv < 10 ? ' Ideal para venta en bloque.' : ''));
  }

  // Estimación a faena
  var pesoFaena = (lot.category || '').toLowerCase().indexOf('novillo') >= 0 ? 480 : 0;
  if (pesoFaena > 0 && promPeso > 0 && promGmd > 0 && promPeso < pesoFaena) {
    var diasAFaena = Math.round((pesoFaena - promPeso) / promGmd);
    html += _alInsight('Tiempo a faena', 'Con GMD actual, <strong>' + diasAFaena + ' días</strong> hasta peso promedio ' + pesoFaena + ' kg.');
  }

  // Engorde acumulado
  var conIngreso = animales.filter(function(a) { return a.deltaTotal != null && a.deltaTotal > 0; });
  if (conIngreso.length) {
    var promDelta = conIngreso.reduce(function(s, a) { return s + a.deltaTotal; }, 0) / conIngreso.length;
    html += _alInsight('Engorde acumulado', 'Promedio: <strong>+' + Math.round(promDelta) + ' kg/animal</strong> desde primer pesaje.');
  }

  // Valor estimado
  var precioKg = (typeof rp !== 'undefined' && rp && rp.precio_kg_carne) ? parseFloat(rp.precio_kg_carne) : 18;
  var pesoTotal = pesoActuales.reduce(function(s, x) { return s + x; }, 0);
  if (pesoTotal > 0) {
    var moneda = (typeof rp !== 'undefined' && rp && rp.moneda) || 'Bs';
    var valor = pesoTotal * precioKg;
    html += _alInsight('Valor estimado', 'A ' + moneda + ' ' + precioKg + '/kg: <strong>' + moneda + ' ' + valor.toLocaleString('es-BO', { maximumFractionDigits: 0 }) + '</strong>');
  }

  if (!html) {
    html = '<div style="color:var(--muted);font-size:12px;padding:14px">Cargá pesajes individuales para ver insights del lote.</div>';
  }

  document.getElementById('al-insights').innerHTML = html;
}

function _alInsight(label, text) {
  return '<div style="padding:12px 14px;background:var(--bg2,#161616);border-radius:6px;border-left:3px solid var(--amber);margin-bottom:8px;font-size:12px">' +
    '<div style="font-family:\'DM Mono\',monospace;font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:4px">' + label + '</div>' +
    '<div>' + text + '</div>' +
  '</div>';
}

function _alRenderDistribucion(animales) {
  var pesoActuales = animales.filter(function(a) { return a.pesoActual; }).map(function(a) { return a.pesoActual; });
  if (!pesoActuales.length) {
    document.getElementById('al-distribucion').innerHTML = '<div style="color:var(--muted);font-size:12px">Sin datos</div>';
    return;
  }
  // Buckets fijos para distribución por rango (más narrativos que el histograma)
  var minP = Math.min.apply(null, pesoActuales);
  var maxP = Math.max.apply(null, pesoActuales);
  var bucketSize = 30;
  var startP = Math.floor(minP / bucketSize) * bucketSize;
  var endP = Math.ceil((maxP + 1) / bucketSize) * bucketSize;
  var n = animales.length;
  var html = '';
  for (var b = startP; b < endP; b += bucketSize) {
    var count = pesoActuales.filter(function(p) { return p >= b && p < b + bucketSize; }).length;
    if (count === 0) continue;
    var pct = (count / n) * 100;
    var color = b < startP + (endP - startP) * 0.33 ? 'var(--orange,#FF9500)' : (b < startP + (endP - startP) * 0.66 ? 'var(--amber)' : 'var(--green)');
    html += '<div style="display:grid;grid-template-columns:90px 1fr 40px;gap:10px;align-items:center;margin-bottom:8px;font-size:12px">' +
      '<span style="font-family:\'DM Mono\',monospace;color:var(--muted);font-size:11px">' + b + '-' + (b + bucketSize) + ' kg</span>' +
      '<div style="height:22px;background:var(--bg2,#161616);border-radius:4px;position:relative;overflow:hidden">' +
        '<div style="height:100%;width:' + pct + '%;background:' + color + ';border-radius:4px;display:flex;align-items:center;padding-left:8px;color:#000;font-family:\'DM Mono\',monospace;font-size:10px;font-weight:700">' + count + '</div>' +
      '</div>' +
      '<span style="font-family:\'DM Mono\',monospace;color:var(--text);font-weight:600;text-align:right">' + pct.toFixed(0) + '%</span>' +
    '</div>';
  }
  document.getElementById('al-distribucion').innerHTML = html;
}

function _alRenderComparativo(lot, animales) {
  // Otros lotes activos de misma categoría
  var sameCat = (db.lots || []).filter(function(l) {
    var st = (l.status || '').toLowerCase();
    return l.code !== lot.code && st !== 'sold' && st !== 'vendido' && st !== 'cuarentena' &&
      (l.category || '').toLowerCase() === (lot.category || '').toLowerCase();
  });

  if (!sameCat.length) {
    document.getElementById('al-comp-subtitle').textContent = 'Sin otros lotes de misma categoría';
    document.getElementById('al-comp-table').innerHTML = '<div style="color:var(--muted);font-size:12px;padding:8px">No hay otros lotes activos de "' + escH(lot.category || '') + '" para comparar.</div>';
    return;
  }

  var animDB = {};
  try { animDB = JSON.parse(localStorage.getItem('e5m_animals') || '{}'); } catch(e) {}

  // Calcular GMD y peso promedio para cada lote
  function lotStats(lc, fallbackEntry) {
    var anims = (animDB[lc] || []).map(function(a) { return _alCalcAnimalStats(a, fallbackEntry); });
    var pesos = anims.filter(function(a) { return a.pesoActual; }).map(function(a) { return a.pesoActual; });
    var gmds = anims.filter(function(a) { return a.gmd != null; }).map(function(a) { return a.gmd; });
    return {
      promPeso: pesos.length ? pesos.reduce(function(s, x) { return s + x; }, 0) / pesos.length : 0,
      promGmd: gmds.length ? gmds.reduce(function(s, x) { return s + x; }, 0) / gmds.length : 0
    };
  }

  var thisStats = lotStats(lot.code, lot.entry_date);
  var rows = [{ code: lot.code, isThis: true, peso: thisStats.promPeso, gmd: thisStats.promGmd }];
  sameCat.forEach(function(l) {
    var s = lotStats(l.code, l.entry_date);
    rows.push({ code: l.code, isThis: false, peso: s.promPeso, gmd: s.promGmd });
  });
  rows = rows.filter(function(r) { return r.gmd > 0 || r.peso > 0; });

  document.getElementById('al-comp-subtitle').textContent = 'cat: ' + (lot.category || 'sin cat');

  // Chart comparativo
  var ctx = document.getElementById('al-chart-comparativo');
  if (ctx) {
    _alCharts.comp = new Chart(ctx, {
      type: 'bar',
      data: {
        labels: rows.map(function(r) { return r.code; }),
        datasets: [{
          label: 'GMD',
          data: rows.map(function(r) { return parseFloat(r.gmd.toFixed(2)); }),
          backgroundColor: rows.map(function(r) { return r.isThis ? '#C9A84C' : '#3A3A3A'; }),
          borderRadius: 4
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        indexAxis: 'y',
        plugins: { legend: { display: false } },
        scales: {
          x: { beginAtZero: true, grid: { color: '#2A2A2A' } },
          y: { grid: { display: false } }
        }
      }
    });
  }

  // Tabla
  var tHtml = '<table style="width:100%;border-collapse:collapse;font-size:12px;margin-top:8px">' +
    '<thead><tr>' +
      '<th style="padding:6px 8px;text-align:left;font-family:\'DM Mono\',monospace;font-size:10px;color:var(--muted)">LOTE</th>' +
      '<th style="padding:6px 8px;text-align:right;font-family:\'DM Mono\',monospace;font-size:10px;color:var(--muted)">PESO</th>' +
      '<th style="padding:6px 8px;text-align:right;font-family:\'DM Mono\',monospace;font-size:10px;color:var(--muted)">GMD</th>' +
    '</tr></thead><tbody>';
  rows.forEach(function(r) {
    tHtml += '<tr style="' + (r.isThis ? 'background:rgba(201,168,76,0.06)' : '') + '">' +
      '<td style="padding:7px 8px;border-bottom:1px solid var(--bor)">' + (r.isThis ? '<strong style="color:var(--amber)">' + escH(r.code) + ' (este)</strong>' : escH(r.code)) + '</td>' +
      '<td style="padding:7px 8px;text-align:right;font-family:\'DM Mono\',monospace;border-bottom:1px solid var(--bor)">' + (r.peso > 0 ? Math.round(r.peso) + ' kg' : '-') + '</td>' +
      '<td style="padding:7px 8px;text-align:right;font-family:\'DM Mono\',monospace;border-bottom:1px solid var(--bor)">' + (r.gmd > 0 ? r.gmd.toFixed(2) : '-') + '</td>' +
    '</tr>';
  });
  tHtml += '</tbody></table>';
  document.getElementById('al-comp-table').innerHTML = tHtml;
}

function _alRenderSanidad(lot) {
  // Curaciones del lote (últimos 180 días)
  var hace180 = new Date(Date.now() - 180 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10);
  var treats = (db.treatments || []).filter(function(t) {
    return t.lot_code === lot.code && t.date >= hace180;
  });

  var ultDespara = '-';
  var ultVacuna = '-';
  treats.sort(function(a, b) { return String(b.date).localeCompare(String(a.date)); });
  for (var i = 0; i < treats.length; i++) {
    var pname = String(treats[i].product_name || '').toLowerCase();
    if (ultDespara === '-' && (pname.indexOf('iverme') >= 0 || pname.indexOf('parasit') >= 0 || pname.indexOf('despara') >= 0)) ultDespara = treats[i].date;
    if (ultVacuna === '-' && pname.indexOf('vacuna') >= 0) ultVacuna = treats[i].date;
  }

  // Costo total sanidad
  var products = db.products || [];
  var costoTotal = 0;
  treats.forEach(function(t) {
    var prod = products.find(function(p) { return p.id === t.product_id || p.name === t.product_name; });
    if (prod && prod.cost) {
      var qty = parseFloat(t.quantity) || 0;
      costoTotal += qty * parseFloat(prod.cost);
    }
  });
  var costoCab = lot.animal_count ? (costoTotal / lot.animal_count) : 0;
  var moneda = (typeof rp !== 'undefined' && rp && rp.moneda) || 'Bs';

  document.getElementById('al-sanidad').innerHTML =
    '<table style="width:100%;border-collapse:collapse;font-size:12px">' +
      '<tr><td style="padding:7px 0;color:var(--muted)">Curaciones (180d)</td><td style="padding:7px 0;text-align:right"><strong>' + treats.length + '</strong></td></tr>' +
      '<tr><td style="padding:7px 0;color:var(--muted);border-top:1px solid var(--bor)">Última desparasitación</td><td style="padding:7px 0;text-align:right;font-family:\'DM Mono\',monospace;font-size:11px;border-top:1px solid var(--bor)">' + ultDespara + '</td></tr>' +
      '<tr><td style="padding:7px 0;color:var(--muted);border-top:1px solid var(--bor)">Última vacuna</td><td style="padding:7px 0;text-align:right;font-family:\'DM Mono\',monospace;font-size:11px;border-top:1px solid var(--bor)">' + ultVacuna + '</td></tr>' +
      (costoTotal > 0 ? '<tr><td style="padding:7px 0;color:var(--muted);border-top:1px solid var(--bor)">Costo sanidad/cab</td><td style="padding:7px 0;text-align:right;border-top:1px solid var(--bor)"><strong>' + moneda + ' ' + costoCab.toFixed(0) + '</strong></td></tr>' : '') +
    '</table>';
}

// v1.4.97: Línea de tiempo del lote en Análisis Lote (con linaje si es sub-lote)
// Reusa _ahGetLineage y _ahCollectInheritedEvents que ya existen para Análisis Histórico.
// Versión compacta: sólo eventos relevantes para un lote activo (sin ventas todavía).
function _alRenderTimeline(lot) {
  var card = document.getElementById('al-timeline-card');
  var lista = document.getElementById('al-timeline-lista');
  var sub = document.getElementById('al-timeline-subtitle');
  if (!card || !lista) return;

  var lotCode = lot.code;

  // Linaje recursivo via cost_origin.from_lot
  var lineage = (typeof _ahGetLineage === 'function') ? _ahGetLineage(lotCode) : [{ code: lotCode, splitDate: null }];
  var inherited = (typeof _ahCollectInheritedEvents === 'function') ? _ahCollectInheritedEvents(lineage) : { pesajes:[], compras:[], treatments:[], bajas:[], partos:[], conteos:[], mantenimientos:[], splits:[] };
  var hasLineage = lineage.length > 1;

  var eventos = [];

  // Eventos PROPIOS del lote
  // 1. Compra principal (más cabezas)
  var compras = (db.compras_ganado || []).filter(function(c) {
    if (c.lot_code === lotCode) return true;
    if (Array.isArray(c.lote_destinos) && c.lote_destinos.indexOf(lotCode) >= 0) return true;
    return false;
  });
  var comprasValidas = compras.filter(function(c) {
    if (!c.fecha) return false;
    var cabs = parseInt(c.animal_count || c.cabezas || 0) || 0;
    var kgTot = parseFloat(c.total_kg || c.kg_total || 0) || 0;
    return cabs > 0 && kgTot > 0;
  });
  var compraPrincipal = comprasValidas.slice().sort(function(a,b) {
    return (parseInt(b.animal_count || b.cabezas || 0) || 0) - (parseInt(a.animal_count || a.cabezas || 0) || 0);
  })[0];
  comprasValidas.forEach(function(c) {
    var cabs = parseInt(c.animal_count || c.cabezas || 0) || 0;
    var kgTot = parseFloat(c.total_kg || c.kg_total || 0) || 0;
    var prom = (kgTot / cabs).toFixed(1);
    var esPrincipal = (c === compraPrincipal);
    var desc = (esPrincipal ? 'Ingreso' : 'Compra adicional') + ': ' + cabs + ' cab @ ' + prom + ' kg';
    if (c._via_traspaso) desc += ' (vía ' + c._origen_lote + ')';
    if (c.proveedor) desc += ' — ' + c.proveedor;
    eventos.push({ date: c.fecha.slice(0,10), tipo: esPrincipal ? 'lote' : 'compra_extra', desc: desc });
  });

  // 2. Pesajes (agrupados por fecha)
  var pesajesPorFecha = {};
  (db.pesajes || []).filter(function(p) {
    return p.lot_code === lotCode && (p.tipo || '').toLowerCase() !== 'venta';
  }).forEach(function(p) {
    var d = String(p.date || '').slice(0,10);
    if (!d) return;
    if (!pesajesPorFecha[d]) pesajesPorFecha[d] = { suma:0, count:0 };
    var peso = parseFloat(p.peso_promedio || p.peso_prom || p.peso || 0) || 0;
    if (peso > 0) { pesajesPorFecha[d].suma += peso; pesajesPorFecha[d].count += 1; }
  });
  Object.keys(pesajesPorFecha).forEach(function(d) {
    var i = pesajesPorFecha[d];
    if (i.count > 0) {
      eventos.push({ date: d, tipo: 'lote', desc: 'Pesaje: ' + (i.suma/i.count).toFixed(1) + ' kg prom (' + i.count + ' registros)' });
    }
  });

  // 3. Tratamientos sanitarios (resumen por fecha)
  var treatsPorFecha = {};
  (db.treatments || []).filter(function(t) { return t.lot_code === lotCode; }).forEach(function(t) {
    var d = String(t.applied_at || t.date || '').slice(0,10);
    if (!d) return;
    if (!treatsPorFecha[d]) treatsPorFecha[d] = { n:0, productos:[] };
    treatsPorFecha[d].n += 1;
    if (t.product_name) treatsPorFecha[d].productos.push(t.product_name);
  });
  Object.keys(treatsPorFecha).forEach(function(d) {
    var i = treatsPorFecha[d];
    var prods = i.productos.length ? ' (' + i.productos.slice(0,3).join(', ') + (i.productos.length>3 ? '…' : '') + ')' : '';
    eventos.push({ date: d, tipo: 'sanidad', desc: 'Sanidad: ' + i.n + ' aplicación' + (i.n>1?'es':'') + prods });
  });

  // 4. Movimientos de potrero (rotation_history)
  var rh = (db.rotation_history || []).filter(function(r) { return r.lot_code === lotCode; });
  rh.forEach(function(r) {
    var d = String(r.entry_date || r.entrada || r.date || '').slice(0,10);
    if (!d) return;
    var to = r.paddock || r.potrero || '?';
    eventos.push({ date: d, tipo: 'rotacion', desc: 'Rotación a potrero: ' + to });
  });

  // 5. Bajas y partos
  (db.bajas || []).filter(function(b) { return b.lot_code === lotCode; }).forEach(function(b) {
    var d = String(b.fecha || b.date || '').slice(0,10);
    if (!d) return;
    eventos.push({ date: d, tipo: 'baja', desc: 'Baja: ' + (b.motivo || 'sin motivo') + (b.animal_id ? ' (animal ' + b.animal_id + ')' : '') });
  });
  (db.partos || []).filter(function(p) { return p.lot_code === lotCode; }).forEach(function(p) {
    var d = String(p.fecha || p.date || '').slice(0,10);
    if (!d) return;
    var cabs = parseInt(p.cabezas || p.count || 1) || 1;
    eventos.push({ date: d, tipo: 'parto', desc: 'Parto: ' + cabs + ' cab' });
  });

  // 6. v1.8.7: Fusiones
  // 6a. Este lote FUE fusionado hacia otro (origen)
  if (lot.status === 'fusionado' && lot.fused_into) {
    var dFus = String(lot.fused_at || '').slice(0,10);
    eventos.push({ date: dFus, tipo: 'fusion', desc: 'Lote fusionado en ' + lot.fused_into + ' (' + (lot.fused_count || 0) + ' animales movidos)' });
  }
  // 6b. Este lote RECIBIÓ animales de otro lote fusionado (destino)
  (db.lots || []).filter(function(l) {
    return l.status === 'fusionado' && l.fused_into === lotCode;
  }).forEach(function(origenLot) {
    var dFus = String(origenLot.fused_at || '').slice(0,10);
    eventos.push({ date: dFus, tipo: 'fusion', desc: 'Recibió ' + (origenLot.fused_count || 0) + ' animales de ' + origenLot.code + ' (fusión)' });
  });
  // 6c. Respaldo desde Kardex (por si el lote destino no tiene el dato en lots)
  (db.kardex || []).filter(function(k) {
    return k.lote === lotCode && k.tipo === 'fusion';
  }).forEach(function(k) {
    var d = String(k.fecha || '').slice(0,10);
    if (!d) return;
    // Evitar duplicar si ya está por 6b (mismo día + mismas cabezas)
    var yaExiste = eventos.some(function(e){ return e.tipo === 'fusion' && e.date === d; });
    if (!yaExiste) {
      eventos.push({ date: d, tipo: 'fusion', desc: k.desc || ('Fusión: ' + (k.cabezas || 0) + ' animales') });
    }
  });

  // Eventos HEREDADOS si hay linaje
  if (hasLineage) {
    var parentBuy = null, parentBuyCabs = 0;
    (inherited.compras || []).forEach(function(c) {
      var cabs = parseInt(c.animal_count || c.cabezas || 0) || 0;
      if (cabs > parentBuyCabs) { parentBuyCabs = cabs; parentBuy = c; }
    });
    if (parentBuy) {
      var pCabs = parseInt(parentBuy.animal_count || parentBuy.cabezas || 0) || 0;
      var pKg = parseFloat(parentBuy.total_kg || parentBuy.kg_total || 0) || 0;
      var pProm = pKg > 0 && pCabs > 0 ? (pKg/pCabs).toFixed(1) : '?';
      var pDesc = 'Ingreso original (' + parentBuy._from_lot + '): ' + pCabs + ' cab @ ' + pProm + ' kg';
      if (parentBuy.proveedor) pDesc += ' — ' + parentBuy.proveedor;
      eventos.push({ date: String(parentBuy.fecha).slice(0,10), tipo: 'ingreso', desc: pDesc });
    }
    // Pesajes heredados agrupados
    var inhPesajesPorFecha = {};
    (inherited.pesajes || []).filter(function(p) { return (p.tipo || '').toLowerCase() !== 'venta'; }).forEach(function(p) {
      var d = String(p.date || '').slice(0,10);
      if (!d) return;
      if (!inhPesajesPorFecha[d]) inhPesajesPorFecha[d] = { suma:0, count:0, from:p._from_lot };
      var peso = parseFloat(p.peso_promedio || p.peso_prom || p.peso || 0) || 0;
      if (peso > 0) { inhPesajesPorFecha[d].suma += peso; inhPesajesPorFecha[d].count += 1; }
    });
    Object.keys(inhPesajesPorFecha).forEach(function(d) {
      var i = inhPesajesPorFecha[d];
      if (i.count > 0) {
        eventos.push({ date: d, tipo: 'heredado', desc: 'Pesaje heredado (' + i.from + '): ' + (i.suma/i.count).toFixed(1) + ' kg prom (' + i.count + ' registros)' });
      }
    });
    // Tratamientos heredados
    var inhTreatsPorFecha = {};
    (inherited.treatments || []).forEach(function(t) {
      var d = String(t.applied_at || t.date || '').slice(0,10);
      if (!d) return;
      if (!inhTreatsPorFecha[d]) inhTreatsPorFecha[d] = { n:0, from:t._from_lot };
      inhTreatsPorFecha[d].n += 1;
    });
    Object.keys(inhTreatsPorFecha).forEach(function(d) {
      var i = inhTreatsPorFecha[d];
      eventos.push({ date: d, tipo: 'heredado', desc: 'Sanidad heredada (' + i.from + '): ' + i.n + ' aplicación' + (i.n>1?'es':'') });
    });
    // Splits — el HITO de la separación
    (inherited.splits || []).forEach(function(s) {
      var prom = s.total_kg && s.cabs ? (s.total_kg/s.cabs).toFixed(1) : '?';
      // v1.8.25: distinguir si el origen fue un marcaje de cuarentena o una separación real
      var desc;
      if (s.via === 'marcaje') {
        desc = 'Marcado desde cuarentena ' + s.from_lot + ': ' + s.cabs + ' cab @ ' + prom + ' kg → ' + s.to_lot;
      } else {
        desc = 'Separado de ' + s.from_lot + ': ' + s.cabs + ' cab @ ' + prom + ' kg → ' + s.to_lot;
      }
      eventos.push({ date: String(s.date).slice(0,10), tipo: 'split', desc: desc, _via: s.via });
    });
  }

  // Ordenar cronológicamente
  // v1.8.25: orden secundario por tipo cuando es el mismo día, para que la secuencia
  // lógica sea: ingreso original (compra) → marcaje/split → heredados → eventos del lote → venta.
  var _ordenTipo = { ingreso: 0, heredado: 1, split: 2, sanidad: 3, pesaje: 4, conteo: 5, parto: 6, baja: 7, fusion: 8, venta: 9, sale: 9 };
  eventos.sort(function(a, b) {
    var fc = a.date.localeCompare(b.date);
    if (fc !== 0) return fc;
    var oa = (_ordenTipo[a.tipo] != null) ? _ordenTipo[a.tipo] : 5;
    var ob = (_ordenTipo[b.tipo] != null) ? _ordenTipo[b.tipo] : 5;
    return oa - ob;
  });

  // Subtitle: cuántos eventos + cuántos heredados
  var nProp = eventos.filter(function(e) { return e.tipo !== 'heredado' && e.tipo !== 'split'; }).length;
  var nHer = eventos.filter(function(e) { return e.tipo === 'heredado'; }).length;
  var nSplit = eventos.filter(function(e) { return e.tipo === 'split'; }).length;
  var subParts = [nProp + ' eventos propios'];
  if (hasLineage) {
    subParts.push(nHer + ' heredado' + (nHer!==1?'s':'') + ' (de ' + lineage[0].code + ')');
    if (nSplit) subParts.push(nSplit + ' separación' + (nSplit>1?'es':''));
  }
  if (sub) sub.textContent = subParts.join(' · ');

  // v1.4.100: Render como TIMELINE VERTICAL VISUAL — no lista plana.
  // Línea continua a la izquierda + punto por evento + chip para split.
  var lineStyle = 'position:absolute;left:6px;top:6px;bottom:6px;width:2px;background:#3b3b4f;border-radius:1px;';
  var html = '<div style="position:relative;padding-left:22px">';
  html += '<div style="' + lineStyle + '"></div>';

  eventos.forEach(function(e, idx) {
    var isLast = idx === eventos.length - 1;
    var dotBg, dotBorder = '#0D1117', dotSize = 14, dotShadow = '', extraEvStyle = '', descColor = '#E6EDF3', descWeight = '400', dateColor = '#7D8590', opacity = 1;

    if (e.tipo === 'ingreso') {
      // v1.8.25: compra original / ingreso del ganado — hito de origen destacado en verde
      dotBg = '#3fb950'; dotSize = 16; dotShadow = 'box-shadow:0 0 0 3px rgba(63,185,80,.25);';
      extraEvStyle = 'background:rgba(63,185,80,.08);border-left:2px solid #3fb950;padding:8px 12px;margin-left:-2px;border-radius:0 6px 6px 0;';
      descColor = '#7ee787'; descWeight = '500'; dateColor = '#3fb950';
    } else if (e.tipo === 'split') {
      dotBg = '#a855f7'; dotSize = 16; dotShadow = 'box-shadow:0 0 0 3px rgba(168,85,247,.3);';
      extraEvStyle = 'background:rgba(168,85,247,.08);border-left:2px solid #a855f7;padding:8px 12px;margin-left:-2px;border-radius:0 6px 6px 0;';
      descColor = '#c4a4f9'; descWeight = '500'; dateColor = '#a855f7';
    } else if (e.tipo === 'heredado') {
      dotBg = '#0D1117'; dotBorder = '#9CA3AF'; descColor = '#9CA3AF'; opacity = 0.8;
    } else if (e.tipo === 'lote') {
      dotBg = '#7c3aed'; dotShadow = 'box-shadow:0 0 0 2px rgba(124,58,237,.25);';
    } else if (e.tipo === 'compra_extra') {
      dotBg = '#3b82f6';
    } else if (e.tipo === 'sanidad') {
      dotBg = '#10b981';
    } else if (e.tipo === 'rotacion') {
      dotBg = '#f59e0b';
    } else if (e.tipo === 'baja') {
      dotBg = '#ef4444';
    } else if (e.tipo === 'parto') {
      dotBg = '#ec4899';
    } else if (e.tipo === 'fusion') {
      dotBg = '#58a6ff'; dotShadow = 'box-shadow:0 0 0 3px rgba(88,166,255,.25);';
      extraEvStyle = 'background:rgba(88,166,255,.08);border-left:2px solid #58a6ff;padding:8px 12px;margin-left:-2px;border-radius:0 6px 6px 0;';
      descColor = '#a8d0ff'; descWeight = '500'; dateColor = '#58a6ff';
    } else {
      dotBg = '#7D8590';
    }

    var dotLeft = e.tipo === 'split' ? -23 : -22;
    var dotTop = e.tipo === 'split' ? 3 : 4;

    html += '<div style="position:relative;padding-bottom:' + (isLast ? '0' : '18') + 'px;opacity:' + opacity + ';' + extraEvStyle + '">';
    html += '<div style="position:absolute;left:' + dotLeft + 'px;top:' + dotTop + 'px;width:' + dotSize + 'px;height:' + dotSize + 'px;border-radius:50%;background:' + dotBg + ';border:2px solid ' + dotBorder + ';box-sizing:border-box;' + dotShadow + '"></div>';
    html += '<div style="font-family:\'DM Mono\',monospace;font-size:10px;color:' + dateColor + ';text-transform:uppercase;letter-spacing:.3px;margin-bottom:3px">' + _ahFmtFecha(e.date) + (e.tipo === 'split' ? ' · separación' : '') + '</div>';
    html += '<div style="font-size:13px;line-height:1.4;color:' + descColor + ';font-weight:' + descWeight + '">' + (e.tipo === 'split' ? '✂ ' : '') + e.desc + '</div>';
    html += '</div>';
  });

  html += '</div>';
  lista.innerHTML = html;
  // v1.8.27: mostrar la card (estaba en display:none por defecto y nunca se activaba,
  // por eso la línea de tiempo no aparecía en Análisis Lote aunque sí se generaba el HTML).
  card.style.display = eventos.length ? 'block' : 'none';
}

function _alRenderTabla(animales, filter) {
  var rows = animales.slice();
  if (filter === 'top') {
    rows = rows.filter(function(a) { return a.gmd != null && a.gmd >= 0.9; }).sort(function(a, b) { return b.gmd - a.gmd; });
  } else if (filter === 'rezagados') {
    rows = rows.filter(function(a) { return a.gmd != null && a.gmd < 0.5; }).sort(function(a, b) { return a.gmd - b.gmd; });
  } else {
    rows.sort(function(a, b) { return (b.gmd || -Infinity) - (a.gmd || -Infinity); });
  }

  if (!rows.length) {
