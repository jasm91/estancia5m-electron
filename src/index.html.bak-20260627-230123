// BLINDAJE DE IDs — prevención de colisiones de id por contador local
// ════════════════════════════════════════════════════════════════
// Raíz del bug reportado: muchos registros se crean con "id: db.next_ids.X++", un contador
// LOCAL que se reinicia a 1 al reinstalar la app o usarla en otro equipo. Como las tablas se
// sincronizan desde el server (con ids ya altos), el contador reseteado vuelve a emitir ids
// YA usados → colisión. Eso dejó 3 bajas con id=1 y hacía que "Vender carne" abriera el animal
// equivocado (.find() por id agarra el primero).
//
// reconcileNextIds(): sube cada contador al máximo id presente en su tabla + 1. Solo SUBE,
// nunca baja. Idempotente: seguro de correr al arrancar y después de cada sync.
var _NEXTID_MAP = {
  sale:'sales', product:'products', alert:'alerts', treatment:'treatments',
  lot:'lots', partos:'partos', pesaje:'pesajes', maint:'maintenance',
  diesel:'diesel', trace:'trace_records', activity:'activities',
  employee:'employees', advance:'advances', purchase:'purchases'
};
function reconcileNextIds() {
  try {
    if (!db.next_ids) db.next_ids = {};
    var bumped = [];
    Object.keys(_NEXTID_MAP).forEach(function(key){
      var arr = db[_NEXTID_MAP[key]];
      if (!Array.isArray(arr) || !arr.length) return;
      var maxId = arr.reduce(function(m, r){
        var n = parseInt(r && r.id, 10);
        return (!isNaN(n) && n > m) ? n : m;
      }, 0);
      var need = maxId + 1;
      var cur = parseInt(db.next_ids[key], 10);
      if (isNaN(cur) || cur < need) { db.next_ids[key] = need; bumped.push(key + '→' + need); }
    });
    if (bumped.length) console.log('[Blindaje IDs] contadores reconciliados:', bumped.join(', '));
  } catch(e){ console.warn('[Blindaje IDs] error', e); }
}

// Red de seguridad: reparar IDs de baja duplicados o faltantes (por si llegan por sync).
// La primera ocurrencia conserva su id; las siguientes (o las sin id) reciben uno nuevo,
// único, basado en timestamp. Sin flag "done" para que también repare duplicados futuros.
(function repararIdsBajas() {
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', repararIdsBajas);
    return;
  }
  setTimeout(function() {
    try {
      if (!Array.isArray(db.bajas) || !db.bajas.length) return;
      var vistos = {};
      var necesita = false;
      db.bajas.forEach(function(b) {
        var id = b.id;
        if (id === undefined || id === null || id === '' || vistos[String(id)]) necesita = true;
        if (id !== undefined && id !== null && id !== '') vistos[String(id)] = true;
      });
      if (!necesita) return;

      var usados = {};
      var reparados = [];
      var seed = Date.now();
      db.bajas.forEach(function(b) {
        var id = b.id;
        var idStr = String(id);
        var invalido = (id === undefined || id === null || id === '');
        if (invalido || usados[idStr]) {
          var nuevoId = seed++;
          while (usados[String(nuevoId)] || vistos[String(nuevoId)]) nuevoId++;
          reparados.push('Animal #' + (b.animal_id || '?') + ': ' + (invalido ? 'sin id' : 'id ' + idStr) + ' → ' + nuevoId);
          b.id = nuevoId;
          usados[String(nuevoId)] = true;
        } else {
          usados[idStr] = true;
        }
      });

      if (reparados.length) {
        if (typeof saveDB === 'function') saveDB();
        if (typeof replaceTableInRailway === 'function') try { replaceTableInRailway('bajas', db.bajas || []); } catch(e){}
        console.log('[Migración BAJA-ID] IDs de baja reparados:', reparados);
        if (typeof renderBajasDesktop === 'function') try { renderBajasDesktop(); } catch(e){}
        if (typeof toast === 'function') toast('Se repararon ' + reparados.length + ' IDs de baja duplicados', 'success');
      }
    } catch(e) { console.warn('[Migración BAJA-ID] error', e); }
  }, 3800);
})();

// Reconciliar contadores al arrancar (tras el pull inicial que carga los datos del server).
(function reconcileNextIdsStartup() {
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', reconcileNextIdsStartup);
    return;
  }
  setTimeout(function(){ try { reconcileNextIds(); if (typeof saveDB === 'function') saveDB(); } catch(e){} }, 4000);
})();






// Handler post-restore: cuando la app reinicia después de un restore,
// el localStorage está vacío. Hay que hacer pull forzado del server.
(function handlePostRestore() {
  if (sessionStorage.getItem('_post_restore') !== '1') return;
  console.log('[PostRestore] Detectado, haciendo pull forzado del server...');
  toast('Sincronizando datos restaurados desde server...', 'info');

  // Esperar 1s para que la app cargue lo básico
  setTimeout(function() {
    var apiUrl = (typeof getApiUrl === 'function') ? getApiUrl() : 'https://estancia5m-api-production.up.railway.app/api';
    var token = localStorage.getItem('e5m_api_token') || '';
    if (!token) {
      sessionStorage.removeItem('_post_restore');
      return;
    }
    fetch(apiUrl + '/sync-pull?include_sold=true', {
      headers: { 'Authorization': 'Bearer ' + token }
    })
    .then(function(r){ return r.json(); })
    .then(function(remote) {
      if (!remote || remote.error) {
        toast('Error trayendo datos restaurados', 'error');
        sessionStorage.removeItem('_post_restore');
        return;
      }
      // Aplicar TODO al localStorage
      try {
        // Tablas array → db.[name]
        var arrayTables = ['lots','sales','purchases','employees','products','treatments',
          'health_alerts','field_activities','tasks','pesajes','advances','maintenance',
          'agua','sal','conteo','partos','alimento','animal_movements','lluvias',
          'diesel','aceite','cuentas','kardex','historial_sueldos','compras_ganado',
          'bajas','maquinaria','rotation_history','pasture_evals','inventory_counts',
          'reproductive_services'];
        if (typeof db === 'undefined' || !db) window.db = {};
        arrayTables.forEach(function(t) {
          if (Array.isArray(remote[t])) db[t] = remote[t];
        });
        // Mapeos especiales: server usa 'products', desktop usa 'products'/'vet_products'
        if (Array.isArray(remote.products)) db.products = remote.products;
        if (Array.isArray(remote.health_alerts)) db.alerts = remote.health_alerts;
        if (Array.isArray(remote.field_activities)) db.activities = remote.field_activities;

        // Animals → e5m_animals
        var animals = remote.animals || remote.animals_data || {};
        if (animals && typeof animals === 'object') {
          localStorage.setItem('e5m_animals', JSON.stringify(animals));
        }
        // Tablas-objeto → keys propias
        if (remote.estancia_params && typeof remote.estancia_params === 'object' && Object.keys(remote.estancia_params).length) {
          // FIX v1.4.33: stampear updated_at NOW para que el merge posterior considere
          // estos params como "los más recientes" frente a cualquier cache local viejo
          remote.estancia_params.updated_at = new Date().toISOString();
          localStorage.setItem('e5m_params', JSON.stringify(remote.estancia_params));
        }
        if (remote.branding && typeof remote.branding === 'object' && Object.keys(remote.branding).length) {
          // FIX v1.4.33: stampear updated_at fresh para que gane en próximo merge
          remote.branding.updated_at = new Date().toISOString();
          localStorage.setItem('e5m_branding', JSON.stringify(remote.branding));
        }
        if (remote.report_params && typeof remote.report_params === 'object' && Object.keys(remote.report_params).length) {
          // FIX v1.4.33: idem report_params
          remote.report_params.updated_at = new Date().toISOString();
          localStorage.setItem('e5m_report_params', JSON.stringify(remote.report_params));
        }
        if (remote.diesel_tank) {
          localStorage.setItem('e5m_diesel_tank', JSON.stringify(remote.diesel_tank));
          // FIX v1.4.33: stampear timestamp fresh para diesel_tank
          localStorage.setItem('e5m_diesel_tank_updated_at', new Date().toISOString());
        }
        if (remote.pluvios_config) {
          localStorage.setItem('e5m_pluvios', JSON.stringify(remote.pluvios_config));
          // FIX v1.4.33: stampear timestamp para pluvios también
          localStorage.setItem('e5m_pluvios_updated_at', new Date().toISOString());
        }
        // Tasks
        if (Array.isArray(remote.tasks)) {
          localStorage.setItem('e5m_tasks', JSON.stringify(remote.tasks));
        }

        // Persistir db
        var DB_KEY_LOCAL = (typeof DB_KEY !== 'undefined') ? DB_KEY : 'estancia5m_db';
        localStorage.setItem(DB_KEY_LOCAL, JSON.stringify(db));

        console.log('[PostRestore] Datos sincronizados desde server. Liberando flag.');
        sessionStorage.removeItem('_post_restore');
        toast('Datos restaurados sincronizados ✓', 'success');

        // Recargar UI
        setTimeout(function() { location.reload(); }, 1000);
      } catch(err) {
        console.error('[PostRestore] Error aplicando datos:', err);
        sessionStorage.removeItem('_post_restore');
        toast('Error aplicando datos: ' + err.message, 'error');
      }
    })
    .catch(function(err) {
      console.error('[PostRestore] Error de red:', err);
      sessionStorage.removeItem('_post_restore');
      toast('Error de red: ' + err.message, 'error');
    });
  }, 1500);
})();

