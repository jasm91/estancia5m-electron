function savePluvioConfig() {
  var listEl = document.getElementById('pluvio-config-list');
  if (!listEl) return;
  var newPluvios = [];
  var _pluvRenameMap = [];   // v1.8.68: {oldKey,newKey} para migrar el histórico de lluvias
  var rows = listEl.querySelectorAll('[id^="pluvio-row-"]');
  rows.forEach(function(row, i) {
    var nameEl = row.querySelector('[id^="pc-name-"]');
    var name = (nameEl ? nameEl.value : '').trim();
    if (!name) return;
    var key = name.toLowerCase().replace(/[^a-z0-9]/g, '_') + '_mm';
    var oldKey = row.getAttribute('data-oldkey') || '';
    if (oldKey && oldKey !== key) _pluvRenameMap.push({ oldKey: oldKey, newKey: key });
    newPluvios.push({
      key: key,
      label: name,
      color: _PLUVIO_COLORS[i % _PLUVIO_COLORS.length]
    });
  });
  if (!newPluvios.length) { toast('Agrega al menos un pluviómetro', 'error'); return; }
  // v1.8.68: la lluvia histórica se guarda en una columna cuya clave deriva del nombre
  // (ej. "Lote 15" → lote_15_mm). Al renombrar, la clave cambia y el histórico quedaba
  // INVISIBLE (getLluviaMm leía la clave nueva, vacía). Acá migramos el valor a la clave nueva.
  var _migL = 0;
  if (_pluvRenameMap.length && Array.isArray(db.lluvias)) {
    db.lluvias.forEach(function(r){
      _pluvRenameMap.forEach(function(m){
        if (r[m.oldKey] !== undefined) {
          if (r[m.newKey] === undefined || r[m.newKey] === null || r[m.newKey] === '') r[m.newKey] = r[m.oldKey];
          delete r[m.oldKey];
          _migL++;
        }
      });
    });
    if (_migL) { saveDB(); try { replaceTableInRailway('lluvias', db.lluvias || []); } catch(e){} }
  }
  savePluvios(newPluvios);
  PLUVIOS = newPluvios;
  closeModal('modal-pluvio-config');
  renderLluviasDesktop();
  toast(_migL ? ('Pluviómetros actualizados · ' + _migL + ' registro(s) de lluvia migrados') : ('Pluviómetros: ' + newPluvios.map(function(p){ return p.label; }).join(', ')), 'success');
}

