function runSimulador() {
  var lotCode = ((document.getElementById('sim-lote')||{}).value||'').trim();
  var precio = parseFloat((document.getElementById('sim-precio')||{}).value) || 34;
  var pesoMin = parseFloat((document.getElementById('sim-peso-min')||{}).value) || 0;
  var pesoMax = parseFloat((document.getElementById('sim-peso-max')||{}).value) || 9999;
  var animDB = (typeof getAnimalesDB === 'function') ? getAnimalesDB() : {};
  var lots = db.lots || [];

  // Collect eligible animals
  var eligible = [];
  var lotCodes = lotCode ? [lotCode] : Object.keys(animDB);
  lotCodes.forEach(function(lc) {
    (animDB[lc]||[]).forEach(function(a) {
      var ps = a.pesajes || [];
      var last = ps.length ? ps[ps.length-1] : null;
      var peso = last ? last.peso : 0;
      if (peso >= pesoMin && peso <= pesoMax) {
        // Calculate GMD
        var gmd = 0;
        if (ps.length >= 2) {
          var first = ps[0]; var lastP = ps[ps.length-1];
          var days = Math.max(1, Math.round((new Date(lastP.fecha) - new Date(first.fecha)) / 86400000));
          gmd = Math.round((lastP.peso - first.peso) / days * 1000) / 1000;
        }
        eligible.push({id: a.id || a.animal_id, lot: lc, peso: peso, gmd: gmd, raza: a.raza || a.breed || ''});
      }
    });
  });

  if (!eligible.length) {
    document.getElementById('sim-result').innerHTML = '<div style="color:var(--muted);font-size:13px;padding:20px;text-align:center">No hay animales en el rango de peso seleccionado.</div>';
    return;
  }

  var totalKg = eligible.reduce(function(s,a){return s+a.peso;},0);
  var avgPeso = Math.round(totalKg / eligible.length);
  var avgGmd = eligible.filter(function(a){return a.gmd>0;});
  var gmdProm = avgGmd.length ? Math.round(avgGmd.reduce(function(s,a){return s+a.gmd;},0)/avgGmd.length*1000)/1000 : 0;

  // Calculate costs per day
  var mp = new Date().toISOString().slice(0,7);
  var dieselMes = (db.diesel||[]).filter(function(d){return d.type==='despacho'&&(d.fecha||'').startsWith(mp);}).reduce(function(s,d){return s+(parseFloat(d.litros)||0);},0);
  var salMes = (db.sal||[]).filter(function(s){return (s.date||'').startsWith(mp);}).reduce(function(s2,r){return s2+(r.qty||0);},0);
  var totalAnimals = lots.reduce(function(s,l){return s+(l.animal_count||0);},0);
  var mantMes = (db.maintenance||[]).filter(function(m){return (m.date||'').startsWith(mp);}).reduce(function(s,m){return s+(m.cost||0);},0);
  var persTotal = (db.employees||[]).reduce(function(s,e){return s+(e.salary||0);},0);
  var costoMesTot = (dieselMes * 7.5) + mantMes + persTotal; // diesel at ~7.5 Bs/L estimate
  var costoDiaPorCab = totalAnimals > 0 ? Math.round(costoMesTot / 30 / totalAnimals * 100) / 100 : 0;

  // Scenarios
  var scenarios = [
    {label: 'Vender HOY', days: 0},
    {label: 'Esperar 30 dias', days: 30},
    {label: 'Esperar 60 dias', days: 60},
    {label: 'Esperar 90 dias', days: 90}
  ];

  var html = '<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:16px">';
  html += '<div class="kpi-card"><div class="kpi-val" style="color:var(--amber2)">'+eligible.length+'</div><div class="kpi-lbl">Animales</div></div>';
  html += '<div class="kpi-card"><div class="kpi-val">'+avgPeso+' kg</div><div class="kpi-lbl">Peso promedio</div></div>';
  html += '<div class="kpi-card"><div class="kpi-val">'+(totalKg/1000).toFixed(1)+' ton</div><div class="kpi-lbl">Kg totales</div></div>';
  html += '<div class="kpi-card"><div class="kpi-val">'+gmdProm+'</div><div class="kpi-lbl">GMD prom (kg/dia)</div></div>';
  html += '</div>';

  html += '<table class="tbl" style="font-size:12px"><thead><tr><th>Escenario</th><th>Peso prom.</th><th>Kg totales</th><th>Ingreso bruto</th><th>Costo mantener</th><th>Ingreso neto</th><th>Diferencia</th></tr></thead><tbody>';

  var baseNeto = 0;
  scenarios.forEach(function(sc, i) {
    var projPeso = avgPeso + (gmdProm * sc.days);
    var projTotalKg = Math.round(projPeso * eligible.length);
    var ingresoBruto = Math.round(projTotalKg * precio);
    var costoMantener = Math.round(costoDiaPorCab * eligible.length * sc.days);
    var ingresoNeto = ingresoBruto - costoMantener;
    if (i === 0) baseNeto = ingresoNeto;
    var diff = ingresoNeto - baseNeto;
    var diffColor = diff > 0 ? 'var(--green)' : diff < 0 ? 'var(--red)' : 'var(--muted)';
    var best = i > 0 && diff > 0 ? 'background:rgba(34,197,94,.08)' : '';
    html += '<tr style="'+best+'"><td style="font-weight:700">'+sc.label+'</td>';
    html += '<td>'+Math.round(projPeso)+' kg</td>';
    html += '<td>'+projTotalKg.toLocaleString()+' kg</td>';
    html += '<td style="color:var(--green)">Bs. '+ingresoBruto.toLocaleString()+'</td>';
    html += '<td style="color:var(--red)">'+(costoMantener?'Bs. '+costoMantener.toLocaleString():'-')+'</td>';
    html += '<td style="font-weight:700">Bs. '+ingresoNeto.toLocaleString()+'</td>';
    html += '<td style="color:'+diffColor+';font-weight:700">'+(diff>0?'+':'')+diff.toLocaleString()+'</td></tr>';
  });
  html += '</tbody></table>';

  html += '<div style="margin-top:12px;padding:10px 14px;background:var(--sur2);border-radius:8px;font-size:11px;color:var(--muted);line-height:1.6">';
  html += '<b>Supuestos:</b> GMD constante '+gmdProm+' kg/dia · Costo/dia/cabeza: Bs. '+costoDiaPorCab+' (diesel, personal, mantenimiento) · Precio constante '+precio+' Bs/kg. Los costos reales pueden variar.';
  html += '</div>';

  document.getElementById('sim-result').innerHTML = html;
}

