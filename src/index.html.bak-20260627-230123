var _dashTo     = null;

function setDashPeriod(period, btn) {
  _dashPeriod = period;
  document.querySelectorAll('.dash-period-btn').forEach(function(b){ b.classList.remove('active'); });
  if (btn) btn.classList.add('active');

  var customInputs = document.getElementById('custom-range-inputs');
  var label = document.getElementById('period-label');
  var todayStr = today();

  if (period === 'custom') {
    if (customInputs) customInputs.style.display = 'flex';
    if (!document.getElementById('range-from').value) {
      document.getElementById('range-from').value = localDate(new Date(Date.now()-30*86400000));
      document.getElementById('range-to').value = todayStr;
    }
    applyCustomRange();
    return;
  } else {
    if (customInputs) customInputs.style.display = 'none';
  }

  var from, to = todayStr;
  if (period === 'dia') {
    from = todayStr;
    if (label) label.textContent = 'Hoy · ' + new Date().toLocaleDateString('es-BO',{weekday:'long',day:'numeric',month:'long'});
  } else if (period === 'semana') {
    from = localDate(new Date(Date.now()-7*86400000));
    if (label) label.textContent = 'Últimos 7 dias';
  } else if (period === 'mes') {
    from = localDate(new Date(Date.now()-30*86400000));
    if (label) label.textContent = 'Últimos 30 dias';
  } else {
    from = null; to = null;
    if (label) label.textContent = 'Todo el periodo';
  }

  _dashFrom = from;
  _dashTo   = to;
  renderDashWithPeriod();
}

function applyCustomRange() {
  _dashFrom = document.getElementById('range-from').value;
  _dashTo   = document.getElementById('range-to').value;
  var label = document.getElementById('period-label');
  if (label && _dashFrom && _dashTo) label.textContent = _dashFrom + ' → ' + _dashTo;
  renderDashWithPeriod();
}

function inPeriod(dateStr) {
  if (!_dashFrom && !_dashTo) return true;
  if (_dashFrom && dateStr < _dashFrom) return false;
  if (_dashTo   && dateStr > _dashTo)   return false;
  return true;
}

function renderDashWithPeriod() {
  // Sales filtered
  var filteredSales = _dashFrom || _dashTo
    ? db.sales.filter(function(s){ return inPeriod(s.date); })
    : db.sales;

  // Activities filtered
  var filteredActs = _dashFrom || _dashTo
    ? db.activities.filter(function(a){ return inPeriod((a.date||'').slice(0,10)); })
    : db.activities;

  // Treatments filtered
  var filteredTreats = _dashFrom || _dashTo
    ? db.treatments.filter(function(t){ return inPeriod(t.applied_at); })
    : db.treatments;

  // Update sales card
  var salesEl = document.getElementById('dash-sales');
  if (salesEl) {
    salesEl.innerHTML = '';
    if (!filteredSales.length) {
      salesEl.innerHTML = '<div style="text-align:center;padding:20px;color:var(--muted);font-size:12px">Sin ventas en este periodo</div>';
    } else {
      var totalPeriod = filteredSales.reduce(function(s,v){return s+(v.total||0);},0);
      filteredSales.slice(-5).reverse().forEach(function(s){
        var row = document.createElement('div');
        row.style.cssText = 'display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid rgba(48,54,61,.4)';
        var info = document.createElement('div');
        var name = document.createElement('div'); name.style.cssText='font-size:12px;color:var(--text)'; name.textContent=s.buyer;
        var meta = document.createElement('div'); meta.style.cssText='font-size:10px;color:var(--muted);font-family:"DM Mono",monospace'; meta.textContent='Lote '+s.lot_code+' · '+fmtDT(s.created_at||s.date);
        info.appendChild(name); info.appendChild(meta);
        var amt = document.createElement('div'); amt.style.cssText='font-family:"DM Mono",monospace;font-size:12px;color:var(--green);font-weight:600'; amt.textContent='Bs. '+(s.total||0).toLocaleString();
        row.appendChild(info); row.appendChild(amt);
        salesEl.appendChild(row);
      });
      var totalRow = document.createElement('div');
      totalRow.style.cssText = 'display:flex;justify-content:space-between;padding:8px 0;font-size:12px;border-top:1px solid var(--bor);margin-top:4px';
      totalRow.innerHTML = '<span style="color:var(--muted)">Total per00edodo</span><span style="color:var(--amber2);font-weight:600">Bs '+totalPeriod.toLocaleString()+'</span>';
      salesEl.appendChild(totalRow);
    }
  }

  // Update activity
  var actEl = document.getElementById('dash-activity');
  if (actEl) {
    actEl.innerHTML = '';
    if (!filteredActs.length) {
      actEl.innerHTML = '<div style="color:var(--muted);font-size:12px;text-align:center;padding:20px">Sin actividad en este periodo</div>';
    } else {
      filteredActs.slice(-5).reverse().forEach(function(a){
        var div = document.createElement('div'); div.className='tl-item done';
        var dateEl = document.createElement('div'); dateEl.className='tl-date'; dateEl.textContent=fmtDT(a.created_at||a.date)+' · '+escH(a.employee);
        var ttl = document.createElement('div'); ttl.className='tl-ttl'; ttl.textContent=escH(a.desc);
        div.appendChild(dateEl); div.appendChild(ttl);
        if(a.lot){var sub=document.createElement('div');sub.className='tl-sub';sub.textContent='Lote '+escH(a.lot);div.appendChild(sub);}
        actEl.appendChild(div);
      });
    }
  }

  // Update treatments count in stats
  var sanWeek = document.getElementById('san-week');
  if (sanWeek) sanWeek.textContent = filteredTreats.reduce(function(s,t){return s+t.count;},0);
}

