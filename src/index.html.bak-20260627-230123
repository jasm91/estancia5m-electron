function generateTrace() {
  var lot_code = document.getElementById('trace-lot').value;
  var buyer = (document.getElementById('trace-buyer').value||'').trim();
  var type = document.getElementById('trace-type').value;
  var notes = (document.getElementById('trace-notes')||{}).value||'';
  if(!lot_code||!buyer){toast('Selecciona lote e ingresa comprador','error');return;}
  var lot = db.lots.find(function(l){return l.code===lot_code;});
  var treats = db.treatments.filter(function(t){return t.lot_code===lot_code;});
  var certNum = 'CERT-'+lot_code.replace('-','')+'-'+Date.now().toString().slice(-8);
  // Guardar IDs seleccionados (vacío = todos)
  var selectedIds = _traceSelectedAnimals.slice();
  // console.log('[Trazabilidad] IDs seleccionados:', selectedIds.length, selectedIds);
  var rec = {
    id: db.next_ids.trace++,
    cert_number: certNum,
    lot_code: lot_code,
    buyer: buyer,
    type: type,
    date: localDate(),
    lot_detail: lot,
    treatments_count: treats.length,
    notes: notes,
    animal_ids: selectedIds // guardar selección
  };
  db.trace_records.push(rec);
  saveDB();
  closeModal('modal-trace');
  renderTrazabilidad();
  var nAnimales = selectedIds.length > 0 ? selectedIds.length : (lot ? lot.animal_count : '?');
  toast('Certificado '+certNum+' — '+nAnimales+' animales','success');
  viewTrace(rec.id);
}

function viewTrace(id) {
  var t = db.trace_records.find(function(r){return r.id===id;});
  if(!t){toast('Certificado no encontrado','error');return;}
  var lot = t.lot_detail || db.lots.find(function(l){return l.code===t.lot_code;}) || {};
  var treats = db.treatments.filter(function(x){return x.lot_code===t.lot_code;});
  var animalesDB = getAnimalesDB();
  var todosAnimales = animalesDB[t.lot_code] || [];
  // Filtrar por IDs seleccionados si existen
  var animals = (t.animal_ids && t.animal_ids.length > 0)
    ? todosAnimales.filter(function(a){
        var aid = (a.animal_id||a.id||'').toString().trim();
        return t.animal_ids.some(function(sid){ return sid.toString().trim() === aid; });
      })
    : todosAnimales;
  // console.log('[Trazabilidad] animal_ids guardados:', t.animal_ids, '| animales filtrados:', animals.length, '| total lote:', todosAnimales.length);

  // Construir HTML del certificado
  var meses = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
  var fechaEmision = new Date(t.date+'T12:00:00');
  var fechaStr = fechaEmision.getDate()+' de '+meses[fechaEmision.getMonth()]+' de '+fechaEmision.getFullYear();

  // Tabla de animales individuales
  var animalesHTML = '';
