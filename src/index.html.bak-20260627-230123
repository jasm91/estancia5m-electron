function _salPopulateTipoFilter() {
  var wrap = document.getElementById('sal-tipo-filter-wrap');
  var sel  = document.getElementById('sal-tipo-filter');
  if (!sel) return;

  var tipos = _salGetTipos(); // ordenados por kg desc
  // Mostrar el filtro sólo si hay ≥2 tipos distintos en la data
  if (tipos.length < 2) {
    if (wrap) wrap.style.display = 'none';
    // Reset filtro si quedó algo seleccionado de antes
    if (window._salTipo) window._salTipo = '';
    return;
  }
  if (wrap) wrap.style.display = 'flex';

  var current = window._salTipo || '';
  var totalRecs = tipos.reduce(function(s,t){ return s + t.count; }, 0);
  var opts = ['<option value="">Todas (' + tipos.length + ')</option>'];
  tipos.forEach(function(t){
    var label = t.label + ' · ' + Math.round(t.kg).toLocaleString() + ' kg';
    var sel = (t.normalized === current) ? ' selected' : '';
    opts.push('<option value="' + escH(t.normalized) + '"' + sel + '>' + escH(label) + '</option>');
  });
  sel.innerHTML = opts.join('');
}

function _salRenderTipoCard(allRecords) {
  var card     = document.getElementById('sal-stat-tipo-card');
  var grid     = document.getElementById('sal-stats-grid');
  var canvas   = document.getElementById('sal-chart-tipo-donut');
  var legendEl = document.getElementById('sal-stat-tipo-legend');
  if (!card || !grid) return;

  // Agregar por tipo dentro del período actual (no de toda la DB)
  var byTipo = {};
  allRecords.forEach(function(r){
    var n = _salNormalizeTipo(r && r.tipo);
    var kg = parseFloat(r.qty||r.total||r.kg||0)||0;
    if (!kg) return;
    byTipo[n] = (byTipo[n] || 0) + kg;
  });
  var entries = Object.keys(byTipo).map(function(k){
    return { normalized: k, label: _salTipoLabel(k), kg: byTipo[k] };
  }).sort(function(a,b){ return b.kg - a.kg; });

  // Mostrar sólo si hay ≥2 tipos con kg en el período
  if (entries.length < 2) {
    card.style.display = 'none';
    grid.style.gridTemplateColumns = 'repeat(3,1fr)';
    if (window._salCharts.tipo) { try { window._salCharts.tipo.destroy(); } catch(e){} window._salCharts.tipo = null; }
    return;
  }
  card.style.display = '';
  grid.style.gridTemplateColumns = 'repeat(4,1fr)';

  var totalKg = entries.reduce(function(s,e){ return s + e.kg; }, 0);
  // Top 3 + Otros agregado para no saturar el donut
  var top = entries.slice(0, 3);
  var hasOtros = entries.length > 3;
  if (hasOtros) {
    var otrosKg = entries.slice(3).reduce(function(s,e){ return s + e.kg; }, 0);
    top.push({ normalized: '_otros', label: 'Otros', kg: otrosKg });
  }

  // Leyenda con %
  legendEl.innerHTML = top.map(function(e){
    var pct = totalKg > 0 ? Math.round((e.kg / totalKg) * 100) : 0;
    var color = (e.normalized === '_otros') ? '#888780' : _salTipoColor(e.normalized);
    return '<div style="display:flex;align-items:center;gap:5px">' +
      '<span style="width:7px;height:7px;background:' + color + ';border-radius:1px;flex-shrink:0;display:inline-block"></span>' +
      '<span style="color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">' + escH(e.label) + ' ' + pct + '%</span>' +
    '</div>';
  }).join('');

  // Donut con Chart.js
  if (window._salCharts.tipo) { try { window._salCharts.tipo.destroy(); } catch(e){} window._salCharts.tipo = null; }
  if (typeof Chart === 'undefined' || !canvas) return;
  window._salCharts.tipo = new Chart(canvas.getContext('2d'), {
    type: 'doughnut',
    data: {
      labels: top.map(function(e){ return e.label; }),
      datasets: [{
        data: top.map(function(e){ return Math.round(e.kg); }),
        backgroundColor: top.map(function(e){
          return (e.normalized === '_otros') ? '#888780' : _salTipoColor(e.normalized);
        }),
        borderWidth: 0
      }]
    },
    options: {
      responsive: false, maintainAspectRatio: false,
      cutout: '62%',
      plugins: {
        legend: { display: false },
        tooltip: { callbacks: { label: function(c){ return c.label + ': ' + c.parsed + ' kg'; } } }
      }
    }
  });
}

// Chart de potreros (stacked bars por mes)
function _salRenderChartPaddocks(byPaddock, period) {
  var canvas = document.getElementById('sal-chart-potreros');
  var emptyEl = document.getElementById('sal-chart-potreros-empty');
  if (!canvas) return;

  // Construir array de meses [YYYY-MM] en orden cronológico ascendente
  var months = [];
  var d = new Date();
  d.setDate(1);
  for (var i = period - 1; i >= 0; i--) {
    var m = new Date(d.getFullYear(), d.getMonth() - i, 1);
    months.push(m.toISOString().slice(0,7));
  }
  // Labels legibles (Ene, Feb…)
  var MES_NAMES = ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];
  var labels = months.map(function(ym){
    var parts = ym.split('-');
    return MES_NAMES[parseInt(parts[1],10) - 1] + ' ' + parts[0].slice(2);
  });

  // Identificar top potreros por consumo total
  var potreroTotals = {};
  Object.keys(byPaddock).forEach(function(m){
    Object.keys(byPaddock[m]).forEach(function(p){
      potreroTotals[p] = (potreroTotals[p] || 0) + byPaddock[m][p];
    });
  });
  var sortedPotreros = Object.keys(potreroTotals).sort(function(a,b){ return potreroTotals[b] - potreroTotals[a]; });

  if (sortedPotreros.length === 0) {
    canvas.style.display = 'none';
    emptyEl.style.display = 'block';
    if (window._salCharts.potreros) { window._salCharts.potreros.destroy(); window._salCharts.potreros = null; }
    return;
  }
  canvas.style.display = 'block';
  emptyEl.style.display = 'none';

  // Top 3 + Otros agregado
  var topNames = sortedPotreros.slice(0, 3);
  var hasOtros = sortedPotreros.length > 3;
  var COLORS = ['#7F77DD', '#1D9E75', '#D85A30', '#BA7517'];

  var datasets = topNames.map(function(name, idx){
    return {
      label: name,
      data: months.map(function(ym){ return Math.round((byPaddock[ym] && byPaddock[ym][name]) || 0); }),
      backgroundColor: COLORS[idx],
      borderRadius: 3,
      stack: 's1'
    };
  });
  if (hasOtros) {
    datasets.push({
      label: 'Otros',
      data: months.map(function(ym){
        if (!byPaddock[ym]) return 0;
        var sum = 0;
        Object.keys(byPaddock[ym]).forEach(function(p){
          if (topNames.indexOf(p) < 0) sum += byPaddock[ym][p];
        });
        return Math.round(sum);
      }),
      backgroundColor: COLORS[3],
      borderRadius: 3,
      stack: 's1'
    });
  }

  // Destroy previous chart
  if (window._salCharts.potreros) {
    window._salCharts.potreros.destroy();
    window._salCharts.potreros = null;
  }
  if (typeof Chart === 'undefined') return;

  var isDark = true; // Desktop usa tema oscuro
  var txtColor = 'rgba(255,255,255,0.65)';
  var gridColor = 'rgba(255,255,255,0.08)';

  window._salCharts.potreros = new Chart(canvas.getContext('2d'), {
    type: 'bar',
    data: { labels: labels, datasets: datasets },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { position: 'bottom', labels: { color: txtColor, font: { size: 11 }, boxWidth: 12, padding: 10 } },
        tooltip: { callbacks: { label: function(c){ return c.dataset.label + ': ' + c.parsed.y + ' kg'; } } }
      },
      scales: {
        x: { stacked: true, grid: { display: false }, ticks: { color: txtColor, font: { size: 11 } } },
        y: { stacked: true, grid: { color: gridColor, drawBorder: false }, ticks: { color: txtColor, font: { size: 11 }, callback: function(v){ return v + 'kg'; } }, beginAtZero: true }
      }
    }
  });
}

