  });
  html += '</tbody></table></div>';

  // COMPOSICIÓN DE GASTOS — v1.4.67: 2 donuts (Total + Operativos) + tabla debajo
  html += '<div style="font-size:14px;font-weight:700;color:var(--amber2);margin:20px 0 10px;border-bottom:1px solid var(--bor);padding-bottom:6px">🧮 Composición de Gastos</div>';
  var gastos = [
    { rubro: '🏥 Sanidad', total: gastSanidad,         operativo: true,  color: '#f87171' },
    { rubro: '🍽️ Alimentación', total: gastAlimento,    operativo: true,  color: '#fb923c' },
    { rubro: '👷 Personal', total: gastPersonal + gastAdelantos, operativo: true, color: '#fbbf24' },
    { rubro: '⛽ Combustible', total: gastDiesel,       operativo: true,  color: '#a3e635' },
    { rubro: '🔧 Mantenimiento', total: gastMaint,      operativo: true,  color: '#34d399' },
    { rubro: '🛒 Compras insumos', total: gastCompras,  operativo: true,  color: '#22d3ee' },
    { rubro: '🛢️ Aceite/Lubricantes', total: gastAceite, operativo: true, color: '#60a5fa' },
    { rubro: '🏢 Administración', total: gastoAdmin,    operativo: true,  color: '#a78bfa' },
    { rubro: '🏗️ Estructura', total: gastoEstructura,   operativo: true,  color: '#f472b6' },
    { rubro: '🐄 Compra de ganado', total: inversionCompras, operativo: false, color: '#fb7185' },
  ];

  var totalOperativos = gastos.filter(function(g){ return g.operativo; }).reduce(function(s,g){ return s + g.total; }, 0);
  var hayOperativos = totalOperativos > 0;
  var hayCompras = inversionCompras > 0;

  // Layout: 2 donuts lado a lado (responsive)
  html += '<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:16px;margin-bottom:20px">';

  // ── DONUT 1: EGRESOS TOTALES (Compra ganado vs Operativos) ──
