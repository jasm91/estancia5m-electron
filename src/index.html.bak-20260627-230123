// VERIFICACIÓN AUTOMÁTICA DE UPDATES AL ARRANQUE
// ══════════════════════════════════════════════════
function checkForUpdateOnStartup() {
  // Si ya hay una versión descargada esperando instalar, mostrar el badge directo
  if (window.estancia && window.estancia.app && window.estancia.app.updateStatus) {
    window.estancia.app.updateStatus().then(function(status){
      if (status && status.downloaded && status.version) {
        showUpdateBadge(status.version, true);
        showUpdateNotification(status.version, true);
        return;
      }
      // Si no hay descargada, hacer fetch a GitHub para comparar
      checkLatestVersionFromGithub();
    }).catch(function(){
      checkLatestVersionFromGithub();
    });
  } else {
    checkLatestVersionFromGithub();
  }
}

// Helper para leer el GitHub PAT desde múltiples ubicaciones (settings/localStorage/input)
function getGhToken() {
  var fromInput = ((document.getElementById('cfg-gh-token')||{}).value||'').trim();
  if (fromInput) return Promise.resolve(fromInput);
  if (window.estancia && window.estancia.settings && window.estancia.settings.get) {
    return window.estancia.settings.get('gh_token').then(function(t){
      return t || localStorage.getItem('gh_token') || '';
    }).catch(function(){
      return localStorage.getItem('gh_token') || '';
    });
  }
  return Promise.resolve(localStorage.getItem('gh_token') || '');
}

function checkLatestVersionFromGithub() {
  getGhToken().then(function(ghToken){
    var headers = {};
    if (ghToken) headers['Authorization'] = 'token ' + ghToken;
    fetch('https://api.github.com/repos/jasm91/estancia5m-electron/releases/latest', { headers: headers })
      .then(function(r){ if (!r.ok) throw new Error('HTTP '+r.status); return r.json(); })
      .then(function(data){
        if (!data || !data.tag_name) return;
        var latestVersion = data.tag_name.replace('v','');
        var currentVersion = (typeof _APP_VERSION !== 'undefined' ? _APP_VERSION : '0.0.0');
        if (compareVersions(latestVersion, currentVersion) > 0) {
          showUpdateBadge(latestVersion, false);
          showUpdateNotification(latestVersion, false);
        }
      })
      .catch(function(e){ console.warn('[UpdateCheck] No se pudo verificar:', e.message); });
  });
}

// ═══ Min Version Check temprano (al arranque, sin auth) ═══
// Usa endpoint público /api/versions para detectar versiones obsoletas inmediatamente,
// incluso si el pull falla o el token está mal. Se ejecuta apenas la app puede.
(function earlyVersionCheck() {
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', earlyVersionCheck);
    return;
  }
  if (!navigator.onLine) return;
  setTimeout(function() {
    var apiUrl = (typeof getApiUrl === 'function') ? getApiUrl() : 'https://estancia5m-api-production.up.railway.app/api';
    fetch(apiUrl + '/versions', { signal: (function(){ var c=new AbortController(); setTimeout(function(){c.abort();},5000); return c.signal; })() })
      .then(function(r){ return r.ok ? r.json() : null; })
      .then(function(data) {
        if (data && data.desktop_min && typeof checkMinVersionRequired === 'function') {
          checkMinVersionRequired(data.desktop_min, data.desktop_latest);
        }
      })
      .catch(function(){ /* silencio: si falla, el pull regular lo cubre */ });
  }, 800);
})();

function compareVersions(a, b) {
  var pa = String(a).split('.').map(function(n){return parseInt(n)||0;});
  var pb = String(b).split('.').map(function(n){return parseInt(n)||0;});
  for (var i = 0; i < Math.max(pa.length, pb.length); i++) {
    var na = pa[i]||0, nb = pb[i]||0;
    if (na > nb) return 1;
    if (na < nb) return -1;
  }
  return 0;
}

// ═══ Min Version Enforcement ═══
// Si el server exige una versión mínima más nueva que la actual, mostrar modal bloqueante.
// El usuario solo puede salir actualizando o cerrando la app.
function checkMinVersionRequired(minVersion, latestVersion) {
  if (!minVersion) return;
  var currentVersion = (typeof _APP_VERSION !== 'undefined' ? _APP_VERSION : '0.0.0');
  if (compareVersions(currentVersion, minVersion) < 0) {
    console.warn('[MinVersion] Versión obsoleta: ' + currentVersion + ' < requerida ' + minVersion);
    showMinVersionBlocker(currentVersion, minVersion, latestVersion || minVersion);
  } else {
    // Si la app cumple, asegurar que el modal no esté visible
    var existing = document.getElementById('min-version-blocker');
    if (existing) existing.remove();
  }
}

