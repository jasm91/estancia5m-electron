// v1.4.79: toggle collapsable de secciones del sidebar
function toggleNavSec(secKey) {
  var sec = document.querySelector('.nav-sec[data-sec="' + secKey + '"]');
  if (!sec) return;
  sec.classList.toggle('collapsed');
  // Persistir estado por sección
  try {
    var collapsed = JSON.parse(localStorage.getItem('e5m_nav_collapsed_secs') || '{}');
    collapsed[secKey] = sec.classList.contains('collapsed');
    localStorage.setItem('e5m_nav_collapsed_secs', JSON.stringify(collapsed));
  } catch(e){}
}

// v1.4.79: aplicar estados guardados al cargar (default: solo Operación Principal expandida)
(function initNavSections() {
  function apply() {
    var saved;
    try { saved = JSON.parse(localStorage.getItem('e5m_nav_collapsed_secs') || 'null'); } catch(e){ saved = null; }
    // Si nunca se configuró → por defecto solo Operación Principal expandida
    if (!saved) {
      saved = {
        'inicio': true,
        'operacion-principal': false,  // expandida por default
        'operacion-secundaria': true,
        'reportes': true,
        'equipo': true,
        'sistema': true
      };
    }
    Object.keys(saved).forEach(function(key) {
      var sec = document.querySelector('.nav-sec[data-sec="' + key + '"]');
      if (sec && saved[key]) sec.classList.add('collapsed');
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', apply, { once: true });
  } else {
    apply();
  }
})();


function publishTasksToPWA() {
  var apiUrl = getApiUrl();
  var token  = localStorage.getItem('e5m_api_token') || '';
  var tasks  = JSON.parse(localStorage.getItem('e5m_tasks') || '[]');
  if (!tasks.length) { toast('No hay tareas para publicar. Crea tareas primero.', 'error'); return; }
  toast('Publicando ' + tasks.length + ' tareas...', '');
  fetch(apiUrl + '/tasks/bulk', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
    body: JSON.stringify({ tasks: tasks }),
  })
  .then(function(r) { return r.json(); })
  .then(function(data) {
    if (data.ok) {
      toast('✓ ' + data.count + ' tareas publicadas', 'success');
    } else {
      toast('Error: ' + (data.error || 'Sin respuesta'), 'error');
    }
  })
  .catch(function() { toast('Sin conexion al servidor', 'error'); });
}

