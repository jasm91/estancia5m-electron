// TRU-TEST Excel format:
// Row with "Animal Count", "Average Weight (kg)", "Minimum Weight (kg)", "Maximum Weight (kg)"
// Followed by individual animal weights in a column

function initTruTestImport() {
  var inp = document.getElementById('trutest-import');
  if (!inp) return;
  inp.addEventListener('change', function() {
    var file = this.files[0];
    if (!file) return;
    var name = file.name.toLowerCase();
    if (name.endsWith('.csv')) {
      var reader = new FileReader();
      reader.onload = function(e) { parseTruTestCSV(e.target.result); };
      reader.readAsText(file);
    } else if (name.endsWith('.xlsx')) {
      var reader2 = new FileReader();
      reader2.onload = function(e) { parseTruTestXLSX(e.target.result); };
      reader2.readAsArrayBuffer(file);
    }
    this.value = '';
  });
}

function parseTruTestCSV(text) {
  // TRU-TEST CSV: session info rows, then data rows with individual weights
  var lines = text.split('').map(function(l){return l.trim();}).filter(Boolean);
  var data = {date:'', count:0, avg:0, min:0, max:0, weights:[]};

  lines.forEach(function(line) {
    var cols = line.split(',').map(function(c){return c.replace(/"/g,'').trim();});
    if (cols[0] && cols[0].toLowerCase().includes('date')) data.date = cols[1]||'';
    if (cols[0] && cols[0].toLowerCase().includes('animal count')) data.count = parseFloat(cols[1])||0;
    if (cols[0] && cols[0].toLowerCase().includes('average weight')) data.avg = parseFloat(cols[1])||0;
    if (cols[0] && cols[0].toLowerCase().includes('minimum weight')) data.min = parseFloat(cols[1])||0;
    if (cols[0] && cols[0].toLowerCase().includes('maximum weight')) data.max = parseFloat(cols[1])||0;
    // Individual weights: a line with just a number
    var num = parseFloat(cols[0]);
    if (!isNaN(num) && cols.length <= 2 && num > 50 && num < 2000) data.weights.push(num);
  });

  if (!data.avg && !data.count) {
    toast('No se reconocio el formato TRU-TEST. Verifica que sea el reporte de sesion.', 'error');
    return;
  }
  openTruTestModal(data);
}

function parseTruTestXLSX(buffer) {
  // Simple XLSX parser - read as binary and extract numbers
  // Since we can't use SheetJS in Electron easily, guide user to export as CSV
  toast('Para importar desde Excel, exporta el reporte TRU-TEST como CSV primero (Archivo → Guardar como → CSV)', 'error');
}

function openTruTestModal(data) {
  // Show confirmation dialog before importing
  var msg = 'Datos detectados del TRU-TEST:\n' +
    'Animales: ' + (data.count||'?') + '' +
    'Peso promedio: ' + (data.avg||'?') + ' kg' +
    'Peso minimo: ' + (data.min||'?') + ' kg' +
    'Peso maximo: ' + (data.max||'?') + ' kg' +
    (data.weights.length ? 'Pesos individuales: ' + data.weights.length + ' registros' : '') +
    '¿A que lote corresponde este pesaje?';

  // Pre-fill the pesaje modal with TRU-TEST data
  openModal('modal-pesaje');
  setTimeout(function() {
    if (data.count) document.getElementById('pesaje-count').value = data.count;
    if (data.avg)   document.getElementById('pesaje-avg').value   = data.avg;
    if (data.min)   document.getElementById('pesaje-min').value   = data.min;
    if (data.max)   document.getElementById('pesaje-max').value   = data.max;
    if (data.date) {
      // Try to parse date from TRU-TEST format
      var d = new Date(data.date);
