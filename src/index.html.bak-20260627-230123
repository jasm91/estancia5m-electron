<div class="modal" style="max-width:700px"><h2>🤝 Registrar Venta de Ganado</h2>
<div class="form-row">
  <div class="form-group"><label class="form-label">Lote</label>
    <select class="form-select" id="sale-lot" onchange="onSaleLotChange(this.value)"><option value="">Seleccionar...</option></select>
  </div>
  <div class="form-group"><label class="form-label">Tipo de venta</label>
    <select class="form-select" id="sale-scope" onchange="onSaleScopeChange(this.value)">
      <option value="lot">Lote completo</option>
      <option value="individual">Animales individuales</option>
    </select>
  </div>
</div>
<!-- Venta por lote (modo actual) -->
<div id="sale-lot-mode">
  <div class="form-row">
    <div class="form-group">
      <label class="form-label">Animales vendidos <span id="sale-count-max" style="color:var(--muted);font-size:10px"></span></label>
      <input class="form-input" type="number" id="sale-count" oninput="validateSaleCount();calcSaleTotal()" min="1">
      <div id="sale-count-warn" style="font-size:11px;color:var(--red);margin-top:4px;display:none">Supera el total del lote</div>
    </div>
    <div class="form-group"><label class="form-label">Peso total (kg)</label><input class="form-input" type="number" id="sale-kg" oninput="calcSaleTotal()"></div>
  </div>
  <div style="background:rgba(88,166,255,.06);border:1px solid rgba(88,166,255,.2);border-radius:8px;padding:12px;margin-bottom:8px">
    <div style="font-size:11px;font-weight:700;color:var(--blue);margin-bottom:8px">⚖️ Peso al momento de venta</div>
    <div class="form-row">
      <div class="form-group">
        <label class="form-label">Peso promedio por animal (kg)</label>
        <input class="form-input" type="number" id="sale-peso-momento" placeholder="Ej: 480" step="0.1" min="0" oninput="onSalePesoMomento()">
        <div style="font-size:10px;color:var(--muted);margin-top:3px">Se registrará como pesaje en cada animal del lote</div>
      </div>
      <div class="form-group">
        <label class="form-label">Peso total calculado</label>
        <input class="form-input" id="sale-kg-calc" readonly style="background:var(--sur2);color:var(--green)">
      </div>
    </div>
  </div>
</div>
<!-- Venta individual por ID -->
<div id="sale-individual-mode" style="display:none">
  <div class="form-row">
    <div class="form-group" style="flex:1"><label class="form-label">Buscar por ID</label>
      <input class="form-input" id="sale-animal-search" placeholder="Filtrar por ID..." oninput="filterSaleAnimals(this.value)">
    </div>
    <div class="form-group" style="flex:1"><label class="form-label">Filtrar por rango de peso</label>
      <div style="display:flex;gap:8px;align-items:center">
        <input class="form-input" type="number" id="sale-peso-min" placeholder="Min kg" oninput="filterSaleAnimals()" style="width:90px">
        <span style="color:var(--muted);font-size:12px">-</span>
        <input class="form-input" type="number" id="sale-peso-max" placeholder="Max kg" oninput="filterSaleAnimals()" style="width:90px">
      </div>
    </div>
  </div>
  <div class="form-group">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px">
      <label class="form-label" style="margin:0">Seleccionar animales <span id="sale-selected-count" style="color:var(--amber2);font-weight:700"></span></label>
      <div style="display:flex;gap:8px">
        <button class="btn btn-ghost btn-sm" onclick="selectAllSaleAnimals()">Selec. todos</button>
        <button class="btn btn-ghost btn-sm" onclick="clearSaleAnimals()">Limpiar</button>
      </div>
    </div>
    <div id="sale-animals-list" style="max-height:200px;overflow-y:auto;border:1px solid var(--bor);border-radius:8px;background:var(--sur2)"></div>
  </div>
  <div id="sale-individual-summary" style="display:none;background:var(--sur2);border:1px solid var(--bor);border-radius:8px;padding:10px 14px;margin-bottom:8px">
    <div style="display:flex;gap:24px;font-size:12px">
      <div><span style="color:var(--muted)">Animales: </span><span id="sai-count" style="font-weight:700;color:var(--amber2)">0</span></div>
      <div><span style="color:var(--muted)">Peso total: </span><span id="sai-kg" style="font-weight:700">0 kg</span></div>
      <div><span style="color:var(--muted)">Peso prom: </span><span id="sai-avg" style="font-weight:700">0 kg</span></div>
    </div>
  </div>
</div>
<!-- Campos comunes -->
<div class="form-group"><label class="form-label">Nombre del comprador</label><input class="form-input" id="sale-buyer" placeholder="Ej: Frigorifico Boliviano S.A."></div>
<div class="form-row">
  <div class="form-group"><label class="form-label">Tipo comprador</label>
    <select class="form-select" id="sale-type">
      <option value="frigorifico">Frigorifico</option><option value="feria">Feria ganadera</option>
      <option value="particular">Particular</option><option value="exportacion">Exportacion</option>
    </select>
  </div>
  <div class="form-group"><label class="form-label">Precio Bs./kg</label><input class="form-input" type="number" id="sale-price" step="0.01" oninput="calcSaleTotal()"></div>
</div>
<div class="form-row">
  <div class="form-group">
    <label class="form-label">Descuento peso (%)
      <span style="color:var(--muted);font-size:10px;font-weight:400">opcional</span>
    </label>
    <input class="form-input" type="number" id="sale-discount-pct" placeholder="0" min="0" max="50" step="0.1" oninput="calcSaleTotal()">
    <div id="sale-discount-info" style="font-size:11px;color:var(--muted);margin-top:4px;display:none"></div>
  </div>
  <div class="form-group"><label class="form-label">Total (Bs.)</label><input class="form-input" id="sale-total" readonly style="background:var(--sur2);color:var(--green)"></div>
</div>
<div class="form-row">
  <div class="form-group"><label class="form-label">Fecha</label><input class="form-input" type="date" id="sale-date"></div>
  <div class="form-group"><label class="form-label">N° factura</label><input class="form-input" id="sale-invoice" placeholder="FAC-2026-0001"></div>
</div>
<div class="form-group">
  <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-family:DM Mono,monospace;font-size:11px;color:var(--muted)">
    <input type="checkbox" id="sale-trace"> Requiere certificado de trazabilidad
  </label>
</div>
<div class="form-actions">
  <button class="btn btn-ghost" onclick="closeModal('modal-sale')">Cancelar</button>
  <button class="btn btn-primary" onclick="saveSale()">Registrar venta</button>
</div></div></div>

