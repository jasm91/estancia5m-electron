// v1.4.113 LEGACY: feed de últimos depósitos. Ya no se usa porque la tabla cumple el rol.
// Se mantiene la función por si algún snapshot externo del DOM la llama; es no-op sin container.
function _salRenderFeed(records) {
  var container = document.getElementById('sal-feed-list');
  if (!container) return;
  // Ordenar por fecha descendente
  var sorted = records.slice().sort(function(a,b){
    var fa = String(a.fecha || a.applied_at || a.date || '').slice(0,10);
    var fb = String(b.fecha || b.applied_at || b.date || '').slice(0,10);
    return fb.localeCompare(fa);
  });
  var top = sorted.slice(0, 10);
  if (top.length === 0) {
    container.innerHTML = '<div style="padding:30px 20px;text-align:center;color:var(--muted);font-size:13px">Sin depósitos registrados en este período</div>';
    return;
  }
  var html = top.map(function(r){
    var fecha = String(r.fecha || r.applied_at || r.date || '').slice(0,10);
    var kg = parseFloat(r.qty || r.total || r.kg || 0);
    var product = r.product_name || r.product || '';
    var paddock = _salGetRecordPaddock(r) || '—';
    var lot = r.lot_code || '';
    // Origen badge
    var origen = String(r.by || r.source || '').toLowerCase();
    var origBadge = '';
    if (origen.indexOf('whatsapp') >= 0 || r.source === 'whatsapp') {
      origBadge = '<span style="background:#EEEDFE;color:#26215C;font-size:10px;padding:2px 7px;border-radius:10px;font-weight:500">WhatsApp</span>';
    } else if (origen.indexOf('pwa') >= 0) {
      origBadge = '<span style="background:#E1F5EE;color:#04342C;font-size:10px;padding:2px 7px;border-radius:10px;font-weight:500">PWA</span>';
    } else {
      origBadge = '<span style="background:var(--sur2);color:var(--muted);font-size:10px;padding:2px 7px;border-radius:10px;font-weight:500">Desktop</span>';
    }
    var sub = fecha + ' · ' + (r.by || 'Sin autor');
    if (lot) sub += ' · lote ' + lot;
    return '<div style="padding:12px 18px;border-bottom:1px solid var(--bor);display:flex;justify-content:space-between;align-items:center">' +
      '<div style="flex:1">' +
        '<div style="display:flex;align-items:center;gap:8px;margin-bottom:3px">' +
          '<span style="font-size:13px;font-weight:500;color:var(--text)">' + escH(paddock) + ' · ' + Math.round(kg) + ' kg ' + escH(product) + '</span>' +
          origBadge +
        '</div>' +
        '<div style="font-size:11px;color:var(--muted)">' + escH(sub) + '</div>' +
      '</div>' +
    '</div>';
  }).join('');
  container.innerHTML = html;
}

var TIPO_ICONS = {tractor:'🚜',camioneta:'🛻',camion:'🚚',generador:'⚡',bomba:'💧',moto:'🏍',implemento:'⚙️',otro:'📦'};

function renderMaquinaria() {
  if (!db.maquinaria) db.maquinaria = [];
  var maqs = db.maquinaria;
  var diesel = db.diesel || [];
  var aceite = db.aceite || [];
  var maint = db.maintenance || [];
  var now = new Date();
  var mp = now.getFullYear() + '-' + String(now.getMonth()+1).padStart(2,'0');

  // KPIs
  var totalValor = maqs.reduce(function(s,m){return s+(m.valor||0);},0);
  var operativos = maqs.filter(function(m){return m.estado==='operativo';}).length;
  var enRep = maqs.filter(function(m){return m.estado==='reparacion';}).length;
  var totalDieselMes = 0, totalCostoMes = 0;
  maqs.forEach(function(m){
    var desp = diesel.filter(function(d){return d.type==='despacho'&&matchMaq(d.vehiculo,m)&&(d.fecha||'').startsWith(mp);});
    totalDieselMes += desp.reduce(function(s,d){return s+(parseFloat(d.litros)||0);},0);
    var mMaint = maint.filter(function(r){return matchMaq(r.equipo||r.title||r.desc,m)&&(r.date||'').startsWith(mp);});
    totalCostoMes += mMaint.reduce(function(s,r){return s+(parseFloat(r.cost)||0);},0);
  });

  var subEl = document.getElementById('maq-sub');
  if (subEl) subEl.textContent = maqs.length + ' equipos · ' + operativos + ' operativos · Bs. ' + Math.round(totalValor).toLocaleString() + ' en activos';

  var kpiEl = document.getElementById('maq-kpis');
  if (kpiEl) {
    kpiEl.innerHTML = [
      {l:'Equipos',v:maqs.length,c:'var(--amber2)'},
      {l:'Operativos',v:operativos,c:'var(--green)'},
      {l:'En reparación',v:enRep,c:enRep?'var(--red)':'var(--green)'},
      {l:'Valor activos',v:'Bs.'+Math.round(totalValor).toLocaleString(),c:'var(--blue)'},
      {l:'Diesel mes',v:totalDieselMes.toFixed(0)+' L',c:'var(--amber2)'},
      {l:'Mant. mes',v:'Bs.'+Math.round(totalCostoMes),c:'var(--muted)'},
    ].map(function(k){
      return '<div style="background:var(--sur);border:1px solid var(--bor);border-radius:10px;padding:10px 14px">'+
        '<div style="font-size:9px;color:var(--muted);font-weight:700;text-transform:uppercase;margin-bottom:2px">'+k.l+'</div>'+
        '<div style="font-size:18px;font-weight:800;color:'+k.c+'">'+k.v+'</div></div>';
    }).join('');
  }

  // Cards
  var cardsEl = document.getElementById('maq-cards');
  if (!cardsEl) return;
  if (!maqs.length) {
    cardsEl.innerHTML = '<div style="text-align:center;padding:40px;color:var(--muted);grid-column:1/-1">Sin equipos registrados. Click en "+ Registrar equipo" para comenzar.</div>';
    return;
  }
  cardsEl.innerHTML = maqs.map(function(m) {
    var icon = TIPO_ICONS[m.tipo] || '📦';
    var estadoColors = {operativo:'var(--green)',reparacion:'var(--amber2)',fuera_servicio:'var(--red)'};
    var estadoLabels = {operativo:'Operativo',reparacion:'En reparación',fuera_servicio:'Fuera de servicio'};
    // Diesel de este equipo
    var mDesp = diesel.filter(function(d){return d.type==='despacho'&&matchMaq(d.vehiculo,m);});
    var mDespMes = mDesp.filter(function(d){return (d.fecha||'').startsWith(mp);});
    var dieselMes = mDespMes.reduce(function(s,d){return s+(parseFloat(d.litros)||0);},0);
    var dieselTotal = mDesp.reduce(function(s,d){return s+(parseFloat(d.litros)||0);},0);
    // Aceite
    var mAceite = aceite.filter(function(a){return matchMaq(a.vehiculo||a.equipo,m);});
    var lastAceite = mAceite.length ? mAceite.sort(function(a,b){return (b.fecha||'').localeCompare(a.fecha||'');})[0] : null;
    // Mantenimiento
    var mMaint = maint.filter(function(r){return matchMaq(r.equipo||r.title||r.desc,m);});
    var mMaintMes = mMaint.filter(function(r){return (r.date||'').startsWith(mp);});
    var maintCost = mMaint.reduce(function(s,r){return s+(parseFloat(r.cost)||0);},0);
    var maintMesCost = mMaintMes.reduce(function(s,r){return s+(parseFloat(r.cost)||0);},0);
    // Costo total
    var recargasPrecio = diesel.filter(function(d){return d.type==='recarga'&&d.precio;});
    var precioL = recargasPrecio.length ? recargasPrecio.reduce(function(s,d){return s+(d.precio||0);},0)/recargasPrecio.length : 0;
    var costoOp = Math.round(dieselTotal*precioL + maintCost);

    return '<div style="background:var(--sur);border:1px solid var(--bor);border-radius:12px;overflow:hidden">'+
      '<div style="padding:14px 16px;display:flex;gap:12px;align-items:flex-start">'+
        (m.photo_url?'<img src="'+m.photo_url+'" style="width:60px;height:60px;border-radius:8px;object-fit:cover;flex-shrink:0">':'<div style="width:60px;height:60px;border-radius:8px;background:var(--sur2);display:flex;align-items:center;justify-content:center;font-size:28px;flex-shrink:0">'+icon+'</div>')+
        '<div style="flex:1;min-width:0">'+
          '<div style="display:flex;justify-content:space-between;align-items:center">'+
            '<div style="font-size:14px;font-weight:700;color:var(--text)">'+escH(m.nombre||'')+'</div>'+
            '<span style="font-size:10px;font-weight:600;padding:2px 8px;border-radius:10px;color:'+estadoColors[m.estado]+';background:rgba(0,0,0,.2);border:1px solid '+estadoColors[m.estado]+'">'+estadoLabels[m.estado]+'</span>'+
          '</div>'+
          '<div style="font-size:11px;color:var(--muted);margin-top:2px">'+escH(m.modelo||'')+' '+(m.anio||'')+' · '+escH(m.tipo||'')+(m.horometro?' · '+(m.horometro)+' hrs/km':'')+'</div>'+
          '<div style="font-size:11px;color:var(--blue);margin-top:2px">Valor: Bs. '+(m.valor||0).toLocaleString()+'</div>'+
        '</div>'+
      '</div>'+
      '<div style="display:grid;grid-template-columns:1fr 1fr 1fr;border-top:1px solid var(--bor);font-size:11px">'+
        '<div style="padding:8px 12px;border-right:1px solid rgba(48,54,61,.3)"><div style="color:var(--muted);font-size:9px;font-weight:700">⛽ DIESEL MES</div><div style="font-weight:700;color:var(--amber2)">'+dieselMes.toFixed(0)+' L</div><div style="color:var(--muted);font-size:9px">Total: '+dieselTotal.toFixed(0)+' L</div></div>'+
        '<div style="padding:8px 12px;border-right:1px solid rgba(48,54,61,.3)"><div style="color:var(--muted);font-size:9px;font-weight:700">🛢 ACEITE</div><div style="font-weight:700">'+(lastAceite?lastAceite.fecha:'—')+'</div><div style="color:var(--muted);font-size:9px">'+(mAceite.length)+' cambios</div></div>'+
        '<div style="padding:8px 12px"><div style="color:var(--muted);font-size:9px;font-weight:700">🔧 MANT.</div><div style="font-weight:700;color:var(--red)">Bs.'+Math.round(maintMesCost)+'</div><div style="color:var(--muted);font-size:9px">Total: Bs.'+Math.round(maintCost)+'</div></div>'+
      '</div>'+
      '<div style="display:flex;gap:6px;padding:8px 12px;border-top:1px solid var(--bor)">'+
        '<button class="btn btn-ghost btn-sm" style="font-size:10px;flex:1" onclick="viewMaqHistorial(\''+m.id+'\')">📋 Historial</button>'+
        '<button class="btn btn-ghost btn-sm" style="font-size:10px;flex:1;color:var(--blue)" onclick="openModalMaq(\''+m.id+'\')">✎ Editar</button>'+
        '<button class="btn btn-ghost btn-sm" style="font-size:10px;color:var(--red)" onclick="deleteMaq(\''+m.id+'\')">x</button>'+
      '</div>'+
    '</div>';
  }).join('');
}

function matchMaq(text, maq) {
  if (!text || !maq) return false;
  var t = (text||'').toLowerCase();
  var n = (maq.nombre||'').toLowerCase();
  var mod = (maq.modelo||'').toLowerCase();
  return t === n || t === mod || t.includes(n) || n.includes(t) || (mod && (t.includes(mod) || mod.includes(t)));
}

function getMaqList() { return db.maquinaria || []; }

function populateMaqSelect(selectId, currentVal) {
  var sel = document.getElementById(selectId);
  if (!sel) return;
  var maqs = getMaqList();
  // Preserve existing options if no maquinaria registered
  if (!maqs.length) return;
  var curVal = currentVal || sel.value || '';
  sel.innerHTML = '<option value="">Seleccionar equipo...</option>';
  maqs.forEach(function(m) {
    var icon = TIPO_ICONS[m.tipo] || '';
    var o = document.createElement('option');
    o.value = m.nombre;
    o.textContent = icon + ' ' + m.nombre + (m.modelo ? ' (' + m.modelo + ')' : '');
    if (m.nombre === curVal) o.selected = true;
    sel.appendChild(o);
  });
  // Add "Otro" option for unlisted equipment
  var other = document.createElement('option');
  other.value = '__otro__';
  other.textContent = '➕ Otro (escribir)';
  sel.appendChild(other);
}

function openModalMaq(editId) {
  _maqPhotoBase64 = null;
  document.getElementById('maq-edit-id').value = editId || '';
  var title = document.getElementById('maq-modal-title');
  var fields = ['maq-nombre','maq-modelo','maq-anio','maq-valor','maq-horometro','maq-notas'];
  fields.forEach(function(id){var e=document.getElementById(id);if(e)e.value='';});
  var tipoEl = document.getElementById('maq-tipo'); if(tipoEl) tipoEl.value = 'tractor';
  var estadoEl = document.getElementById('maq-estado'); if(estadoEl) estadoEl.value = 'operativo';
  var preview = document.getElementById('maq-photo-preview'); if(preview) preview.innerHTML = '';
  var photoInput = document.getElementById('maq-photo'); if(photoInput) photoInput.value = '';

  if (editId) {
    var maq = (db.maquinaria||[]).find(function(m){return m.id===editId;});
    if (maq) {
      if(title) title.textContent = '✎ Editar Equipo';
      document.getElementById('maq-nombre').value = maq.nombre || '';
      document.getElementById('maq-modelo').value = maq.modelo || '';
      if(tipoEl) tipoEl.value = maq.tipo || 'tractor';
      document.getElementById('maq-anio').value = maq.anio || '';
      document.getElementById('maq-valor').value = maq.valor || '';
      document.getElementById('maq-horometro').value = maq.horometro || '';
      if(estadoEl) estadoEl.value = maq.estado || 'operativo';
      document.getElementById('maq-notas').value = maq.notas || '';
      if (maq.photo_url && preview) preview.innerHTML = '<img src="'+maq.photo_url+'" style="max-width:100px;border-radius:6px">';
    }
  } else {
    if(title) title.textContent = '🚜 Registrar Equipo';
  }

  // Photo handler
  if (photoInput) {
    photoInput.onchange = function() {
      if (!this.files || !this.files[0]) return;
      var reader = new FileReader();
      reader.onload = function(e) {
        var img = new Image();
        img.onload = function() {
          var canvas = document.createElement('canvas');
          var scale = Math.min(1, 600 / img.width);
          canvas.width = img.width * scale; canvas.height = img.height * scale;
          canvas.getContext('2d').drawImage(img, 0, 0, canvas.width, canvas.height);
          _maqPhotoBase64 = canvas.toDataURL('image/jpeg', 0.5);
          if (preview) preview.innerHTML = '<img src="'+_maqPhotoBase64+'" style="max-width:100px;border-radius:6px">';
        };
        img.src = e.target.result;
      };
      reader.readAsDataURL(this.files[0]);
    };
  }
  openModal('modal-maquinaria');
}

