      if (anims.length >= _cur || (_cur - anims.length) <= Math.max(3, _cur * 0.05)) lt.animal_count = anims.length; else lt.animal_count = Math.max(_cur, anims.length);
      var ws = anims.map(function(a){ return a.pesajes && a.pesajes.length ? a.pesajes[a.pesajes.length-1].peso : 0; }).filter(function(w){ return w > 0; });
      if (ws.length) lt.avg_weight = Math.round(ws.reduce(function(s,w){return s+w;},0)/ws.length*10)/10;
    }
  });

  const active = db.lots.filter(l=>!l.status||l.status==='activo'||l.status==='active');
  const cuarentena = db.lots.filter(l=>l.status==='cuarentena');
  const vendidos = db.lots.filter(l=>l.status==='vendido'||l.status==='sold');
  var subtitle = active.length+' lotes activos · '+active.reduce((s,l)=>s+l.animal_count,0)+' animales';
  if (cuarentena.length) subtitle += ' · 🚧 ' + cuarentena.length + ' en cuarentena (' + cuarentena.reduce((s,l)=>s+(l.animal_count||0),0) + ' cab.)';
  if (vendidos.length) subtitle += ' · 💰 ' + vendidos.length + ' vendidos';
  document.getElementById('lotes-sub').textContent = subtitle;

  // Aplicar filtro
  var lotsToShow = db.lots.filter(function(l) {
    if (_lotesFilter === 'todos') return true;
    if (_lotesFilter === 'active') return !l.status || l.status === 'activo' || l.status === 'active';
    if (_lotesFilter === 'cuarentena') return l.status === 'cuarentena';
    if (_lotesFilter === 'vendido') return l.status === 'vendido' || l.status === 'sold';
    return true;
  });

  // Helper: encuentra la compra de ganado asociada a un lote
  // Primero busca por lot_code directo (lote cuarentena), después en lote_destinos (lotes destino post-marcaje)
  function findCompraForLot(code) {
    var compras = db.compras_ganado || [];
    var direct = compras.find(function(c) { return c.lot_code === code; });
    if (direct) return direct;
    return compras.find(function(c) {
      return c.lote_destinos && c.lote_destinos.indexOf(code) >= 0;
    });
  }
  const tbody = document.getElementById('lotes-tbody');
  if (!lotsToShow.length) {
    tbody.innerHTML = '<tr><td colspan="10" style="text-align:center;padding:24px;color:var(--muted)">Sin lotes en este filtro</td></tr>';
    return;
  }
  tbody.innerHTML = lotsToShow.map(function(lot){
    var isCuarentena = lot.status === 'cuarentena';
    var isMarcado = lot.status === 'marcado_completo';
    // v1.4.108: ocultar botón Mover para lotes vendidos, inactivos o sin animales
    var lotStatusLower = String(lot.status || '').toLowerCase();
    var isInactive = lotStatusLower === 'vendido' || lotStatusLower === 'sold' || lotStatusLower === 'inactivo' || lotStatusLower === 'inactive';
    var isEmpty = (lot.animal_count || 0) === 0;
    var btnMover;
    var btnFusionar = '';
    if (isCuarentena) {
      btnMover = '<button class="btn btn-primary btn-sm" onclick="openMarcarCuarentena(\''+(lot.code||'').replace(/'/g,"\\'")+'\')" style="background:#A855F7;border-color:#A855F7" title="Marcar IDs y pesos individuales">📝 Marcar</button>';
    } else if (isMarcado || isInactive || isEmpty) {
      btnMover = ''; // sin botón
    } else {
      btnMover = '<button class="btn btn-ghost btn-sm" onclick="openMoveLot(\''+(lot.code||'').replace(/'/g,"\\'")+'\')">Mover</button>';
      // v1.8.2: fusionar disponible solo si hay >=2 lotes activos con animales
      btnFusionar = '<button class="btn btn-ghost btn-sm" onclick="openFusionarLote(\''+(lot.code||'').replace(/'/g,"\\'")+'\')" title="Fusionar todos los animales de este lote en otro">🔀 Fusionar</button>';
    }
    // Datos de proveedor / detalles desde la compra asociada (si existe)
    var compra = findCompraForLot(lot.code);
    var proveedorTxt = compra && compra.proveedor ? compra.proveedor : '-';
    var detalleTxt = '';
    if (compra) {
      var partes = [];
      if (compra.fecha) partes.push('🗓 ' + compra.fecha);
      if (compra.total) partes.push('💰 Bs. ' + compra.total.toLocaleString());
      if (compra.notes) partes.push(compra.notes);
      detalleTxt = partes.join(' · ');
    }
    // v1.4.80: si el lote nació de un movimiento batch, mostrar el lote padre como "origen"
    // y trazar la cadena hasta el lote original (con proveedor real si hay).
    if (!compra && lot._createdViaBulkMove) {
      var move = (db.animal_movements || []).find(function(m){ return m.to_lot === lot.code; });
      if (move) {
        // Buscar la cadena hacia atrás hasta el lote original que sí tenga compra
        var chain = [];
        var curLot = move.from_lot;
        var guard = 10;
        while (curLot && guard-- > 0) {
          chain.push(curLot);
          var compraPadre = findCompraForLot(curLot);
          if (compraPadre && compraPadre.proveedor) {
            // Encontrado: chain muestra la trazabilidad, proveedor real al final
            proveedorTxt = compraPadre.proveedor + ' ← ' + chain.reverse().join(' ← ');
            break;
          }
          // Buscar otro movimiento que haya creado curLot
          var prevMove = (db.animal_movements || []).find(function(m){ return m.to_lot === curLot; });
          if (!prevMove) {
            proveedorTxt = '← ' + chain.reverse().join(' ← ');
            break;
          }
          curLot = prevMove.from_lot;
        }
        if (proveedorTxt === '-') proveedorTxt = '← ' + move.from_lot;
        // Detalle: fecha + cantidad + motivo
        var partes2 = [];
        if (move.date) partes2.push('🗓 ' + move.date);
        partes2.push('📤 ' + move.count + ' cab');
        if (move.reason) partes2.push(move.reason);
        if (!detalleTxt || detalleTxt === '-') detalleTxt = partes2.join(' · ');
      }
    }
    // v1.4.108: si el lote vino de un lot_split (Desktop o bot WhatsApp) y NO tiene
    // _createdViaBulkMove ni animal_movements, usar cost_origin.from_lot para trazar.
    // Aplica a: bot split (cost_origin.via='whatsapp'), bot lot_rotation,
    // y casos legacy donde el origen quedó en cost_origin pero no en movements.
    if (proveedorTxt === '-' && lot.cost_origin && lot.cost_origin.from_lot) {
      var chain3 = [];
      var curLot3 = lot.cost_origin.from_lot;
      var guard3 = 10;
      while (curLot3 && guard3-- > 0) {
        chain3.push(curLot3);
        var compraPadre3 = findCompraForLot(curLot3);
        if (compraPadre3 && compraPadre3.proveedor) {
          proveedorTxt = compraPadre3.proveedor + ' ← ' + chain3.reverse().join(' ← ');
          break;
        }
        // Subir un nivel más: buscar lot del cur y revisar su cost_origin
        var nextLot = (db.lots || []).find(function(l){ return l && l.code === curLot3; });
        if (nextLot && nextLot.cost_origin && nextLot.cost_origin.from_lot) {
          curLot3 = nextLot.cost_origin.from_lot;
        } else {
          // No hay más cadena; mostramos lo que tenemos
          proveedorTxt = '← ' + chain3.reverse().join(' ← ');
          break;
        }
      }
      // Detalles desde cost_origin
      if (!detalleTxt || detalleTxt === '-') {
        var partes3 = [];
        if (lot.cost_origin.date) partes3.push('🗓 ' + lot.cost_origin.date);
        partes3.push('📥 ' + (lot.cost_origin.animal_count || lot.animal_count || 0) + ' cab');
        if (lot.cost_origin.total_kg) partes3.push(Math.round(lot.cost_origin.total_kg) + ' kg');
        if (lot.cost_origin.via === 'whatsapp') partes3.push('via WhatsApp');
        detalleTxt = partes3.join(' · ');
      }
    }
    if (!detalleTxt) detalleTxt = lot.notes ? escH(lot.notes) : '-';
    // Si es marcado_completo y hay lote destino, mostrarlo en detalles
    if (isMarcado && lot.marcaje_lot_destino) {
      detalleTxt = '→ ' + escH(lot.marcaje_lot_destino) + (detalleTxt && detalleTxt !== '-' ? ' · ' + detalleTxt : '');
    }
    var rowBg = isCuarentena ? 'background:rgba(168,85,247,.04)' : (isMarcado ? 'background:rgba(107,114,128,.04);opacity:.75' : '');
    return '<tr'+(rowBg?' style="'+rowBg+'"':'')+'>'+
      '<td><span style="font-family:DM Mono,monospace;background:var(--sur2);padding:3px 8px;border-radius:5px;color:'+(isCuarentena?'#A855F7':(isMarcado?'#9CA3AF':'var(--amber2)'))+';border:1px solid var(--bor)">'+escH(lot.code)+'</span></td>'+
      '<td>'+capFirst(lot.category)+'</td>'+
      '<td style="color:var(--muted);font-size:12px">'+escH(lot.breed||'-')+'</td>'+
      '<td>'+escH(lot.paddock||'-')+'</td>'+
      '<td style="font-weight:500">'+lot.animal_count+'</td>'+
      '<td>'+((lot.animal_count||0) > 0 && lot.avg_weight ? lot.avg_weight+' kg' : '<span style="color:var(--muted)">—</span>')+'</td>'+
      '<td>'+lotStatusBadge(lot)+'</td>'+
      '<td style="font-size:12px;color:'+(proveedorTxt==='-'?'var(--muted)':'var(--text)')+'">'+escH(proveedorTxt)+'</td>'+
      '<td style="font-size:11px;color:var(--muted);max-width:240px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="'+escH(detalleTxt)+'">'+escH(detalleTxt)+'</td>'+
      '<td style="display:flex;gap:6px">'+
        btnMover +
        btnFusionar +
        (isMarcado ? '' : '<button class="btn btn-danger btn-sm" onclick="deleteLot(\''+(lot.code||'').replace(/'/g,"\\'")+'\')">X</button>')+
      '</td>'+
    '</tr>';
  }).join('');
}

function lotStatusBadge(lot) {
  if(lot.status==='sold' || lot.status==='vendido') return'<span class="bdg bdg-purple">Vendido</span>';
  if(lot.status==='fusionado') return'<span class="bdg" style="background:rgba(88,166,255,.15);color:#58a6ff;border:1px solid #58a6ff" title="Fusionado en '+(lot.fused_into||'?')+'">🔀 Fusionado → '+(lot.fused_into||'?')+'</span>';
  if(lot.status==='cuarentena') return'<span class="bdg" style="background:rgba(168,85,247,.15);color:#A855F7;border:1px solid #A855F7">🚧 Cuarentena</span>';
  if(lot.status==='marcado_completo') return'<span class="bdg" style="background:rgba(107,114,128,.15);color:#9CA3AF;border:1px solid #6B7280">📦 Marcado</span>';
  const alerts = db.alerts.filter(a=>!a.resolved&&a.lot_code===lot.code);
  if(alerts.length) return'<span class="bdg bdg-amber">⚠ Alerta</span>';
  return'<span class="bdg bdg-green">✓ Activo</span>';
}

// v1.8.69: autor de un registro hecho desde el Escritorio. Antes se hardcodeaba "Cesar Moreno"
// (tenant de César) → en otros tenants la trazabilidad mostraba "por Cesar Moreno". Usa el
// propietario configurado; si no hay, "Escritorio".
window._desktopAuthor = function(){
  try { var rp = (typeof getRp === 'function') ? getRp() : {}; var p = String(rp.propietario||'').trim(); return p || 'Escritorio'; }
  catch(e){ return 'Escritorio'; }
};

function openMoveLot(idOrCode) {
  // v1.8.24: buscar por code primero (único), id como fallback
  var lot = db.lots.find(function(l){return l.code===idOrCode;});
  if (!lot) lot = db.lots.find(function(l){return String(l.id)===String(idOrCode);});
  if (!lot) { toast('Lote no encontrado', 'error'); return; }
  // v1.4.108 GUARD: rechazar lotes vendidos, inactivos o sin animales
  var statusLower = String(lot.status || '').toLowerCase();
  if (statusLower === 'vendido' || statusLower === 'sold' || statusLower === 'inactivo' || statusLower === 'inactive') {
    toast('No se puede rotar el lote ' + lot.code + ' (status: ' + lot.status + ')', 'warning');
    return;
  }
  if ((lot.animal_count || 0) === 0) {
    toast('No se puede rotar el lote ' + lot.code + ' (sin animales)', 'warning');
    return;
  }
  movingLotId = lot.id;   // v1.8.69 FIX: usaba `id` (indefinido) → el botón Rotar tiraba ReferenceError
  document.getElementById('move-lot-code').value = lot.code+' - '+lot.paddock;
  document.getElementById('move-reason').value = '';
  var currentPaddock = String(lot.paddock || '').trim();
  var sel = document.getElementById('move-paddock');
  if (sel) {
    var params = typeof getParams==='function' ? getParams() : {potreros:[]};
    sel.innerHTML = '<option value="">Seleccionar potrero...</option>';
    (params.potreros||[]).forEach(function(p){
      // v1.4.108 FIX: excluir el potrero actual del lote (no se puede rotar al mismo)
      if (p.name && currentPaddock && String(p.name).toLowerCase() === currentPaddock.toLowerCase()) return;
      // v1.4.108 FIX: la ocupación post-rotación NO incluye al lote que se está moviendo
      var currentInPotrero = (db.lots||[]).filter(function(l){
        return (l.paddock||'').toLowerCase()===(p.name||'').toLowerCase() && l.id !== lot.id;
      }).reduce(function(s,l){return s+(l.animal_count||0);},0);
      var o = document.createElement('option');
      o.value = p.name;
      o.textContent = p.name + (p.capacity ? ' (' + currentInPotrero + '/' + p.capacity + ' cab)' : '');
      if (p.capacity && currentInPotrero >= p.capacity) o.style.color = '#EF4444';
      sel.appendChild(o);
    });
  }
  // Populate suggestions
  var sugEl = document.getElementById('move-paddock-suggestions-d');
  if (sugEl) {
    var params2 = getParams();
    var potreros2 = params2.potreros || [];
    var history2 = db.rotation_history || [];
    var lots2 = db.lots || [];
    var today2 = new Date();
    var readyPots = [];
    potreros2.forEach(function(p) {
      // v1.4.108: excluir el potrero actual también de las sugerencias
      if (p.name && currentPaddock && String(p.name).toLowerCase() === currentPaddock.toLowerCase()) return;
      var occ = lots2.filter(function(l){return (l.paddock||'').toLowerCase()===p.name.toLowerCase()&&l.status!=='sold'&&(l.animal_count||0)>0 && l.id !== lot.id;});  // v1.8.69 FIX: era `id` (indefinido)
      if (occ.length > 0) return;
      var exits = history2.filter(function(r){return r.potrero===p.name&&r.exit_date;}).sort(function(a,b){return (b.exit_date||'').localeCompare(a.exit_date||'');});
      var daysRest = exits.length ? Math.round((today2-new Date(exits[0].exit_date))/86400000) : 999;
      var ready = p.rest_days ? daysRest >= p.rest_days : true;
      if (ready) readyPots.push({name:p.name, daysRest:daysRest});
    });
    readyPots.sort(function(a,b){return b.daysRest-a.daysRest;});
    if (readyPots.length) {
      sugEl.innerHTML = '<div style="font-size:10px;color:var(--green);margin-bottom:4px">✅ Sugeridos:</div>' +
        readyPots.slice(0,3).map(function(p){return '<button class="btn btn-ghost btn-sm" onclick="document.getElementById(\'move-paddock\').value=\''+p.name+'\';checkMoveWarningDesktop()" style="font-size:10px;border:1px solid rgba(34,197,94,.3);color:var(--green);margin-right:4px">'+p.name+' ('+p.daysRest+'d)</button>';}).join('');
    } else {
      sugEl.innerHTML = '<div style="font-size:10px;color:var(--amber2)">⚠️ Ningun potrero con descanso suficiente registrado</div>';
    }
  }
  openModal('modal-move');
}

function checkMoveWarningDesktop() {
  var newP = (document.getElementById('move-paddock')||{}).value||'';
  var warnEl = document.getElementById('move-paddock-warning-d');
  if (!warnEl || !newP) { if(warnEl) warnEl.innerHTML=''; return; }
  var params2 = getParams();
  var pot = (params2.potreros||[]).find(function(p){return p.name===newP;});
  if (!pot) { warnEl.innerHTML=''; return; }
  var occ = db.lots.filter(function(l){return (l.paddock||'').toLowerCase()===newP.toLowerCase()&&l.status!=='sold'&&(l.animal_count||0)>0;});
  if (occ.length) { warnEl.innerHTML='<div style="padding:6px 10px;background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.3);border-radius:6px;font-size:11px;color:var(--red)">🔴 Ocupado con '+occ.reduce(function(s,l){return s+l.animal_count;},0)+' cabezas</div>'; return; }
  var exits = (db.rotation_history||[]).filter(function(r){return r.potrero===newP&&r.exit_date;}).sort(function(a,b){return (b.exit_date||'').localeCompare(a.exit_date||'');});
  if (exits.length && pot.rest_days) {
    var dr = Math.round((new Date()-new Date(exits[0].exit_date))/86400000);
    if (dr < pot.rest_days) { warnEl.innerHTML='<div style="padding:6px 10px;background:rgba(245,166,35,.1);border:1px solid rgba(245,166,35,.3);border-radius:6px;font-size:11px;color:var(--amber2)">⚠️ Solo '+dr+' dias de descanso (min '+pot.rest_days+')</div>'; return; }
  }
  warnEl.innerHTML='<div style="padding:6px 10px;background:rgba(34,197,94,.06);border:1px solid rgba(34,197,94,.15);border-radius:6px;font-size:11px;color:var(--green)">✅ Potrero listo</div>';
}

// v1.4.104: helper Desktop para mantener rotation_history al crear/editar lotes.
// Espejo del syncRotationOnLotChange del server v4.5.1, pero local (no async).
// Garantiza que cualquier lote con paddock asignado tenga una entry abierta
// correspondiente en db.rotation_history. Idempotente.
//
// Llamado desde:
//   - saveLot() (modal "+ Nuevo lote")
//   - Crear lote de cuarentena (compra)
//   - Crear lote destino desde marcaje de cuarentena
//
// moveLot() NO necesita llamarlo porque ya maneja history por su cuenta.
function _ensureRotationEntry(lot, opts) {
  if (!lot || !lot.code) return;
  var status = String(lot.status || '').toLowerCase();
  if (status === 'vendido' || status === 'sold' || status === 'inactivo' || status === 'inactive') return;
  if ((lot.animal_count || 0) === 0 && !(opts && opts.allowEmpty)) return;
  var paddock = String(lot.paddock || '').trim();
  if (!paddock) return;

  if (!db.rotation_history) db.rotation_history = [];
  var hasOpen = db.rotation_history.some(function(r) {
    return r && r.lot_code === lot.code && r.potrero === paddock && !r.exit_date;
  });
  if (hasOpen) return;

  var nowIso = new Date().toISOString();
  var todayStr = (typeof localDate === 'function') ? localDate() : nowIso.slice(0, 10);
  db.rotation_history.push({
    id: Date.now() + Math.floor(Math.random() * 1000),
    lot_code: lot.code,
    potrero: paddock,
    from_potrero: '',
    entry_date: todayStr,
    entry_at: nowIso,
    exit_date: null,
    exit_at: null,
    days_occupied: 0,
    cabezas: lot.animal_count || 0,
    reason: (opts && opts.reason) || 'Creación de lote',
    by: 'Desktop',
    source: 'desktop'
  });
}

function moveLot() {
  var lot = db.lots.find(function(l){return String(l.id)===String(movingLotId);});
  var newPaddock = (document.getElementById('move-paddock').value||'').trim();
  var reason = (document.getElementById('move-reason').value||'').trim();
  if(!newPaddock){toast('Selecciona el potrero destino','error');return;}
  // Validar capacidad del potrero destino
  var potreroCap = getPotreroCapacity(newPaddock);
  if (potreroCap && (lot.animal_count||0) > potreroCap) {
    toast('Potrero "' + newPaddock + '" tiene capacidad para ' + potreroCap + ' animales. El lote tiene ' + (lot.animal_count||0), 'error'); return;
  }
  const old = lot.paddock;
  lot.paddock = newPaddock;
  // Record rotation history
  if (!db.rotation_history) db.rotation_history = [];
if (!db.pasture_evals) db.pasture_evals = [];
  // Cerrar TODAS las rotaciones abiertas del lote (no solo la del potrero anterior).
  // Solo una rotación puede estar "en curso" por lote. Defensivo contra estados inconsistentes
  // donde queden múltiples abiertas por bugs previos o syncs cruzados.
  var rotacionesAbiertas = db.rotation_history.filter(function(r){
    return r.lot_code === lot.code && !r.exit_date;
  });
  rotacionesAbiertas.forEach(function(r){
    r.exit_date = localDate();
    r.exit_at = new Date().toISOString();
    var d1 = new Date(r.entry_date);
    var d2 = new Date();
    r.days_occupied = Math.max(1, Math.round((d2-d1)/86400000));
  });
  if (rotacionesAbiertas.length > 1) {
    console.warn('[moveLot] Cerradas ' + rotacionesAbiertas.length + ' rotaciones abiertas (deberían ser 1). Posible inconsistencia previa.');
  }
  // FIX v1.4.35 BUG-LOT-3: idempotencia para evitar duplicación cuando hay sync cruzado.
  // Si ya existe una rotación abierta para este lote+potrero creada en los últimos 5 segundos
  // (por otra instancia del mismo flow), no crear otra.
  var nowMs = Date.now();
  var rotacionExistenteRecien = db.rotation_history.find(function(r){
    if (r.lot_code !== lot.code || r.potrero !== newPaddock) return false;
    if (r.exit_date) return false;
    var entryMs = r.entry_at ? new Date(r.entry_at).getTime() : 0;
    return entryMs && (nowMs - entryMs) < 5000;
  });
  if (rotacionExistenteRecien) {
    console.warn('[moveLot] Rotación ya creada hace <5s para lote+potrero, omitiendo duplicación');
  } else {
    // Open new occupation
    db.rotation_history.push({
      id: Date.now(), lot_code: lot.code, potrero: newPaddock, from_potrero: old||'',
      entry_date: localDate(), entry_at: new Date().toISOString(),
      exit_date: null, exit_at: null, days_occupied: 0,
      cabezas: lot.animal_count||0, reason: reason||'', by: 'Desktop'
    });
  }
  addActivity('Sistema', 'movimiento', lot.code, 'Lote '+(lot.code)+' movido de '+(old)+' a '+(newPaddock)+'. '+(reason)+'');
  // Auto-Kardex
  if (!db.kardex) db.kardex = [];
  db.kardex.push({id:Date.now()+3,lote:lot.code,tipo:'movimiento',fecha:localDate(),cabezas:lot.animal_count||0,precio:0,total:0,desc:'Rotacion: '+(old||'?')+' → '+newPaddock+(reason?' ('+reason+')':''),by:'Desktop',created_at:new Date().toISOString(),auto:true});
  saveDB(true);
  closeModal('modal-move');
  renderLotes();
  renderRotacion();
  replaceTableInRailway('rotation_history', db.rotation_history || []);
  replaceTableInRailway('lots', db.lots || []);
  toast('Lote '+lot.code+' movido a '+newPaddock,'success');
  try { auditLog('update', 'lots', lot.id, 'Movido: ' + lot.code + ' · ' + (old||'(sin potrero)') + ' → ' + newPaddock, { paddock: [old || '', newPaddock] }); } catch(e){}
}


// ═════════════════════════════════════════════════════════════
// v1.8.2 — FUSIÓN FORMAL DE LOTES
// Mueve todos los animales del origen al destino, marca origen como 'fusionado'
// ═════════════════════════════════════════════════════════════
var _fusionandoLotId = null;

function openFusionarLote(idOrCode) {
  // v1.8.24: buscar por code primero (único), id como fallback. Evita agarrar lote
  // equivocado si hubiera IDs duplicados (mismo bug que afectaba el marcaje).
  var lot = db.lots.find(function(l){ return l.code === idOrCode; });
  if (!lot) lot = db.lots.find(function(l){ return String(l.id) === String(idOrCode); });
  if (!lot) { toast('Lote no encontrado', 'error'); return; }
  _fusionandoLotId = lot.code; // guardar code (estable) en vez de id

  document.getElementById('fusionar-origen-code').value = lot.code;
  var origenInfo = document.getElementById('fusionar-origen-info');
  if (origenInfo) origenInfo.textContent = (lot.animal_count||0) + ' animales · ' + (lot.paddock||'sin potrero') + (lot.breed?' · '+lot.breed:'');

  // Poblar destinos: solo lotes ACTIVOS reales (excluye vendido/fusionado/cuarentena/marcado y los CUAR-xxx)
  var destSel = document.getElementById('fusionar-destino');
  destSel.innerHTML = '<option value="">Seleccionar lote destino...</option>';
  db.lots.filter(function(l){
    if (l.code === lot.code) return false;
    var st = String(l.status||'').toLowerCase();
    // Excluir estados no-activos
    if (st === 'vendido' || st === 'sold' || st === 'fusionado' || st === 'merged') return false;
    if (st === 'cuarentena' || st === 'marcado' || st === 'marcado_completo' || st === 'inactivo' || st === 'inactive') return false;
    // Defensa extra: excluir lotes de cuarentena por convención de código (CUAR-001, etc.)
    if (/^CUAR-\d+$/i.test(l.code || '')) return false;
    // Defensa extra: excluir si el potrero dice cuarentena
    if (/cuarentena/i.test(l.paddock || '')) return false;
    // Solo destinos con al menos 1 animal tienen sentido como destino de fusión
    // (permitimos 0 también, por si quiere consolidar en un lote recién creado)
    return true;
  }).forEach(function(l){
    var o = document.createElement('option');
    o.value = l.code;
    o.textContent = l.code + ' (' + (l.animal_count||0) + ' cab · ' + (l.paddock||'s/potrero') + ')';
    destSel.appendChild(o);
  });

  document.getElementById('fusionar-motivo').value = '';
  document.getElementById('fusionar-warning').innerHTML = '';
  document.getElementById('fusionar-resumen').style.display = 'none';
  openModal('modal-fusionar');
}

function checkFusionWarning() {
  var origen = db.lots.find(function(l){ return String(l.id) === String(_fusionandoLotId); });
  var destCode = document.getElementById('fusionar-destino').value;
  var warnEl = document.getElementById('fusionar-warning');
  var resumenEl = document.getElementById('fusionar-resumen');
  if (!origen || !destCode) { warnEl.innerHTML = ''; resumenEl.style.display = 'none'; return; }
  var dest = db.lots.find(function(l){ return l.code === destCode; });
  if (!dest) return;

  var totalFinal = (dest.animal_count||0) + (origen.animal_count||0);
  var warnings = [];

  // Validar capacidad del potrero destino
  var cap = (typeof getPotreroCapacity === 'function') ? getPotreroCapacity(dest.paddock) : null;
  if (cap && totalFinal > cap) {
    warnings.push('⚠ El potrero "' + dest.paddock + '" tiene capacidad para ' + cap + ' animales. La fusión daría ' + totalFinal + '.');
  }
  // Distinta raza
  if (origen.breed && dest.breed && origen.breed !== dest.breed) {
    warnings.push('⚠ Razas distintas: origen ' + origen.breed + ' vs destino ' + dest.breed + '.');
  }
  // Distinta categoría
  if (origen.category && dest.category && origen.category !== dest.category) {
    warnings.push('⚠ Categorías distintas: ' + origen.category + ' vs ' + dest.category + '.');
  }

  if (warnings.length) {
    warnEl.innerHTML = warnings.map(function(w){
      return '<div style="color:var(--amber);font-size:11px;margin-top:2px">'+w+'</div>';
    }).join('');
  } else {
    warnEl.innerHTML = '<div style="color:var(--green);font-size:11px">✓ Sin advertencias</div>';
  }

  resumenEl.style.display = 'block';
  // Mensaje sobre potrero: si son iguales, lo confirma; si difieren, recuerda al usuario
  var potreroOrigen = origen.paddock || '(sin potrero)';
  var potreroDest = dest.paddock || '(sin potrero)';
  var mismoPotrero = (potreroOrigen === potreroDest);
  var lineaPotrero;
  if (mismoPotrero) {
    lineaPotrero = '• Los ' + totalFinal + ' animales quedan en <b style="color:var(--text)">' + escH(potreroDest) + '</b>.';
  } else {
    lineaPotrero = '• <span style="color:var(--amber)">📍 Verificá:</span> el sistema registrará los ' + totalFinal + ' animales en <b style="color:var(--text)">' + escH(potreroDest) + '</b> (potrero de ' + escH(dest.code) + '). Los ' + (origen.animal_count||0) + ' de ' + escH(origen.code) + ' venían de <b style="color:var(--text)">' + escH(potreroOrigen) + '</b> — asegurate que ya estén físicamente juntos.';
  }

  resumenEl.innerHTML =
    '<div style="margin-bottom:8px"><span style="font-size:16px">🏷️</span> <b>El lote resultante se llamará <span style="color:var(--amber2)">' + escH(dest.code) + '</span></b></div>' +
    '<div style="font-size:11px;color:var(--muted);line-height:1.5">' +
      '• <b style="color:var(--text)">' + escH(dest.code) + '</b> conserva su nombre y pasa de ' + (dest.animal_count||0) + ' a <b style="color:var(--amber2)">' + totalFinal + ' animales</b>.<br>' +
      lineaPotrero + '<br>' +
      '• <b style="color:var(--text)">' + escH(origen.code) + '</b> se vacía y queda marcado como fusionado (verás "🔀 Fusionado → ' + escH(dest.code) + '" en el filtro Todos).' +
    '</div>';
}

function confirmarFusion() {
  // v1.8.24: _fusionandoLotId ahora guarda el code (estable). Buscar por code, id como fallback.
  var origen = db.lots.find(function(l){ return l.code === _fusionandoLotId; });
  if (!origen) origen = db.lots.find(function(l){ return String(l.id) === String(_fusionandoLotId); });
  var destCode = document.getElementById('fusionar-destino').value;
  var motivo = (document.getElementById('fusionar-motivo').value||'').trim();
  if (!origen) { toast('Lote origen no encontrado', 'error'); return; }
  if (!destCode) { toast('Selecciona el lote destino', 'error'); return; }
  var dest = db.lots.find(function(l){ return l.code === destCode; });
  if (!dest) { toast('Lote destino no encontrado', 'error'); return; }
  if (origen.code === destCode) { toast('No podés fusionar un lote consigo mismo', 'error'); return; }
  // Defensa: no permitir cuarentena/marcado como destino aunque se fuerce el valor
  var destSt = String(dest.status||'').toLowerCase();
  if (destSt === 'cuarentena' || destSt === 'marcado' || destSt === 'marcado_completo' || /^CUAR-\d+$/i.test(dest.code||'')) {
    toast('No se puede fusionar hacia un lote en cuarentena', 'error'); return;
  }
  // Defensa: el origen tampoco puede estar en cuarentena
  var origenSt = String(origen.status||'').toLowerCase();
  if (origenSt === 'cuarentena' || origenSt === 'marcado' || origenSt === 'marcado_completo') {
    toast('No se puede fusionar un lote en cuarentena (primero marcalo)', 'error'); return;
  }

  var nAnimales = origen.animal_count || 0;
  if (!confirm('¿Fusionar ' + origen.code + ' (' + nAnimales + ' animales) en ' + dest.code + '?\n\nEl lote resultante se llamará "' + dest.code + '" y tendrá ' + ((dest.animal_count||0) + nAnimales) + ' animales.\n' + origen.code + ' quedará vacío y marcado como fusionado.\n\nEs reversible manualmente pero no automáticamente.')) {
    return;
  }

  // 1) Mover los animales en e5m_animals (origen.code → dest.code)
  var movedCount = 0;
  try {
    var rawAnim = (typeof getAnimalesDB === 'function') ? getAnimalesDB() : JSON.parse(localStorage.getItem('e5m_animals') || '{}');
    var origenAnimals = rawAnim[origen.code] || [];
    movedCount = origenAnimals.length;
    if (!rawAnim[dest.code]) rawAnim[dest.code] = [];

    // v1.8.6: deduplicar por animal_id/id para no acumular el mismo animal dos veces
    // (causa del desajuste 40 vs 89: fusiones previas duplicaban).
    var destExistentes = {};
    rawAnim[dest.code].forEach(function(a){
      var k = String((a && (a.animal_id || a.id)) || '');
      if (k) destExistentes[k] = true;
    });
    // Reasignar cada animal del origen al destino, evitando duplicados
    origenAnimals.forEach(function(a){
      if (a && typeof a === 'object') {
        a.lot_code = dest.code;
        if (!a.fusion_origin) a.fusion_origin = origen.code;
      }
      var k = String((a && (a.animal_id || a.id)) || '');
      if (k && destExistentes[k]) return; // ya está, no duplicar
      if (k) destExistentes[k] = true;
      rawAnim[dest.code].push(a);
    });
    // Vaciar origen
    rawAnim[origen.code] = [];
    // saveAnimalesDB persiste + push a Railway en un solo paso
    if (typeof saveAnimalesDB === 'function') { saveAnimalesDB(rawAnim); }
    else { localStorage.setItem('e5m_animals', JSON.stringify(rawAnim)); }

    // v1.8.6: recontar animal_count desde la REALIDAD de e5m_animals (no sumar conteos que pueden divergir)
    var realDestCount = (rawAnim[dest.code] || []).length;
    // Solo usar el conteo real si el lote estaba marcado individualmente.
    // Si el destino no tenía animales individuales antes, mantener la suma de conteos agregados.
    var destTeniaIndividuales = (movedCount > 0) || (realDestCount > 0);
    if (destTeniaIndividuales && realDestCount > 0) {
      dest.animal_count = realDestCount;
    } else {
      dest.animal_count = (dest.animal_count||0) + (origen.animal_count||0);
    }
  } catch(e) {
    console.error('[fusion] error moviendo animales:', e);
    toast('Error moviendo animales: ' + e.message, 'error');
    return;
  }

  // 2) Marcar origen vacío
  origen.animal_count = 0;

  // 3) Marcar origen como fusionado
  origen.status = 'fusionado';
  origen.fused_into = dest.code;
  origen.fused_at = new Date().toISOString();
  origen.fused_count = movedCount || (origen.fused_count || 0);

  // 4) Cerrar rotaciones abiertas del origen
  if (!db.rotation_history) db.rotation_history = [];
  db.rotation_history.filter(function(r){
    return r.lot_code === origen.code && !r.exit_date;
  }).forEach(function(r){
    r.exit_date = localDate();
    r.exit_at = new Date().toISOString();
    var d1 = new Date(r.entry_date); var d2 = new Date();
    r.days_occupied = Math.max(1, Math.round((d2-d1)/86400000));
    r.exit_reason = 'Fusión en ' + dest.code;
  });

  // 5) Activity + Kardex
  addActivity('Sistema', 'fusion', origen.code, 'Lote ' + origen.code + ' fusionado en ' + dest.code + ' (' + nAnimales + ' animales)' + (motivo?'. '+motivo:''));
  if (!db.kardex) db.kardex = [];
  db.kardex.push({
    id: Date.now()+7, lote: dest.code, tipo: 'fusion', fecha: localDate(),
    cabezas: nAnimales, precio: 0, total: 0,
    desc: 'Fusión: recibió ' + nAnimales + ' animales de ' + origen.code + (motivo?' ('+motivo+')':''),
    by: 'Desktop', created_at: new Date().toISOString(), auto: true
  });

  // 6) Persistir y sincronizar
  saveDB(true);
  closeModal('modal-fusionar');
  renderLotes();
  if (typeof renderRotacion === 'function') renderRotacion();
  replaceTableInRailway('lots', db.lots || []);
  replaceTableInRailway('rotation_history', db.rotation_history || []);
  // (animales ya sincronizados por saveAnimalesDB arriba)

  try { auditLog('update', 'lots', origen.id, 'Fusión: ' + origen.code + ' → ' + dest.code + ' (' + nAnimales + ' animales)', { status: ['activo', 'fusionado'], fused_into: ['', dest.code] }); } catch(e){}

  _fusionandoLotId = null;
  toast('✓ ' + origen.code + ' fusionado en ' + dest.code + ' · ' + nAnimales + ' animales movidos', 'success');
}



// ═════════════════════════════════════════════════════════════
// v1.8.6 — Reparar inconsistencias de animales por lote
// Deduplica animales repetidos en e5m_animals y reconcilia animal_count.
// Causa: fusiones previas (v1.8.2-1.8.5) podían duplicar animales y desajustar el conteo.
// Uso: desde consola → repararAnimalesLotes()  ó  botón en Lotes.
// ═════════════════════════════════════════════════════════════
function repararAnimalesLotes(silencioso) {
  var rawAnim = {};
  try { rawAnim = (typeof getAnimalesDB === 'function') ? getAnimalesDB() : JSON.parse(localStorage.getItem('e5m_animals') || '{}'); }
  catch(e) { if(!silencioso) toast('Error leyendo animales', 'error'); return; }

  var reporte = [];
  var cambios = false;

  // v1.8.19: normalizar animales que usan 'id' en vez de 'animal_id', y arreglar los "N/A"
  Object.keys(rawAnim).forEach(function(lotCode){
    var arr = rawAnim[lotCode] || [];
    if (!Array.isArray(arr)) return;
    arr.forEach(function(a){
      if (!a || typeof a !== 'object') return;
      // Migrar id → animal_id
      if (!a.animal_id && a.id) {
        a.animal_id = a.id;
        delete a.id;
        cambios = true;
      }
      // Reemplazar IDs "N/A" o vacíos por un placeholder único
      var aid = String(a.animal_id || '');
      if (!aid || aid === 'N/A' || aid.toLowerCase() === 'n/a') {
        a.animal_id = 'CRIA-' + String(Date.now()).slice(-6) + '-' + Math.floor(Math.random()*100);
        a._needs_id = true; // marca para que César le asigne un ID real después
        cambios = true;
        reporte.push('ID temporal asignado a cría sin ID en ' + lotCode + ' → ' + a.animal_id);
      }
      // Normalizar breed/raza
      if (!a.breed && a.raza) { a.breed = a.raza; cambios = true; }
    });
  });

  Object.keys(rawAnim).forEach(function(lotCode){
    var arr = rawAnim[lotCode] || [];
    if (!Array.isArray(arr)) return;
    var antes = arr.length;
    // Deduplicar por animal_id/id
    var seen = {};
    var dedup = [];
    arr.forEach(function(a){
      var k = String((a && (a.animal_id || a.id)) || '');
      if (!k) { dedup.push(a); return; } // sin id, conservar
      if (seen[k]) return; // duplicado, descartar
      seen[k] = true;
      dedup.push(a);
    });
    if (dedup.length !== antes) {
      rawAnim[lotCode] = dedup;
      cambios = true;
      reporte.push(lotCode + ': ' + antes + ' → ' + dedup.length + ' (quitados ' + (antes - dedup.length) + ' duplicados)');
    }
  });

  // Reconciliar animal_count de cada lote con la realidad
  (db.lots || []).forEach(function(lot){
    var st = String(lot.status||'').toLowerCase();
    if (st === 'vendido' || st === 'sold' || st === 'fusionado') return; // estos quedan en 0 a propósito
    var realCount = (rawAnim[lot.code] || []).length;
    // Solo reconciliar si el lote tiene animales individuales (realCount > 0).
    // Lotes por conteo puro (realCount === 0) mantienen su animal_count manual.
    if (realCount > 0 && lot.animal_count !== realCount) {
      reporte.push('Conteo ' + lot.code + ': ' + lot.animal_count + ' → ' + realCount);
      lot.animal_count = realCount;
      cambios = true;
    }
  });

  if (!cambios) {
    if (!silencioso) toast('✓ No se encontraron inconsistencias', 'success');
    return { ok: true, cambios: 0, reporte: [] };
  }

  // Persistir
  if (typeof saveAnimalesDB === 'function') saveAnimalesDB(rawAnim);
  else localStorage.setItem('e5m_animals', JSON.stringify(rawAnim));
  saveDB(true);
  if (typeof renderLotes === 'function') renderLotes();
  replaceTableInRailway('lots', db.lots || []);

  console.log('[Reparar] Cambios aplicados:\n' + reporte.join('\n'));
  if (!silencioso) {
    alert('Reparación completa:\n\n' + reporte.join('\n') + '\n\nLos cambios se sincronizaron al servidor.');
  }
  try { auditLog('repair', 'animals', 0, 'Reparación animales/conteo: ' + reporte.length + ' cambios'); } catch(e){}
  return { ok: true, cambios: reporte.length, reporte: reporte };
}


function deleteLot(idOrCode) {
  // v1.8.24: buscar por code primero (único), id como fallback
  var lot = db.lots.find(function(l){ return l.code === idOrCode; });
  if (!lot) lot = db.lots.find(function(l){ return String(l.id) === String(idOrCode); });
  if (!lot) return;
  // FIX v1.4.35 BUG-LOT-2: validar referencias antes de borrar. Antes deleteLot eliminaba el lot
  // pero dejaba huérfanos en e5m_animals, rotation_history, pesajes, treatments, sales, etc.
  // Esos registros quedaban sin lote padre y causaban bugs de render + crecimiento sin control
  // del localStorage.
  var code = lot.code;
  var refs = [];
  var animalsCount = 0;
  try {
    var rawAnim = JSON.parse(localStorage.getItem('e5m_animals') || '{}');
    animalsCount = (rawAnim[code] || []).length;
  } catch(e){}
  if (animalsCount > 0) refs.push(animalsCount + ' animales en cache');
  if ((lot.animal_count || 0) > 0) refs.push(lot.animal_count + ' cabezas registradas');
  var rotCount = (db.rotation_history || []).filter(function(r){ return r.lot_code === code; }).length;
  if (rotCount > 0) refs.push(rotCount + ' rotaciones');
  var pesCount = (db.pesajes || []).filter(function(p){ return p.lot_code === code; }).length;
  if (pesCount > 0) refs.push(pesCount + ' pesajes');
  var trCount = (db.treatments || []).filter(function(t){ return t.lot_code === code; }).length;
  if (trCount > 0) refs.push(trCount + ' tratamientos');
  var saleCount = (db.sales || []).filter(function(s){ return s.lot_code === code || (s.lot_codes||[]).indexOf(code) >= 0; }).length;
  if (saleCount > 0) refs.push(saleCount + ' ventas');
  var bajaCount = (db.bajas || []).filter(function(b){ return b.lot_code === code; }).length;
  if (bajaCount > 0) refs.push(bajaCount + ' bajas');
  var cgCount = (db.compras_ganado || []).filter(function(c){
    return c.lot_code === code || (c.lote_destinos||[]).indexOf(code) >= 0;
  }).length;
  if (cgCount > 0) refs.push(cgCount + ' compras de ganado');

  if (refs.length > 0) {
    // Lote con datos: pedir doble confirmación con detalle
    var detalle = refs.join(', ');
    if (!confirm('⚠ ATENCIÓN: El lote "' + code + '" tiene datos asociados:\n\n' + detalle + '\n\nEliminarlo dejará registros huérfanos en el sistema. Se recomienda:\n• Si el lote fue vendido: márcalo como vendido en lugar de borrarlo\n• Si fue por error y no tiene actividad: borrar es seguro\n\n¿Borrar de todas formas?')) return;
    if ((lot.animal_count || 0) > 0 || animalsCount > 0) {
      if (!confirm('SEGUNDA CONFIRMACIÓN: el lote todavía tiene animales activos. Los animales NO se eliminarán del sistema, pero quedarán huérfanos (sin lote padre). ¿Estás seguro?')) return;
    }
  } else {
    if (!confirm('¿Eliminar este lote?')) return;
  }
  // v1.8.24: borrar por code (único). trackDeletion sigue usando el id real del lote encontrado.
  trackDeletion(lot.id, 'lots');
  db.lots = db.lots.filter(function(l){ return l.code !== code; });
  saveDB(true); renderLotes();
  replaceTableInRailway('lots', db.lots || []);
  renderDashboard();
  try { auditLog('delete', 'lots', lot.id, 'Eliminado lote "' + code + '"' + (refs.length ? ' con datos: ' + refs.join(', ') : '')); } catch(e){}
  toast('Lote eliminado','warning');
}

// Animales pendientes a agregar al nuevo lote
var _lotNewAnimals = [];

function addLotAnimal() {
  var idInput = document.getElementById('lot-new-animal-id');
  var razaSel = document.getElementById('lot-new-animal-raza');
  var pesoInput = document.getElementById('lot-new-animal-peso');
  var id = (idInput.value||'').trim();
  if(!id){ toast('Ingresa un ID de animal','error'); return; }
  // Verificar duplicado
  if(_lotNewAnimals.find(function(a){ return a.id===id; })){ toast('El ID '+id+' ya esta en la lista','error'); return; }
  var raza = razaSel ? razaSel.value : '';
  var peso = parseFloat(pesoInput ? pesoInput.value : '') || null;
  _lotNewAnimals.push({id:id, raza:raza, peso:peso, pesajes: peso?[{fecha:localDate(), peso:peso}]:[]});
  idInput.value='';
  if(pesoInput) pesoInput.value='';
  renderLotAnimalList();
  idInput.focus();
}

function removeLotAnimal(id) {
  _lotNewAnimals = _lotNewAnimals.filter(function(a){ return a.id!==id; });
  renderLotAnimalList();
}

function clearLotAnimals() {
  _lotNewAnimals = [];
  renderLotAnimalList();
}

function renderLotAnimalList() {
  var el = document.getElementById('lot-animal-list');
  var badge = document.getElementById('lot-animal-count-badge');
  var empty = document.getElementById('lot-animal-list-empty');
  if(badge) badge.textContent = '('+_lotNewAnimals.length+')';
  if(!el) return;
  if(!_lotNewAnimals.length) {
    el.innerHTML = '<div id="lot-animal-list-empty" style="padding:16px;text-align:center;color:var(--muted);font-size:12px">Sin animales agregados. Ingresa ID y presiona + Add o Enter.</div>';
    return;
  }
  el.innerHTML = _lotNewAnimals.map(function(a, i){
    return '<div style="display:flex;align-items:center;gap:10px;padding:6px 12px;border-bottom:1px solid rgba(48,54,61,.3);font-size:12px">'+
      '<span style="font-family:DM Mono,monospace;font-weight:700;color:var(--amber2);min-width:70px">'+a.id+'</span>'+
      '<span style="color:var(--muted);min-width:50px">'+a.raza+'</span>'+
      '<span style="font-family:DM Mono,monospace;min-width:70px">'+(a.peso?a.peso+' kg':'-')+'</span>'+
      '<button onclick="removeLotAnimal(\'' + a.id + '\')" style="margin-left:auto;background:none;border:none;color:var(--red);cursor:pointer;font-size:14px;padding:0 4px">&times;</button>'+
    '</div>';
  }).join('');
}

// v1.8.81: reuso de nombres de lote — al chocar con un code existente (activo o vendido),
// agrega sufijo año-mes para distinguir campañas (Tropa 3 -> Tropa 3 2026-06). No toca lotes ya creados.
function _uniqueLotCode(base, dateStr) {
  base = String(base || '').trim();
  if (!base) return base;
  var lots = db.lots || [];
  function _ex(c){ return lots.some(function(l){ return String(l.code||'').trim().toUpperCase() === String(c).trim().toUpperCase(); }); }
  if (!_ex(base)) return base;
  var d = dateStr ? new Date(String(dateStr) + 'T00:00:00') : new Date();
  if (isNaN(d.getTime())) d = new Date();
  var ym = d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0');
  var cand = base + ' ' + ym;
  if (!_ex(cand)) return cand;
  var n = 2;
  while (n < 100 && _ex(base + ' ' + ym + ' (' + n + ')')) n++;
  return base + ' ' + ym + ' (' + n + ')';
}

function saveLot() {
  var code = (document.getElementById('lot-code')||{}).value;
  if(code) code = code.trim();
  if(!code){ toast('Ingresa un codigo para el lote','error'); return; }
  if(db.lots.find(function(l){ return l.code===code; })){
    var _uniqL = _uniqueLotCode(code, (document.getElementById('lot-entry')||{}).value || localDate());
    if(!confirm('Ya existe un lote "'+code+'".\n\nPara no mezclarlo con el anterior, se creará como:\n\n    '+_uniqL+'\n\n¿Continuar?')){ return; }
    code = _uniqL;
  }
  // FIX v1.4.34: no permitir fechas futuras
  var lotEntryVal = (document.getElementById('lot-entry')||{}).value||localDate();
  if(!validateNotFuture(lotEntryVal, 'fecha de ingreso')) return;

  var totalAnimals = _lotNewAnimals.length;
  var avgWeight = null;
  if(totalAnimals > 0) {
    var conPeso = _lotNewAnimals.filter(function(a){ return a.peso; });
    if(conPeso.length > 0) avgWeight = Math.round(conPeso.reduce(function(s,a){ return s+a.peso; },0)/conPeso.length*10)/10;
  }

  var newLot = {
    id: db.next_ids.lot++,
    code: code,
    category: (document.getElementById('lot-category')||{}).value||'novillo',
    breed: (document.getElementById('lot-breed-sel')||{value:''}).value,
    paddock: (document.getElementById('lot-paddock-sel')||{value:''}).value,
    animal_count: totalAnimals || 0,
    avg_weight: avgWeight,
    entry_date: lotEntryVal,
    status: 'active',
    notes: (document.getElementById('lot-notes')||{}).value||''
  };
  // Validar capacidad del potrero
  if (newLot.paddock && totalAnimals > 0) {
    var potreroCap = getPotreroCapacity(newLot.paddock);
    if (potreroCap && totalAnimals > potreroCap) {
      toast('Potrero "' + newLot.paddock + '" tiene capacidad para ' + potreroCap + ' animales. Intentas ingresar ' + totalAnimals, 'error');
      db.next_ids.lot--; return;
    }
  }
  db.lots.push(newLot);
  // v1.4.104: garantizar entry en rotation_history si el lote tiene paddock
  _ensureRotationEntry(newLot, { reason: 'Lote creado desde Desktop' });

  // Guardar animales en e5m_animals si se ingresaron
  if(totalAnimals > 0) {
    var animalesDB = getAnimalesDB();
    animalesDB[code] = _lotNewAnimals.map(function(a){
      return { id:a.id, raza:a.raza, pesajes:a.pesajes||[] };
    });
    saveAnimalesDB(animalesDB);
    // FIX continuidad: forzar animal_count = animales reales antes del push
    // (defensivo contra cualquier race entre saveAnimalesDB y bulk-push)
    newLot.animal_count = animalesDB[code].length;
    // Pushear animales normalizados a Railway
    var animalesNorm = {};
    animalesNorm[code] = animalesDB[code].map(function(a){
      return { animal_id:a.id, breed:a.raza, pesajes:a.pesajes };
    });
    var apiUrl = getApiUrl();
    var token = localStorage.getItem('e5m_api_token') || '';
    // Merge con animales existentes antes de pushear
    var existingRaw = {};
    try { existingRaw = JSON.parse(localStorage.getItem('e5m_animals')||'{}'); } catch(e){}
    var allAnimalsNorm = {};
    Object.keys(existingRaw).forEach(function(lc){
      allAnimalsNorm[lc] = (existingRaw[lc]||[]).map(function(a){
        return { animal_id:a.animal_id||a.id||'', breed:a.breed||a.raza||'', pesajes:a.pesajes||[] };
      });
    });
    fetch(apiUrl+'/bulk-push', {
      method:'POST',
      headers:{'Content-Type':'application/json','Authorization':'Bearer '+token},
      body: JSON.stringify({table:'animals', records: allAnimalsNorm})
    }).catch(function(){});
  }

  _lotNewAnimals = [];
  saveDB(true); closeModal('modal-lot'); renderLotes(); renderDashboard();
  toast('Lote '+code+' creado'+(totalAnimals?' con '+totalAnimals+' animales':''),'success');
  try { auditLog('create', 'lots', newLot.id, _summarizeRecord('lots', newLot)); } catch(e){}
}

