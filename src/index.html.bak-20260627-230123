function renderActividadLote() {
  var lotSel = document.getElementById('actividad-filter-lot');
  if (lotSel) {
    var curVal = lotSel.value;
    lotSel.innerHTML = '<option value="">Todos los lotes</option>';
    var d2 = typeof db !== 'undefined' ? db : {};
    (d2.lots||[]).forEach(function(l){
      var o = document.createElement('option');
      o.value = l.code;
      o.textContent = l.code + ' - ' + (l.paddock||'');
      lotSel.appendChild(o);
    });
    lotSel.value = curVal;
  }
  var filterLot  = (document.getElementById('actividad-filter-lot')||{}).value||'';
  var filterType = (document.getElementById('actividad-filter-type')||{}).value||'';
  var all = [];
  var d = typeof db !== 'undefined' ? db : {};
  if (!filterType || filterType==='curacion') {
    (d.treatments||[]).forEach(function(r){
      if(filterLot && r.lot_code!==filterLot) return;
      all.push({date:r.applied_at||r.created_at||'',created_at:r.created_at||'',tag:'CUR',color:'var(--red)',
        title:r.product_name+' - '+r.count+' animales - '+r.total+' '+r.unit,
        sub:r.diagnosis||'',lot:r.lot_code,by:r.by||''});
    });
  }
  if (!filterType || filterType==='pesaje') {
    (d.pesajes||[]).forEach(function(r){
      if(filterLot && r.lot_code!==filterLot) return;
      var esVentaP = r.tipo==='venta'||r.nota==='Peso al momento de venta';
      var tituloP = esVentaP
        ? 'Pesaje venta — Animal '+(r.animal_id||'?')+' — '+(r.peso||'?')+' kg'
        : 'Pesaje: '+(r.avg_weight||'?')+' kg prom - '+(r.animal_count||'?')+' animales';
      var subP = esVentaP ? 'Peso registrado al momento de venta' : '';
      all.push({date:r.date,created_at:r.created_at||'',tag:esVentaP?'PES-V':'PES',color:esVentaP?'var(--green)':'var(--amber2)',
        title:tituloP,
        sub:(r.min_weight?'Min: '+r.min_weight+' / Max: '+r.max_weight+' kg':''),
        lot:r.lot_code,by:r.by||''});
    });
  }
  if (!filterType || filterType==='agua') {
    var eMap={lleno:'OK Lleno',medio:'Medio',bajo:'Bajo',seco:'Seco',roto:'Roto'};
    (d.agua||[]).forEach(function(r){
      if(filterLot && r.lot_code!==filterLot) return;
      all.push({date:r.date,created_at:r.created_at||'',tag:'H2O',color:'var(--blue)',
        title:'Agua: '+(eMap[r.estado]||r.estado),
        sub:r.obs||'',lot:r.lot_code,by:r.by||''});
    });
  }
  if (!filterType || filterType==='sal') {
    (d.sal||[]).forEach(function(r){
      if(filterLot && r.lot_code!==filterLot) return;
      all.push({date:r.date,created_at:r.created_at||'',tag:'SAL',color:'var(--muted)',
        title:'Sal: '+(r.qty||0)+' kg'+(r.tipo?' - '+r.tipo:''),
        sub:r.obs||'',lot:r.lot_code,by:r.by||''});
    });
  }
  if (!filterType || filterType==='conteo') {
    (d.conteo||[]).forEach(function(r){
      if(filterLot && r.lot_code!==filterLot) return;
      var diff=r.diff||0;
      all.push({date:r.date,created_at:r.created_at||'',tag:'CNT',color:'var(--purple)',
        title:'Conteo: '+r.counted+' cab. (sistema: '+r.ref+') Dif: '+(diff>0?'+':'')+diff,
        sub:r.obs||'',lot:r.lot_code,by:r.by||'',diff:diff});
    });
  }
  if (!filterType || filterType==='parto') {
    (d.partos||[]).forEach(function(r){
      if(filterLot && r.lot_code!==filterLot) return;
      all.push({date:r.date,ca:r.created_at||r.date,tag:'PAR',color:'var(--green)',
        title:'Parto: '+(r.sexo==='macho'?'Macho':'Hembra')+(r.peso?' '+r.peso+' kg':'')+' - '+(r.estado||''),
        sub:(r.cria_id?'Arete: '+r.cria_id:'')+(r.obs?' '+r.obs:''),
        lot:r.lot_code,by:r.by||''});
    });
  }
  if (!filterType || filterType==='alimento') {
    (d.alimento||[]).forEach(function(r){
      if(filterLot && r.lot_code!==filterLot) return;
      all.push({date:r.date,created_at:r.created_at||'',tag:'ALI',color:'var(--green)',
        title:'Alimento: '+((r.tipo||'').replace(/_/g,' '))+' - '+(r.qty||0)+' kg',
        sub:r.obs||'',lot:r.lot_code,by:r.by||''});
    });
  }
  if (!filterType || filterType==='movimiento') {
    (d.activities||[]).filter(function(a){return a.type==='movimiento';}).forEach(function(r){
      if(filterLot && r.lot!==filterLot) return;
      all.push({date:r.date,created_at:r.created_at||r.date||'',tag:'MOV',color:'var(--amber2)',
        title:r.desc||'Movimiento de lote',
        sub:'',lot:r.lot||'',by:r.employee||''});
    });
  }
  if (!filterType || filterType==='baja') {
    (d.bajas||[]).forEach(function(r){
      if(filterLot && r.lot_code!==filterLot) return;
      var ventaInfo = r.venta_registrada ? ' — ✓ Carne vendida Bs.'+(r.venta_total||0) : r.venta_carne ? ' — ⏳ Venta carne pendiente' : '';
      all.push({date:r.fecha,created_at:r.created_at||'',tag:'BAJA',color:'var(--red)',
        title:'🪦 Baja: Animal #'+(r.animal_id||'?')+' — '+(r.causa||'desconocida')+(r.ultimo_peso?' — '+r.ultimo_peso+' kg':''),
        sub:(r.obs||'')+ventaInfo,lot:r.lot_code,by:r.by||''});
    });
  }
  if (!filterType || filterType==='mantenimiento') {
    (d.maintenance||[]).forEach(function(r){
      all.push({date:r.date,created_at:r.created_at||r.date||'',tag:'MANT',color:'var(--blue)',
        title:'🔧 '+(r.desc||'Mantenimiento')+(r.equipo?' — '+r.equipo:''),
        sub:(r.cost?'Bs.'+r.cost+' ':'')+(r.who?'('+r.who+') ':'')+(r.status||'')+(r.location?' · '+r.location:''),lot:r.location||'',by:r.who||r.by||''});
    });
  }
  all.sort(function(a,b){ return (b.created_at||b.fecha||b.date||'').localeCompare(a.created_at||a.fecha||a.date||''); });
  var el = document.getElementById('actividad-lote-list');
  if (!el) return;
  if (!all.length) {
    el.innerHTML = '<div style="text-align:center;padding:32px;color:var(--muted);font-size:12px">Sin actividad'+(filterLot?' para lote '+filterLot:'')+'</div>';
    return;
  }
  el.innerHTML = '';
  all.forEach(function(r) {
    var row = document.createElement('div');
    row.style.cssText = 'display:flex;gap:12px;padding:10px 16px;border-bottom:1px solid rgba(48,54,61,.3);font-size:12px;align-items:flex-start';
    var diffStyle = (r.diff !== undefined) ? (r.diff < 0 ? ';color:var(--red)' : r.diff > 0 ? ';color:var(--blue)' : '') : '';
    var safeTitle = (r.title||r.titulo||'').replace(/&/g,'&amp;').replace(/</g,'&lt;');
    var safeSub = (r.sub||'') ? (r.sub||'').replace(/&/g,'&amp;').replace(/</g,'&lt;') : '';
    row.innerHTML =
      '<div style="font-size:9px;font-weight:700;color:'+r.color+';background:rgba(0,0,0,.2);padding:2px 5px;border-radius:4px;flex-shrink:0;margin-top:2px;font-family:DM Mono,monospace">'+r.tag+'</div>'+
      '<div style="flex:1;min-width:0">'+
        '<div style="font-weight:500;color:var(--text)'+diffStyle+'">'+safeTitle+'</div>'+
        (safeSub?'<div style="color:var(--muted);margin-top:2px">'+safeSub+'</div>':'')+
        '<div style="color:var(--muted);font-size:10px;margin-top:3px">'+
          ((r.lot||r.lote)?'<span style="color:var(--amber2);background:rgba(212,160,23,.08);padding:1px 6px;border-radius:3px;margin-right:6px">'+r.lot+'</span>':'')+
          (function(){var src=r.by||r.empleado||'';var sc={Desktop:'#6366F1',Campo:'#22C55E',Auto:'#9CA3AF'};var c=sc[src]||(src.indexOf('WhatsApp')===0?'#25D366':'#9CA3AF');return src?'<span style="font-size:9px;padding:1px 5px;border-radius:3px;background:'+c+';color:#fff;font-weight:600;margin-right:4px">'+escH(src)+'</span>':'';})()+ fmtDT(r.created_at||r.date||'')+
        '</div>'+
      '</div>';
    el.appendChild(row);
  });
}

function showLotesTab(tabId, btn) {
  // v1.7.1: la sub-pestaña Partos dentro de Lotes está deprecada — gestión movida a 💞 Reproducción > Partos.
  // Si algo intenta abrirla (deeplink, restore de estado), redirigir a la lista principal.
  if (tabId === 'lotes-tab-partos') {
    var listBtn = document.getElementById('lotes-tab-list-btn');
    return showLotesTab('lotes-tab-list', listBtn);
  }
  var allTabs = ['lotes-tab-list','lotes-tab-pesajes','lotes-tab-agua','lotes-tab-sal','lotes-tab-conteo','lotes-tab-partos','lotes-tab-alimento','lotes-tab-animales','lotes-tab-bajas','lotes-tab-historial','lotes-tab-rotacion','lotes-tab-actividad','lotes-tab-params'];
  allTabs.forEach(function(id){
    var el=document.getElementById(id);
    if(el) el.style.display = id===tabId ? 'block' : 'none';
  });
  document.querySelectorAll('[id$="-btn"][id^="lotes-tab"]').forEach(function(b){ b.classList.remove('active'); });
  if(btn) btn.classList.add('active');
  if(tabId==='lotes-tab-params' && typeof renderParams==='function') renderParams();
  if(tabId==='lotes-tab-pesajes' && typeof renderPesajesFromAnimales==='function') renderPesajesFromAnimales();
  if(tabId==='lotes-tab-animales' && typeof renderAnimalesLote==='function') renderAnimalesLote();
  if(tabId==='lotes-tab-bajas' && typeof renderBajasDesktop==='function') renderBajasDesktop();
  if(tabId==='lotes-tab-historial' && typeof renderHistorialAnimales==='function') renderHistorialAnimales();
  if(tabId==='lotes-tab-actividad' && typeof renderActividadLote==='function') renderActividadLote();
  var subTypes = {
    'lotes-tab-agua':'agua','lotes-tab-sal':'sal','lotes-tab-conteo':'conteo',
    'lotes-tab-partos':'partos','lotes-tab-alimento':'alimento'
  };
  if(subTypes[tabId] && typeof SUBMODULE_CONFIG!=='undefined' && typeof populateSubmoduleLots==='function') {
    var type = subTypes[tabId];
    if(SUBMODULE_CONFIG[type]) {
      populateSubmoduleLots(SUBMODULE_CONFIG[type].id_prefix);
      if(typeof renderSubmodule==='function') renderSubmodule(type);
    }
  }
  // v1.4.113: tab Sal incluye dashboards (stats, charts, donut por tipo)
  if (tabId === 'lotes-tab-sal' && typeof renderSalDashboards === 'function') {
    try { renderSalDashboards(); } catch(e){ console.warn('[showLotesTab] renderSalDashboards err', e); }
  }
}
function today(){var d=new Date();return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0');}
function localDate(d){d=d||new Date();return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0');}

// FIX v1.4.34: helper para validar que una fecha de transacción no sea futura.
// Retorna true si OK, false si es futura (y muestra toast al usuario).
// Uso típico al inicio de funciones save: if (!validateNotFuture(fechaValor, 'venta')) return;
function validateNotFuture(dateStr, fieldLabel){
  if (!dateStr) return true;   // si está vacío, otra validación se encarga
  try {
    var t = today();
    if (String(dateStr) > t) {
      var msg = 'No se pueden registrar fechas futuras' + (fieldLabel ? ' (' + fieldLabel + ')' : '') + '. Hoy es ' + t + '.';
      if (typeof toast === 'function') toast(msg, 'error');
      else alert(msg);
      return false;
    }
  } catch(e){}
  return true;
}
