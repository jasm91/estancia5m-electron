function bpPreview() {
  var text = (document.getElementById('bp-text') || {}).value || '';
  _bpParsed = parseBulkData(text);
  var info = document.getElementById('bp-preview-info');
  var tbl = document.getElementById('bp-preview-table');
  var btn = document.getElementById('bp-confirm-btn');
  var statsEl = document.getElementById('bp-stats');
  if (!_bpParsed.length) {
    if (info) { info.textContent = 'Pegá datos para previsualizar'; info.style.color = 'var(--muted)'; }
    if (tbl) tbl.innerHTML = '';
    if (statsEl) statsEl.style.display = 'none';
    if (btn) { btn.disabled = true; btn.textContent = 'Agregar animales'; }
    return;
  }

  // v1.4.90: clasificar cada item — valido / advertencia / error
  // Reglas:
  //   ERROR     → no se va a guardar (ID duplicado de otro animal ya marcado, exceso de tope en MC)
  //   ADVERTENCIA → se guarda pero requiere atención (peso fuera de rango, sin peso, etc.)
  //   VALIDO    → todo OK
  // El comportamiento de guardado es el que ya estaba: en MC trunca al tope, en CG/newlot agrega todo.
  var tope = null;
  var espacioRestante = null;
  if (_bpContext === 'mc' && typeof _mcLoteCuarentena !== 'undefined' && _mcLoteCuarentena) {
    tope = _mcLoteCuarentena.animal_count || 0;
    var yaMarcadosCount = (typeof _mcAnimals !== 'undefined') ? _mcAnimals.length : 0;
    espacioRestante = Math.max(0, tope - yaMarcadosCount);
  }

  // IDs ya existentes (según contexto) para detectar duplicados
  var existingIds = {};
  if (_bpContext === 'newlot' && typeof _lotNewAnimals !== 'undefined') {
    _lotNewAnimals.forEach(function(a){ existingIds[String(a.id)] = true; });
  } else if (_bpContext === 'mc' && typeof _mcAnimals !== 'undefined') {
    _mcAnimals.forEach(function(a){ existingIds[String(a.id)] = true; });
  } else if (_bpContext === 'cg' && typeof _cgAnimals !== 'undefined') {
    _cgAnimals.forEach(function(a){ existingIds[String(a.id)] = true; });
  }

  // Clasificar cada item
  _bpParsed.forEach(function(a, idx){
    a._estado = 'valido';
    a._notas = [];
    var id = String(a.id || '').trim();
    if (!id) {
      a._estado = 'error';
      a._notas.push('ID vacío');
      return;
    }
    // Duplicado con existentes
    if (existingIds[id]) {
      a._estado = 'error';
      a._notas.push('ID ya está en la lista');
      return;
    }
    // Exceso de tope (solo MC)
    if (_bpContext === 'mc' && espacioRestante != null && idx >= espacioRestante) {
      a._estado = 'error';
      a._notas.push('Excede cantidad de compra');
      return;
    }
    // Sin peso
    if (!a.peso || a.peso <= 0) {
      a._estado = 'advertencia';
      a._notas.push('Sin peso');
    } else {
      // Rangos sospechosos
      if (a.peso < 50) { a._estado = 'advertencia'; a._notas.push('Peso bajo (<50kg)'); }
      else if (a.peso > 700) { a._estado = 'advertencia'; a._notas.push('Peso alto (>700kg)'); }
    }
    // Sin raza (solo advertencia leve, no bloquea)
    if (!a.raza) {
      if (a._estado === 'valido') a._estado = 'advertencia';
      a._notas.push('Sin raza');
    }
  });

  var validos = _bpParsed.filter(function(a){ return a._estado === 'valido'; });
  var advertencias = _bpParsed.filter(function(a){ return a._estado === 'advertencia'; });
  var errores = _bpParsed.filter(function(a){ return a._estado === 'error'; });
  // Items que sí se van a guardar (válidos + advertencias)
  var guardables = validos.concat(advertencias);

  // Estadísticas para info (solo de los guardables, porque los errores no entran)
  var pesoTotal = guardables.reduce(function(s, a){ return s + (a.peso||0); }, 0);
  var conPeso = guardables.filter(function(a){ return a.peso > 0; }).length;
  var pesoProm = conPeso ? Math.round(pesoTotal / conPeso * 10) / 10 : 0;

  // Validación contra tope (alerta principal, mantenida del original)
  var validacion = '';
  if (_bpContext === 'mc' && tope != null) {
    if (_bpParsed.length > espacioRestante) {
      validacion = '<div style="margin-top:6px;padding:8px 10px;background:rgba(231,76,60,.08);border:1px solid rgba(231,76,60,.3);border-radius:6px;font-size:11px;color:var(--red)">⚠ Estás pegando ' + _bpParsed.length + ' animales pero solo quedan ' + espacioRestante + ' por marcar. Se guardarán los primeros ' + espacioRestante + ' y se descartarán ' + (_bpParsed.length - espacioRestante) + '.</div>';
    } else if (_bpParsed.length < espacioRestante) {
      validacion = '<div style="margin-top:6px;padding:6px 10px;background:rgba(212,160,23,.06);border:1px solid rgba(212,160,23,.2);border-radius:6px;font-size:11px;color:var(--amber2)">ℹ Quedarán ' + (espacioRestante - _bpParsed.length) + ' animales sin marcar (podés guardar parcial).</div>';
    } else {
      validacion = '<div style="margin-top:6px;padding:6px 10px;background:rgba(57,211,83,.06);border:1px solid rgba(57,211,83,.2);border-radius:6px;font-size:11px;color:var(--green)">✓ Cantidad exacta — coincide con lo esperado.</div>';
    }
  } else if (_bpContext === 'cg') {
    var cantEsperadaEl = document.getElementById('cg-cuarentena-count');
    var cantEsperada = cantEsperadaEl ? parseInt(cantEsperadaEl.value) || 0 : 0;
    if (cantEsperada > 0) {
      if (_bpParsed.length === cantEsperada) {
        validacion = '<div style="margin-top:6px;padding:6px 10px;background:rgba(57,211,83,.06);border:1px solid rgba(57,211,83,.2);border-radius:6px;font-size:11px;color:var(--green)">✓ Cantidad coincide con la compra (' + cantEsperada + ').</div>';
      } else {
        validacion = '<div style="margin-top:6px;padding:8px 10px;background:rgba(231,76,60,.08);border:1px solid rgba(231,76,60,.3);border-radius:6px;font-size:11px;color:var(--red)">⚠ La compra dice ' + cantEsperada + ' animales pero estás pegando ' + _bpParsed.length + '. Revisá si falta algo.</div>';
      }
    }
  }

  // v1.4.90: renderizar 3 stats cards (consistente con modal-import-pesajes)
  if (statsEl) {
    statsEl.style.display = 'grid';
    statsEl.innerHTML =
      '<div style="background:rgba(57,211,83,.06);border:1px solid rgba(57,211,83,.25);border-radius:6px;padding:10px 12px;text-align:center">' +
        '<div style="font-size:18px;font-weight:700;color:var(--green);font-family:DM Mono,monospace">' + validos.length + '</div>' +
        '<div style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em">Válidos</div>' +
      '</div>' +
      '<div style="background:rgba(255,149,0,.06);border:1px solid rgba(255,149,0,.25);border-radius:6px;padding:10px 12px;text-align:center">' +
        '<div style="font-size:18px;font-weight:700;color:var(--amber2);font-family:DM Mono,monospace">' + advertencias.length + '</div>' +
        '<div style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em">Advertencias</div>' +
      '</div>' +
      '<div style="background:rgba(231,76,60,.06);border:1px solid rgba(231,76,60,.25);border-radius:6px;padding:10px 12px;text-align:center">' +
        '<div style="font-size:18px;font-weight:700;color:var(--red);font-family:DM Mono,monospace">' + errores.length + '</div>' +
        '<div style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em">Errores</div>' +
      '</div>';
  }

  if (info) {
    info.innerHTML = '<strong>' + guardables.length + ' a guardar</strong> · Peso total: <strong>' + pesoTotal.toLocaleString() + ' kg</strong> · Promedio: <strong>' + pesoProm + ' kg</strong>' + validacion;
    info.style.color = 'var(--text)';
  }

  // Tabla preview con colores por estado (consistente con modal-import-pesajes)
  if (tbl) {
    var rows = _bpParsed.slice(0, 50).map(function(a, i){
      var bg = '', estadoHtml = '';
      if (a._estado === 'error') {
        bg = 'rgba(231,76,60,.05)';
        estadoHtml = '<span style="color:var(--red);font-size:10px">❌ ' + escH(a._notas.join(', ')) + '</span>';
      } else if (a._estado === 'advertencia') {
        bg = 'rgba(255,149,0,.04)';
        estadoHtml = '<span style="color:var(--amber2);font-size:10px">⚠ ' + escH(a._notas.join(', ')) + '</span>';
      } else {
        estadoHtml = '<span style="color:var(--green);font-size:10px">✅ OK</span>';
      }
      return '<tr style="background:' + bg + ';border-bottom:1px solid var(--bor)">' +
        '<td style="padding:5px 8px;color:var(--muted)">' + (i+1) + '</td>' +
        '<td style="padding:5px 8px;font-family:DM Mono,monospace;color:var(--amber2);font-weight:600">' + escH(a.id || '—') + '</td>' +
        '<td style="padding:5px 8px">' + escH(a.raza||'—') + '</td>' +
        '<td style="padding:5px 8px;font-family:DM Mono,monospace;text-align:right">' + (a.peso || '—') + (a.peso ? ' kg' : '') + '</td>' +
        '<td style="padding:5px 8px">' + estadoHtml + '</td>' +
      '</tr>';
    }).join('');
    var more = _bpParsed.length > 50 ? '<div style="padding:6px;text-align:center;color:var(--muted);font-size:10px">... y ' + (_bpParsed.length-50) + ' más</div>' : '';
    tbl.innerHTML = '<table class="tbl" style="font-size:11px;width:100%"><thead><tr>' +
      '<th style="text-align:left">#</th>' +
      '<th style="text-align:left">ID</th>' +
      '<th style="text-align:left">Raza</th>' +
      '<th style="text-align:right">Peso</th>' +
      '<th style="text-align:left">Estado</th>' +
      '</tr></thead><tbody>' + rows + '</tbody></table>' + more;
  }

  // Botón habilitado solo si hay algo guardable (válido o con advertencia)
  if (btn) {
    btn.disabled = guardables.length === 0;
    if (guardables.length > 0) {
      btn.textContent = 'Agregar ' + guardables.length + ' animal' + (guardables.length === 1 ? '' : 'es');
    } else {
      btn.textContent = 'Sin animales válidos';
    }
  }
}

function bpConfirm() {
  if (!_bpParsed.length) { toast('Nada que agregar', 'error'); return; }
  // v1.4.90: solo guardar items que pasen la clasificación (valido + advertencia).
  // Los items con _estado === 'error' se descartan (ID vacío, duplicado, exceso de tope).
  var guardables = _bpParsed.filter(function(a){
    return a._estado === 'valido' || a._estado === 'advertencia';
  });
  if (!guardables.length) { toast('No hay animales válidos para guardar', 'error'); return; }
  var descartados = _bpParsed.length - guardables.length;

  if (_bpContext === 'cg') {
    // Modo Compra Ganado — agregar a _cgAnimals
    if (typeof _cgAnimals === 'undefined') { toast('Modo no inicializado', 'error'); return; }
    var razaDefault = (document.getElementById('cg-raza') || {}).value || '';
    guardables.forEach(function(a){
      _cgAnimals.push({
        id: a.id || '',
        peso: a.peso || 0,
        raza: a.raza || razaDefault
      });
    });
    if (typeof renderCGAnimalsTable === 'function') renderCGAnimalsTable();
    if (typeof calcCGTotal === 'function') calcCGTotal();
    var msgCg = guardables.length + ' animales agregados a la compra';
    if (descartados > 0) msgCg += ' (' + descartados + ' descartados por errores)';
    toast(msgCg, 'success');
  } else if (_bpContext === 'mc') {
    // Modo Marcar Cuarentena — agregar a _mcAnimals con tope si lo hay
    if (typeof _mcAnimals === 'undefined') { toast('Modo no inicializado', 'error'); return; }
    var tope = _mcLoteCuarentena ? (_mcLoteCuarentena.animal_count || 9999) : 9999;
    var espacio = Math.max(0, tope - _mcAnimals.length);
    if (espacio === 0) { toast('Ya alcanzaste la cantidad de la compra', 'warning'); return; }
    // Los errores ya fueron filtrados arriba, incluyendo los que exceden tope.
    // Por seguridad, igual aplicamos slice por si llega algún caso edge.
    var aAgregar = guardables.slice(0, espacio);
    var categoriaDefault = _mcLoteCuarentena ? _mcLoteCuarentena.category : '';
    var razaDefaultMc = _mcLoteCuarentena ? _mcLoteCuarentena.breed : '';
    aAgregar.forEach(function(a){
      _mcAnimals.push({
        id: a.id || '',
        peso: a.peso || (_mcLoteCuarentena ? _mcLoteCuarentena.avg_weight || 0 : 0),
        categoria: categoriaDefault,
        raza: a.raza || razaDefaultMc
      });
    });
    if (typeof renderMCAnimals === 'function') renderMCAnimals();
    var msg = aAgregar.length + ' animales agregados al marcaje';
    if (descartados > 0) msg += ' (' + descartados + ' descartados por errores)';
    toast(msg, 'success');
  } else if (_bpContext === 'newlot') {
    // Modo Nuevo Lote — agregar a _lotNewAnimals
    // Los duplicados ya fueron marcados como error y filtrados arriba, pero hacemos doble check
    // por compatibilidad con el comportamiento anterior.
    if (typeof _lotNewAnimals === 'undefined') { toast('Modo no inicializado', 'error'); return; }
    var razaDefaultLot = (document.getElementById('lot-new-animal-raza') || {}).value || '';
    var fechaLot = (document.getElementById('lot-entry') || {}).value || localDate();
    var existentes = {};
    _lotNewAnimals.forEach(function(a){ existentes[a.id] = true; });

    var agregados = 0;
    guardables.forEach(function(a){
      var idStr = String(a.id || '').trim();
      if (!idStr) return;
      if (existentes[idStr]) return;  // defensive: ya marcado como error pero por las dudas
      _lotNewAnimals.push({
        id: idStr,
        raza: a.raza || razaDefaultLot,
        peso: a.peso || null,
        pesajes: a.peso ? [{ fecha: fechaLot, peso: a.peso }] : []
      });
      existentes[idStr] = true;
      agregados++;
    });

    if (typeof renderLotAnimalList === 'function') renderLotAnimalList();
    var msg2 = agregados + ' animales agregados al lote nuevo';
    if (descartados > 0) msg2 += ' (' + descartados + ' descartados por errores)';
    toast(msg2, 'success');
  } else {
    toast('Contexto desconocido', 'error');
    return;
  }
  closeBulkPaste();
}

function parseBulkData(text) {
  var lines = text.trim().split(/\r?\n/);
  var animals = [];
  var seen = {};
  lines.forEach(function(line) {
    // Skip empty lines and headers
    if (!line.trim()) return;
    var lower = line.toLowerCase();
    if (lower.indexOf('id') >= 0 && (lower.indexOf('raza') >= 0 || lower.indexOf('breed') >= 0 || lower.indexOf('peso') >= 0)) return;
    // Parse: support comma, semicolon, tab separators
    var parts = line.split(/[,;]+/).map(function(s) { return s.trim(); });
    if (parts.length < 2) return;
    // Try to find ID, Raza, Peso
    var id = '', raza = '', peso = 0;
    // If first column is a row number (1,2,3...) skip it
    var startCol = 0;
    if (parts.length >= 3 && /^\d+$/.test(parts[0]) && parseInt(parts[0]) < 1000 && parts.length >= 4) {
      startCol = 1; // Skip row number
    }
    id = String(parts[startCol] || '').trim();
    if (!id || id === '0') return;
    raza = String(parts[startCol + 1] || '').trim();
    // Find peso - first numeric value after ID
    for (var i = startCol + 1; i < parts.length; i++) {
      var num = parseFloat(parts[i]);
      if (!isNaN(num) && num > 50 && num < 2000) { peso = num; break; }
    }
    // Dedup
    if (seen[id]) return;
    seen[id] = true;
    animals.push({ id: id, raza: raza, peso: peso });
  });
  return animals;
}

function previewBulkAnimals() {
  var text = document.getElementById('bulk-paste-area').value;
  _bulkAnimals = parseBulkData(text);
  var count = document.getElementById('bulk-preview-count');
  var table = document.getElementById('bulk-preview-table');
  var btn = document.getElementById('bulk-confirm-btn');
  if (!_bulkAnimals.length) {
    count.textContent = 'No se encontraron animales válidos';
    count.style.color = 'var(--red)';
    table.innerHTML = '';
    btn.disabled = true;
    return;
  }
  count.textContent = _bulkAnimals.length + ' animales encontrados';
  count.style.color = 'var(--green)';
  btn.disabled = false;
  // Check for duplicates with existing animals
  var lotCode = (document.getElementById('bulk-lot-select') || {}).value || '';
  var animalesDB = getAnimalesDB();
  var existing = {};
  Object.keys(animalesDB).forEach(function(lot) {
    (animalesDB[lot] || []).forEach(function(a) {
      existing[String(a.id || a.animal_id || '')] = lot;
    });
  });
  var avgPeso = _bulkAnimals.reduce(function(s, a) { return s + a.peso; }, 0) / _bulkAnimals.length;
  table.innerHTML = '<div style="font-size:11px;color:var(--muted);margin-bottom:6px">Peso promedio: <strong>' + Math.round(avgPeso * 10) / 10 + ' kg</strong></div>' +
    '<table class="tbl" style="font-size:11px"><thead><tr><th>#</th><th>ID</th><th>Raza</th><th>Peso</th><th>Estado</th></tr></thead><tbody>' +
    _bulkAnimals.map(function(a, i) {
      var dup = existing[a.id];
      var estado = dup ? '<span style="color:var(--amber)">⚠ Ya existe en ' + dup + '</span>' : '<span style="color:var(--green)">✓ Nuevo</span>';
      return '<tr><td>' + (i + 1) + '</td><td style="font-family:DM Mono;font-weight:700;color:var(--amber2)">' + escH(a.id) + '</td><td>' + escH(a.raza) + '</td><td style="font-family:DM Mono">' + (a.peso || '—') + ' kg</td><td>' + estado + '</td></tr>';
    }).join('') +
