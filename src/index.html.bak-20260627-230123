function bulkRangePreview() {
  var mn = parseFloat(document.getElementById('bulk-range-min').value) || 0;
  var mx = parseFloat(document.getElementById('bulk-range-max').value) || 999999;
  if (!mn && !mx) {
    document.getElementById('bulk-range-preview').textContent = 'Ingresá un rango';
    return;
  }
  var count = 0;
  document.querySelectorAll('.bulk-row-check').forEach(function(cb) {
    var w = parseFloat(cb.getAttribute('data-weight')) || 0;
    if (w >= mn && w <= mx) count++;
  });
  document.getElementById('bulk-range-preview').textContent =
    count + ' animal' + (count === 1 ? '' : 'es') + ' en rango ' + mn + ' – ' + mx + ' kg';
}

function bulkApplyRange() {
  var mn = parseFloat(document.getElementById('bulk-range-min').value) || 0;
  var mx = parseFloat(document.getElementById('bulk-range-max').value) || 999999;
  var nSelected = 0;
  document.querySelectorAll('.bulk-row-check').forEach(function(cb) {
    var w = parseFloat(cb.getAttribute('data-weight')) || 0;
    if (w >= mn && w <= mx) {
      if (!cb.checked) {
        cb.checked = true;
        bulkToggleRow(cb);
      }
      nSelected++;
    }
  });
  closeModal('modal-bulk-range');
  toast(nSelected + ' animales seleccionados por rango ' + mn + '–' + mx + ' kg', 'success');
}

// ── Abrir modal Mover Selección ──
function openBulkMover() {
  var keys = Object.keys(window._bulkSelected);
  if (keys.length === 0) { toast('Seleccioná al menos un animal', 'error'); return; }

  // Validar mismo lote origen
  var lots = {};
  keys.forEach(function(k){ lots[window._bulkSelected[k].lot] = true; });
  var uniqLots = Object.keys(lots);
  if (uniqLots.length > 1) {
    toast('Los animales seleccionados son de ' + uniqLots.length + ' lotes diferentes. Mové de a un lote por vez.', 'error');
    return;
  }
  var fromLot = uniqLots[0];

  // Stats
  var weights = keys.map(function(k){ return window._bulkSelected[k].weight || 0; }).filter(function(w){return w>0;});
  var avg = weights.length ? (weights.reduce(function(a,b){return a+b;},0) / weights.length).toFixed(1) : '-';
  var total = weights.length ? Math.round(weights.reduce(function(a,b){return a+b;},0)).toLocaleString() : '-';

  document.getElementById('bulk-mover-count').textContent = keys.length + ' animales';
  document.getElementById('bulk-mover-from').textContent = fromLot;
  document.getElementById('bulk-mover-avg').textContent = avg + ' kg';
  document.getElementById('bulk-mover-total').textContent = total + ' kg';
  document.getElementById('bulk-mover-date').value = localDate();
  document.getElementById('bulk-mover-motivo').value = '';

  // Populate destination select (solo lotes activos, distintos del origen)
  // v1.4.77: aplicar mismo criterio "activo" que el resto del sistema
  // (excluye vendidos, marcados, cuarentena, inactivos)
  var toLotSel = document.getElementById('bulk-to-lot');
  toLotSel.innerHTML = '<option value="">Seleccionar lote...</option>';
  (db.lots||[]).forEach(function(l) {
    if (l.code === fromLot) return;
    var isActive = !l.status || l.status === 'activo' || l.status === 'active';
    if (!isActive) return;
    var o = document.createElement('option');
    o.value = l.code;
    o.textContent = l.code + ' · ' + (l.category||'') + ' · ' + (l.paddock||'sin potrero') + ' · ' + (l.animal_count||0) + ' cab';
    toLotSel.appendChild(o);
  });

  // Sugerir código nuevo lote
  var suggested = fromLot + '-A';
  var existingCodes = (db.lots||[]).map(function(l){ return l.code; });
  var letter = 'A';
  while (existingCodes.indexOf(fromLot + '-' + letter) >= 0) {
    letter = String.fromCharCode(letter.charCodeAt(0) + 1);
  }
  suggested = fromLot + '-' + letter;
  document.getElementById('bulk-new-code').value = suggested;

  // Heredar categoría/raza del lote origen
  var fromLotObj = (db.lots||[]).find(function(l){return l.code === fromLot;});
  if (fromLotObj) {
    var catEl = document.getElementById('bulk-new-cat');
    if (fromLotObj.category) {
      var opt = Array.from(catEl.options).find(function(o){return o.value === fromLotObj.category;});
      if (opt) catEl.value = fromLotObj.category;
    }
    document.getElementById('bulk-new-raza').value = fromLotObj.raza || '';
  }

  // Populate potrero select — v1.4.78: usar fuente correcta de potreros
  // Los potreros viven en localStorage.e5m_params (params.potreros[]),
  // no en db.potreros (campo inexistente). Soportar tanto strings como objetos.
  var paddockSel = document.getElementById('bulk-new-paddock');
  paddockSel.innerHTML = '<option value="">Seleccionar potrero...</option>';
  try {
    var params = JSON.parse(localStorage.getItem('e5m_params') || '{}');
    var potreros = params.potreros || [];
    potreros.forEach(function(p) {
      var nombre = (typeof p === 'string') ? p : (p.name || p.nombre || '');
      var ha = (typeof p === 'object' && (p.area_ha || p.ha)) ? (p.area_ha || p.ha) : null;
      if (!nombre) return;
      var o = document.createElement('option');
      o.value = nombre;
      o.textContent = nombre + (ha ? ' (' + ha + ' ha)' : '');
      paddockSel.appendChild(o);
    });
  } catch(e) {
    console.warn('No se pudieron cargar potreros:', e);
  }

  // Reset tabs al estado por defecto (existente)
  bulkSwitchDest('existing', document.querySelector('.bulk-dest-tab[data-dest="existing"]'));

  openModal('modal-bulk-mover');
}

function bulkSwitchDest(mode, btn) {
  document.querySelectorAll('.bulk-dest-tab').forEach(function(b){ b.classList.remove('active'); });
  if (btn) btn.classList.add('active');
  document.getElementById('bulk-dest-existing').style.display = mode === 'existing' ? 'block' : 'none';
  document.getElementById('bulk-dest-new').style.display = mode === 'new' ? 'block' : 'none';
  document.getElementById('modal-bulk-mover').setAttribute('data-mode', mode);
}

// ── Confirmar movimiento batch ──
function confirmarBulkMover() {
  var mode = document.getElementById('modal-bulk-mover').getAttribute('data-mode') || 'existing';
  var date = document.getElementById('bulk-mover-date').value || localDate();
  var motivo = document.getElementById('bulk-mover-motivo').value || '';
  if (!validateNotFuture(date, 'fecha de movimiento')) return;

  var keys = Object.keys(window._bulkSelected);
  if (keys.length === 0) { toast('Sin selección', 'error'); return; }
  var fromLot = window._bulkSelected[keys[0]].lot;

  var toLot;
  if (mode === 'existing') {
    toLot = document.getElementById('bulk-to-lot').value;
    if (!toLot) { toast('Seleccioná lote destino', 'error'); return; }
  } else {
    // Crear nuevo lote
    var newCode = (document.getElementById('bulk-new-code').value || '').trim();
    var newCat = document.getElementById('bulk-new-cat').value;
    var newRaza = document.getElementById('bulk-new-raza').value || '';
    var newPaddock = document.getElementById('bulk-new-paddock').value || '';
    if (!newCode) { toast('Falta código del nuevo lote', 'error'); return; }
    if ((db.lots||[]).some(function(l){return l.code === newCode;})) {
      var _uniqBm = _uniqueLotCode(newCode, localDate());
      if(!confirm('Ya existe un lote "'+newCode+'".\n\nPara no mezclarlo, se creará como:\n\n    '+_uniqBm+'\n\n¿Continuar?')){ return; }
      newCode = _uniqBm;
    }
    if (!newPaddock) { toast('Seleccioná un potrero destino', 'error'); return; }

    // v1.8.24: asignar id único (antes se creaba sin id → causaba lotes con id=undefined
    // y colisiones al sincronizar). Los lotes se referencian por code, pero el id debe ser único.
    if (!db.next_ids) db.next_ids = {};
    if (!db.next_ids.lot || db.next_ids.lot <= (db.lots||[]).reduce(function(m,l){var n=parseInt(l.id);return (!isNaN(n)&&n>m)?n:m;},0)) {
      db.next_ids.lot = (db.lots||[]).reduce(function(m,l){var n=parseInt(l.id);return (!isNaN(n)&&n>m)?n:m;},0) + 1;
    }
    var newLot = {
      id: db.next_ids.lot++,
      code: newCode,
      category: newCat,
      raza: newRaza,
      paddock: newPaddock,
      animal_count: 0,
      avg_weight: 0,
      entry_date: date,
      status: 'activo',
      provider: ((db.lots||[]).find(function(l){return l.code === fromLot;})||{}).provider || '',
      _createdViaBulkMove: true
    };
    db.lots.push(newLot);
    toLot = newCode;
    // v1.4.105: garantizar entry en rotation_history para el lote destino creado en bulk-move
    if (typeof _ensureRotationEntry === 'function') {
      _ensureRotationEntry(newLot, { reason: 'Lote creado desde Bulk-move de animales', allowEmpty: true });
    }
  }

  // Verificar capacidad
  var capCheck = (typeof checkPotreroCapacity === 'function') ? checkPotreroCapacity(toLot, keys.length) : {ok:true};
  if (!capCheck.ok) {
    if (!confirm(capCheck.msg + '\n\n¿Continuar de todos modos?')) return;
  }

  // Ejecutar el movimiento animal por animal
  var adb = getAnimalesDB();
  var fromAnimals = adb[fromLot] || [];
  if (!adb[toLot]) adb[toLot] = [];

  var batchId = 'bm-' + Date.now();
  var movedIds = [];
  var movedAnimals = [];

  keys.forEach(function(k) {
    var sel = window._bulkSelected[k];
    var animalIdx = fromAnimals.findIndex(function(a){ return (a.id||a.animal_id||'').toString() === sel.id.toString(); });
    if (animalIdx < 0) return;
    var animal = fromAnimals[animalIdx];

    // Stamp del movimiento granular en el animal
    if (!animal._movements) animal._movements = [];
    animal._movements.push({
      date: date,
      from_lot: fromLot,
      to_lot: toLot,
      weight_at_move: sel.weight || 0,
      batch_id: batchId,
      reason: motivo
    });

    // Sacar del origen, agregar al destino
    fromAnimals.splice(animalIdx, 1);
    adb[toLot].push(animal);
    movedIds.push(sel.id);
    movedAnimals.push({id: sel.id, weight: sel.weight});
  });

  adb[fromLot] = fromAnimals;
  saveAnimalesDB(adb);

  // Actualizar animal_count de los lotes
  var fromLotObj = db.lots.find(function(l){ return l.code === fromLot; });
  var toLotObj = db.lots.find(function(l){ return l.code === toLot; });
  if (fromLotObj) fromLotObj.animal_count = Math.max(0, (fromLotObj.animal_count||0) - movedIds.length);
  if (toLotObj) toLotObj.animal_count = (toLotObj.animal_count||0) + movedIds.length;

  // Recalcular peso promedio del lote destino
  if (toLotObj) {
    var allTo = adb[toLot] || [];
    var pesos = allTo.map(function(a){
      var ps = a.pesajes || [];
      return ps.length ? ps[ps.length-1].peso : 0;
    }).filter(function(w){return w>0;});
    if (pesos.length) toLotObj.avg_weight = Math.round(pesos.reduce(function(s,p){return s+p;},0) / pesos.length * 10) / 10;
  }

  // Guardar movimiento como evento (resumen)
  if (!db.animal_movements) db.animal_movements = [];
  var weights = movedAnimals.map(function(m){return m.weight;}).filter(function(w){return w>0;});
  var avgW = weights.length ? weights.reduce(function(a,b){return a+b;},0) / weights.length : 0;
  db.animal_movements.push({
    id: batchId,
    date: date,
    from_lot: fromLot,
    to_lot: toLot,
    animal_ids: movedIds,
    count: movedIds.length,
    avg_weight: Math.round(avgW * 10) / 10,
    total_kg: Math.round(weights.reduce(function(a,b){return a+b;},0)),
    reason: motivo,
    created_new_lot: mode === 'new',
    by: _desktopAuthor(),
    source: 'desktop',
    created_at: new Date().toISOString()
  });

  // ════════════════════════════════════════════════════════════════
  // v1.4.83 — TRANSFERENCIA CONTABLE DUAL EN KARDEX (ponderada por peso)
  // ════════════════════════════════════════════════════════════════
  // 1) Calcular el "precio por kg" del lote origen
  //    precio_kg_origen = (DEBE origen - HABER previo) / total_kg_origen_pre_movimiento
  //
  //    Caso A: el lote origen tiene compra registrada → usar su DEBE
  //    Caso B: el lote origen vino a su vez de una transferencia → tiene su propio cost_origin
  //            o transferencias previas. En ambos casos, basta con sumar todo el DEBE neto.
  // 2) Costo a transferir = precio_kg_origen × suma_pesos_animales_movidos
  // 3) Crear 2 asientos en Kardex con tipo='transferencia_interna':
  //    - Salida del lote origen (HABER)
  //    - Entrada al lote destino (DEBE)
  // 4) Setear cost_origin en el lote destino para mostrar el linaje
  if (!db.kardex) db.kardex = [];

  // Calcular DEBE neto del lote origen (compras + transferencias entrantes - transferencias salientes ya hechas)
  var lotMovsOrigen = db.kardex.filter(function(m){return m.lote === fromLot;});
  var debeOrigen = lotMovsOrigen.filter(function(m){
    return m.tipo==='compra' || m.tipo==='ajuste' ||
           (m.tipo==='transferencia_interna' && m._transfer_role==='entrada');
  }).reduce(function(s,m){return s+(m.total||0);},0);
  var haberOrigenTransfers = lotMovsOrigen.filter(function(m){
    return m.tipo==='transferencia_interna' && m._transfer_role==='salida';
  }).reduce(function(s,m){return s+(m.total||0);},0);
  var costoNetoOrigen = debeOrigen - haberOrigenTransfers;

  // Total kg del lote origen ANTES del movimiento (incluye los que se van a mover)
  // adb[fromLot] ya tiene a los animales removidos; tenemos que sumar también los movedAnimals.
  var pesosRemainingOrigen = (adb[fromLot] || []).map(function(a){
    var ps = a.pesajes || [];
    return ps.length ? ps[ps.length-1].peso : 0;
  }).filter(function(w){return w>0;});
  var pesosMovidos = movedAnimals.map(function(m){return m.weight;}).filter(function(w){return w>0;});
  var totalKgOrigenPre = pesosRemainingOrigen.concat(pesosMovidos).reduce(function(s,w){return s+w;},0);
  var totalKgMovidos = pesosMovidos.reduce(function(s,w){return s+w;},0);

  var precioKgOrigen = 0;
  var costoTransferir = 0;
  if (totalKgOrigenPre > 0 && costoNetoOrigen > 0) {
    precioKgOrigen = costoNetoOrigen / totalKgOrigenPre;
    costoTransferir = Math.round(precioKgOrigen * totalKgMovidos);
  }

  // Solo crear asientos si hay costo real que transferir (lote origen sin compra registrada = 0)
  if (costoTransferir > 0) {
    var precioPorCabTransfer = movedIds.length > 0 ? Math.round(costoTransferir / movedIds.length) : 0;

    // ASIENTO 1: salida del origen (HABER)
    db.kardex.push({
      id: 'kx-bm-out-' + Date.now(),
      lote: fromLot,
      tipo: 'transferencia_interna',
      _transfer_role: 'salida',
      _batch_id: batchId,
      fecha: date,
      cabezas: movedIds.length,
      precio: precioPorCabTransfer,
      total: costoTransferir,
      desc: '↑ Transferencia a ' + toLot + ' — ' + movedIds.length + ' cab · ' +
            Math.round(totalKgMovidos) + ' kg · ' + precioKgOrigen.toFixed(2) + ' Bs/kg' +
            (motivo ? ' (' + motivo + ')' : ''),
      by: 'Desktop',
      created_at: new Date().toISOString(),
      auto: true
    });

    // ASIENTO 2: entrada al destino (DEBE)
    db.kardex.push({
      id: 'kx-bm-in-' + (Date.now() + 1),
      lote: toLot,
      tipo: 'transferencia_interna',
      _transfer_role: 'entrada',
      _batch_id: batchId,
      fecha: date,
      cabezas: movedIds.length,
      precio: precioPorCabTransfer,
      total: costoTransferir,
      desc: '↓ Origen contable: ' + fromLot + ' — ' + movedIds.length + ' cab · ' +
            Math.round(totalKgMovidos) + ' kg · ' + precioKgOrigen.toFixed(2) + ' Bs/kg' +
            (motivo ? ' (' + motivo + ')' : ''),
      by: 'Desktop',
      created_at: new Date().toISOString(),
      auto: true
    });

    // Marcar linaje contable en el lote destino
    if (toLotObj) {
      toLotObj.cost_origin = {
        from_lot: fromLot,
        date: date,
        cost: costoTransferir,
        animal_count: movedIds.length,
        total_kg: Math.round(totalKgMovidos),
        precio_kg: Math.round(precioKgOrigen * 100) / 100,
        batch_id: batchId
      };
    }
  } else {
    // Sin costo origen: solo dejar nota informativa en el destino (no contable)
    console.log('[bulk-move] Lote origen ' + fromLot + ' sin costo registrado — se omite asiento contable');
  }

  saveDB();

  // v1.4.81: Sync con server vía /api/animal-movements/bulk (endpoint real).
  // Validamos respuesta para garantizar consistencia. Si el server detecta error
  // (ej: animal_ids missing en el server, conflict en lot code), avisamos al usuario.
  // El estado local YA está aplicado; el server hace su propia validación independiente.
  // v1.4.84: enviar animals_payload (datos completos de los animales) para tolerar
  // desincronización: si el server no tiene los animales locales aún (race condition
  // con bulk-push de animales), los acepta del payload sin fallar.
  try {
    var apiUrl = getApiUrl();
    var token = localStorage.getItem('e5m_api_token') || '';
    var newLotData = mode === 'new' ? db.lots.find(function(l){return l.code === toLot;}) : null;

    // Armar payload de animales con datos completos para el server (fallback)
    var adbSnapshot = getAnimalesDB();
    var allAdbFromOrigin = (adbSnapshot[toLot] || []).filter(function(a) {
      return movedIds.indexOf(String(a.id || a.animal_id || '')) >= 0;
    });
    var animalsPayload = allAdbFromOrigin.map(function(a) {
      return {
        animal_id: String(a.id || a.animal_id || ''),
        breed: a.breed || a.raza || '',
        pesajes: a.pesajes || [],
        _movements: a._movements || []
      };
    });

    fetch(apiUrl + '/animal-movements/bulk', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': 'Bearer ' + token,
        'x-app-version': '1.4.84'
      },
      body: JSON.stringify({
        batch_id: batchId,
        from_lot: fromLot,
        to_lot: toLot,
        animal_ids: movedIds,
        animals_payload: animalsPayload,  // v1.4.84: datos completos para fallback
        date: date,
        motivo: motivo,
        created_new_lot: mode === 'new',
        new_lot_data: newLotData,
        by: _desktopAuthor(),
        source: 'desktop'
      })
    })
      .then(function(r) {
        return r.json().then(function(d){ return { ok: r.ok, status: r.status, data: d }; });
      })
      .then(function(res) {
        if (res.ok && res.data && res.data.ok) {
          // Marcar el batch como sincronizado en local
          var localBatch = (db.animal_movements || []).find(function(m){return m.id === batchId;});
          if (localBatch) {
            localBatch._synced = true;
            localBatch._synced_at = new Date().toISOString();
            saveDB();
          }
          if (res.data.missing_ids && res.data.missing_ids.length > 0) {
            console.warn('[bulk-move] Server reportó animales no encontrados:', res.data.missing_ids);
            toast('⚠ ' + res.data.missing_ids.length + ' animales no se encontraron en el server (sync parcial)', 'error');
          } else {
            console.log('[bulk-move] Sync OK con server. Batch ' + batchId + ' confirmado.');
          }
        } else {
          var errMsg = (res.data && res.data.error) || ('HTTP ' + res.status);
          console.error('[bulk-move] Sync FAILED:', errMsg, res.data);
          toast('⚠ Movimiento local OK, pero sync al server falló: ' + errMsg + '. Se reintentará.', 'error');
          // Marcar para reintento
          var localBatch2 = (db.animal_movements || []).find(function(m){return m.id === batchId;});
          if (localBatch2) {
            localBatch2._sync_error = errMsg;
            localBatch2._sync_retry_pending = true;
            saveDB();
          }
        }
      })
      .catch(function(err) {
        console.error('[bulk-move] Network error:', err);
        toast('⚠ Movimiento local OK. Sin conexión: se sincronizará automáticamente.', 'success');
        // Marcar para reintento cuando vuelva la conexión
        var localBatch3 = (db.animal_movements || []).find(function(m){return m.id === batchId;});
        if (localBatch3) {
          localBatch3._sync_retry_pending = true;
          saveDB();
        }
      });
  } catch(e) {
    console.error('[bulk-move] Unexpected error in sync block:', e);
  }

  // Activity log
  if (typeof addActivity === 'function') {
    addActivity('Sistema', 'movimiento', toLot,
      'Movimiento batch: ' + movedIds.length + ' animales de ' + fromLot + ' a ' + toLot +
      (mode === 'new' ? ' (lote nuevo)' : '') +
      (motivo ? ' — ' + motivo : ''),
      date);
  }

  toast('✓ ' + movedIds.length + ' animales movidos a ' + toLot, 'success');
  closeModal('modal-bulk-mover');
  bulkClearSelection();
  renderAnimalesLote();
  if (typeof renderLotes === 'function') renderLotes();
  if (typeof renderHistorialAnimales === 'function') renderHistorialAnimales();
}

// ═══ BAJAS (MUERTES) ═══
function renderBajasDesktop() {
  if (!db.bajas) db.bajas = [];
  var now = new Date();
  var curYear = now.getFullYear();

  // Populate lot filter — v1.8.8: solo lotes que tienen al menos una baja registrada
  // (antes mostraba TODOS los lotes, incluyendo cuarentena/vendidos/fusionados sin bajas)
  var lotSel = document.getElementById('bajas-lot-filter');
  if (lotSel && lotSel.options.length <= 1) {
    // Códigos de lote que aparecen en db.bajas
    var lotesConBajas = {};
    (db.bajas || []).forEach(function(b){ if (b.lot_code) lotesConBajas[b.lot_code] = true; });
    // Ordenar y agregar solo esos, con su categoría desde db.lots si existe
    Object.keys(lotesConBajas).sort().forEach(function(code){
      var lot = (db.lots||[]).find(function(l){ return l.code === code; });
      var cat = lot ? (lot.category || '') : '';
      var o = document.createElement('option');
      o.value = code;
      o.textContent = code + (cat ? ' - ' + cat : '');
      lotSel.appendChild(o);
    });
  }
  // Populate year filter
  var yearSel = document.getElementById('bajas-year-filter');
  if (yearSel && yearSel.options.length === 0) {
    for (var y = curYear; y >= 2024; y--) {
      var o = document.createElement('option'); o.value = y; o.textContent = y;
      if (y === curYear) o.selected = true;
      yearSel.appendChild(o);
    }
  }

  var selLot = (lotSel||{}).value || '';
  var selYear = parseInt((yearSel||{}).value || curYear);
  var prefix = selYear + '-';

  var registros = db.bajas.filter(function(b) {
    if (!(b.fecha||'').startsWith(prefix)) return false;
    if (selLot && b.lot_code !== selLot) return false;
    return true;
  });

  var totalBajas = registros.length;
  var kgPerdidos = registros.reduce(function(s,b){ return s + (b.ultimo_peso||0); },0);
  var activeLots = db.lots.filter(function(l){ var s=(l.status||'').toLowerCase(); return s!=='sold'&&s!=='vendido'; });
  var totalCab = activeLots.reduce(function(s,l){ return s + (l.animal_count||0); },0);
  var mortPct = totalCab > 0 ? Math.round(totalBajas / (totalCab + totalBajas) * 1000) / 10 : 0;

  // Causas
  var causas = {};
  registros.forEach(function(b){ var c = b.causa||'desconocida'; causas[c] = (causas[c]||0) + 1; });
  var topCausa = Object.keys(causas).sort(function(a,b){ return causas[b]-causas[a]; })[0] || '-';
  var pendientesVenta = registros.filter(function(b){ return b.venta_carne && !b.venta_registrada; }).length;
  var ventasRealizadas = registros.filter(function(b){ return b.venta_registrada; });
  var kgVendidosCarne = ventasRealizadas.reduce(function(s,b){ return s + (b.venta_kg||0); },0);
  var ingresoCarne = ventasRealizadas.reduce(function(s,b){ return s + (b.venta_total||0); },0);

  var subEl = document.getElementById('bajas-subtitle');
  if (subEl) subEl.textContent = selYear + ' · ' + totalBajas + ' bajas · ' + mortPct + '% mortandad' + (selLot ? ' · Lote ' + selLot : '');

  var kpiEl = document.getElementById('bajas-kpis');
  if (kpiEl) {
    kpiEl.innerHTML = [
      {l:'Total Bajas',v:totalBajas,c:totalBajas?'var(--red)':'var(--green)'},
      {l:'Kg Perdidos',v:Math.round(kgPerdidos).toLocaleString()+' kg',c:'var(--red)'},
      {l:'% Mortandad',v:mortPct+'%',c:mortPct>3?'var(--red)':mortPct>0?'var(--amber2)':'var(--green)'},
      {l:'Causa Principal',v:topCausa,c:'var(--muted)'},
      {l:'Venta Pendiente',v:pendientesVenta,c:pendientesVenta?'var(--amber2)':'var(--green)'},
      {l:'Carne Vendida',v:kgVendidosCarne?kgVendidosCarne+' kg':'—',c:'var(--green)'},
      {l:'Ingreso Carne',v:ingresoCarne?'Bs.'+Math.round(ingresoCarne).toLocaleString():'—',c:'var(--green)'},
    ].map(function(k){
      return '<div style="background:var(--sur);border:1px solid var(--bor);border-radius:10px;padding:10px 14px">'+
        '<div style="font-size:9px;color:var(--muted);font-weight:700;text-transform:uppercase;margin-bottom:2px">'+k.l+'</div>'+
        '<div style="font-size:18px;font-weight:800;color:'+k.c+';font-family:DM Mono,monospace">'+k.v+'</div></div>';
    }).join('');
  }

