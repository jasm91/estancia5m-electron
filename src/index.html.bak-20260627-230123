    var estado;
    if (a.gmd == null) estado = '<span class="tag tag-muted" style="display:inline-block;padding:2px 8px;border-radius:10px;font-family:\'DM Mono\',monospace;font-size:10px;background:var(--bg2,#161616);color:var(--muted)">Sin datos</span>';
