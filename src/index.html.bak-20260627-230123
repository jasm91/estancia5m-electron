// LLUVIAS
// ══════════════════════════════════════════════════
var _PLUVIO_COLORS = ['var(--green)','var(--blue)','var(--amber2)','var(--red)','var(--purple)','var(--text)'];
var _PLUVIO_DEFAULTS = [
  {key:'campamento_mm',label:'Campamento',color:'var(--green)'},
  {key:'lote4_mm',label:'Lote 4',color:'var(--blue)'},
  {key:'lote27_mm',label:'Lote 27',color:'var(--amber2)'}
];
function getPluvios() {
  try {
    var saved = localStorage.getItem('e5m_pluvios');
    if (saved) {
      var parsed = JSON.parse(saved);
      if (Array.isArray(parsed) && parsed.length) return parsed;
    }
  } catch(e) {}
  return _PLUVIO_DEFAULTS;
}
function savePluvios(list) {
  localStorage.setItem('e5m_pluvios', JSON.stringify(list));
  // FIX v1.4.33: timestamp en clave separada (pluvios es array, no se le puede meter updated_at directo)
  localStorage.setItem('e5m_pluvios_updated_at', new Date().toISOString());
  replaceTableInRailway('pluvios_config', list);
}
var PLUVIOS = getPluvios();
function getLluviaMm(r, pKey) {
  if (r[pKey] !== undefined) return parseFloat(r[pKey]) || 0;
  // Backward compat: old records with just 'mm' → campamento
  if (pKey === 'campamento_mm' && r.mm !== undefined) return parseFloat(r.mm) || 0;
  return 0;
}
function getLluviaAvg(r) {
  var vals = PLUVIOS.map(function(p){ return getLluviaMm(r, p.key); }).filter(function(v){ return v > 0; });
  return vals.length ? Math.round(vals.reduce(function(s,v){return s+v;},0) / vals.length * 10) / 10 : 0;
}
function getLluviaForFilter(r, filter) {
  if (filter === 'todos') return getLluviaAvg(r);
  return getLluviaMm(r, filter);
}

function configPluvios() {
  var pluvios = getPluvios();
