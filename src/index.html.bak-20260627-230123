    var rows = animals.map(function(a, idx) {
      var aid = a.animal_id || a.id || 'N/A';
      var raza = a.breed || a.raza || '-';
      var ps = a.pesajes || [];
      // Peso inicial y peso final (venta)
      var pesoInicial = ps.length ? ps[0].peso : '-';
      var pesoFinal = ps.length ? ps[ps.length-1].peso : '-';
      var fechaIngreso = a.fecha_ingreso || (ps.length ? ps[0].fecha : '-');
      // GMD si hay 2+ pesajes
      var gmd = '-';
      if(ps.length >= 2) {
        var dias = Math.round((new Date(ps[ps.length-1].fecha) - new Date(ps[0].fecha)) / 86400000);
        if(dias > 0) gmd = ((ps[ps.length-1].peso - ps[0].peso) / dias).toFixed(3);
      }
      // Tratamientos del animal
      var tratsAnimal = treats.filter(function(tr){
        return _normalizeTreatmentScope(tr)==='lot' || tr.animal_id===aid;
      }).map(function(tr){return tr.product_name;}).join(', ') || '-';

      return '<tr style="background:'+(idx%2===0?'#f9f9f9':'#fff')+'">'+
        '<td style="padding:5px 8px;border:1px solid #ddd;font-weight:600;color:#8B6914">'+escH(aid)+'</td>'+
        '<td style="padding:5px 8px;border:1px solid #ddd">'+escH(raza)+'</td>'+
        '<td style="padding:5px 8px;border:1px solid #ddd;text-align:center">'+escH(fechaIngreso)+'</td>'+
        '<td style="padding:5px 8px;border:1px solid #ddd;text-align:right">'+pesoInicial+' kg</td>'+
        '<td style="padding:5px 8px;border:1px solid #ddd;text-align:right;font-weight:700">'+pesoFinal+' kg</td>'+
        '<td style="padding:5px 8px;border:1px solid #ddd;text-align:right">'+gmd+(gmd!=='-'?' kg/d':'')+'</td>'+
        '<td style="padding:5px 8px;border:1px solid #ddd;font-size:10px">'+escH(tratsAnimal)+'</td>'+
      '</tr>';
    }).join('');

    animalesHTML = '<h3 style="color:#2E7D32;font-size:13px;margin:20px 0 8px;border-bottom:2px solid #2E7D32;padding-bottom:4px">DETALLE POR ANIMAL ('+animals.length+' cabezas)</h3>'+
      '<table style="width:100%;border-collapse:collapse;font-size:11px">'+
        '<thead><tr style="background:#2E7D32;color:#fff">'+
          '<th style="padding:6px 8px;border:1px solid #ddd;text-align:left">ID Animal</th>'+
          '<th style="padding:6px 8px;border:1px solid #ddd;text-align:left">Raza</th>'+
