function saveProduct() {
  const name = document.getElementById('prod-name').value.trim();
  if(!name){ toast('Ingresa el nombre del producto','error'); return; }
  
  const productData = {
    name: name,
    type: document.getElementById('prod-type').value,
    unit: document.getElementById('prod-unit').value,
    stock_qty: parseFloat(document.getElementById('prod-stock').value) || 0,
    stock_min: parseFloat(document.getElementById('prod-min').value) || 0,
    dose_per_50kg: parseFloat(document.getElementById('prod-dose').value) || null,
    unit_cost: parseFloat(document.getElementById('prod-cost').value) || 0,
    expiry_date: document.getElementById('prod-expiry').value || null,
    supplier: document.getElementById('prod-supplier').value
  };
  
  if (editingProductId !== null) {
    var idx = db.products.findIndex(function(p){ return p.id == editingProductId; });
    if (idx === -1) { toast('Producto no encontrado','error'); return; }
    var _oldProdName = String(db.products[idx].name||'');   // v1.8.68: nombre previo
    db.products[idx] = Object.assign({}, db.products[idx], productData);
    // v1.8.68: los movimientos de Sal y Alimento guardan el producto SOLO por nombre
    // (stock_product, sin product_id) → al renombrar el producto se huerfanaban en el kardex.
    var _prodMig = 0;
    if (_oldProdName && _oldProdName !== name) {
      (db.sal||[]).forEach(function(r){ if((r.stock_product||'')===_oldProdName){ r.stock_product=name; _prodMig++; } });
      (db.alimento||[]).forEach(function(r){ if((r.stock_product||'')===_oldProdName){ r.stock_product=name; _prodMig++; } });
    }
    saveDB(); closeModal('modal-product'); renderStock();
    if (_prodMig) { try { replaceTableInRailway('sal', db.sal||[]); } catch(e){} try { replaceTableInRailway('alimento', db.alimento||[]); } catch(e){} }
    toast(_prodMig ? ('Producto actualizado · '+_prodMig+' registro(s) de sal/alimento migrados') : 'Producto actualizado','success');
  } else {
    db.products.push(Object.assign({ id: db.next_ids.product++ }, productData));
    saveDB(); closeModal('modal-product'); renderStock();
    toast('Producto agregado','success');
  }
  
  editingProductId = null;
}

