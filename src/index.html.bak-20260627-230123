// ═══ #1 PULL AL ARRANQUE: garantizar que el local arranque con datos del server ═══
// Antes de cualquier interacción, hacer pull si hay token + online. Con timeout 8s.
// Si falla por red o timeout, se sigue con cache local (offline-first).

// ══════════════════════════════════════════════════════════════
// v1.8.21 — Detección de sesiones simultáneas (ping/presencia)
// Cada dispositivo pingea cada 60s. Si hay otra sesión activa del
// mismo tenant (ping en últimos 2 min), muestra chip de alerta.
// ══════════════════════════════════════════════════════════════
var _e5mSesionesData = [];

// Identidad estable del dispositivo (generada una vez por instalación)
function _getDeviceId() {
  var id = localStorage.getItem('e5m_device_id');
  if (!id) {
    id = 'dev_' + Math.random().toString(36).slice(2, 10) + Date.now().toString(36).slice(-4);
    localStorage.setItem('e5m_device_id', id);
  }
  return id;
}

// Etiqueta legible: "PC Windows (HOSTNAME)" / "Mac (HOSTNAME)" / "Linux (HOSTNAME)"
function _getDeviceLabel() {
  // Cachear para no recalcular
  var cached = localStorage.getItem('e5m_device_label');
  if (cached) return cached;
  var plat = '', host = '';
  try {
    var os = require('os');
    host = os.hostname() || '';
    plat = process.platform || '';
  } catch(e) {
    // Fallback si no hay acceso a node (navegador)
    plat = (navigator.platform || '').toLowerCase();
  }
  var nombre;
  if (plat === 'win32' || /win/i.test(plat)) nombre = 'PC Windows';
  else if (plat === 'darwin' || /mac/i.test(plat)) nombre = 'Mac';
  else if (/linux/i.test(plat)) nombre = 'Linux';
  else nombre = 'Dispositivo';
  var label = host ? (nombre + ' (' + host + ')') : nombre;
  localStorage.setItem('e5m_device_label', label);
  return label;
}

function _getDevicePlatform() {
  try { return process.platform || ''; } catch(e) { return (navigator.platform || ''); }
}

// Pingea al server y procesa la respuesta
function _e5mPingSesion() {
  var token = (typeof getApiToken === 'function') ? getApiToken() : (localStorage.getItem('e5m_api_token') || '');
  var apiUrl = (typeof getApiUrl === 'function') ? getApiUrl() : (localStorage.getItem('e5m_api_url') || '');
  if (!token || !apiUrl || !navigator.onLine) return;

  fetch(apiUrl + '/ping', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
    body: JSON.stringify({
      device_id: _getDeviceId(),
      label: _getDeviceLabel(),
      platform: _getDevicePlatform()
    })
  })
  .then(function(r) { return r.ok ? r.json() : null; })
  .then(function(data) {
    if (!data) return;
    _e5mSesionesData = data.others || [];
    _e5mRenderSesionChip();
  })
  .catch(function(e) { /* silencioso, reintenta en 60s */ });
}

// v1.8.66: chip "Otra sesión activa" DESACTIVADO por ahora (daba avisos confusos).
// El ping de presencia sigue corriendo (el server conserva el dato); para reactivar
// el chip, poner esta bandera en true.
var E5M_SESSION_CHIP_ENABLED = false;

// Muestra u oculta el chip de alerta según haya otras sesiones
function _e5mRenderSesionChip() {
  var chip = document.getElementById('multi-session-chip');
  var lbl = document.getElementById('multi-session-label');
  if (!chip) return;
  if (!E5M_SESSION_CHIP_ENABLED) { chip.style.display = 'none'; return; }
  var n = _e5mSesionesData.length;
  if (n > 0) {
    chip.style.display = 'inline-flex';
    if (lbl) lbl.textContent = n === 1 ? 'Otra sesión activa' : (n + ' sesiones activas');
  } else {
    chip.style.display = 'none';
  }
}

// Al hacer click en el chip, muestra el detalle de quién está activo
function _mostrarSesionesActivas() {
  if (!_e5mSesionesData.length) {
    if (typeof toast === 'function') toast('No hay otras sesiones activas en este momento', 'info');
    return;
  }
  var lista = _e5mSesionesData.map(function(s) {
    var hace = '';
    try {
      var seg = Math.round((Date.now() - new Date(s.last_seen).getTime()) / 1000);
      hace = seg < 60 ? ('hace ' + seg + 's') : ('hace ' + Math.round(seg/60) + 'min');
    } catch(e) {}
    return '• ' + (s.label || 'Dispositivo') + (hace ? ' — ' + hace : '');
  }).join('\n');
  alert('⚠️ Sesiones activas además de esta:\n\n' + lista +
    '\n\nCuidado al guardar: si dos personas editan a la vez, los cambios se combinan automáticamente pero conviene coordinar para no pisarse.');
}

// Arranque: pingea ya y después cada 60s
(function _e5mIniciarPingSesiones() {
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', _e5mIniciarPingSesiones);
    return;
  }
  // Primer ping a los 3s (dar tiempo a que cargue token/apiUrl)
  setTimeout(_e5mPingSesion, 3000);
  // Luego cada 60s
  setInterval(_e5mPingSesion, 60000);
})();


(function startupPull() {
  // Esperar a que el DOM esté listo y db cargada
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', startupPull);
    return;
  }
  // Bypass si está en post-restore (ya hay flujo dedicado para eso)
  if (sessionStorage.getItem('_post_restore') === '1') return;
  // Bypass si no hay token (primera vez)
  var token = localStorage.getItem('e5m_api_token') || '';
  if (!token) return;
  if (!navigator.onLine) {
    console.log('[StartupPull] Offline, usando cache local');
    return;
  }

  // Esperar 1.5s para que la app cargue lo básico antes de pullear
  setTimeout(function() {
    if (typeof pullFromRailwayDesktop !== 'function') {
      console.warn('[StartupPull] pullFromRailwayDesktop no disponible aún');
      return;
    }
    var lastSync = localStorage.getItem('e5m_last_sync_at') || '';
    console.log('[StartupPull] Última sync local: ' + (lastSync || 'nunca') + ' → trayendo datos del server...');
    setSyncStatus('syncing');
    pullFromRailwayDesktop(false);
  }, 1500);
})();

// v1.8.20: migración — normaliza animales de partos + reconcilia con sus partos.
// Vincula cada parto con su animal (por madre+fecha+lote) y copia cría_id + peso correctos.
(function migrarAnimalesPartoViejos() {
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', migrarAnimalesPartoViejos);
    return;
  }
  // v1.8.38: flag nuevo para que la reconciliación mejorada (matcheo por lote+sexo de crías
  // huérfanas) corra una vez más, aunque la v1820 ya se haya ejecutado.
  if (localStorage.getItem('e5m_migracion_animales_v1838') === 'done') return;
  setTimeout(function() {
    try {
      var animDB = (typeof getAnimalesDB === 'function') ? getAnimalesDB() : null;
      if (!animDB) return;
      var cambios = false;

      // Paso 1: normalizar estructura (id→animal_id, breed, etc.)
      Object.keys(animDB).forEach(function(lotCode){
        var arr = animDB[lotCode];
        if (!Array.isArray(arr)) return;
        arr.forEach(function(a){
          if (!a || typeof a !== 'object') return;
          if (!a.animal_id && a.id) { a.animal_id = a.id; delete a.id; cambios = true; }
          if (!a.breed && a.raza) { a.breed = a.raza; cambios = true; }
        });
      });

      // Paso 2: reconciliar cada parto con su animal (por madre+fecha+lote)
      // Copiar el cría_id y peso correctos del PARTO al ANIMAL (el parto es la fuente de verdad
      // porque César cargó ahí los datos vía modal pesar).
      if (Array.isArray(db.partos)) {
        db.partos.forEach(function(p){
          if (p.estado === 'muerto' || !p.lot_code) return;
          var arr = animDB[p.lot_code];
          if (!Array.isArray(arr)) return;
          // Buscar animal por parto_id, o por madre+fecha (origin parto)
          var a = arr.find(function(x){ return x.parto_id && String(x.parto_id) === String(p.id); });
          if (!a) {
            a = arr.find(function(x){
              return x.origin === 'parto' &&
                     String(x.madre_id||'') === String(p.madre_id||'') &&
                     String(x.entry_date||'') === String(p.date||'');
            });
          }
          // Si no hay origin marcado (animales muy viejos), intentar por raza Torillo/Ternera + madre
          if (!a) {
            a = arr.find(function(x){
              var br = String(x.breed||x.raza||'').toLowerCase();
              return (br === 'torillo' || br === 'ternera') &&
                     String(x.madre_id||'') === String(p.madre_id||'');
            });
          }
          // v1.8.38: último recurso — crías huérfanas con ID placeholder que NO tienen madre_id
          // ni parto_id (partos viejos previos al vínculo). Reconciliar por lote + sexo↔raza:
          // Torillo = cría macho, Ternera = cría hembra. Solo se emparejan crías con ID placeholder
          // (CRIA-XXXXXX-XXX) y se marcan como usadas (_reconciliado) para no asignar el mismo parto dos veces.
          if (!a) {
            var sexoParto = String(p.sexo||'').toLowerCase();
            var razaEsperada = (sexoParto === 'macho' || sexoParto === 'm') ? 'torillo'
                             : (sexoParto === 'hembra' || sexoParto === 'h') ? 'ternera' : '';
            a = arr.find(function(x){
              if (x._reconciliado) return false; // ya emparejada con otro parto
              if (!String(x.animal_id||'').match(/^CRIA-\d{6}(-\d+)?$/)) return false; // v1.8.74: placeholder con o SIN sufijo (saveReproParto genera CRIA-###### sin sufijo)
              var br = String(x.breed||x.raza||'').toLowerCase();
              // matchear por sexo↔raza si hay; si no hay raza, aceptar cualquier placeholder del lote
              return razaEsperada ? (br === razaEsperada) : true;
            });
            if (a) a._reconciliado = true;
          }
          if (a) {
            // Vincular establemente
            if (!a.parto_id) { a.parto_id = p.id; cambios = true; }
            if (!a.origin) { a.origin = 'parto'; cambios = true; }
            // v1.8.38: copiar madre y fecha del parto si faltan (para que no vuelva a quedar huérfana)
            if (!a.madre_id && p.madre_id) { a.madre_id = p.madre_id; cambios = true; }
            if (!a.entry_date && p.date) { a.entry_date = p.date; cambios = true; }
            // Copiar cría_id real del parto (si lo tiene y es distinto del temporal)
            if (p.cria_id && p.cria_id !== 'N/A' && a.animal_id !== p.cria_id) {
              a.animal_id = p.cria_id;
              delete a._needs_id;
              cambios = true;
            }
            // Copiar peso del parto si el animal no lo tiene
            if (p.peso && p.peso > 0) {
              if (!Array.isArray(a.pesajes)) a.pesajes = [];
              var tienePeso = a.pesajes.some(function(pj){ return pj.fecha === p.date; });
              if (!tienePeso) { a.pesajes.push({ fecha: p.date, peso: p.peso }); cambios = true; }
            }
          }
        });
      }

      // v1.8.38 — Paso 2.5: crear el animal faltante para cada parto vivo que NO tenga su
      // cría en e5m_animals. Así cada parto tiene su cabeza real (Animales y Partos quedan
      // sincronizados). Se evita duplicar verificando por parto_id y por cria_id existente.
      if (Array.isArray(db.partos)) {
        db.partos.forEach(function(p){
          if (p.estado === 'muerto' || !p.lot_code) return;
          if (!animDB[p.lot_code]) animDB[p.lot_code] = [];
          var arr = animDB[p.lot_code];
          // ¿Ya existe un animal para este parto? (por parto_id o por cria_id real)
          var yaExiste = arr.some(function(x){
            if (x.parto_id && String(x.parto_id) === String(p.id)) return true;
            if (p.cria_id && p.cria_id !== 'N/A' && String(x.animal_id||'') === String(p.cria_id)) return true;
            return false;
          });
          if (yaExiste) return;
          // Crear el animal-cría
          var sexoP = String(p.sexo||'').toLowerCase();
          var razaCria = (sexoP === 'macho' || sexoP === 'm') ? 'Torillo'
                       : (sexoP === 'hembra' || sexoP === 'h') ? 'Ternera' : '';
          var nuevoAnimalId = (p.cria_id && p.cria_id !== 'N/A')
                            ? p.cria_id
                            : ('CRIA-' + String(Date.now()).slice(-6) + '-' + Math.floor(Math.random()*1000));
          var nuevaCria = {
            animal_id: nuevoAnimalId,
            sexo: p.sexo || '',
            breed: razaCria,
            raza: razaCria,
            madre_id: p.madre_id || '',
            entry_date: p.date || '',
            origin: 'parto',
            parto_id: p.id,
            pesajes: (p.peso && p.peso > 0) ? [{ fecha: p.date, peso: p.peso, tipo: 'nacimiento', nota: 'Peso al nacer' }] : []
          };
          if (!p.cria_id || p.cria_id === 'N/A') nuevaCria._needs_id = true;
          arr.push(nuevaCria);
          cambios = true;
          console.log('[Migración v1.8.38] Cría creada para parto sin animal: ' + nuevoAnimalId + ' en ' + p.lot_code);
        });
      }

      // Paso 3: los que quedaron con N/A y no se pudieron reconciliar → ID temporal
      Object.keys(animDB).forEach(function(lotCode){
        var arr = animDB[lotCode];
        if (!Array.isArray(arr)) return;
        arr.forEach(function(a){
          if (!a || typeof a !== 'object') return;
          var aid = String(a.animal_id || '');
          if (!aid || aid === 'N/A' || aid.toLowerCase() === 'n/a') {
            a.animal_id = 'CRIA-' + String(Date.now()).slice(-6) + '-' + Math.floor(Math.random()*1000);
            a._needs_id = true;
            cambios = true;
          }
        });
      });

      if (cambios) {
        if (typeof saveAnimalesDB === 'function') saveAnimalesDB(animDB);
        // v1.8.38: recalcular animal_count de los lotes desde e5m_animals, para que las crías
        // recién creadas se reflejen en el conteo de cada lote y en el header.
        if (db && Array.isArray(db.lots)) {
          db.lots.forEach(function(lt){
            var anims = animDB[lt.code];
            if (anims && anims.length > 0) {
              lt.animal_count = Math.max(lt.animal_count || 0, anims.length);
            }
          });
          if (typeof saveDB === 'function') try { saveDB(true); } catch(e){}
        }
        console.log('[Migración v1.8.20] Crías de partos reconciliadas con sus animales');
        if (typeof renderAnimalesLote === 'function') try { renderAnimalesLote(); } catch(e){}
        if (typeof renderReproPartos === 'function') try { renderReproPartos(); } catch(e){}
        if (typeof renderLotes === 'function') try { renderLotes(); } catch(e){}
        if (typeof renderTopbarSummary === 'function') try { renderTopbarSummary(); } catch(e){}
      }
      localStorage.setItem('e5m_migracion_animales_v1820', 'done');
      localStorage.setItem('e5m_migracion_animales_v1838', 'done');
    } catch(e) { console.warn('[Migración v1.8.20] error', e); }
  }, 2500);
})();

// v1.8.22: migración — reconstruir cost_origin de lotes que vinieron de cuarentena
// vía marcaje, para que la trazabilidad (Análisis Lote/Histórico) llegue hasta la
// compra inicial. Usa compras_ganado.lote_destinos para reconstruir el vínculo.
(function migrarCostOriginMarcaje() {
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', migrarCostOriginMarcaje);
    return;
  }
  if (localStorage.getItem('e5m_migracion_cost_origin_v1822') === 'done') return;
  setTimeout(function() {
    try {
      if (!Array.isArray(db.compras_ganado) || !Array.isArray(db.lots)) return;
      var cambios = false;
      db.compras_ganado.forEach(function(compra) {
        var cuarLote = compra.lot_code; // lote cuarentena donde entró la compra
        var destinos = compra.lote_destinos || [];
        if (!cuarLote || !destinos.length) return;
        destinos.forEach(function(destCode) {
          var destLot = db.lots.find(function(l) { return l.code === destCode; });
          if (!destLot) return;
          // Solo setear si NO tiene cost_origin con from_lot (no pisar separaciones reales)
          if (destLot.cost_origin && destLot.cost_origin.from_lot) return;
          destLot.cost_origin = {
            from_lot: cuarLote,
            date: compra.marcaje_completo_at ? String(compra.marcaje_completo_at).slice(0,10) : (destLot.entry_date || compra.fecha || ''),
            animal_count: destLot.animal_count || 0,
            total_kg: 0,
            via: 'marcaje',
            compra_id: compra.id || null,
            _reconstruido: true
          };
          cambios = true;
        });
      });
      if (cambios) {
        saveDB(false);
        console.log('[Migración v1.8.22] cost_origin reconstruido desde compras→cuarentena');
        if (typeof renderAnalisisLote === 'function') try { renderAnalisisLote(); } catch(e){}
        if (typeof renderAnalisisHistorico === 'function') try { renderAnalisisHistorico(); } catch(e){}
      }
      localStorage.setItem('e5m_migracion_cost_origin_v1822', 'done');
    } catch(e) { console.warn('[Migración v1.8.22] error', e); }
  }, 3000);
})();

// v1.8.23: migración CRÍTICA — reparar IDs de lote duplicados o faltantes.
// Detectado: CUAR-001 y CUAR-009 compartían id=1; SSD3-C y TEST 123-Flacos con id=undefined.
// Esto rompía operaciones que buscan por id (marcaje, mover, eliminar) porque .find() agarraba
// el lote equivocado. Los lotes se referencian por 'code' en todo el sistema (444 refs vs 0 por id),
// así que reasignar IDs es seguro. Corre cada vez que detecta el problema (no usa flag de "done"
// para que también arregle duplicados que lleguen por sync futuro).
(function repararIdsLotes() {
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', repararIdsLotes);
    return;
  }
  setTimeout(function() {
    try {
      if (!Array.isArray(db.lots) || !db.lots.length) return;
      // Detectar IDs duplicados o faltantes
      var vistos = {};
      var necesitaReparar = false;
      db.lots.forEach(function(l) {
        var id = l.id;
        if (id === undefined || id === null || id === '' || vistos[String(id)]) {
          necesitaReparar = true;
        }
        if (id !== undefined && id !== null && id !== '') vistos[String(id)] = true;
      });
      if (!necesitaReparar) return;

      // Calcular el próximo id libre
      var maxId = db.lots.reduce(function(m, l) {
        var n = parseInt(l.id);
        return (!isNaN(n) && n > m) ? n : m;
      }, 0);
      var nextId = maxId + 1;

      // Reasignar: el primer lote que use cada id conserva el id; los siguientes (o los sin id) reciben uno nuevo
      var usados = {};
      var reparados = [];
      db.lots.forEach(function(l) {
        var id = l.id;
        var idStr = String(id);
        var invalido = (id === undefined || id === null || id === '');
        if (invalido || usados[idStr]) {
          var nuevoId = nextId++;
          reparados.push(l.code + ': ' + (invalido ? 'sin id' : 'id ' + idStr) + ' → ' + nuevoId);
          l.id = nuevoId;
          usados[String(nuevoId)] = true;
        } else {
          usados[idStr] = true;
        }
      });

      // Actualizar el contador para que no vuelva a colisionar
      if (!db.next_ids) db.next_ids = {};
      if (!db.next_ids.lot || db.next_ids.lot <= nextId) db.next_ids.lot = nextId;

      if (reparados.length) {
        saveDB(true); // sync de lotes
        console.log('[Migración v1.8.23] IDs de lote reparados:', reparados);
        if (typeof renderLotes === 'function') try { renderLotes(); } catch(e){}
        if (typeof toast === 'function') toast('Se repararon ' + reparados.length + ' IDs de lote duplicados', 'success');
      }
    } catch(e) { console.warn('[Migración v1.8.23] error', e); }
  }, 3500);
})();


