  db.cuentas.push({
    id:Date.now(),cuenta:cuenta,subcuenta:subcuenta,tipo:tipo,tipo_gasto:tipo,
    fecha:fecha,detalle:detalle,monto:monto,
    by:'Desktop',created_at:new Date().toISOString()
  });
