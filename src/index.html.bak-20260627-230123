function renderWeeklyReport() {
  var weekAgo = localDate(new Date(Date.now()-7*86400000));
  var treats = (db.treatments||[]).filter(function(t){ return (t.applied_at||'') >= weekAgo; });
  var rp = document.getElementById('weekly-report');
  if(!treats.length){ rp.innerHTML='<p style="color:var(--muted);font-family:DM Mono,monospace;font-size:12px">Sin tratamientos esta semana.</p>'; return; }

  // Agrupar por producto
  var byProduct = {};
  treats.forEach(function(t){
    var pname = t.product_name||'Sin nombre';
    if(!byProduct[pname]) byProduct[pname] = { applications:[], totalAnimals:0, totalQty:0, totalCost:0, unit:t.unit||'' };
    var p = byProduct[pname];
    p.totalQty += t.total||0;
    p.totalCost += t.cost||0;
    p.unit = t.unit||p.unit;
    // Registrar aplicacion con detalle
    if(t.scope==='individual' && t.animal_id) {
      p.applications.push({
        type:'individual', animal_id:t.animal_id, lot:t.lot_code,
        date:fmtDT(t.created_at||t.applied_at), dose:t.dose, count:1
      });
      p.totalAnimals += 1;
    } else {
      p.applications.push({
        type:'lot', lot:t.lot_code, count:t.count||0,
        date:fmtDT(t.created_at||t.applied_at), dose:t.dose
      });
      p.totalAnimals += (t.count||0);
    }
  });

  var html = '';
  Object.keys(byProduct).forEach(function(pname){
    var p = byProduct[pname];
    // Agrupar animales individuales por lote para display compacto
    var indivByLot = {};
    var lotApps = [];
    p.applications.forEach(function(app){
      if(app.type==='individual'){
        if(!indivByLot[app.lot]) indivByLot[app.lot] = [];
        indivByLot[app.lot].push(app);
      } else {
        lotApps.push(app);
      }
    });

    html += '<div style="border:1px solid var(--bor);border-radius:8px;margin-bottom:14px;overflow:hidden">';
    // Header del producto
    html += '<div style="background:rgba(212,160,23,.08);padding:10px 14px;display:flex;justify-content:space-between;align-items:center">';
    html += '<div><span style="font-weight:700;color:var(--amber2)">'+escH(pname)+'</span>';
    html += ' <span style="font-size:11px;color:var(--muted);margin-left:8px">'+p.totalQty.toFixed(1)+' '+p.unit+' usados</span></div>';
    html += '<div style="font-size:12px"><span style="color:var(--amber2)">'+p.totalAnimals+' animales</span>';
    if(p.totalCost) html += ' · <span style="color:var(--green)">Bs '+p.totalCost.toLocaleString()+'</span>';
    html += '</div></div>';

    // Aplicaciones por lote completo
    if(lotApps.length) {
      html += '<div style="padding:8px 14px;border-bottom:1px solid rgba(48,54,61,.3)">';
      html += '<div style="font-size:10px;font-weight:700;color:var(--muted);margin-bottom:6px;text-transform:uppercase">Por lote</div>';
      lotApps.forEach(function(app){
        html += '<div style="display:flex;gap:10px;font-size:12px;padding:3px 0">';
        html += '<span style="color:var(--amber2);font-family:DM Mono,monospace;min-width:60px">'+escH(app.lot||'-')+'</span>';
        html += '<span style="color:var(--muted)">'+app.count+' animales</span>';
        html += '<span style="color:var(--muted);margin-left:auto">'+app.date+'</span>';
        html += '</div>';
      });
      html += '</div>';
    }

    // Animales individuales por lote
    Object.keys(indivByLot).forEach(function(lot){
      var animals = indivByLot[lot];
      html += '<div style="padding:8px 14px;border-bottom:1px solid rgba(48,54,61,.2)">';
      html += '<div style="font-size:10px;font-weight:700;color:var(--muted);margin-bottom:6px;text-transform:uppercase">Individual · Lote '+escH(lot)+'</div>';
      html += '<div style="display:flex;flex-wrap:wrap;gap:6px">';
      animals.forEach(function(app){
        html += '<div style="background:rgba(88,166,255,.08);border:1px solid rgba(88,166,255,.2);border-radius:4px;padding:3px 8px;font-size:11px;font-family:DM Mono,monospace">';
        html += '<span style="color:var(--blue)">#'+escH(app.animal_id)+'</span>';
        html += ' <span style="color:var(--muted)">'+app.date+'</span>';
        html += '</div>';
      });
      html += '</div></div>';
    });

    html += '</div>';
  });

  var totalAnimals = treats.reduce(function(s,t){ return s+(t.count||0); },0);
  var totalCost = treats.reduce(function(s,t){ return s+(t.cost||0); },0);
  html += '<div style="margin-top:8px;padding:12px;background:var(--sur2);border-radius:8px;font-size:12px;display:flex;gap:16px">';
  html += '<span><strong style="color:var(--amber2)">Total semana:</strong> '+totalAnimals+' animales</span>';
  html += '<span><strong style="color:var(--green)">Costo:</strong> Bs '+totalCost.toLocaleString()+'</span>';
  html += '<span style="margin-left:auto;color:var(--muted)">'+weekAgo+' — hoy</span>';
  html += '</div>';

  rp.innerHTML = html;
}

function onTrLotChange(lotCode) {
  var lot = db.lots.find(function(l){return l.code===lotCode;});
  var maxEl = document.getElementById('tr-count-max');
  var countEl = document.getElementById('tr-count');
  if (lot && maxEl) {
    maxEl.textContent = '(max. '+lot.animal_count+')';
    if (countEl) { countEl.max = lot.animal_count; countEl.value = lot.animal_count; }
    updateTreatmentTotal();
  } else if (maxEl) {
    maxEl.textContent = '';
  }
  validateTrCount();
}

function validateTrCount() {
  var lotCode = (document.getElementById('tr-lot')||{}).value;
  var count = parseInt((document.getElementById('tr-count')||{}).value)||0;
  var warn = document.getElementById('tr-count-warn');
  var lot = db.lots.find(function(l){return l.code===lotCode;});
  if (warn) warn.style.display = (lot && count > lot.animal_count) ? 'block' : 'none';
}

// v1.4.61: Helper común para el toggle "Lote ya vendido (carga retroactiva)".
// Cuando includeSold=true, repuebla el dropdown con TODOS los lotes (incluyendo vendidos)
// con tag visual [VENDIDO]. Si false, vuelve solo a los activos.
function onRetroactiveToggle(selectId, includeSold) {
  var sel = document.getElementById(selectId);
  if (!sel) return;
  var currentVal = sel.value;  // recordar selección actual

  var filtered;
  if (includeSold) {
    filtered = db.lots.filter(function(l) { return true; });
  } else {
    filtered = db.lots.filter(function(l) {
      var st = (l.status || '').toLowerCase();
      return !st || st === 'activo' || st === 'active';
    });
  }

  var opts = filtered.map(function(l) {
    var st = (l.status || '').toLowerCase();
    var tag = '';
    if (st === 'sold' || st === 'vendido') tag = ' [VENDIDO]';
    else if (st === 'cuarentena') tag = ' [CUAR]';
    else if (st === 'marcado_completo') tag = ' [MARCADO]';
    var count = l.animal_count != null ? ' (' + l.animal_count + ' cab.)' : '';
    return '<option value="' + escH(l.code) + '">' + escH(l.code) + ' - ' + escH(l.category || '') + tag + count + '</option>';
  }).join('');

  sel.innerHTML = '<option value="">Seleccionar...</option>' + opts;
  // Re-seleccionar valor previo si todavía existe en las opciones
  if (currentVal) {
    var stillExists = filtered.some(function(l) { return l.code === currentVal; });
    if (stillExists) sel.value = currentVal;
  }
}

function saveTreatment() {
  const product_id = parseInt(document.getElementById('tr-product').value);
  const scope = document.getElementById('tr-scope').value;
  const lot_code = document.getElementById('tr-lot').value;
  const animal_id = document.getElementById('tr-animal').value.trim();
  const count = parseInt(document.getElementById('tr-count').value)||1;
  const dose = parseFloat(document.getElementById('tr-dose').value);
  const date = document.getElementById('tr-date').value;
  const next = document.getElementById('tr-next').value;
  const diag = document.getElementById('tr-diag').value.trim();
  const notes = '';

  if(!product_id||!dose||!date){toast('Completa producto, dosis y fecha','error');return;}
  // FIX v1.4.34: no permitir fechas futuras (tr-next sí puede ser futuro)
  if(!validateNotFuture(date, 'fecha aplicación')) return;
  // v1.4.61: detectar si es carga retroactiva (lote vendido)
  var isRetroactive = (document.getElementById('tr-retroactive') || {}).checked || false;
  if(scope==='lot'&&!lot_code){toast('Selecciona un lote','error');return;}
  if(scope==='lot'&&lot_code&&!isRetroactive) {
    // Validaciones normales solo si NO es retroactivo
    var treatLot = db.lots.find(function(l){return l.code===lot_code;});
    if (treatLot && treatLot.animal_count === 0) {
      toast('El lote '+lot_code+' no tiene animales activos','error'); return;
    }
    if (treatLot && count > treatLot.animal_count) {
      toast('El lote '+lot_code+' tiene solo '+treatLot.animal_count+' animales','error'); return;
    }
  }
  if(scope==='individual'&&!animal_id){toast('Ingresa ID del animal','error');return;}

  const prod = db.products.find(p=>p.id===product_id);
  const totalUsed = dose*count;

  if(prod.stock_qty<totalUsed){toast('Stock insuficiente. Disponible: '+prod.stock_qty+' '+prod.unit+'. Necesario: '+totalUsed+' '+prod.unit,'error');return;}

  // Descontar stock
  prod.stock_qty = Math.round((prod.stock_qty - totalUsed)*100)/100;

  const t = {
    id:db.next_ids.treatment++,
    product_id,product_name:prod.name,scope,
    lot_code:scope==='lot'?lot_code:'',
    animal_id:scope==='individual'?animal_id:'',
    count,dose,total:totalUsed,
    applied_at:date,next_app:next||null,
    diagnosis:diag,notes,
    by:(document.getElementById('tr-by')||{value:'Cesar Moreno'}).value||'Cesar Moreno',
    cost:Math.round(totalUsed*(prod.unit_cost||0)*100)/100,
    retroactive: isRetroactive  // v1.4.61: marca para auditoría
  };
  db.treatments.push(t);

  // Auto alert if low stock
  if(prod.stock_qty<=prod.stock_min) {
    const existing = db.alerts.find(a=>!a.resolved&&a.type==='stock_low'&&a.title.includes(prod.name));
    if(!existing) db.alerts.push({id:db.next_ids.alert++,type:'stock_low',severity:prod.stock_qty===0?'critical':'warning',title:'Stock '+(prod.stock_qty===0?'agotado':'bajo')+': '+(prod.name)+'',message:'Quedan '+(prod.stock_qty)+' '+(prod.unit)+'. Minimo: '+(prod.stock_min)+'.',resolved:false,created_at:date});
  }

  // Schedule next application alert
  if(next) {
    db.alerts.push({id:db.next_ids.alert++,type:'treatment_due',severity:'warning',title:'Tratamiento pendiente: '+(prod.name)+'',message:'Aplicacion programada para '+(next)+'. '+(scope==='lot'?'Lote '+lot_code:'Animal '+animal_id)+'.',resolved:false,created_at:date});
  }

  addActivity(_desktopAuthor(),'curacion',lot_code||animal_id,'Curacion: '+(prod.name)+' × '+(count)+' animales'+(diag?' - '+diag:'')+'');
  saveDB();
  closeModal('modal-treatment');
  renderDashboard();
  renderSanidad();
  renderStock();
  replaceTableInRailway('treatments', db.treatments || []);
  replaceTableInRailway('vet_products', db.products || []);
  toast('Curacion registrada. Stock de '+prod.name+': '+prod.stock_qty+' '+prod.unit,'success');
  // FIX v1.4.35: audit log para curación
  try { auditLog('create', 'treatments', t.id, _summarizeRecord('treatments', t)); } catch(e){}
}

function deleteTreatment(id) {
  if (!confirm('00bfEliminar esta curacion? El stock NO se restaura.')) return;
  
  // FIX v1.4.35: audit log para deleteTreatment
  var _delRec_deleteTreatment = (db.treatments || []).find(function(r){ return String(r.id) === String(id); });
  var _delSummary_deleteTreatment = _delRec_deleteTreatment ? _summarizeRecord('treatments', _delRec_deleteTreatment) : 'Curación #' + id;
  try { auditLog('delete', 'treatments', id, _delSummary_deleteTreatment); } catch(e){}
  trackDeletion(id, 'treatments');
  db.treatments = db.treatments.filter(function(t){ return t.id !== id; });
  saveDB();
  replaceTableInRailway('treatments', db.treatments || []);
  renderSanidad();
  pushTableToRailway('treatments', db.treatments);
  toast('Curacion eliminada', 'success');
}

