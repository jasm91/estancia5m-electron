      var total = registros.reduce(function(s,r){ return s + getLluviaMm(r, p.key); }, 0);
      var dias = registros.filter(function(r){ return getLluviaMm(r, p.key) > 0; }).length;
      var maxDay = registros.length ? Math.max.apply(null, registros.map(function(r){ return getLluviaMm(r, p.key); })) : 0;
      var prom = dias > 0 ? (total / dias).toFixed(1) : '0';
      return '<div style="background:'+(isSelected?'rgba(255,255,255,.04)':'var(--sur)')+';border:1px solid '+(isSelected?p.color:'var(--bor)')+';border-radius:12px;padding:14px 16px;border-left:3px solid '+p.color+';cursor:pointer;transition:all .2s" onclick="document.getElementById(\'lluvia-d-pluvio\').value=\''+p.key+'\';renderLluviasDesktop()">' +
