function renderTraceAnimals() {
  var lotCode = (document.getElementById('trace-lot')||{}).value||'';
  var search = ((document.getElementById('trace-search')||{}).value||'').toLowerCase();
  var el = document.getElementById('trace-animals-list');
  var countEl = document.getElementById('trace-sel-count');
  if(!el) return;
  var animalesDB = getAnimalesDB();
  var animals = (animalesDB[lotCode]||[]).filter(function(a){
    if(!search) return true;
    return (a.animal_id||a.id||'').toString().toLowerCase().indexOf(search) >= 0;
  });
  if(!animals.length) {
    el.innerHTML = '<div style="padding:16px;text-align:center;color:var(--muted);font-size:12px">Sin animales en este lote</div>';
    return;
  }
  el.innerHTML = '';
  animals.forEach(function(a) {
    var aid = (a.animal_id||a.id||'').toString();
    var raza = a.breed||a.raza||'';
    var ps = a.pesajes||[];
    var lastP = ps.length ? ps[ps.length-1].peso : null;
    var sel = _traceSelectedAnimals.indexOf(aid) >= 0;
    var div = document.createElement('div');
    div.id = 'trc-row-'+aid;
    div.style.cssText = 'display:flex;align-items:center;gap:10px;padding:7px 12px;border-bottom:1px solid rgba(48,54,61,.3);cursor:pointer;'+(sel?'background:rgba(201,168,76,.08)':'');

    // Checkbox — se crea con createElement para preservar el event listener
    var chkEl = document.createElement('input');
    chkEl.type = 'checkbox';
    chkEl.id = 'trc-chk-'+aid;
    chkEl.checked = sel;
    chkEl.style.cssText = 'accent-color:var(--amber);flex-shrink:0';
    chkEl.onchange = (function(a){ return function(){
      toggleTraceAnimal(a, this.checked, this);
    }; })(aid);
    div.appendChild(chkEl);

    // Spans de texto — también createElement para no pisar el checkbox
    var spanId = document.createElement('span');
    spanId.style.cssText = 'font-family:DM Mono,monospace;font-size:12px;font-weight:600;color:var(--amber2);min-width:80px';
    spanId.textContent = aid;
    div.appendChild(spanId);

    var spanRaza = document.createElement('span');
    spanRaza.style.cssText = 'font-size:11px;color:var(--muted)';
    spanRaza.textContent = raza;
    div.appendChild(spanRaza);

    var spanPeso = document.createElement('span');
    spanPeso.style.cssText = 'margin-left:auto;font-family:DM Mono,monospace;font-size:12px;font-weight:700';
    spanPeso.textContent = lastP ? lastP+' kg' : '-';
    div.appendChild(spanPeso);

    // Click en el div también togglea
    div.onclick = (function(a, chk){ return function(e){
      if(e.target === chk) return; // el checkbox ya lo maneja
      chk.checked = !chk.checked;
      toggleTraceAnimal(a, chk.checked, chk);
    }; })(aid, chkEl);

    el.appendChild(div);
  });
  if(countEl) {
    var total = (animalesDB[lotCode]||[]).length;
    countEl.textContent = _traceSelectedAnimals.length > 0
      ? '('+_traceSelectedAnimals.length+' seleccionados de '+total+')'
      : '(0 = todos los animales)';
  }
}

function toggleTraceAnimal(aid, checked, chkEl) {
  var idx = _traceSelectedAnimals.indexOf(aid);
  if(checked && idx < 0) _traceSelectedAnimals.push(aid);
  if(!checked && idx >= 0) _traceSelectedAnimals.splice(idx,1);
  // Update row background
  if(chkEl) {
    var row = chkEl.parentElement;
    if(row) row.style.background = checked ? 'rgba(201,168,76,.08)' : '';
  }
  var countEl = document.getElementById('trace-sel-count');
  var lotCode = (document.getElementById('trace-lot')||{}).value||'';
  var animalesDB = getAnimalesDB();
  var total = (animalesDB[lotCode]||[]).length;
  if(countEl) countEl.textContent = _traceSelectedAnimals.length > 0
    ? '('+_traceSelectedAnimals.length+' seleccionados de '+total+')'
    : '(0 = todos los animales)';
}

