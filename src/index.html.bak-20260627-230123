function savePurchase() {
  var productLinkId = (document.getElementById('pur-product-link')||{}).value||'';
  var qty = parseFloat((document.getElementById('pur-qty')||{}).value)||0;
  var price = parseFloat((document.getElementById('pur-price')||{}).value)||0;
  var date = (document.getElementById('pur-date')||{}).value||'';
  if(!productLinkId){toast('Selecciona un producto o Otros','error');return;}
  if(!qty||!price||!date){toast('Completa cantidad, precio y fecha','error');return;}
  // FIX v1.4.34: no permitir fechas futuras
  if(!validateNotFuture(date, 'fecha de compra')) return;
  var isOtro = productLinkId === 'otro';
  var desc = isOtro ? ((document.getElementById('pur-desc')||{}).value||'').trim() : '';
  if(isOtro && !desc){toast('Ingresa una descripcion','error');return;}
  var prod = isOtro ? null : db.products.find(function(p){ return p.id == productLinkId; });
  var type = isOtro ? ((document.getElementById('pur-type')||{}).value||'otro') : 'veterinaria';
  var rec = {
    id: db.next_ids.purchase++,
    desc: prod ? prod.name : desc,
    type: type, qty: qty,
    unit: prod ? prod.unit : ((document.getElementById('pur-unit')||{}).value||''),
    unit_price: price, total: Math.round(qty*price*100)/100,
    supplier: (document.getElementById('pur-supplier')||{}).value||'',
    date: date, status: (document.getElementById('pur-status')||{}).value||'paid',
    notes: (document.getElementById('pur-notes')||{}).value||'',
    product_id: prod ? prod.id : null, is_otro: isOtro
  };
  db.purchases.push(rec);
  if (prod) {
    var prevQty = prod.stock_qty;
    prod.stock_qty = Math.round((prod.stock_qty + qty)*100)/100;
    if (prod.stock_qty > prod.stock_min) {
      db.alerts = db.alerts.filter(function(a){
        return !(a.type==='stock_low' && a.title.includes(prod.name) && !a.resolved);
      });
    }
    toast('Compra registrada. Stock de '+prod.name+': '+prevQty+' > '+prod.stock_qty+' '+prod.unit, 'success');
  } else {
    toast('Compra registrada: '+desc, 'success');
  }
  var purSel = document.getElementById('pur-product-link'); if(purSel) purSel.value = '';
  var si = document.getElementById('pur-stock-info'); if(si) si.style.display = 'none';
  var og = document.getElementById('pur-otros-group'); if(og) og.style.display = 'none';
  ['pur-qty','pur-price','pur-total','pur-supplier','pur-notes','pur-desc'].forEach(function(id){
    var el = document.getElementById(id); if(el) el.value = '';
  });
  saveDB(); closeModal('modal-purchase'); renderCompras(); renderStock(); renderDashboard();
  replaceTableInRailway('purchases', db.purchases || []);
  replaceTableInRailway('vet_products', db.products || []);
  // Audit (solo si fue create — toma el último de db.purchases)
  try {
    var lastPur = db.purchases[db.purchases.length-1];
    if (lastPur && !lastPur.id_was_existing) {
      auditLog('create', 'purchases', lastPur.id, _summarizeRecord('purchases', lastPur));
    }
  } catch(e){}
}


