function setupBajaPhotoHandler() {
  var photo = document.getElementById('baja-photo');
  var preview = document.getElementById('baja-photo-preview');
  if (photo) {
    photo.onchange = function() {
      if (!this.files || !this.files[0]) return;
      var reader = new FileReader();
      reader.onload = function(e) {
        var img = new Image();
        img.onload = function() {
          var canvas = document.createElement('canvas');
          var maxW = 600; var scale = Math.min(1, maxW / img.width);
          canvas.width = img.width * scale; canvas.height = img.height * scale;
          canvas.getContext('2d').drawImage(img, 0, 0, canvas.width, canvas.height);
          _bajaPhotoBase64 = canvas.toDataURL('image/jpeg', 0.4);
          if (preview) preview.innerHTML = '<img src="' + _bajaPhotoBase64 + '" style="max-width:120px;border-radius:6px;border:1px solid var(--bor)">';
        };
        img.src = e.target.result;
      };
      reader.readAsDataURL(this.files[0]);
    };
  }
}

