var _ipParsed = []; // pesajes parseados con su validación
var _ipLotCode = null;

// Descargar plantilla Excel pre-cargada con animales del lote
function downloadPesajesTemplate() {
  var modal = document.getElementById("modal-pesaje-animal");
  var lotCode = modal ? modal._lotCode : "";
  if (!lotCode) { toast("No se identificó el lote", "error"); return; }

  var lot = (db.lots || []).find(function(l) { return l.code === lotCode; });
  var all = getAnimalesDB();
  var animals = all[lotCode] || [];

  if (!animals.length) {
    toast("Este lote no tiene animales individuales registrados", "error");
    return;
  }

  if (!window.estancia || !window.estancia.xlsx || !window.estancia.xlsx.saveAs) {
    toast("Función Excel no disponible en esta versión", "error");
    return;
  }

  // Construir hojas
  var fechaHoy = localDate();

  // Hoja 1: Pesajes
  var headerPesajes = [
    "ID / Caravana",
    "Raza",
    "Peso anterior (kg)",
    "Fecha último pesaje",
    "Peso nuevo (kg)",
    "Notas"
  ];

  var rowsPesajes = [headerPesajes];
  animals.forEach(function(a) {
    var pesajes = (a.pesajes || []).slice().sort(function(x, y) { return String(x.fecha).localeCompare(y.fecha); });
    var ultimo = pesajes.length ? pesajes[pesajes.length - 1] : null;
    rowsPesajes.push([
      String(a.id || a.animal_id || ""),
      a.raza || a.breed || "",
      ultimo ? ultimo.peso : "",
      ultimo ? ultimo.fecha : "",
      "", // PESO NUEVO — vacío para que César complete
      ""
    ]);
  });

  // Hoja 2: Instrucciones
  var instrucciones = [
    ["INSTRUCCIONES PARA PESAJE MASIVO"],
    [""],
    ["1. Completá la columna 'Peso nuevo (kg)' para cada animal pesado"],
    ["2. Si un animal no fue pesado hoy, dejá la celda vacía (será ignorado)"],
    ["3. Podés agregar notas opcionales en la última columna"],
    ["4. Guardá el archivo y volvé al sistema"],
    ["5. Hacé click en 'Importar Excel/CSV' y subí este archivo"],
    [""],
    ["Lote: " + lotCode],
    ["Categoría: " + (lot ? lot.category : "")],
    ["Potrero: " + (lot ? lot.paddock : "")],
    ["Animales en el lote: " + animals.length],
    ["Fecha generación: " + fechaHoy],
    [""],
    ["⚠ NO modifiques las columnas A-D (ID, Raza, Peso anterior, Fecha)"],
    ["⚠ Las cabeceras deben mantenerse para que el import funcione"]
  ];

  var fileName = "Pesajes_" + lotCode + "_" + fechaHoy + ".xlsx";
  // El handler xlsx:save-as espera un OBJETO { 'NombreHoja': [filas], ... }, no un array
  var sheetsObj = {
    "Pesajes": rowsPesajes,
    "Instrucciones": instrucciones
  };
  window.estancia.xlsx.saveAs(sheetsObj, fileName).then(function(result) {
    if (!result || result.success === false) {
      // Cancelado por el usuario o error
      if (result && result.error) {
        toast("Error guardando Excel: " + result.error, "error");
      }
      return;
    }
    if (result.success && result.path) {
      toast("✓ Excel guardado: " + animals.length + " animales", "success");
    }
  }).catch(function(e) {
    console.error("Error generando Excel:", e);
    toast("Error: " + (e.message || "no se pudo generar"), "error");
  });
}

