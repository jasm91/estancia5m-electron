// Backup forzado: siempre escribe, con debounce de 60s para evitar duplicados
// (caso de arranque + cierre rápido, o múltiples disparadores en simultáneo)
async function runBackupNow(reason) {
  // Debounce: si hay un backup hace menos de 60s, saltear
  var lastTs = parseInt(localStorage.getItem('e5m_last_backup_ts') || '0');
  if (lastTs && (Date.now() - lastTs) < 60000) {
    console.log('[Backup] Skip — backup hace menos de 60s');
    return false;
  }
  try {
    var backup = getBackupData();
    var json = JSON.stringify(backup, null, 2);
    var fecha = localDate();
    // Sufijo con hora+minutos para no pisar backups del mismo día
    var d = new Date();
    var hhmm = String(d.getHours()).padStart(2,'0') + String(d.getMinutes()).padStart(2,'0');
    var filename = 'backup_estanciapro_' + fecha + '_' + hhmm + (reason ? '_' + reason : '') + '.json';
    if (window.estancia && window.estancia.backup) {
      var result = await window.estancia.backup.auto(json, filename);
      if (result && result.success) {
        var now = new Date().toLocaleString('es-BO');
        localStorage.setItem('e5m_last_backup', now);
        localStorage.setItem('e5m_last_backup_ts', String(Date.now()));
        // Re-programar próximo (mantengo compat con UI vieja del schedule semanal)
        var enabled = localStorage.getItem('e5m_auto_backup_enabled') !== '0'; // default ON
        if (enabled) {
          var freq = parseInt(localStorage.getItem('e5m_auto_backup_freq') || '7');
          var nextDate = new Date();
          nextDate.setDate(nextDate.getDate() + freq);
          localStorage.setItem('e5m_auto_backup_next', nextDate.toISOString());
        }
        var lbl = document.getElementById('cfg-last-backup');
        if (lbl) lbl.textContent = 'Último backup: ' + now;
        console.log('[Backup] OK (' + (reason||'auto') + '):', result.path);
        return true;
      } else {
        console.warn('[Backup] Falló:', result && result.error);
      }
    }
  } catch(e) {
    console.warn('[Backup] Error:', e);
  }
  return false;
}

// Wrapper de compat: runAutoBackupIfDue (mantiene el flujo viejo del schedule semanal
// pero ya no es la fuente principal — backup ahora corre al arranque y al cierre)
async function runAutoBackupIfDue() {
  // Default ON: si nunca se configuró, asumimos activado
  var rawEnabled = localStorage.getItem('e5m_auto_backup_enabled');
  var enabled = rawEnabled === null || rawEnabled === '1';
  if(!enabled) return;
  var nextStr = localStorage.getItem('e5m_auto_backup_next');
  // Si nunca corrió, programar para ahora (forzar backup en este tick)
  if(!nextStr) {
    return runBackupNow('inicio');
  }
  var next = new Date(nextStr);
  if(new Date() < next) return; // Aun no es momento
  return runBackupNow('schedule');
}

