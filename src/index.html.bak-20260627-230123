function _reproPopulateLoteFilter() {
  var sel = document.getElementById('repro-filter-lote');
  if (!sel) return;
  var current = sel.value;
  var lots = (db && Array.isArray(db.lots)) ? db.lots : [];
  // v1.8.12: excluir cuarentena/marcado/fusionado/vendido y los CUAR-xxx (igual que selectores de modales)
  var activeLots = lots.filter(function(l) {
    var s = (l.status || '').toLowerCase();
    if (s === 'sold' || s === 'vendido' || s === 'fusionado' || s === 'merged') return false;
    if (s === 'cuarentena' || s === 'marcado' || s === 'marcado_completo' || s === 'inactivo') return false;
    if (/^CUAR-\d+$/i.test(l.code || '')) return false;
    return true;
  }).map(function(l) { return l.code; }).filter(Boolean).sort();
  sel.innerHTML = '<option value="">Todos</option>' +
    activeLots.map(function(code) {
      return '<option value="' + code + '"' + (code === current ? ' selected' : '') + '>' + code + '</option>';
    }).join('');
}

function _reproPopulateAnimalsList() {
  var list = document.getElementById('repro-animal-list');
  if (!list) return;
  var hint = document.getElementById('repro-srv-animal-hint');
  var loteSel = document.getElementById('repro-srv-lote');
  var selectedLote = loteSel ? loteSel.value : '';

  // Si no hay lote elegido, datalist vacío + mensaje
  if (!selectedLote) {
    list.innerHTML = '';
    if (hint) hint.textContent = 'Elegí el lote para ver las caravanas registradas';
    return;
  }

  // Leer e5m_animals (estructura: { lot_code: [animals] }) — SOLO el lote elegido
  var animalsOfLot = [];
  try {
    var raw = localStorage.getItem('e5m_animals');
    if (raw) {
      var parsed = JSON.parse(raw);
      if (parsed && typeof parsed === 'object' && Array.isArray(parsed[selectedLote])) {
        animalsOfLot = parsed[selectedLote];
      }
    }
  } catch(e) { console.warn('[Repro] read e5m_animals', e); }

  // Excluir machos (toros/novillos) y terneros si tienen category
  var hembras = animalsOfLot.filter(function(a) {
    if (!a) return false;
    var cat = String(a.category || a.categoria || '').toLowerCase();
    if (cat && (cat === 'toro' || cat === 'novillo' || cat === 'ternero')) return false;
    return true;
  });

  // Dedup por caravana/id, omitiendo IDs claramente autogenerados (puro número/timestamp largo)
  var seen = {};
  var unique = [];
  hembras.forEach(function(a) {
    // v1.8.12: e5m_animals guarda como animal_id (no caravana). Probar varios campos.
    var key = String(a.animal_id || a.caravana || a.id || '').trim();
    if (!key) return;
    // Filtrar IDs feos: solo números cortos (≤4 dígitos) o que contengan letras
    var isPureShortNum = /^\d{1,4}$/.test(key);
    var hasLetters = /[a-zA-Z]/.test(key);
    if (!hasLetters && !isPureShortNum) return; // descartar timestamps gigantes y autogenerados
    if (seen[key]) return;
    seen[key] = true;
    unique.push({ key: key, raza: a.raza || a.breed || '' });
  });

  // Ordenar: las que parecen caravanas con prefijo letra (V-..., VT...) primero
  unique.sort(function(a, b) {
    var aHasLetter = /^[a-zA-Z]/.test(a.key);
    var bHasLetter = /^[a-zA-Z]/.test(b.key);
    if (aHasLetter !== bHasLetter) return aHasLetter ? -1 : 1;
    return a.key.localeCompare(b.key, undefined, { numeric: true });
  });

  // Render
  list.innerHTML = unique.map(function(a) {
    var label = String(a.key).replace(/"/g, '&quot;');
    var raza = a.raza ? (' — ' + String(a.raza).replace(/"/g, '&quot;')) : '';
    return '<option value="' + label + '">' + label + raza + '</option>';
  }).join('');

  // Hint según resultado
  if (hint) {
    if (unique.length === 0) {
      hint.textContent = 'Lote ' + selectedLote + ' sin caravanas registradas — podés escribir el ID libre';
    } else {
      hint.textContent = unique.length + ' caravana' + (unique.length === 1 ? '' : 's') + ' en ' + selectedLote + ' (también podés escribir un ID libre)';
    }
  }
}

function _reproPopulateLoteSelector() {
  var sel = document.getElementById('repro-srv-lote');
