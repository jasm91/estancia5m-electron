      else topRow += '<span style="font-size:11px;color:var(--muted)">· '+escH(a.empleado)+'</span>';
    }
    if (a.lote) topRow += '<span style="font-size:11px;color:var(--amber2)">· Lote '+escH(a.lote)+'</span>';
    topRow += '</div>';

    var titleRow = '<div style="font-size:13px;font-weight:500;color:var(--text)">'+escH(a.titulo)+'</div>';
    var subRow = a.sub ? '<div style="font-size:11px;color:var(--muted);margin-top:2px">'+escH(a.sub)+'</div>' : '';

