  var _delSummary_deleteProduct = _delRec_deleteProduct ? _summarizeRecord('products', _delRec_deleteProduct) : 'Producto #' + id;
  try { auditLog('delete', 'products', id, _delSummary_deleteProduct); } catch(e){}
  trackDeletion(id, 'products');
  db.products = db.products.filter(function(p){ return p.id !== id; });
