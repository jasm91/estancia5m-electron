function _reproPartoPopulateMadres() {
  var sel = document.getElementById('repro-parto-madre');
  if (!sel) return;

  // Vacas preñadas = vacas (animal_id) con un servicio cuyo result='preñada'
  // y que aún NO tienen un parto que referencie ese servicio_id
  var servicios = _reproGetServicios();
  var partos = _reproGetPartos();
  var serviciosConsumidos = {};
  partos.forEach(function(p) {
    if (p.servicio_id) serviciosConsumidos[p.servicio_id] = true;
  });

  var prenadas = servicios
    .filter(function(s) { return s.result === 'preñada' && s.animal_id; })
    .filter(function(s) { return !serviciosConsumidos[s.id]; })
    // Por vaca, quedarse con el servicio preñador más reciente
    .sort(function(a, b) { return (b.date || '').localeCompare(a.date || ''); });

  var byVaca = {};
  prenadas.forEach(function(s) {
    if (!byVaca[s.animal_id]) byVaca[s.animal_id] = s;
  });

  // Ordenar por fecha esperada de parto (date + 280d)
  var lista = Object.keys(byVaca).map(function(k) { return byVaca[k]; }).sort(function(a, b) {
    var da = a.date ? new Date(a.date).getTime() + 280*86400000 : Infinity;
    var db_ = b.date ? new Date(b.date).getTime() + 280*86400000 : Infinity;
    return da - db_;
  });

  if (!lista.length) {
    sel.innerHTML = '<option value="">— No hay vacas preñadas con servicio diagnosticado —</option>';
    document.getElementById('repro-parto-madre-hint').innerHTML =
      'Para registrar un parto, primero registrá un <b>+ Servicio</b> y <b>+ Diagnóstico</b> preñada.';
    return;
  }

  sel.innerHTML = '<option value="">— Elegí una vaca —</option>' + lista.map(function(s) {
    var esperada = s.date ? new Date(new Date(s.date).getTime() + 280*86400000).toISOString().slice(0, 10) : '?';
    var label = s.animal_id + ' · servicio ' + _reproFmtDate(s.date) + ' · esperado ' + esperada;
    return '<option value="' + s.id + '">' + label + '</option>';
  }).join('');
}

function _reproPartoPopulateLoteSelector() {
  var sel = document.getElementById('repro-parto-lote');
  if (!sel) return;
  var lots = (db && Array.isArray(db.lots)) ? db.lots : [];
  // v1.8.12: excluir cuarentena/marcado/fusionado/vendido y los CUAR-xxx
  var activeLots = lots.filter(function(l) {
    var s = (l.status || '').toLowerCase();
    if (s === 'sold' || s === 'vendido' || s === 'fusionado' || s === 'merged') return false;
    if (s === 'cuarentena' || s === 'marcado' || s === 'marcado_completo' || s === 'inactivo') return false;
    if (/^CUAR-\d+$/i.test(l.code || '')) return false;
    return true;
  }).map(function(l) { return l.code; }).filter(Boolean).sort();
  sel.innerHTML = '<option value="">— Sin lote —</option>' +
    activeLots.map(function(c) { return '<option value="' + c + '">' + c + '</option>'; }).join('');
}

function _reproPartoOnMadreChange() {
  var srvId = document.getElementById('repro-parto-madre').value;
  document.getElementById('repro-parto-servicio-id').value = srvId;
  if (!srvId) {
    document.getElementById('repro-parto-context').textContent = 'Seleccioná la madre. El sistema autocompleta padre + lote desde su último servicio.';
    document.getElementById('repro-parto-padre').value = '';
    return;
  }
  var srv = _reproGetServicios().find(function(s) { return s.id === srvId; });
  if (!srv) return;

  // Auto-completar padre desde servicio
  var padre = '';
  if (srv.tipo_servicio === 'IA') {
    padre = srv.semen_lote ? ('Pajuela: ' + srv.semen_lote) : '';
  } else {
    padre = srv.toro_id || '';
  }
  document.getElementById('repro-parto-padre').value = padre;

  // Auto-completar lote desde servicio
  if (srv.lot_code) {
    var sel = document.getElementById('repro-parto-lote');
    if (sel) sel.value = srv.lot_code;
  }

  // Context
  var ctx = 'Madre <b>' + srv.animal_id + '</b> · servicio ' + _reproFmtDate(srv.date) + ' · ' + _reproTipoLabel(srv.tipo_servicio);
  if (srv.lot_code) ctx += ' · lote ' + srv.lot_code;
  if (srv.date) {
    var esperada = new Date(new Date(srv.date).getTime() + 280*86400000).toISOString().slice(0, 10);
    ctx += ' · fecha esperada parto ' + esperada;
  }
  document.getElementById('repro-parto-context').innerHTML = ctx;
}

function saveReproParto() {
  // v1.8.14: detectar modo edición vs creación
  var partoId = document.getElementById('repro-parto-id').value;
  var isEditing = !!partoId;

  var srvId = document.getElementById('repro-parto-servicio-id').value;
  var srv = srvId ? _reproGetServicios().find(function(s) { return s.id === srvId; }) : null;
  var date = document.getElementById('repro-parto-date').value;
  var padre = (document.getElementById('repro-parto-padre').value || '').trim();
  var lote = document.getElementById('repro-parto-lote').value || '';
  var sexo = document.getElementById('repro-parto-sexo').value;
  // v1.8.14: peso opcional — null si vacío, no 0 (para distinguir "no pesado" de "pesa cero")
  var pesoRaw = document.getElementById('repro-parto-peso').value;
  var peso = (pesoRaw === '' || pesoRaw === null) ? null : (parseFloat(pesoRaw) || null);
  var estado = document.getElementById('repro-parto-estado').value;
  var criaId = (document.getElementById('repro-parto-cria-id').value || '').trim();
  var notes = (document.getElementById('repro-parto-notes').value || '').trim();

  // En modo edición, si no hay servicio asociado (parto huérfano) no exigir
  if (!isEditing && !srv) { alert('Falta elegir la madre'); return; }
  if (!date) { alert('Falta la fecha del parto'); return; }
  if (typeof validateNotFuture === 'function' && !validateNotFuture(date, 'fecha del parto')) return;

  // Modo edición: actualizar registro existente
  if (isEditing) {
    if (!Array.isArray(db.partos)) db.partos = [];
    var idx = db.partos.findIndex(function(p){ return String(p.id) === String(partoId); });
    if (idx === -1) { alert('Parto no encontrado'); return; }
    var _oldCriaId = String((db.partos[idx]||{}).cria_id||'').trim(); // v1.8.76: para re-encontrar el animal si perdió parto_id
    // v1.8.78: GUARD anti-colisión — no permitir poner una cría_id que ya tiene OTRO animal del lote.
    var _criaNew = String(criaId||'').trim();
    if (_criaNew && _criaNew !== 'N/A' && _criaNew !== _oldCriaId) {
      var _lotChk = lote || db.partos[idx].lot_code;
      var _adbChk = (typeof getAnimalesDB === 'function') ? getAnimalesDB() : {};
      var _colis = (_adbChk[_lotChk]||[]).some(function(x){ return String(x.animal_id||x.id||'')===_criaNew && !(x.parto_id && String(x.parto_id)===String(partoId)); });
      if (_colis) { toast('Ya existe un animal con ID "'+_criaNew+'" en el lote '+_lotChk+'. Elegí otro arete.','error'); return; }
    }
    var nowIso = new Date().toISOString();
    db.partos[idx] = Object.assign({}, db.partos[idx], {
      date: date,
      padre_id: padre || db.partos[idx].padre_id,
      lot_code: lote || db.partos[idx].lot_code,
      sexo: sexo,
      peso: peso,
      peso_pendiente: (peso === null || peso === undefined),
      estado: estado,
      cria_id: criaId || db.partos[idx].cria_id,
      obs: notes,
      updated_at: nowIso
    });
    // v1.8.74: propagar el cría_id (y peso) editados al ANIMAL ya creado por este parto.
    // Antes, editar el parto no tocaba el animal → quedaba con el ID placeholder (CRIA-######)
    // y no coincidía con el cría_id mostrado en Partos.
    try {
      var _newCria = String(criaId || db.partos[idx].cria_id || '').trim();
      var _lotKey = db.partos[idx].lot_code;
      var animDBe = (typeof getAnimalesDB === 'function') ? getAnimalesDB() : null;
      if (animDBe && _lotKey && Array.isArray(animDBe[_lotKey])) {
        // v1.8.76: buscar por parto_id; si el animal ya perdió parto_id (datos viejos), caer a match por el cría_id anterior.
        var _an = animDBe[_lotKey].find(function(x){ return x.parto_id && String(x.parto_id) === String(partoId); });
        if (!_an && _oldCriaId && _oldCriaId !== 'N/A') {
          _an = animDBe[_lotKey].find(function(x){ return String(x.animal_id||x.id||'') === _oldCriaId; });
          if (_an && !_an.parto_id) _an.parto_id = partoId; // re-vincular hacia el futuro
        }
        if (_an) {
          var _renamed = false, _oldAnimId = String(_an.animal_id || _an.id || '');
          if (_newCria && _newCria !== 'N/A' && _an.animal_id !== _newCria) {
            _an.animal_id = _newCria; _an.id = _newCria; delete _an._needs_id;
            _an.id_updated_at = new Date().toISOString(); // v1.8.76: durabilidad ante server-wins
            _renamed = true;
          }
          if (peso !== null && peso !== undefined && peso > 0) {
            if (!Array.isArray(_an.pesajes)) _an.pesajes = [];
            if (!_an.pesajes.some(function(pj){ return pj.fecha === date; })) _an.pesajes.push({ fecha: date, peso: peso });
          }
          if (typeof saveAnimalesDB === 'function') saveAnimalesDB(animDBe);
          if (_renamed) {
            try { auditLog('update','animals', _newCria, 'Cambio de ID (parto): '+_oldAnimId+' → '+_newCria+' en '+_lotKey, { animal_id:[_oldAnimId,_newCria] }); } catch(e){}
            try { if (typeof addActivity==='function') addActivity((typeof _desktopAuthor==='function'?_desktopAuthor():'Escritorio'),'otro',_lotKey,'Cambio de ID de cría (parto): '+_oldAnimId+' → '+_newCria+' en '+_lotKey); } catch(e){}
          }
          // v1.8.76 (Opción acotada): si renombramos el animal, registrar el rename {lote, idViejo, idNuevo} para
          // proteger SOLO este animal del server-wins hasta confirmar push, y disparar el push (igual que saveEditAnimalId).
          if (_renamed) {
            try {
              var _pr = JSON.parse(localStorage.getItem('e5m_pending_renames')||'[]'); if (!Array.isArray(_pr)) _pr = [];
              _pr = _pr.filter(function(r){ return !(r && r.lot===_lotKey && String(r.oldId)===_oldAnimId && String(r.newId)===String(_newCria)); });
              _pr.push({ lot: _lotKey, oldId: _oldAnimId, newId: _newCria });
              localStorage.setItem('e5m_pending_renames', JSON.stringify(_pr));
            } catch(e){}
            if (typeof pushToRailway === 'function') { try { pushToRailway(); } catch(e){} }
          }
        }
      }
    } catch(e){ console.warn('[Repro] propagar cria_id editado al animal', e); }
    try { localStorage.setItem(DB_KEY, JSON.stringify(db)); } catch(e) {}
    if (typeof saveDB === 'function') saveDB(true);
    closeModal('modal-repro-parto');
    renderReproPartos();
    if (typeof toast === 'function') toast('Parto actualizado', 'success');
    return;
  }

  var madre = srv.animal_id;
  if (!lote) lote = srv.lot_code || '';

  // Inferir paddock desde lote
  var paddock = '';
  if (lote && db && Array.isArray(db.lots)) {
    var lt = db.lots.find(function(l) { return l.code === lote; });
    if (lt) paddock = lt.paddock || lt.potrero || '';
  }

  // Verificar capacidad del potrero si la cría sobrevivió
  if (estado !== 'muerto' && typeof checkPotreroCapacity === 'function' && lote) {
    var cap = checkPotreroCapacity(lote, 1);
    if (cap && !cap.ok) {
      if (typeof toast === 'function') toast(cap.msg, 'error');
      else alert(cap.msg);
      return;
    }
  }

  var nowIso = new Date().toISOString();
  var newPartoId = (db.next_ids && db.next_ids.partos) ? db.next_ids.partos++ : ('parto_' + Date.now());

  var record = {
    id: newPartoId,
    lot_code: lote,
    paddock: paddock,
    date: date,
    sexo: sexo,
    peso: peso,
    peso_pendiente: (peso === null || peso === undefined),
    estado: estado,
    cria_id: criaId || 'N/A',
    madre_id: madre,
    padre_id: padre,
    servicio_id: srvId,
    obs: notes,
    by: '',
    created_at: nowIso
  };

  if (!Array.isArray(db.partos)) db.partos = [];
  db.partos.push(record);

  // Crear cría en e5m_animals + sumar animal_count del lote
  if (estado !== 'muerto' && lote) {
    try {
      var animDB = (typeof getAnimalesDB === 'function') ? getAnimalesDB() : null;
      if (animDB) {
        if (!animDB[lote]) animDB[lote] = [];
        // v1.8.19: usar animal_id (no id) para consistencia con el resto del sistema.
        // Si no hay cría_id aún, generar uno temporal legible (CRIA-xxxx) en vez de "N/A".
        var criaAnimalId = (record.cria_id && record.cria_id !== 'N/A')
          ? record.cria_id
          : ('CRIA-' + String(Date.now()).slice(-6));
        // Reflejar el ID generado de vuelta en el parto para que coincidan
        if (!record.cria_id || record.cria_id === 'N/A') {
          record.cria_id = criaAnimalId;
          var pIdx = db.partos.findIndex(function(p){ return String(p.id) === String(record.id); });
          if (pIdx !== -1) db.partos[pIdx].cria_id = criaAnimalId;
        }
        animDB[lote].push({
          animal_id: criaAnimalId,
          breed: sexo === 'macho' ? 'Torillo' : 'Ternera',
          raza: sexo === 'macho' ? 'Torillo' : 'Ternera',
          sexo: sexo,
          madre_id: madre,
          padre_id: padre,
          entry_date: date,
          origin: 'parto',
          parto_id: record.id,
          pesajes: (peso !== null && peso !== undefined && peso > 0) ? [{ fecha: date, peso: peso }] : []
        });
        if (typeof saveAnimalesDB === 'function') saveAnimalesDB(animDB);
      }
      // Sumar animal_count
      var lt2 = db.lots.find(function(l) { return l.code === lote; });
      if (lt2) {
        lt2.animal_count = (lt2.animal_count || 0) + 1;
        lt2.id_updated_at = nowIso; // marca para sync
      }
    } catch(e) { console.error('[Repro] error agregando cría', e); }
  }

  // Registrar actividad (igual que saveSubmodule original)
  try {
    if (typeof addActivity === 'function') {
      var msg = estado === 'muerto' ?
        ('❌ Mortinato: ' + (sexo === 'macho' ? 'Macho' : 'Hembra') + (peso ? ' — ' + peso + ' kg' : '')) :
        ('🐣 Parto: ' + (sexo === 'macho' ? 'Torillo' : 'Ternera') + ' #' + record.cria_id +
         (peso ? ' — ' + peso + ' kg' : '') + ' — ' + estado);
      addActivity('', 'parto', lote, msg, date);
    }
  } catch(e) { console.warn('[Repro] addActivity fail', e); }

  // Persistir todo
  try { localStorage.setItem(DB_KEY, JSON.stringify(db)); } catch(e) { console.error('[Repro] save localStorage', e); }

  // Push del parto al server
  _reproPushParto(record);

  closeModal('modal-repro-parto');
  renderReproPartos();
  // Refrescar también Servicios porque cambia el conteo de preñadas pendientes
  if (document.getElementById('repro-tab-servicios')) renderReproServicios();
}

function _reproPushParto(record) {
  var apiUrl = (typeof getApiUrl === 'function') ? getApiUrl() : (localStorage.getItem('e5m_api_url') || 'https://estancia5m-api-production.up.railway.app/api');
  var token = localStorage.getItem('e5m_api_token') || '';
  if (!token) {
    console.log('[Repro] sin token, parto queda local — sync-push lo subirá luego');
    return;
  }
  fetch(apiUrl + '/partos', {
    method: 'POST',
    headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' },
    body: JSON.stringify(record)
  }).then(function(r) { return r.json(); })
    .then(function(resp) { console.log('[Repro] POST parto OK', resp && resp.id); })
    .catch(function(e) { console.warn('[Repro] POST parto fail (sync push retomará)', e); });
}

