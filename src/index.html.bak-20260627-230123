      list.map(function(s){
        var originLabel = s.triggered_by==='auto-push'?'Auto (sync)':s.triggered_by==='auto-desktop'?'Auto (inicio)':s.triggered_by==='pre-restore'?'Pre-restauración':'Manual';
        return '<tr>'+
          '<td style="font-family:DM Mono,monospace">'+new Date(s.created_at).toLocaleString('es-BO')+'</td>'+
          '<td style="font-family:DM Mono,monospace">'+s.size_kb+' KB</td>'+
          '<td style="color:var(--muted)">'+escH(originLabel)+'</td>'+
          '<td style="display:flex;gap:8px">'+
            '<a href="'+apiUrl+'/cloud-backup/'+s.id+'?token='+token+'" download style="color:var(--blue);font-size:11px;text-decoration:none">⬇ Descargar</a>'+
            '<button onclick="restoreCloudSnapshot(\''+s.id+'\',\''+new Date(s.created_at).toLocaleString('es-BO').replace(/'/g,'')+'\')" style="background:none;border:none;color:var(--amber2);font-size:11px;cursor:pointer;text-decoration:underline">🔄 Restaurar</button>'+
          '</td></tr>';
      }).join('')+
