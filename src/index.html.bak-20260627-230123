// ══════════════════════════════════════════════════
// CENTRO DE ATENCIÓN OPERATIVA (v1.4.85)
// ══════════════════════════════════════════════════
// Sistema de detectores automáticos que analizan el estado actual de la app
// y generan alertas accionables. Cada detector retorna un array de alertas.
// Severidad: 'critico' (acción hoy) | 'atencion' (esta semana) | 'sugerencia' (cuando puedas)
// Cada alerta lleva: { id, severity, icon, title, msg, action_label?, action_fn? }

window._centroAtencionState = { current_filter: 'all', alerts_cache: [] };

function _detectarAlertas() {
  var out = [];
  var hoy = new Date();
  var hoyMs = hoy.getTime();
  var lots = (db.lots || []).filter(function(l) {
    return !l.status || l.status === 'activo' || l.status === 'active';
  });
  var animales = (typeof getAnimalesDB === 'function') ? getAnimalesDB() : {};
  var params = {};
  try { params = JSON.parse(localStorage.getItem('e5m_params') || '{}'); } catch(e){}

  // ────────────────────────────────────────────
  // 🔴 CRÍTICO — acción hoy
  // ────────────────────────────────────────────

  // 1) Lotes con animales sin pesar hace >60 días
  lots.forEach(function(lot) {
    var animArr = animales[lot.code] || [];
    if (!animArr.length) return;
    var animalesSinPesar = animArr.filter(function(a) {
      var ps = a.pesajes || [];
      if (!ps.length) return true;  // nunca pesados
      var ultPesaje = ps[ps.length-1].fecha;
      if (!ultPesaje) return false;
      var diasDesde = Math.floor((hoyMs - new Date(ultPesaje).getTime()) / 86400000);
      return diasDesde > 60;
    });
    if (animalesSinPesar.length >= 5) {
      out.push({
        id: 'sin-pesar-' + lot.code,
        severity: 'critico',
        icon: '⚖️',
        title: animalesSinPesar.length + ' animales en ' + lot.code + ' sin pesar hace >60 días',
        msg: 'No se puede calcular GMD ni proyectar venta sin pesajes recientes',
        action_label: 'Pesar lote',
        action_fn: "showPage('lotes',null);setTimeout(function(){showLotesTab('lotes-tab-pesajes',document.getElementById('lotes-tab-pesajes-btn'));openModalPesaje('" + escH(lot.code).replace(/'/g, "\\'") + "');},150)"
      });
    }
  });

  // 2) Potreros sobrepoblados (basado en capacidad configurada)
  // capacidad viene de params.potreros[i].capacidad o params.potreros[i].cap_max
  var potrerosCfg = {};
  (params.potreros || []).forEach(function(p) {
    if (typeof p !== 'object') return;
    var nombre = p.name || p.nombre || '';
    if (nombre) potrerosCfg[nombre] = p.capacidad || p.cap_max || 0;
  });
  var potreroOcupacion = {};
  lots.forEach(function(lot) {
    if (!lot.paddock) return;
    if (!potreroOcupacion[lot.paddock]) potreroOcupacion[lot.paddock] = { count: 0, lotes: [] };
    potreroOcupacion[lot.paddock].count += (lot.animal_count || 0);
    potreroOcupacion[lot.paddock].lotes.push(lot.code);
  });
  Object.keys(potreroOcupacion).forEach(function(potrero) {
    var cap = potrerosCfg[potrero];
    if (!cap || cap <= 0) return;
    var ocup = potreroOcupacion[potrero].count;
    var pct = Math.round((ocup / cap) * 100);
    if (pct > 130) {
      out.push({
        id: 'sobrepob-' + potrero,
        severity: 'critico',
        icon: '🚜',
        title: 'Potrero ' + potrero + ' al ' + pct + '% de capacidad (' + ocup + '/' + cap + ' cab)',
        msg: 'Rotar urgente antes de degradar el pasto. Lotes: ' + potreroOcupacion[potrero].lotes.join(', '),
        action_label: 'Ver rotación',
        action_fn: "goToRotacion(null)"
      });
    }
  });

  // 3) Animales en cuarentena hace >30 días
  var lotesCuarentena = (db.lots || []).filter(function(l) {
    return l.status === 'cuarentena' || l.status === 'marcado';
  });
  lotesCuarentena.forEach(function(lot) {
    if (!lot.entry_date) return;
    var dias = Math.floor((hoyMs - new Date(lot.entry_date).getTime()) / 86400000);
    if (dias > 30) {
      out.push({
        id: 'cuar-old-' + lot.code,
        severity: 'critico',
        icon: '🚧',
        title: lot.code + ' en cuarentena hace ' + dias + ' días',
        msg: (lot.animal_count || 0) + ' animales pendientes de asignación definitiva a lote',
        action_label: 'Procesar cuarentena',
        action_fn: "showPage('compra-ganado',null)"
      });
    }
  });

  // 4) Diferencias de conteo no resueltas (alertas reactivas existentes)
  (db.alerts || []).forEach(function(a) {
    if (a.resolved) return;
    if (a.type === 'conteo_diff') {
      out.push({
        id: 'conteo-' + a.id,
        severity: 'critico',
        icon: '🔢',
        title: a.title,
        msg: a.message,
        action_label: 'Resolver',
        action_fn: "resolveAlert('" + String(a.id).replace(/'/g, "\\'") + "');renderCentroAtencion()"
      });
    }
  });

  // 5) Lotes con CV > 15% (oportunidad de separación)
  lots.forEach(function(lot) {
    var animArr = animales[lot.code] || [];
    if (animArr.length < 10) return;  // muy pocos animales, no aplica
    var pesos = animArr.map(function(a) {
      var ps = a.pesajes || [];
      return ps.length ? ps[ps.length-1].peso : 0;
    }).filter(function(w){return w>0;});
    if (pesos.length < 10) return;
    var avg = pesos.reduce(function(s,w){return s+w;},0) / pesos.length;
    var variance = pesos.reduce(function(s,w){return s + Math.pow(w-avg, 2);},0) / pesos.length;
    var stdev = Math.sqrt(variance);
    var cv = (stdev / avg) * 100;
    if (cv > 15) {
      out.push({
        id: 'cv-alto-' + lot.code,
        severity: 'critico',
        icon: '📊',
        title: lot.code + ' con CV ' + cv.toFixed(1) + '% — alta dispersión',
        msg: 'Promedio ' + avg.toFixed(0) + ' kg, σ ' + stdev.toFixed(0) + ' kg. Conviene separar por afinidad de peso',
        action_label: 'Ver histograma',
        action_fn: "goToAnimales(null);setTimeout(function(){var s=document.getElementById('animales-lot-filter');if(s){s.value='" + escH(lot.code).replace(/'/g, "\\'") + "';renderAnimalesLote();}},200)"
      });
    }
  });

  // ────────────────────────────────────────────
  // 🟡 ATENCIÓN — esta semana
  // ────────────────────────────────────────────

  // 6) Tratamientos programados próximos (3-7 días)
  (db.alerts || []).forEach(function(a) {
    if (a.resolved) return;
    if (a.type === 'treatment_due') {
      out.push({
        id: 'trat-' + a.id,
        severity: 'atencion',
        icon: '💉',
        title: a.title,
        msg: a.message,
        action_label: 'Ver sanidad',
        action_fn: "showPage('sanidad',null)"
      });
    }
  });

  // 7) Lotes listos para venta (peso promedio > umbral configurable, GMD positivo)
  var umbralVenta = (params.peso_venta_objetivo || 450);
  lots.forEach(function(lot) {
    if (!lot.avg_weight || lot.avg_weight < umbralVenta) return;
    var animArr = animales[lot.code] || [];
    if (!animArr.length) return;
    out.push({
      id: 'listo-venta-' + lot.code,
      severity: 'atencion',
      icon: '💰',
      title: lot.code + ' listo para evaluar venta',
      msg: 'Peso prom ' + lot.avg_weight + ' kg (objetivo ' + umbralVenta + ' kg) · ' + (lot.animal_count || 0) + ' cab',
      action_label: 'Ver lote',
      action_fn: "showPage('analisis-lote',null);setTimeout(function(){var s=document.getElementById('al-lot-select');if(s){s.value='" + escH(lot.code).replace(/'/g, "\\'") + "';renderAnalisisLote();}},200)"
    });
  });

  // 8) Lotes sin pesaje en >30 días (algunos pesados pero no recientes)
  lots.forEach(function(lot) {
    var animArr = animales[lot.code] || [];
    if (!animArr.length) return;
    // Últimas fechas de pesaje
    var ultFechas = animArr.map(function(a) {
      var ps = a.pesajes || [];
      return ps.length ? ps[ps.length-1].fecha : null;
    }).filter(Boolean);
    if (!ultFechas.length) return;
    ultFechas.sort();
    var maxFecha = ultFechas[ultFechas.length-1];
    var dias = Math.floor((hoyMs - new Date(maxFecha).getTime()) / 86400000);
    // Solo si NO entró en la alerta crítica de >60 días
    if (dias > 30 && dias <= 60) {
      // Verificar que no haya entrado en crítica
      var yaEnCritica = out.some(function(o){ return o.id === 'sin-pesar-' + lot.code; });
      if (!yaEnCritica) {
        out.push({
          id: 'pesaje-30-' + lot.code,
          severity: 'atencion',
          icon: '⚖️',
          title: lot.code + ' sin pesaje hace ' + dias + ' días',
          msg: (lot.animal_count || 0) + ' animales. Pesar pronto para mantener GMD actualizada',
          action_label: 'Pesar',
          action_fn: "showPage('lotes',null);setTimeout(function(){showLotesTab('lotes-tab-pesajes',document.getElementById('lotes-tab-pesajes-btn'));openModalPesaje('" + escH(lot.code).replace(/'/g, "\\'") + "');},150)"
        });
      }
    }
  });

  // 9) Personal con adelantos no descontados > 7 días
  // El campo es `status` con valor 'descontado' o 'pendiente', y `employee` (nombre).
  (db.advances || []).forEach(function(adv) {
    if (adv.status === 'descontado') return;  // ya descontado, no hay alerta
    if (!adv.date) return;
    var dias = Math.floor((hoyMs - new Date(adv.date).getTime()) / 86400000);
    if (dias > 7) {
      var nombre = adv.employee || 'empleado #' + (adv.employee_id || '?');
      out.push({
        id: 'adv-' + adv.id,
        severity: 'atencion',
        icon: '👷',
        title: 'Adelanto pendiente · ' + nombre,
        msg: 'Bs. ' + (adv.amount || 0).toLocaleString() + ' del ' + adv.date + ' (' + dias + ' días)' +
             (adv.reason ? ' · ' + adv.reason : ''),
        action_label: 'Ver personal',
        action_fn: "showPage('personal',null)"
      });
    }
  });

  // 10) Stock bajo (alertas reactivas existentes)
  (db.alerts || []).forEach(function(a) {
    if (a.resolved) return;
    if (a.type === 'stock_low') {
      out.push({
        id: 'stock-' + a.id,
        severity: 'atencion',
        icon: '📦',
        title: a.title,
        msg: a.message,
        action_label: 'Ver stock',
        action_fn: "showPage('stock',null)"
      });
    }
  });

  // ────────────────────────────────────────────
  // 🔵 SUGERENCIA — cuando puedas
  // ────────────────────────────────────────────

  // 11) Lotes similares que podrían fusionarse
  if (lots.length >= 2) {
    var lotsConPeso = lots.filter(function(l){ return l.avg_weight > 0 && (l.animal_count||0) > 0; });
    for (var i = 0; i < lotsConPeso.length; i++) {
      for (var j = i+1; j < lotsConPeso.length; j++) {
        var a = lotsConPeso[i], b = lotsConPeso[j];
        if (a.category !== b.category) continue;  // solo misma categoría
        var diff = Math.abs(a.avg_weight - b.avg_weight);
        if (diff <= 10) {
          out.push({
            id: 'merge-' + a.code + '-' + b.code,
            severity: 'sugerencia',
            icon: '🔗',
            title: a.code + ' y ' + b.code + ' tienen pesos similares',
            msg: a.avg_weight + ' vs ' + b.avg_weight + ' kg (Δ ' + diff.toFixed(1) + ' kg). Considerar fusionar para optimizar manejo',
            action_label: 'Ver lotes',
            action_fn: "goToLotes(null)"
          });
          break;  // solo una sugerencia por lote
        }
      }
    }
  }

  // 12) Lotes pequeños (< 10 cab) — candidatos a fusionar
  lots.forEach(function(lot) {
    if (!lot.animal_count) return;
    if (lot.animal_count < 10 && lot.animal_count > 0) {
      out.push({
        id: 'lot-chico-' + lot.code,
        severity: 'sugerencia',
        icon: '📉',
        title: lot.code + ' tiene solo ' + lot.animal_count + ' cab',
        msg: 'Lotes pequeños son ineficientes operativamente. Considerar fusión con otro lote similar',
        action_label: 'Ver lote',
        action_fn: "goToLotes(null)"
      });
    }
  });

  // 13) Pluviometría: si llovió en la zona y no hay registro reciente (sugerencia ligera)
  // Lo dejamos para una iteración futura — requiere integración con weather API.

  // v1.8.0: 14-15-16) Alertas reproductivas (delegamos a _reproDetectarAlertas)
  // que ya hace todo el análisis. Las traducimos al formato del centro de atención.
  try {
    if (typeof _reproDetectarAlertas === 'function') {
      var reproAlerts = _reproDetectarAlertas();
      reproAlerts.forEach(function(ra, idx) {
        var sevMap = { critico: 'critico', alto: 'alto', medio: 'medio' };
        out.push({
          id: 'repro-' + idx + '-' + (ra.title || '').slice(0, 20).replace(/\s/g, '_'),
          severity: sevMap[ra.severity] || 'medio',
          icon: ra.icon || '🧬',
          title: ra.title,
          msg: ra.msg,
          action_label: ra.action_label || 'Ver Reproducción',
          action_fn: ra.action || "showPage('reproduccion',null);setTimeout(initReproduccion,150)"
        });
      });
    }
  } catch(e) { console.warn('[centroAtencion] repro alerts', e); }

  // v1.8.1: 17) Lotes activos con 0 animales (post-fusión / post-venta sin marcar)
  try {
    var lotesVacios = (db.lots || []).filter(function(l) {
      if (!l) return false;
      var st = String(l.status || '').toLowerCase();
      // Ignorar los ya marcados como vendidos / fusionados
      if (st === 'vendido' || st === 'sold' || st === 'fusionado' || st === 'merged') return false;
      var count = parseFloat(l.animal_count) || 0;
      // También verificar e5m_animals porque animal_count puede estar desincronizado
      var realCount = 0;
      try {
        var animArr = animales[l.code] || [];
        realCount = animArr.length;
      } catch(e){}
      return count === 0 && realCount === 0;
    });
    if (lotesVacios.length > 0) {
      var codigos = lotesVacios.map(function(l) { return l.code; }).slice(0, 5).join(', ');
      var extra = lotesVacios.length > 5 ? ' y ' + (lotesVacios.length - 5) + ' más' : '';
      out.push({
        id: 'lotes-vacios-' + lotesVacios.length,
        severity: 'medio',
        icon: '🗑',
        title: lotesVacios.length + ' lote' + (lotesVacios.length > 1 ? 's' : '') + ' activo' + (lotesVacios.length > 1 ? 's' : '') + ' con 0 animales',
        msg: codigos + extra + ' — posible fusión/venta no marcada. Revisar y eliminar o cambiar estado.',
        action_label: 'Ver lotes',
        action_fn: "showPage('lotes',null);setTimeout(function(){if(typeof showLotesTab==='function'){showLotesTab('lotes-tab-list',document.getElementById('lotes-tab-list-btn'));}},120)"
      });
    }
  } catch(e) { console.warn('[centroAtencion] lotes vacios', e); }

  return out;
}

function renderCentroAtencion() {
  var alerts;
  try {
    alerts = _detectarAlertas();
  } catch(e) {
    console.error('[CentroAtencion] error:', e);
    alerts = [];
  }
  window._centroAtencionState.alerts_cache = alerts;

  var counts = {
    critico: alerts.filter(function(a){return a.severity === 'critico';}).length,
    atencion: alerts.filter(function(a){return a.severity === 'atencion';}).length,
    sugerencia: alerts.filter(function(a){return a.severity === 'sugerencia';}).length
  };

  // Counters
  var countersEl = document.getElementById('alertas-counters');
  if (countersEl) {
    var totalActivas = counts.critico + counts.atencion + counts.sugerencia;
    countersEl.innerHTML =
      _renderCounterCard('🔴', counts.critico, 'Críticas', 'critico', 'var(--red)') +
      _renderCounterCard('🟡', counts.atencion, 'Atención', 'atencion', 'var(--amber2)') +
      _renderCounterCard('🔵', counts.sugerencia, 'Sugerencias', 'sugerencia', 'var(--blue)') +
      _renderCounterCard('✅', '', 'En orden', null, 'var(--green)', totalActivas === 0);
  }

  // Subtitle dinámico
  var subEl = document.getElementById('alertas-subtitle');
  if (subEl) {
    var lastUpd = new Date().toLocaleTimeString('es-BO', { hour: '2-digit', minute: '2-digit' });
