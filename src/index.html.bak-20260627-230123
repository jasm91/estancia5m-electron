function saveEditAnimalId() {
  var lotCode=document.getElementById('edit-aid-lot').value;
  var idx=parseInt(document.getElementById('edit-aid-idx').value);
  var nuevoId=((document.getElementById('edit-aid-value')||{}).value||'').trim()||'N/A';
  var animalesDB=getAnimalesDB();
  var lista=animalesDB[lotCode]||[];
  if(!lista[idx])return;
  var idAnterior = String(lista[idx].animal_id || lista[idx].id || '');   // v1.8.75: robusto (crías de parto no tienen .id)
  // v1.8.78: GUARD anti-colisión — bloquear si el ID nuevo ya existe en OTRO animal (cualquier lote).
  if (nuevoId && nuevoId !== 'N/A' && nuevoId !== idAnterior) {
    var _colLote = null;
    Object.keys(animalesDB).forEach(function(_lc){
      (animalesDB[_lc]||[]).forEach(function(_a,_i){
        if (_lc===lotCode && _i===idx) return;
        if (String(_a.animal_id||_a.id||'')===nuevoId) _colLote = _lc;
      });
    });
    if (_colLote) { toast('Ya existe un animal con ID "'+nuevoId+'" en el lote '+_colLote+'. Elegí otro ID/arete.','error'); return; }
  }
  lista[idx].id=nuevoId;
  lista[idx].animal_id=nuevoId; // FIX v1.4.29: persistir en ambos campos para que sync sea consistente
  lista[idx].id_updated_at = new Date().toISOString(); // FIX v1.4.29: marca temporal para merge correcto en sync-pull
  localStorage.setItem('e5m_animals',JSON.stringify(animalesDB));
  // v1.8.76 (Opción acotada): registrar el rename {lote, idViejo, idNuevo} para proteger SOLO este animal del
  // server-wins hasta que el push confirme (se limpia e5m_pending_renames en push OK). Reemplaza la ventana de 60s.
  if (idAnterior && idAnterior !== nuevoId) {
    try {
      var _pr = JSON.parse(localStorage.getItem('e5m_pending_renames')||'[]'); if (!Array.isArray(_pr)) _pr = [];
      _pr = _pr.filter(function(r){ return !(r && r.lot===lotCode && String(r.oldId)===String(idAnterior) && String(r.newId)===String(nuevoId)); });
      _pr.push({ lot: lotCode, oldId: idAnterior, newId: nuevoId });
      localStorage.setItem('e5m_pending_renames', JSON.stringify(_pr));
    } catch(e) {}
  }

  // v1.8.75: PROPAGAR el cambio de ID a TODO lo que referencia este animal por su id (string).
  // Sin esto se rompía la trazabilidad individual: pesajes, curaciones, movimientos, bajas, partos
  // (cría/madre/padre), servicios reproductivos y ventas quedaban con el ID viejo.
  var _propCount = 0;
  if (idAnterior && idAnterior !== nuevoId) {
    function _mapIds(arr){ return arr.map(function(x){ if(String(x)===idAnterior){ _propCount++; return nuevoId; } return x; }); }
    (db.pesajes||[]).forEach(function(r){ if(String(r.animal_id||'')===idAnterior){ r.animal_id=nuevoId; _propCount++; } });
    (db.treatments||[]).forEach(function(r){ if(String(r.animal_id||'')===idAnterior){ r.animal_id=nuevoId; _propCount++; } if(Array.isArray(r.animal_ids)) r.animal_ids=_mapIds(r.animal_ids); });
    (db.animal_movements||[]).forEach(function(r){ if(String(r.animal_id||'')===idAnterior){ r.animal_id=nuevoId; _propCount++; } if(Array.isArray(r.animal_ids)) r.animal_ids=_mapIds(r.animal_ids); });
    (db.bajas||[]).forEach(function(r){ if(String(r.animal_id||'')===idAnterior){ r.animal_id=nuevoId; _propCount++; } if(r.animal_snapshot){ if(String(r.animal_snapshot.id||'')===idAnterior) r.animal_snapshot.id=nuevoId; if(String(r.animal_snapshot.animal_id||'')===idAnterior) r.animal_snapshot.animal_id=nuevoId; } });
    (db.partos||[]).forEach(function(r){ if(String(r.cria_id||'')===idAnterior){ r.cria_id=nuevoId; _propCount++; } if(String(r.madre_id||'')===idAnterior){ r.madre_id=nuevoId; _propCount++; } if(String(r.padre_id||'')===idAnterior){ r.padre_id=nuevoId; _propCount++; } });
    (db.reproductive_services||[]).forEach(function(r){ if(String(r.animal_id||'')===idAnterior){ r.animal_id=nuevoId; _propCount++; } });
    (db.sales||[]).forEach(function(r){ if(Array.isArray(r.animal_ids)) r.animal_ids=_mapIds(r.animal_ids); });
    if (typeof saveDB === 'function') saveDB();
  }

  // FIX v1.4.29: Disparar push inmediato al server para evitar que un sync-pull sobreescriba el cambio.
  // Sin esto, si entra un pull antes del próximo push automático, el server (que aún tiene el ID viejo)
  // pisa el cambio local y al reabrir el modal vuelve a aparecer el ID original.
  if (typeof pushToRailway === 'function') {
    try { pushToRailway(); } catch(e) { console.error('[saveEditAnimalId] push failed:', e); }
  }

  // v1.8.78: registrar el rename en Auditoría y Actividad (antes no quedaba en ningún lado → imposible rastrear).
  if (idAnterior && idAnterior !== nuevoId) {
    try { auditLog('update','animals', nuevoId, 'Cambio de ID: '+idAnterior+' → '+nuevoId+' (lote '+lotCode+(_propCount?', '+_propCount+' registros migrados':'')+')', { animal_id:[idAnterior,nuevoId] }); } catch(e){}
    try { if (typeof addActivity==='function') addActivity((typeof _desktopAuthor==='function'?_desktopAuthor():'Escritorio'),'otro',lotCode,'Cambio de ID de animal: '+idAnterior+' → '+nuevoId+' en '+lotCode); } catch(e){}
  }
  closeModal('modal-edit-animal-id');
  renderAnimalesLote();
  toast(_propCount ? ('ID actualizado: '+idAnterior+' → '+nuevoId+' · '+_propCount+' registro(s) vinculados migrados') : ('ID actualizado: '+idAnterior+' → '+nuevoId),'success');
}

