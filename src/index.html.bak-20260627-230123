  var selVehiculo = (document.getElementById('diesel-f-vehiculo')||{}).value || '';
  var selMonth = parseInt((document.getElementById('diesel-f-month')||{}).value || '0');

  var registros = db.diesel.filter(function(r){
    if (selType && (r.type||'despacho') !== selType) return false;
    if (selVehiculo && r.vehiculo !== selVehiculo) return false;
    if (selMonth) { var m = parseInt((r.fecha||'').slice(5,7)); if (m !== selMonth) return false; }
    return true;
  });

  var tbody = document.getElementById('diesel-tbody');
  if (tbody) {
    if (!registros.length) {
      tbody.innerHTML = '<tr><td colspan="9" style="text-align:center;padding:24px;color:var(--muted)">Sin registros</td></tr>';
