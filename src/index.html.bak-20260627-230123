// v1.8.55: recalcula una fila cuando se editan los días trabajados
function recalcPsRow(input){
  var tr = input.closest('tr'); if(!tr) return;
  var diasMes = parseInt(tr.dataset.diasMes,10)||30;
  var salarioBase = parseFloat(tr.dataset.salarioBase)||0;
  var adelantos = parseFloat(tr.dataset.adelantos)||0;
  var deudaPrevia = parseFloat(tr.dataset.deudaPrevia)||0;  // v1.8.57
  var dias = parseInt(input.value,10);
  if(isNaN(dias)||dias<0) dias=0;
  if(dias>diasMes){ dias=diasMes; input.value=diasMes; }
  var salarioProrr = diasMes>0 ? Math.round((salarioBase/diasMes)*dias) : salarioBase;
  // v1.8.57: balance = salario prorrateado − deuda previa − adelantos
  var balance = salarioProrr - deudaPrevia - adelantos;
  var neto = Math.max(0, balance);
  tr.dataset.dias = dias;
  tr.dataset.salario = salarioProrr;
  tr.dataset.neto = neto;
  tr.dataset.deudaResultante = balance < 0 ? Math.abs(balance) : 0;
  var salCell = tr.querySelector('.ps-salario-cell');
  if(salCell) salCell.innerHTML = 'Bs. '+salarioProrr.toLocaleString()+'<div style="font-size:9px;color:var(--muted)">base '+salarioBase.toLocaleString()+'</div>';
  var netoCell = tr.querySelector('.ps-neto-cell');
  if(netoCell) netoCell.textContent = 'Bs. '+neto.toLocaleString();
  updatePsTotal();
}

function updatePsTotal(){
  var total=0,count=0;
  document.querySelectorAll('.ps-emp-check').forEach(function(cb){
    if(cb.checked){
      var tr=cb.closest('tr');
      total+=parseFloat(tr.dataset.neto)||0;
      count++;
    }
  });
  var totalEl=document.getElementById('ps-total-amount');
  if(totalEl)totalEl.textContent='Bs. '+total.toLocaleString()+' ('+count+' empleado'+(count===1?'':'s')+')';
  var btn=document.getElementById('ps-guardar-btn');
  if(btn)btn.textContent=count>0?('Registrar '+count+' pago'+(count===1?'':'s')):'Registrar pagos';
}

// v1.8.57: un período (YYYY-MM) está cerrado si hay al menos un pago en historial_sueldos
// para ese mes con estado 'pagado'. Se deriva del historial (sincroniza solo, sin array aparte).
// v1.8.59: el "cierre" es POR EMPLEADO, no global. Un empleado tiene su mes cerrado
// cuando se le pagó su sueldo de ese mes (existe historial_sueldos pagado para él+mes).
// Pagarle el sueldo a uno NO bloquea adelantos para los demás.
function _empMesPagado(empName, mes){
  if(!empName || !mes) return false;
  return (db.historial_sueldos||[]).some(function(r){
    return r.empleado===empName && r.mes===mes && r.estado==='pagado';
  });
}
function guardarPagoSueldo(){
  var mes=(document.getElementById('ps-mes')||{}).value||'';
  var fecha=(document.getElementById('ps-fecha')||{}).value||'';
  var notas=((document.getElementById('ps-notas')||{}).value||'').trim();
  if(!mes){toast('Selecciona el mes','error');return;}
  if(!fecha){toast('Selecciona la fecha de pago','error');return;}
  // FIX v1.4.34: no permitir fechas futuras
  if(!validateNotFuture(fecha, 'fecha de pago')) return;
  if(!db.historial_sueldos)db.historial_sueldos=[];

  var seleccionados=[];
  document.querySelectorAll('.ps-emp-check').forEach(function(cb){
    if(cb.checked){
      var tr=cb.closest('tr');
      seleccionados.push({
        emp:tr.dataset.empName,
        salario:parseFloat(tr.dataset.salario)||0,
        adelantos:parseFloat(tr.dataset.adelantos)||0,
        neto:parseFloat(tr.dataset.neto)||0,
        dias:parseInt(tr.dataset.dias,10)||0,
        dias_mes:parseInt(tr.dataset.diasMes,10)||0,
        salario_base:parseFloat(tr.dataset.salarioBase)||0,
        deuda_previa:parseFloat(tr.dataset.deudaPrevia)||0,
        deuda_resultante:parseFloat(tr.dataset.deudaResultante)||0
      });
    }
  });
  if(!seleccionados.length){toast('Seleccioná al menos un empleado','error');return;}

  var registrados=0;
  seleccionados.forEach(function(s){
    var existing=db.historial_sueldos.find(function(r){return r.empleado===s.emp&&r.mes===mes;});
    if(existing){
      existing.salario=s.salario;existing.adelantos=s.adelantos;existing.pago_neto=s.neto;
      existing.dias=s.dias;existing.dias_mes=s.dias_mes;existing.salario_base=s.salario_base;
      existing.deuda_previa=s.deuda_previa;existing.deuda_resultante=s.deuda_resultante;
      existing.fecha_pago=fecha;existing.notas=notas;existing.estado='pagado';
      existing.updated_at=new Date().toISOString();
    }else{
      db.historial_sueldos.push({
        id:Date.now()+Math.floor(Math.random()*1000),
        empleado:s.emp,mes:mes,salario:s.salario,
        adelantos:s.adelantos,pago_neto:s.neto,
        dias:s.dias,dias_mes:s.dias_mes,salario_base:s.salario_base,
        deuda_previa:s.deuda_previa,deuda_resultante:s.deuda_resultante,
        fecha_pago:fecha,notas:notas,estado:'pagado',
        created_at:new Date().toISOString()
      });
    }
    // v1.8.57: persistir la deuda resultante en el empleado (se arrastra al mes siguiente)
    var empObj=db.employees.find(function(e){return e.name===s.emp;});
    if(empObj){ empObj.deuda_arrastrada = s.deuda_resultante; }
    registrados++;
  });

  // v1.8.57: el período queda "cerrado" por la existencia de pagos en historial_sueldos
  // para ese mes (estado 'pagado'). No se usa un array aparte → sincroniza solo vía historial.

  saveDB();
  closeModal('modal-pago-sueldo');
  if(typeof renderHistorialSueldos==='function')renderHistorialSueldos();
  if(typeof renderPersonal==='function')renderPersonal();
