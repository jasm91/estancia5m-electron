function renderActivitiesDesktop() {
  var al = document.getElementById('activities-list');
  if (!al) return;

  // Poblar filtro empleados
  var empFilter = document.getElementById('act-filter-emp');
  if (empFilter && empFilter.options.length <= 1) {
    db.employees.filter(function(e){return e.active;}).forEach(function(e){
      var o=document.createElement('option');o.value=e.name;o.textContent=e.name;empFilter.appendChild(o);
    });
  }

  var filterEmp = (empFilter||{}).value || '';
  var filterType = (document.getElementById('act-filter-type')||{}).value || '';

  // Calcular fecha límite según período
  var now = new Date();
  var desde = null;
  if (_actPeriod === 'hoy') {
    desde = localDate(now);
  } else if (_actPeriod === 'semana') {
    var d = new Date(now); d.setDate(d.getDate()-7);
    desde = localDate(d);
  } else if (_actPeriod === 'mes') {
    var d2 = new Date(now); d2.setDate(d2.getDate()-30);
    desde = localDate(d2);
  }

  // Recopilar actividades de todas las fuentes
  var all = [];

  // Actividades manuales (field_activities)
  if (!filterType || filterType==='actividad' || filterType==='movimiento') {
    (db.activities||[]).forEach(function(a){
      if (filterEmp && a.employee !== filterEmp) return;
      if (filterType==='movimiento' && a.type!=='movimiento') return;
      if (filterType==='actividad' && a.type==='movimiento') return;
      all.push({
        fecha: a.date||'', tipo:'actividad', tag:a.type||'ACT',
        titulo: a.desc||'', sub:'', lote: a.lot||'',
        empleado: a.employee||'', color:'var(--blue)',
        id: a.id, fuente:'actividad'
      });
    });
  }

  // Tratamientos/curaciones
  if (!filterType || filterType==='curacion') {
    (db.treatments||[]).forEach(function(t){
      if (filterEmp && t.by !== filterEmp) return;
      all.push({
        fecha: t.applied_at||'', tipo:'curacion', tag:'CUR',
        titulo: (t.product_name||'Tratamiento')+' — '+(t.count||0)+' animales',
        sub: t.diagnosis||'', lote: t.lot_code||'',
        empleado: t.by||'', color:'var(--red)',
        id: t.id, fuente:'tratamiento'
      });
    });
  }

  // Pesajes
  if (!filterType || filterType==='pesaje') {
    (db.pesajes||[]).forEach(function(p){
      if (filterEmp) return;
      // Distinguir pesaje de venta vs pesaje normal
      var esVenta = p.tipo === 'venta' || p.nota === 'Peso al momento de venta';
      var titulo, sub;
      if (esVenta) {
        titulo = 'Pesaje de venta — Animal '+escH((p.animal_id||'?').toString())+' — '+( p.peso||'?')+' kg';
        sub = 'Registrado al momento de la venta';
      } else {
        titulo = 'Pesaje lote '+(p.lot_code||'?')+' — prom. '+(p.avg_weight||'?')+' kg';
        sub = (p.animal_count||'?')+' animales pesados';
      }
      all.push({
        fecha: p.date||p.created_at||'', tipo:'pesaje', tag: esVenta?'PES-V':'PES',
        titulo: titulo, sub: sub, lote: p.lot_code||'',
        empleado:'', color: esVenta?'var(--green)':'var(--amber2)',
        id: p.id, fuente:'pesaje'
      });
    });
  }

  // Mantenimiento
  if (!filterType || filterType==='mantenimiento') {
    (db.maintenance||[]).forEach(function(m){
      if (filterEmp && m.who !== filterEmp) return;
      all.push({
        fecha: m.date||'', tipo:'mantenimiento', tag:'MNT',
        titulo: m.title||'Mantenimiento',
        sub: m.location||'', lote:'',
        empleado: m.who||'', color:'var(--green)',
        id: m.id, fuente:'mantenimiento'
      });
    });
  }

  // Conteos
  if (!filterType || filterType==='conteo') {
    (db.conteo||[]).forEach(function(c){
      if (filterEmp) return;
      all.push({
        fecha: c.created_at||c.date||'', tipo:'conteo', tag:'CNT',
        titulo: 'Conteo lote '+c.lot_code+' — '+c.counted+' cabezas',
        sub: c.diff!==0?'Diferencia: '+c.diff+' vs sistema':'', lote: c.lot_code||'',
        empleado:c.by||'', color:'var(--purple)',
        id: c.id, fuente:'conteo'
      });
    });
  }
  // Agua
  if (!filterType || filterType==='agua') {
    (db.agua||[]).forEach(function(r){
      if (filterEmp) return;
      all.push({ fecha:r.created_at||r.date||'', tipo:'agua', tag:'H2O', titulo:'💧 Agua lote '+r.lot_code+' — '+(r.estado||r.nivel||''), sub:r.obs||'', lote:r.lot_code||'', empleado:r.by||'', color:'var(--blue)', id:r.id, fuente:'agua' });
    });
  }
  // Sal
  if (!filterType || filterType==='sal') {
    (db.sal||[]).forEach(function(r){
      if (filterEmp) return;
      all.push({ fecha:r.created_at||r.date||'', tipo:'sal', tag:'SAL', titulo:'🧂 Sal lote '+r.lot_code+' — '+(r.qty||0)+' kg', sub:(r.tipo||'')+(r.obs?' — '+r.obs:''), lote:r.lot_code||'', empleado:r.by||'', color:'var(--amber2)', id:r.id, fuente:'sal' });
    });
  }
  // Partos
  if (!filterType || filterType==='parto') {
    (db.partos||[]).forEach(function(r){
      if (filterEmp) return;
      all.push({ fecha:r.created_at||r.date||'', tipo:'parto', tag:'PAR', titulo:'🐣 Parto lote '+r.lot_code+' — '+(r.sexo==='macho'?'Torillo':'Ternera')+(r.estado==='muerto'?' ❌ Mortinato':''), sub:(r.peso?r.peso+' kg':'')+(r.notes?' — '+r.notes:''), lote:r.lot_code||'', empleado:r.by||'', color:'var(--green)', id:r.id, fuente:'partos' });
    });
  }
  // Alimento
  if (!filterType || filterType==='alimento') {
    (db.alimento||[]).forEach(function(r){
      if (filterEmp) return;
      all.push({ fecha:r.created_at||r.date||'', tipo:'alimento', tag:'ALI', titulo:'🌿 Alimento lote '+r.lot_code+' — '+(r.qty||0)+' kg', sub:r.obs||'', lote:r.lot_code||'', empleado:r.by||'', color:'var(--green)', id:r.id, fuente:'alimento' });
    });
  }
  // Bajas
  if (!filterType || filterType==='baja') {
    (db.bajas||[]).forEach(function(r){
      if (filterEmp) return;
      var ventaInfo = r.venta_registrada ? ' — Vendido Bs.'+(r.venta_total||0) : r.venta_carne ? ' — Venta carne pendiente' : '';
      all.push({ fecha:r.created_at||r.fecha||'', tipo:'baja', tag:'BAJA', titulo:'🪦 Baja #'+(r.animal_id||'?')+' — '+(r.causa||'desconocida')+(r.ultimo_peso?' — '+r.ultimo_peso+' kg':''), sub:(r.obs||'')+ventaInfo, lote:r.lot_code||'', empleado:r.by||'', color:'var(--red)', id:r.id, fuente:'bajas' });
    });
  }
  // Diesel
  if (!filterType || filterType==='diesel') {
    (db.diesel||[]).forEach(function(r){
      if (filterEmp) return;
      var desc = r.type==='recarga' ? '🔄 Recarga diesel: '+(r.litros||0)+' L'+(r.proveedor?' — '+r.proveedor:'') : '⛽ Despacho: '+(r.litros||0)+' L'+(r.vehiculo?' — '+r.vehiculo:'');
      all.push({ fecha:r.created_at||r.fecha||'', tipo:'diesel', tag:r.type==='recarga'?'REC':'DSP', titulo:desc, sub:r.obs||'', lote:'', empleado:r.by||'', color:'var(--blue)', id:r.id, fuente:'diesel' });
    });
  }
  // Compras
  if (!filterType || filterType==='compra') {
    (db.purchases||[]).forEach(function(r){
      if (filterEmp) return;
      all.push({ fecha:r.created_at||r.date||'', tipo:'compra', tag:'COM', titulo:'🛒 Compra: '+(r.desc||'')+(r.qty?' x'+r.qty:''), sub:'Bs. '+(r.total||0)+(r.supplier?' — '+r.supplier:''), lote:'', empleado:r.by||'', color:'var(--purple)', id:r.id, fuente:'purchases' });
    });
  }
  // Ventas
  if (!filterType || filterType==='venta') {
    (db.sales||[]).forEach(function(r){
      if (filterEmp) return;
      var isCarne = r.type==='carne_baja';
      var lotsArr = r.lot_codes && r.lot_codes.length ? r.lot_codes : (r.lot_code ? String(r.lot_code).split(',').map(function(x){return x.trim();}) : []);
      var lotLabel = '';
      if (lotsArr.length > 1) lotLabel = ' — Lotes ' + lotsArr.join(', ') + ' (mix)';
      else if (lotsArr.length === 1) lotLabel = ' — Lote ' + lotsArr[0];
      all.push({ fecha:r.created_at||r.date||'', tipo:'venta', tag:isCarne?'V-CR':'VTA', titulo:(isCarne?'🪦':'💰')+' Venta: '+(r.buyer||'')+lotLabel, sub:(r.animals||r.animal_count||0)+' cab — '+(r.kg||r.total_kg||0)+' kg — Bs. '+(r.total||0), lote:r.lot_code||'', empleado:r.by||'', color:'var(--green)', id:r.id, fuente:'sales' });
    });
  }
  // Adelantos
  if (!filterType || filterType==='adelanto') {
