    items.push({
      product_id: pid, product_name: prod.name, unit: prod.unit || 'ml',
      stock_teorico: prod.stock_qty, stock_fisico: fisico,
      diferencia: diff,
      costo_merma: diff < 0 ? Math.round(Math.abs(diff) * (prod.unit_cost || 0) * 100) / 100 : 0,
      motivo: motivo
    });
    if (diff < 0) totalMerma += Math.abs(diff) * (prod.unit_cost || 0);
  });
  if (!items.length) { toast('No hay productos para contar', 'error'); return; }
  var conDiff = items.filter(function(i) { return i.diferencia !== 0; });
  if (conDiff.length === 0 && !confirm('Todos los conteos coinciden. ¿Guardar?')) return;
  if (conDiff.length > 0 && !confirm(conDiff.length + ' diferencias encontradas.Merma: Bs. ' + Math.round(totalMerma) + '\n' + (ajustar ? 'Stock se AJUSTARÁ.' : 'Stock NO se ajustará.') + '\n\n¿Guardar?')) return;
  if (!db.inventory_counts) db.inventory_counts = [];
  db.inventory_counts.push({
    id: 'ic_' + Date.now(), date: date, by: by, items: items,
    total_merma_bs: Math.round(totalMerma * 100) / 100,
    total_items: items.length, items_con_diferencia: conDiff.length,
    ajustado: ajustar, created_at: new Date().toISOString()
  });
  if (ajustar) {
    items.forEach(function(item) {
      var prod = db.products.find(function(p) { return p.id === item.product_id; });
      if (prod && item.diferencia !== 0) {
        prod.stock_qty = item.stock_fisico;
        prod.stock_updated_at = new Date().toISOString();
      }
    });
  }
  saveDB();
  pushTableToRailway('inventory_counts', db.inventory_counts);
  if (ajustar) replaceTableInRailway('vet_products', db.products);
  if (overlay) overlay.remove();
  renderStock();
  toast('✅ Conteo guardado' + (conDiff.length ? ' — ' + conDiff.length + ' ajustes, merma: Bs. ' + Math.round(totalMerma) : ' — sin diferencias'), 'success');
}

