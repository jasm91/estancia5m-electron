      id:'trat-'+t.id, cuenta:'COSTOS', subcuenta:'Sanidad', tipo_gasto:'VARIABLE',
      tipo:'VARIABLE', fecha:t.applied_at,
      detalle:(t.product_name||'Tratamiento')+(t.lot_code?' - Lote '+t.lot_code:''),
      monto:t.cost||0, origen:'auto', by:t.by||''
    });
  });

  // COSTOS: de diesel (solo recargas que tienen costo)
  (db.diesel||[]).filter(function(d){ return d.type==='recarga' && d.total; }).forEach(function(d) {
    if (!d.fecha) return;
