  };
  if (type === 'movimiento') {
    return (db.activities||[]).find(function(r){ return String(r.id)===String(id); });
  }
  if (type === 'tarea') {
    try { var tasks = JSON.parse(localStorage.getItem('e5m_tasks')||'[]'); return tasks.find(function(t){ return String(t.id)===String(id); }); } catch(e){ return null; }
  }
  var tbl = tableMap[type];
  if (!tbl || !db[tbl]) return null;
  return db[tbl].find(function(r){ return String(r.id)===String(id); });
}

