function getDieselTanks() {
  try {
    var v = localStorage.getItem('e5m_diesel_tank');
    if (!v) return [{id:'tank_1',name:'Cisterna Principal',capacity:1000,current_level:0}];
    var parsed = JSON.parse(v);
    // Backward compat: old single tank → convert to array
    if (!Array.isArray(parsed)) {
      return [{id:'tank_1',name:parsed.name||'Cisterna Principal',capacity:parsed.capacity||1000,current_level:parsed.current_level||0}];
    }
    return parsed.length ? parsed : [{id:'tank_1',name:'Cisterna Principal',capacity:1000,current_level:0}];
  } catch(e) { return [{id:'tank_1',name:'Cisterna Principal',capacity:1000,current_level:0}]; }
}
function saveDieselTanks(tanks) {
  localStorage.setItem('e5m_diesel_tank', JSON.stringify(tanks));
  // FIX v1.4.33: timestamp en clave separada para last-write-wins en sync.
  // diesel_tank es array, no se le puede meter updated_at directo.
  localStorage.setItem('e5m_diesel_tank_updated_at', new Date().toISOString());
  replaceTableInRailway('diesel_tank', tanks);
}
function getTankById(tanks, id) {
  return tanks.find(function(t){ return t.id === id; }) || tanks[0];
}

// v1.8.66: fecha EFECTIVA de un movimiento de diésel = la que el usuario ELIGIÓ en el modal
// (`fecha`; los de WhatsApp viejos usan `date`). Fallback: día LOCAL del created_at.
// `created_at` queda solo como timestamp de registro (trazabilidad) y desempate.
function dieselFechaEfectiva(r) {
  var f = r.fecha || r.date || '';
  if (f) return f.toString().slice(0, 10);
  if (r.created_at) { var s = fmtDT(r.created_at); if (s) return s.slice(0, 10); }
  return '';
}
// Comparador ascendente: fecha efectiva primero, created_at como desempate (mismo día).
function dieselCmpAsc(a, b) {
  var fa = dieselFechaEfectiva(a), fb = dieselFechaEfectiva(b);
  if (fa !== fb) return fa.localeCompare(fb);
  return (a.created_at || '').toString().localeCompare((b.created_at || '').toString());
}
// Para la columna FECHA: si el registro se cargó el mismo día (no retro-fechado), mostrar
// fecha + hora como siempre; si fue retro-fechado, mostrar SOLO la fecha elegida.
function dieselFechaDisplay(r) {
  var fEf = dieselFechaEfectiva(r);
  if (r.created_at && fmtDT(r.created_at).slice(0, 10) === fEf) return fmtDT(r.created_at);
  return fEf || fmtDT(r.created_at || '');
}

function recalcTankLevel() {
  var tanks = getDieselTanks();
  if (!db.diesel) db.diesel = [];
  // Reset all levels
  tanks.forEach(function(t){ t.current_level = 0; });
  // Replay transactions chronologically
  // v1.8.66: replay por fecha EFECTIVA (la elegida en el modal), desempate created_at.
  // Antes ordenaba por created_at → un despacho retro-fechado se aplicaba al final y el
  // balance por fila no correspondía a la cronología real (y un ajuste posterior por fecha
  // pero anterior por registro lo pisaba mal).
  var sorted = db.diesel.slice().sort(dieselCmpAsc);
  sorted.forEach(function(r) {
    var type = r.type || (r.proveedor ? 'recarga' : 'despacho');
    var litros = parseFloat(r.litros) || 0;
    var tank = getTankById(tanks, r.tank_id);
    if (type === 'recarga') tank.current_level += litros;
    else if (type === 'ajuste') tank.current_level = parseFloat(r.nivel_fisico) || tank.current_level;
    else if (type === 'traspaso') {
      // direction 'out' resta del tank_id, 'in' suma al tank_id
      if (r.direction === 'in') tank.current_level += litros;
      else tank.current_level -= litros;
    }
    else tank.current_level -= litros;
    if (tank.current_level < 0) tank.current_level = 0;
    r._balance = Math.round(tank.current_level * 10) / 10;
    r._tank_name = tank.name;
  });
  tanks.forEach(function(t){ t.current_level = Math.round(t.current_level * 10) / 10; });
  saveDieselTanks(tanks);
  return tanks;
}

function populateTankSelector(selId) {
  var sel = document.getElementById(selId);
  if (!sel) return;
  var tanks = getDieselTanks();
  sel.innerHTML = '';
  tanks.forEach(function(t) {
    var o = document.createElement('option');
    o.value = t.id;
    o.textContent = t.name + ' (' + t.current_level + ' / ' + t.capacity + ' L)';
    sel.appendChild(o);
  });
}

