// Devuelve un array de bullets para la versión dada, o array vacío.
function getChangelogFor(version) {
  if (!version) return [];
  // Limpiar "v" prefix si viene
  var v = String(version).replace(/^v/i, '');
  return CHANGELOG_VERSIONS[v] || [];
}

// Renderiza el changelog como HTML compacto para mostrar dentro del banner.
function renderChangelogHTML(version) {
  var bullets = getChangelogFor(version);
  if (!bullets.length) return '';
  var items = bullets.map(function(b) {
    return '<li style="margin:2px 0">' + b + '</li>';
  }).join('');
  return '<div style="margin-top:8px;padding-top:8px;border-top:1px solid var(--bor);font-size:11px;color:var(--text)">' +
    '<div style="color:var(--muted);font-size:10px;text-transform:uppercase;letter-spacing:.06em;margin-bottom:4px">Novedades</div>' +
    '<ul style="margin:0;padding-left:18px;line-height:1.5">' + items + '</ul>' +
  '</div>';
}

