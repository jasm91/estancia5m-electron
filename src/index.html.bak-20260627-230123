  html += '<div style="position:relative;height:200px"><canvas id="chart-egresos-total"></canvas></div>';
  html += '</div>';

  // ── DONUT 2: OPERATIVOS DETALLE ──
  html += '<div style="background:var(--sur);border:1px solid var(--bor);border-radius:10px;padding:16px">';
