function maqRenderD(){maqList();var d=dataCache.maq[MQ.sel];if(!d){el('rd-mqmain').innerHTML='';return;}
 var ph=d.img?'<div class="ph" '+bgi(d.img)+'></div>':'<div class="ph">Sin foto</div>';
 var ES={operativo:['operativo','Operativo'],en_reparacion:['en_reparacion','En reparación'],fuera_servicio:['fuera_servicio','Fuera de servicio']};var es=ES[d.estado]||[null,d.estado||'—'];
 var tx=d.tx&&d.tx.length?d.tx.map(function(t){return '<tr><td style="color:var(--muted)">'+(t.fecha||'—')+'</td><td>'+badge(t.tipo,C[t.tipo])+'</td><td>'+esc(t.desc)+'</td><td style="text-align:right">'+(t.cost?'Bs '+f(t.cost):'—')+'</td></tr>';}).join(''):'<tr><td colspan="4" class="rdempty">Sin transacciones enlazadas a este equipo.</td></tr>';
 el('rd-mqmain').innerHTML='<div class="ficha">'+ph+'<div style="flex:1;min-width:0"><h2>'+esc(d.nombre)+'</h2><div style="display:flex;gap:7px;margin:8px 0 14px">'+badge(d.tipo,null)+badge(es[1],C[es[0]])+'</div><div class="sg"><div class="c"><div class="l">Modelo</div><div class="v" style="font-size:13px">'+esc(d.modelo||'—')+'</div></div><div class="c"><div class="l">Año</div><div class="v">'+(d.anio||'—')+'</div></div><div class="c"><div class="l">Horómetro</div><div class="v">'+f(d.horometro)+'</div></div><div class="c"><div class="l">Valor</div><div class="v">Bs '+f(d.valor)+'</div></div><div class="c"><div class="l">Gasto acum.</div><div class="v" style="color:var(--amber2)">Bs '+f(d.gasto)+'</div></div></div>'+(d.notas?'<div style="margin-top:12px;color:var(--muted);font-size:12px">'+esc(d.notas)+'</div>':'')+'<div class="rdacts" style="max-width:420px"><button onclick="openModalMaq()">Editar / nuevo</button></div></div></div>'+
 '<div class="rdmain" style="flex:none"><div class="rdmh"><span class="t">Transacciones</span><span style="color:var(--muted);font-size:12px">'+(d.tx?d.tx.length:0)+' · Bs '+f(d.gasto)+'</span></div><div class="rdtw"><table class="rdt"><thead><tr><th>Fecha</th><th>Tipo</th><th>Descripción</th><th style="text-align:right">Costo</th></tr></thead><tbody>'+tx+'</tbody></table></div><div class="note">Enlace equipo↔transacción parcial. Para exactitud: capturar el equipo al registrar mant./aceite.</div></div>';}
window.__rdMqPick=function(i){MQ.sel=i;maqRenderD();};
window.__rdMqToggle=function(){COLL=!COLL;var sd=el('rd-eqs-w');if(sd)sd.style.display=COLL?'none':'';};

