function editCuenta(idx) {
  var params = getParams();
  var c = (params.cuentas||[])[idx];
  if (!c) return;

  var tipoOpts = (params.tipos_gasto||[]).map(function(t){return t.name;});
  var oldName = c.name;
  var oldTipo = c.tipo_gasto || '';

  // Modal con ambos campos visibles
  var oldOv = document.getElementById('overlay-edit-cuenta');
  if (oldOv) oldOv.remove();
  var o = document.createElement('div');
  o.id = 'overlay-edit-cuenta';
  o.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:500;display:flex;align-items:center;justify-content:center;padding:20px';
  var b = document.createElement('div');
  b.style.cssText = 'background:var(--sur);border:1px solid var(--bor);border-radius:12px;padding:22px;max-width:480px;width:100%';

  var tipoOptsHtml = tipoOpts.map(function(t){
    return '<option value="'+escH(t)+'"'+(t===oldTipo?' selected':'')+'>'+escH(t)+'</option>';
  }).join('');

  // Contar cuántas subcuentas/registros se afectan si cambia el tipo
  var hijas = (params.subcuentas||[]).filter(function(s){
    return s.cuenta === oldName && (s.cuenta_tipo||'') === oldTipo;
  }).length;

  b.innerHTML =
    '<div style="font-size:15px;font-weight:600;color:var(--text);margin-bottom:14px">✎ Editar cuenta</div>'+
    '<div style="margin-bottom:12px">'+
      '<label style="font-size:11px;color:var(--muted);font-weight:600;display:block;margin-bottom:4px">Nombre de cuenta</label>'+
      '<input type="text" id="_ec_name" class="form-input" value="'+escH(oldName||'')+'" style="width:100%">'+
    '</div>'+
    '<div style="margin-bottom:14px">'+
      '<label style="font-size:11px;color:var(--muted);font-weight:600;display:block;margin-bottom:4px">Tipo de gasto padre</label>'+
      '<select id="_ec_tipo" class="form-select" style="width:100%">'+tipoOptsHtml+'</select>'+
      (hijas > 0 ? '<div style="font-size:10px;color:var(--amber2);margin-top:6px">⚠️ Esta cuenta tiene '+hijas+' subcuenta(s) asociada(s). Si cambiás el tipo, se actualizarán también ellas y todos los registros pasados se reorganizarán dinámicamente en el reporte.</div>' : '<div style="font-size:10px;color:var(--muted);margin-top:4px">Cambios afectan reportes pasados (resolución dinámica).</div>')+
    '</div>'+
    '<div style="display:flex;gap:8px;justify-content:flex-end">'+
      '<button id="_ec_cancel" class="btn btn-ghost">Cancelar</button>'+
      '<button id="_ec_save" class="btn btn-primary">Guardar</button>'+
    '</div>';

  o.appendChild(b);
  document.body.appendChild(o);

  var nameInp = document.getElementById('_ec_name');
  nameInp.focus(); nameInp.select();

  document.getElementById('_ec_cancel').onclick = function(){ o.remove(); };
  o.addEventListener('click', function(e){ if(e.target===o) o.remove(); });

  document.getElementById('_ec_save').onclick = function() {
    var newName = (nameInp.value || '').trim().toUpperCase();
    var newTipo = (document.getElementById('_ec_tipo').value || '').trim().toUpperCase();
    if (!newName) { toast('Ingresa un nombre', 'error'); return; }
    if (!newTipo) newTipo = oldTipo;

    // Validar duplicado (otra cuenta con mismo nombre+tipo)
    var dup = (params.cuentas||[]).some(function(cc, i){
      return i !== idx && cc.name === newName && (cc.tipo_gasto||'') === newTipo;
    });
    if (dup) { toast('Ya existe una cuenta '+newName+' ('+newTipo+')', 'error'); return; }

    // Cascada: actualizar subcuentas hijas que apuntaban a la cuenta vieja
    var changedSubs = 0;
    (params.subcuentas||[]).forEach(function(s){
      if (s.cuenta === oldName && (s.cuenta_tipo||'') === oldTipo) {
        if (newName !== oldName) s.cuenta = newName;
        if (newTipo !== oldTipo) s.cuenta_tipo = newTipo;
        changedSubs++;
      }
    });

    params.cuentas[idx] = { name: newName, tipo_gasto: newTipo };
    saveParams(params);
    // v1.8.68: reescribir registros (compras/kardex) que referencian la cuenta por NOMBRE
    var _cuMig = 0;
    if (newName !== oldName) {
      (db.purchases||[]).forEach(function(p){ if((p.cuenta||'')===oldName){ p.cuenta=newName; _cuMig++; } });
      (db.kardex||[]).forEach(function(k){ if((k.cuenta||'')===oldName){ k.cuenta=newName; _cuMig++; } });
      if (_cuMig) { saveDB(); try { replaceTableInRailway('purchases', db.purchases||[]); } catch(e){} try { replaceTableInRailway('kardex', db.kardex||[]); } catch(e){} }
    }
    o.remove();
    renderParams();
    var msg = 'Cuenta actualizada';
    if (changedSubs) msg += ' (' + changedSubs + ' subcuenta(s) sincronizadas)';
    if (_cuMig) msg += ' · ' + _cuMig + ' registro(s) migrados';
    toast(msg, 'success');
  };

  nameInp.addEventListener('keydown', function(e){
    if (e.key === 'Enter') document.getElementById('_ec_save').click();
    if (e.key === 'Escape') o.remove();
  });
}

