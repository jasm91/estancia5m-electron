function renderRotacion() {
  var el = document.getElementById('rotacion-content');
  if (!el) return;
  var params = getParams();
  var potreros = params.potreros || [];
  var history = db.rotation_history || [];
  var lots = db.lots || [];
  var today = new Date();

  var html = '';

  // Alerts section
  var alerts = [];
  potreros.forEach(function(p) {
    var activeLots = lots.filter(function(l){return (l.paddock||'').toLowerCase() === (p.name||'').toLowerCase() && l.status !== 'sold';});
    var totalCab = activeLots.reduce(function(s,l){return s+(l.animal_count||0);},0);
    
    // Find when this potrero was occupied
    var activeEntry = history.filter(function(r){return r.potrero===p.name && !r.exit_date;});
    var daysOccupied = 0;
    if (activeEntry.length) {
      var oldest = activeEntry.reduce(function(a,b){return a.entry_date < b.entry_date ? a : b;});
      daysOccupied = Math.max(1, Math.round((today - new Date(oldest.entry_date)) / 86400000));
    }

    if (totalCab > 0 && p.max_days && daysOccupied > p.max_days) {
      alerts.push({level:'critico', msg:'🔴 <b>'+p.name+'</b>: '+daysOccupied+' dias ocupado (max '+p.max_days+'). Rotar lotes para evitar degradacion.'});
    } else if (totalCab > 0 && p.max_days && daysOccupied > p.max_days * 0.8) {
      alerts.push({level:'alto', msg:'🟡 <b>'+p.name+'</b>: '+daysOccupied+'/'+p.max_days+' dias. Planificar rotacion pronto.'});
    }
    if (p.capacity && totalCab > p.capacity) {
      alerts.push({level:'critico', msg:'🔴 <b>'+p.name+'</b>: Sobre-ocupacion '+totalCab+'/'+p.capacity+' cabezas.'});
    }

    // Check rested potreros ready
    if (totalCab === 0 && p.rest_days) {
      var lastExit = history.filter(function(r){return r.potrero===p.name && r.exit_date;}).sort(function(a,b){return b.exit_date.localeCompare(a.exit_date);});
      if (lastExit.length) {
        var daysSinceExit = Math.round((today - new Date(lastExit[0].exit_date)) / 86400000);
        if (daysSinceExit >= p.rest_days) {
          alerts.push({level:'info', msg:'🟢 <b>'+p.name+'</b>: '+daysSinceExit+' dias de descanso (min '+p.rest_days+'). Listo para recibir ganado.'});
        }
      }
    }
  });

  if (alerts.length) {
    html += '<div style="margin-bottom:14px">';
    alerts.forEach(function(a) {
      var bg = a.level==='critico' ? 'rgba(239,68,68,.1)' : a.level==='alto' ? 'rgba(245,166,35,.1)' : 'rgba(34,197,94,.08)';
      var bor = a.level==='critico' ? 'rgba(239,68,68,.3)' : a.level==='alto' ? 'rgba(245,166,35,.3)' : 'rgba(34,197,94,.2)';
      html += '<div style="padding:8px 12px;border-radius:8px;background:'+bg+';border:1px solid '+bor+';font-size:12px;margin-bottom:4px">'+a.msg+'</div>';
    });
    html += '</div>';
  }

  // Potrero cards grid
  html += '<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:12px;margin-bottom:16px">';
  potreros.forEach(function(p) {
    var activeLots = lots.filter(function(l){return (l.paddock||'').toLowerCase() === (p.name||'').toLowerCase() && l.status !== 'sold';});
    var totalCab = activeLots.reduce(function(s,l){return s+(l.animal_count||0);},0);
    var isOccupied = totalCab > 0;
    var pctCap = p.capacity ? Math.round(totalCab / p.capacity * 100) : 0;
    var capColor = pctCap > 100 ? 'var(--red)' : pctCap > 80 ? 'var(--amber2)' : 'var(--green)';

    // Days occupied
    var activeEntry = history.filter(function(r){return r.potrero===p.name && !r.exit_date;});
    var daysOcc = 0;
    if (activeEntry.length) {
      var oldest = activeEntry.reduce(function(a,b){return a.entry_date < b.entry_date ? a : b;});
      daysOcc = Math.max(1, Math.round((today - new Date(oldest.entry_date)) / 86400000));
    }
    var daysPct = p.max_days ? Math.round(daysOcc / p.max_days * 100) : 0;
    var daysColor = daysPct > 100 ? 'var(--red)' : daysPct > 80 ? 'var(--amber2)' : 'var(--green)';

    // Days resting (if empty)
    var daysRest = 0;
    if (!isOccupied) {
      var lastExits = history.filter(function(r){return r.potrero===p.name && r.exit_date;}).sort(function(a,b){return b.exit_date.localeCompare(a.exit_date);});
      if (lastExits.length) daysRest = Math.round((today - new Date(lastExits[0].exit_date)) / 86400000);
    }
    var restPct = p.rest_days ? Math.min(100, Math.round(daysRest / p.rest_days * 100)) : 0;
    var restReady = p.rest_days && daysRest >= p.rest_days;

    // Status
    var statusIcon = isOccupied ? (daysPct > 100 ? '🔴' : daysPct > 80 ? '🟡' : '🟢') : (restReady ? '🟢' : '⏳');
    var statusText = isOccupied ? 'OCUPADO' : (restReady ? 'LISTO' : 'DESCANSANDO');
    var statusBg = isOccupied ? (daysPct > 100 ? 'rgba(239,68,68,.12)' : 'rgba(245,166,35,.08)') : (restReady ? 'rgba(34,197,94,.08)' : 'rgba(148,163,184,.08)');
    var statusBor = isOccupied ? (daysPct > 100 ? 'rgba(239,68,68,.3)' : 'rgba(245,166,35,.2)') : (restReady ? 'rgba(34,197,94,.2)' : 'rgba(148,163,184,.15)');

    html += '<div class="card" style="padding:14px;background:'+statusBg+';border:1px solid '+statusBor+'">';
    html += '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">';
    html += '<div style="font-size:14px;font-weight:700">'+statusIcon+' '+escH(p.name)+'</div>';
    html += '<span style="font-size:10px;font-weight:700;padding:2px 8px;border-radius:10px;background:'+statusBor+';color:var(--text)">'+statusText+'</span>';
    html += '</div>';

    // Info line
    html += '<div style="font-size:11px;color:var(--muted);margin-bottom:8px">';
    if (p.hectares) html += p.hectares+' ha · ';
    if (p.pasture_type) html += p.pasture_type+' · ';
    if (p.capacity) html += 'Cap: '+p.capacity+' cab';
    html += '</div>';

    if (isOccupied) {
      // Occupation bar
      html += '<div style="margin-bottom:6px"><div style="display:flex;justify-content:space-between;font-size:10px;margin-bottom:2px"><span>Cabezas</span><span style="font-weight:700;color:'+capColor+'">'+totalCab+(p.capacity?'/'+p.capacity:'')+'</span></div>';
      html += '<div style="height:6px;background:var(--sur2);border-radius:3px;overflow:hidden"><div style="height:100%;width:'+Math.min(100,pctCap)+'%;background:'+capColor+';border-radius:3px"></div></div></div>';

      // Days bar
      html += '<div style="margin-bottom:6px"><div style="display:flex;justify-content:space-between;font-size:10px;margin-bottom:2px"><span>Dias ocupado</span><span style="font-weight:700;color:'+daysColor+'">'+daysOcc+(p.max_days?'/'+p.max_days+' d':'')+'</span></div>';
      html += '<div style="height:6px;background:var(--sur2);border-radius:3px;overflow:hidden"><div style="height:100%;width:'+Math.min(100,daysPct)+'%;background:'+daysColor+';border-radius:3px"></div></div></div>';

      // Lots in this potrero
      html += '<div style="font-size:11px;color:var(--muted)">';
      activeLots.forEach(function(l) { html += '🐄 '+l.code+' ('+l.animal_count+' cab) '; });
      html += '</div>';
      // Latest pasture eval
      var evals = db.pasture_evals || [];
      var lotCodes = activeLots.map(function(l){return l.code;});
      var potEvals = evals.filter(function(e){return e.potrero===p.name || lotCodes.indexOf(e.lot)>=0;}).sort(function(a,b){return (b.date||'').localeCompare(a.date||'');});
      if (potEvals.length) {
        var lastEval = potEvals[0];
        var evalDate = lastEval.date ? new Date(lastEval.date).toLocaleDateString() : '';
        html += '<div style="margin-top:6px;padding:6px 8px;background:rgba(34,197,94,.06);border:1px solid rgba(34,197,94,.1);border-radius:6px;font-size:10px;line-height:1.4">';
        html += '<span style="color:var(--green);font-weight:700">🌿 Eval '+evalDate+':</span> ';
        html += escH((lastEval.result||'').slice(0,120)) + (lastEval.result&&lastEval.result.length>120?'...':'');
        html += '</div>';
      }
    } else {
      // Rest bar
      html += '<div style="margin-bottom:6px"><div style="display:flex;justify-content:space-between;font-size:10px;margin-bottom:2px"><span>Dias descansando</span><span style="font-weight:700;color:'+(restReady?'var(--green)':'var(--muted)')+'">'+daysRest+(p.rest_days?'/'+p.rest_days+' d':'')+(restReady?' ✅':'')+'</span></div>';
      html += '<div style="height:6px;background:var(--sur2);border-radius:3px;overflow:hidden"><div style="height:100%;width:'+restPct+'%;background:'+(restReady?'var(--green)':'var(--muted)')+';border-radius:3px"></div></div></div>';
      html += '<div style="font-size:11px;color:var(--muted)">Sin animales</div>';
      // Show last eval for empty potrero too
      var evals2 = db.pasture_evals || [];
      var potEvals2 = evals2.filter(function(e){return e.potrero===p.name;}).sort(function(a,b){return (b.date||'').localeCompare(a.date||'');});
      if (potEvals2.length) {
        var le = potEvals2[0];
        html += '<div style="margin-top:6px;padding:6px 8px;background:rgba(34,197,94,.06);border:1px solid rgba(34,197,94,.1);border-radius:6px;font-size:10px;line-height:1.4">';
        html += '<span style="color:var(--green);font-weight:700">🌿 Eval '+(le.date?new Date(le.date).toLocaleDateString():'')+':</span> ';
        html += escH((le.result||'').slice(0,120)) + (le.result&&le.result.length>120?'...':'');
        html += '</div>';
      }
    }
    html += '</div>';
  });
  html += '</div>';

  // Pasture evaluations
  var evals = db.pasture_evals || [];
  var recentEvals = evals.slice().sort(function(a,b){return (b.date||'').localeCompare(a.date||'');}).slice(0,10);
  if (recentEvals.length) {
    html += '<div style="font-size:14px;font-weight:700;margin-bottom:10px">🌿 Evaluaciones de Pasto</div>';
    html += '<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:8px;margin-bottom:16px">';
    recentEvals.forEach(function(ev) {
      var isPending = ev.type === 'pending';
      var statusIcon = isPending ? '⏳' : '✅';
      var statusColor = isPending ? 'rgba(245,166,35,.08)' : 'rgba(34,197,94,.06)';
      var statusBorder = isPending ? 'rgba(245,166,35,.2)' : 'rgba(34,197,94,.15)';
      html += '<div class="card" style="padding:12px;background:'+statusColor+';border:1px solid '+statusBorder+'">';
      html += '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px">';
      html += '<div style="font-size:12px;font-weight:700">'+statusIcon+' '+escH(ev.potrero||'?')+'</div>';
      html += '<div style="font-size:10px;color:var(--muted)">'+fmtDT(ev.date||'')+'</div></div>';
      if (ev.result && ev.result !== 'Pendiente — sin internet') {
        html += '<div style="font-size:11px;color:var(--text);line-height:1.5;max-height:80px;overflow:hidden">'+escH(ev.result).replace(/\n/g,'<br>').replace(/\*\*([^*]+)\*\*/g,'<b>$1</b>').slice(0,300)+'</div>';
      } else {
        html += '<div style="font-size:11px;color:var(--muted)">Pendiente de evaluación</div>';
      }
      if (ev.lot) html += '<div style="font-size:10px;color:var(--muted);margin-top:4px">Lote: '+ev.lot+'</div>';
      html += '</div>';
    });
    html += '</div>';
  }

  // Rotation history table
  html += '<div style="font-size:14px;font-weight:700;margin-bottom:10px">📋 Historial de Rotaciones</div>';
  var sortedHistory = history.slice().sort(function(a,b){return (b.entry_at||b.entry_date||'').localeCompare(a.entry_at||a.entry_date||'');});
  if (sortedHistory.length) {
    html += '<table class="tbl" style="font-size:12px"><thead><tr><th>Fecha entrada</th><th>Lote</th><th>Potrero</th><th>Desde</th><th>Cab</th><th>Dias</th><th>Salida</th><th>Motivo</th></tr></thead><tbody>';
    sortedHistory.slice(0,30).forEach(function(r) {
      var isActive = !r.exit_date;
      var days = r.days_occupied || (isActive ? Math.max(1, Math.round((today - new Date(r.entry_date)) / 86400000)) : 0);
      var params2 = getParams();
      var pot = (params2.potreros||[]).find(function(p){return p.name===r.potrero;});
      var maxD = pot ? pot.max_days : 0;
      var overdue = maxD && days > maxD;
      html += '<tr style="'+(isActive?'background:rgba(245,166,35,.05)':'')+'">';
      html += '<td>'+r.entry_date+'</td>';
      html += '<td style="font-weight:700">'+r.lot_code+'</td>';
      html += '<td>'+escH(r.potrero)+'</td>';
      html += '<td style="color:var(--muted)">'+escH(r.from_potrero||'-')+'</td>';
      html += '<td>'+r.cabezas+'</td>';
      html += '<td style="font-weight:700;color:'+(overdue?'var(--red)':isActive?'var(--amber2)':'var(--muted)')+'">'+days+'d'+(isActive?' ⏱':'')+'</td>';
      html += '<td>'+(r.exit_date||'<span style="color:var(--amber2)">Activo</span>')+'</td>';
      html += '<td style="font-size:11px;color:var(--muted)">'+escH(r.reason||'-')+'</td>';
      html += '</tr>';
    });
    html += '</tbody></table>';
  } else {
    html += '<div style="text-align:center;padding:30px;color:var(--muted)"><div style="font-size:28px;margin-bottom:8px">🔄</div>Sin historial de rotaciones. Al mover un lote a otro potrero, se registrara automaticamente.</div>';
  }

  el.innerHTML = html;
}


