// v1.4.67: Renderiza los 2 donuts de Composición de Gastos
// (charts globales _creaChartEgresosTotal y _creaChartOperativos para destruir en re-render)
function _creaRenderGastosDonuts() {
  if (typeof Chart === 'undefined') return;  // Chart.js no disponible
  var data = window._creaGastosData;
  if (!data) return;

  // Destruir charts previos para evitar memory leak
  try { if (window._creaChartEgresosTotal) window._creaChartEgresosTotal.destroy(); } catch(e){}
  try { if (window._creaChartOperativos) window._creaChartOperativos.destroy(); } catch(e){}

  var commonOptions = {
    responsive: true,
    maintainAspectRatio: false,
    cutout: '60%',
    plugins: {
      legend: {
        position: 'right',
        labels: {
          color: '#c9d1d9',
          font: { size: 10 },
          boxWidth: 12,
          padding: 6,
          // v1.4.67: filtrar leyendas con valor 0 para no llenar de "rubros vacíos"
          filter: function(item, chartData) {
            var idx = item.index;
            var val = chartData.datasets[0].data[idx] || 0;
            return val > 0;
          }
        }
      },
      tooltip: {
        callbacks: {
          label: function(ctx) {
            var lbl = ctx.label || '';
            var val = ctx.parsed || 0;
            var tot = ctx.dataset.data.reduce(function(a,b){ return a + b; }, 0);
            var pct = tot > 0 ? (val / tot * 100).toFixed(1) : 0;
            return lbl + ': Bs. ' + Math.round(val).toLocaleString() + ' (' + pct + '%)';
          }
        }
      }
    }
  };

  // ── Donut 1: Egresos Totales (Compra ganado vs Operativos como bloque) ──
  var canvas1 = document.getElementById('chart-egresos-total');
  if (canvas1) {
    var labels1 = [];
    var values1 = [];
    var colors1 = [];
    if (data.totalOperativos > 0) {
      labels1.push('💼 Operativos');
      values1.push(data.totalOperativos);
      colors1.push('#60a5fa');
    }
    if (data.hayCompras) {
      var compraData = data.gastos.find(function(g){ return !g.operativo; });
      labels1.push('🐄 Compra de ganado');
      values1.push(compraData.total);
      colors1.push('#fb7185');
    }
    if (values1.length > 0) {
      window._creaChartEgresosTotal = new Chart(canvas1, {
        type: 'doughnut',
        data: {
          labels: labels1,
          datasets: [{
            data: values1,
            backgroundColor: colors1,
            borderColor: '#0d1117',
            borderWidth: 2
          }]
        },
        options: commonOptions
      });
    }
  }

  // ── Donut 2: Operativos en detalle (sin compra ganado) ──
  var canvas2 = document.getElementById('chart-operativos');
  if (canvas2 && data.totalOperativos > 0) {
    var operativos = data.gastos.filter(function(g){ return g.operativo && g.total > 0; });
    // Ordenar por valor descendente para mejor visualización
    operativos.sort(function(a, b){ return b.total - a.total; });
    window._creaChartOperativos = new Chart(canvas2, {
      type: 'doughnut',
      data: {
        labels: operativos.map(function(g){ return g.rubro; }),
        datasets: [{
          data: operativos.map(function(g){ return g.total; }),
          backgroundColor: operativos.map(function(g){ return g.color; }),
          borderColor: '#0d1117',
          borderWidth: 2
        }]
      },
      options: commonOptions
    });
  }
}

