<script>
function getAnimalesDB(){
  try{
    var raw=JSON.parse(localStorage.getItem("e5m_animals")||"{}");
    // Auto-limpieza: eliminar entradas para lotes que ya no existen en db.lots
    // (huérfanos del cache que quedan después de borrar lotes en otra sesión/PWA/Bot)
