// FIX BUG-BAJA-ID: el contador local db.next_ids.bajas se reiniciaba a 1 en cada
// reinstalación/dispositivo y generaba bajas con id DUPLICADO (3 bajas distintas habían
// quedado con id=1). Con ids repetidos, "Vender carne"/eliminar/ver foto buscaban por id
// con .find()/filter() y agarraban la baja equivocada. Generamos un id único basado en
// timestamp (como la PWA), garantizando que no choque con ninguna baja existente.
function genBajaId() {
  var taken = {};
  (db.bajas || []).forEach(function(b){ if (b && b.id != null) taken[String(b.id)] = true; });
  var id = Date.now();
  while (taken[String(id)]) id++;
  return id;
}

function confirmarBajaAnimal() {
  var fecha = (document.getElementById('baja-fecha') || {}).value || '';
  var causa = (document.getElementById('baja-causa') || {}).value || 'desconocida';
  var obs = ((document.getElementById('baja-obs') || {}).value || '').trim();
  var ventaCarne = (document.getElementById('baja-venta-carne') || {}).checked || false;
  if (!fecha) { toast('Ingresa la fecha', 'error'); return; }
  // FIX v1.4.34: no permitir fechas futuras
  if (!validateNotFuture(fecha, 'fecha de muerte')) return;
  if (!obs) { toast('Ingresa observaciones', 'error'); return; }
  // If opened from Bajas tab (selectors mode)
  if (!_bajaAnimalId) {
    _bajaFromLot = (document.getElementById('baja-lot-select')||{}).value || '';
    _bajaAnimalId = (document.getElementById('baja-animal-select')||{}).value || '';
  }
  if (!_bajaAnimalId || !_bajaFromLot) { toast('Seleccioná lote y animal', 'error'); return; }

  // 1. Get animal data before removing
  var adb = getAnimalesDB();
  var animals = adb[_bajaFromLot] || [];
  var animal = animals.find(function(a) { return (a.id || a.animal_id || '').toString() === _bajaAnimalId.toString(); });
  var lastWeight = 0;
  var raza = '';
  if (animal) {
    raza = animal.raza || animal.breed || '';
    if (animal.pesajes && animal.pesajes.length) lastWeight = animal.pesajes[animal.pesajes.length - 1].peso || 0;
  }

  // 2. Register in bajas table
  if (!db.bajas) db.bajas = [];
  if (!db.next_ids) db.next_ids = {};
  var bajaRecord = {
    id: genBajaId(),
    animal_id: _bajaAnimalId,
    lot_code: _bajaFromLot,
    raza: raza,
    ultimo_peso: lastWeight,
    fecha: fecha,
    causa: causa,
    obs: obs,
    venta_carne: ventaCarne,
    has_photo: !!_bajaPhotoBase64,
    by: 'Desktop',
    created_at: new Date().toISOString(),
    // FIX v1.4.35 BUG-LOT-1: guardar snapshot del animal completo para poder restaurarlo
    // si la baja se elimina por error (deleteBaja). Sin este snapshot, el animal y su
    // historial (pesajes, entry_date, raza) se perdían permanentemente.
    animal_snapshot: animal ? JSON.parse(JSON.stringify(animal)) : null,
    kardex_ref_id: Date.now()+2  // ID del kardex asociado (para reversa)
  };
  db.bajas.push(bajaRecord);
  // Auto-Kardex
  if (!db.kardex) db.kardex = [];
  db.kardex.push({id:bajaRecord.kardex_ref_id,lote:bajaRecord.lot_code||'',tipo:'muerte',fecha:bajaRecord.fecha||localDate(),cabezas:1,precio:0,total:0,desc:'Baja: '+(bajaRecord.causa||'')+ ' — Animal #'+(bajaRecord.animal_id||'?'),by:'Desktop',created_at:new Date().toISOString(),auto:true,baja_id:bajaRecord.id});

  // 3. Remove from animales DB
  adb[_bajaFromLot] = animals.filter(function(a) { return (a.id || a.animal_id || '').toString() !== _bajaAnimalId.toString(); });
  saveAnimalesDB(adb);

  // 4. Update lot animal_count
  var lot = db.lots.find(function(l) { return l.code === _bajaFromLot; });
  if (lot && lot.animal_count > 0) lot.animal_count--;

  // 5. Register activity
  addActivity('Sistema', 'baja', _bajaFromLot, '🪦 Baja Animal #' + _bajaAnimalId + ' - ' + causa + (lastWeight ? ' (' + lastWeight + ' kg)' : '') + ' - ' + obs, fecha);

  // 6. Upload photo if exists — save locally + upload
  if (_bajaPhotoBase64) {
    var txId = String(bajaRecord.id);
    // Save locally for instant viewing
    try {
      var localPhotos = JSON.parse(localStorage.getItem('e5m_local_photos')||'{}');
      localPhotos[txId] = _bajaPhotoBase64;
      localPhotos['baja_'+bajaRecord.id] = _bajaPhotoBase64;
      localStorage.setItem('e5m_local_photos', JSON.stringify(localPhotos));
    } catch(e) { console.warn('Error saving local photo:', e.message); }
    // Upload to server
    var apiUrl = getApiUrl();
    var token = localStorage.getItem('e5m_api_token') || '';
    fetch(apiUrl + '/transaction-image', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
      body: JSON.stringify({ transaction_id: txId, transaction_type: 'bajas', base64: _bajaPhotoBase64.replace(/^data:image\/\w+;base64,/, ''), mime_type: 'image/jpeg', uploaded_by: 'Desktop' })
    }).then(function(r){ return r.json(); })
    .then(function(d){ if(d.ok) console.log('[Baja] Photo uploaded:', txId); else console.error('[Baja] Upload failed:', d); })
    .catch(function(e) { console.error('[Baja] Upload error:', e.message); });
  }

  // 7. Save and sync
  saveDB();
  replaceTableInRailway('bajas', db.bajas || []);
  closeModal('modal-baja-animal');
  renderAnimalesLote();
  renderDashboard();
  if (typeof renderBajasDesktop === 'function') renderBajasDesktop();

  var msg = '🪦 Baja registrada: Animal #' + _bajaAnimalId + ' (' + causa + ')';
  if (ventaCarne) msg += ' — Venta de carne pendiente en pestaña Bajas';
  toast(msg, 'success');
  // FIX v1.4.35: audit log para baja
  try { auditLog('create', 'bajas', bajaRecord.id, _summarizeRecord('bajas', bajaRecord)); } catch(e){}
  _bajaAnimalId = null;
  _bajaFromLot = null;
}

function verHistorialAnimal(animalId,lotCode){
  var row=document.getElementById("hist-row-"+animalId);
  var inner=document.getElementById("hist-inner-"+animalId);
  if(!row||!inner) return;
  if(row.style.display!=="none"){row.style.display="none";return;}
  row.style.display="table-row";
  var animals=getAnimalesDB()[lotCode]||[];
  var a=animals.find(function(x){return x.id===animalId;});

  // v1.4.76: Trazabilidad completa — compra + movimientos + pesajes + venta/baja
  // Reconstruir una línea de tiempo unificada con todos los eventos del animal.
  var events = [];

  // 1) Compra: buscar en db.compras_ganado el lote donde nació en el sistema
  // El lote original es el primero de _movements (si existe) o el actual.
  var originalLot = (a && a._movements && a._movements.length > 0) ? a._movements[0].from_lot : lotCode;
  var compra = (db.compras_ganado || []).find(function(c) {
    return c.lot_code === originalLot ||
           (Array.isArray(c.lote_destinos) && c.lote_destinos.indexOf(originalLot) >= 0);
  });
  if (compra) {
    var pricePerHead = compra.animal_count > 0 ? Math.round((compra.total||0) / compra.animal_count) : 0;
    events.push({
      date: compra.date || compra.fecha || '',
      icon: '🐂',
      type: 'COMPRA',
      color: 'var(--blue)',
      title: 'Ingreso al sistema → ' + originalLot,
      sub: 'Proveedor: ' + (compra.provider || '-') +
           (pricePerHead > 0 ? ' · Bs ' + pricePerHead.toLocaleString() + '/cab' : '') +
           (compra.weight ? ' · ~' + Math.round(compra.weight) + ' kg' : '')
    });
  }

  // 2) Movimientos (granular)
  // v1.8.66: dedupe por fecha+origen+destino (el server puede tener el mismo traslado
  // repetido, ej. doble click) y además de a._movements se leen los movimientos
  // sincronizados del server (db.animal_movements) → cubre traslados hechos en otro
  // equipo / PWA / con el botón individual de versiones anteriores a este fix.
  var _seenMov = {};
  function _pushMov(mdate, mfrom, mto, msub) {
    if (!mfrom && !mto) return;
    var k = (mdate || '') + '|' + (mfrom || '') + '|' + (mto || '');
    if (_seenMov[k]) return;
    _seenMov[k] = 1;
    events.push({
      date: mdate || '',
      icon: '📤',
      type: 'TRASLADO',
      color: 'var(--amber2)',
      title: (mfrom || '?') + ' → ' + (mto || '?'),
      sub: msub || ''
    });
  }
  if (a && Array.isArray(a._movements)) {
    a._movements.forEach(function(m) {
      _pushMov(m.date, m.from_lot, m.to_lot,
        (m.weight_at_move ? m.weight_at_move + ' kg al momento' : '') +
        (m.reason ? ' · ' + m.reason : ''));
    });
  }
  (db.animal_movements || []).forEach(function(m) {
    var match = (m.animal_id !== undefined && m.animal_id !== null && m.animal_id.toString() === animalId.toString()) ||
                (Array.isArray(m.animal_ids) && m.animal_ids.some(function(x){ return (x === undefined || x === null ? '' : x).toString() === animalId.toString(); }));
    if (!match) return;
    var sub = (m.by ? 'por ' + m.by : '');
    var reason = m.reason || m.motivo || '';
    if (reason) sub += (sub ? ' · ' : '') + reason;
    _pushMov(m.date, m.from_lot, m.to_lot, sub);
  });

  // 3) Pesajes
  if (a && Array.isArray(a.pesajes)) {
    a.pesajes.forEach(function(p, i) {
      var gmdNote = '';
      if (i > 0) {
        var prev = a.pesajes[i-1];
        var dias = Math.round((new Date(p.fecha) - new Date(prev.fecha)) / 86400000);
        if (dias > 0) {
          var diff = p.peso - prev.peso;
          var g = (diff / dias).toFixed(3);
          gmdNote = (diff >= 0 ? '+' : '') + diff.toFixed(1) + ' kg (' + g + ' kg/d)';
        }
      }
      events.push({
        date: p.fecha || '',
        icon: '⚖️',
        type: 'PESAJE',
        color: 'var(--green)',
        title: p.peso + ' kg',
        sub: gmdNote
      });
    });
  }

  // 4) Venta — solo si el lote actual fue vendido
  var lotObj = (db.lots||[]).find(function(l){return l.code === lotCode;});
  if (lotObj && (lotObj.status === 'vendido' || lotObj.status === 'sold')) {
    var venta = (db.sales||[]).find(function(s) {
      return s.lot_code === lotCode ||
             (Array.isArray(s.lot_codes) && s.lot_codes.indexOf(lotCode) >= 0);
    });
    if (venta) {
      var precioKg = venta.total_kg ? (venta.total / venta.total_kg).toFixed(2) : '';
      events.push({
        date: venta.date || venta.fecha || '',
        icon: '🤝',
        type: 'VENTA',
        color: 'var(--green)',
        title: 'Comprador: ' + (venta.buyer || '-'),
        sub: (precioKg ? 'Bs ' + precioKg + '/kg' : '') + (venta.total ? ' · Total venta: Bs ' + Math.round(venta.total).toLocaleString() : '')
      });
    }
  }

  // 5) Bajas (muerte)
  if (Array.isArray(db.bajas)) {
    db.bajas.forEach(function(b) {
      if ((b.animal_id||'').toString() === animalId.toString()) {
        events.push({
          date: b.date || b.fecha || '',
          icon: '🪦',
          type: 'BAJA',
          color: 'var(--red)',
          title: b.causa || 'Muerte',
          sub: (b.obs || '')
        });
      }
    });
  }

  // Ordenar cronológicamente
  events.sort(function(a, b) {
    return (a.date || '').localeCompare(b.date || '');
  });

  if (events.length === 0) {
    inner.innerHTML = '<div style="color:var(--muted);font-size:12px">Sin historial registrado</div>';
    return;
  }

  // Render línea de tiempo
  var html = '<div style="font-size:10px;color:var(--muted);font-weight:600;margin-bottom:8px;letter-spacing:.08em">📜 TRAZABILIDAD COMPLETA · ' + escH(animalId) + '</div>';
  html += '<div style="position:relative;padding-left:18px">';
  events.forEach(function(e, idx) {
    var isLast = idx === events.length - 1;
    html += '<div style="position:relative;padding:7px 0' + (isLast ? '' : ';border-bottom:1px dashed rgba(48,54,61,.4)') + '">' +
      '<span style="position:absolute;left:-18px;top:8px;font-size:13px">' + e.icon + '</span>' +
      '<div style="display:flex;gap:12px;align-items:baseline;flex-wrap:wrap;font-size:11px">' +
        '<span style="font-family:DM Mono,monospace;color:var(--muted);min-width:88px">' + (e.date || '-') + '</span>' +
        '<span style="font-family:DM Mono,monospace;color:' + e.color + ';font-weight:700;min-width:80px">' + e.type + '</span>' +
        '<span style="font-weight:600">' + escH(e.title) + '</span>' +
        (e.sub ? '<span style="color:var(--muted)">· ' + escH(e.sub) + '</span>' : '') +
      '</div>' +
    '</div>';
  });
  html += '</div>';
  inner.innerHTML = html;
}

