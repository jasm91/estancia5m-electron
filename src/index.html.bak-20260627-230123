      '</tr>';
  }).join('');
}

// Helper escapeHtml (puede ya existir como escH; protejo)
function _reproEscape(s) {
  return String(s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}
// Usar la del proyecto si existe
if (typeof escapeHtml !== 'function') {
  window.escapeHtml = (typeof escH === 'function') ? escH : _reproEscape;
}

// ─── Modal: + Parto (rico) ─────────────────────────────────────

// ═════════════════════════════════════════════════════════════
// v1.8.13 — Panel de Partos Esperados
// Muestra cards de vacas preñadas (servicio diagnosticado) ordenadas por
// fecha esperada de parto. Click "+ Registrar parto" pre-llena modal.
// ═════════════════════════════════════════════════════════════
function _reproRenderPartosEsperados() {
  var cont = document.getElementById('repro-partos-esperados');
  if (!cont) return;

  // Vacas preñadas no consumidas (misma lógica que _reproPartoPopulateMadres)
  var servicios = _reproGetServicios();
  var partos = _reproGetPartos();
  var serviciosConsumidos = {};
  partos.forEach(function(p){ if (p.servicio_id) serviciosConsumidos[p.servicio_id] = true; });

  var prenadas = servicios
    .filter(function(s){ return s.result === 'preñada' && s.animal_id; })
    .filter(function(s){ return !serviciosConsumidos[s.id]; })
    .sort(function(a, b){ return (b.date || '').localeCompare(a.date || ''); });

  // Quedarse con el servicio preñador más reciente por vaca
  var byVaca = {};
  prenadas.forEach(function(s){ if (!byVaca[s.animal_id]) byVaca[s.animal_id] = s; });

  var lista = Object.keys(byVaca).map(function(k){ return byVaca[k]; }).sort(function(a, b){
    var da = a.date ? new Date(a.date).getTime() + 280*86400000 : Infinity;
    var db_ = b.date ? new Date(b.date).getTime() + 280*86400000 : Infinity;
    return da - db_;
  });

  if (!lista.length) {
    cont.innerHTML =
      '<div style="background:var(--sur);border:0.5px dashed var(--bor);border-radius:10px;padding:18px;text-align:center;color:var(--muted);font-size:12px">' +
        '🤰 No hay partos esperados.<br>' +
        '<span style="font-size:11px">Para que una vaca aparezca acá, registrá un + Servicio con diagnóstico Preñada.</span>' +
      '</div>';
    return;
  }

  // Render tarjetas
  var hoyMs = Date.now();
  var html = '<div style="background:var(--sur);border-radius:12px;padding:14px 16px">';
  html += '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">' +
    '<span style="font-size:13px;font-weight:500">🤰 Partos esperados próximamente</span>' +
    '<span style="font-size:11px;color:var(--muted)">' + lista.length + (lista.length===1?' vaca':' vacas') + ' preñada' + (lista.length===1?'':'s') + '</span>' +
  '</div>';
  html += '<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:10px">';

  lista.forEach(function(s){
    var esperadaMs = s.date ? new Date(s.date).getTime() + 280*86400000 : 0;
    var esperadaStr = esperadaMs ? new Date(esperadaMs).toISOString().slice(0,10) : '?';
    var dias = esperadaMs ? Math.round((esperadaMs - hoyMs) / 86400000) : null;

    // Categorizar urgencia
    var pillBg, pillColor, borderColor, pillTxt;
    if (dias === null) {
      pillBg = 'rgba(150,150,150,.15)'; pillColor = 'var(--muted)'; borderColor = 'var(--bor)'; pillTxt = 'Sin fecha';
    } else if (dias <= 7) {
      pillBg = 'rgba(248,81,73,.15)'; pillColor = 'var(--red)'; borderColor = 'rgba(248,81,73,.5)';
      pillTxt = dias < 0 ? ('⚠ Vencido · ' + Math.abs(dias) + 'd') : (dias === 0 ? '⚠ Hoy' : '⚠ En ' + dias + 'd');
    } else if (dias <= 15) {
      pillBg = 'rgba(212,160,23,.15)'; pillColor = 'var(--amber)'; borderColor = 'rgba(212,160,23,.4)';
      pillTxt = '⏳ En ' + dias + 'd';
    } else {
      pillBg = 'rgba(63,185,80,.15)'; pillColor = 'var(--green)'; borderColor = 'var(--bor)';
      pillTxt = '📅 En ' + dias + 'd';
    }

    var padre = s.tipo_servicio === 'IA' ? (s.semen_lote || 'IA') : (s.toro_id || 'Toro suelto');

    html += '<div style="background:var(--sur2);border:1px solid ' + borderColor + ';border-radius:9px;padding:11px 12px">' +
      '<div style="display:inline-block;padding:2px 7px;border-radius:8px;font-size:10px;background:' + pillBg + ';color:' + pillColor + ';margin-bottom:6px">' + pillTxt + '</div>' +
      '<div style="font-family:DM Mono,monospace;font-size:14px;font-weight:600;color:var(--text);margin-bottom:3px">' + escH(s.animal_id) + '</div>' +
      '<div style="font-size:11px;color:var(--muted);margin-bottom:2px">Padre: ' + escH(padre) + '</div>' +
      '<div style="font-size:11px;color:var(--muted);margin-bottom:2px">Lote: ' + escH(s.lot_code || '—') + ' · Servicio: ' + _reproFmtDate(s.date) + '</div>' +
      '<div style="font-size:11px;color:' + pillColor + ';margin-bottom:9px">Esperado: ' + _reproFmtDate(esperadaStr) + '</div>' +
      '<button onclick="_reproQuickParto(\'' + s.id + '\')" style="width:100%;padding:6px;background:var(--green);color:#0d1117;border:none;border-radius:6px;font-size:11px;font-weight:600;cursor:pointer">+ Registrar parto</button>' +
    '</div>';
  });
  html += '</div>';

  // Leyenda
  html += '<div style="display:flex;gap:14px;font-size:10px;color:var(--muted);margin-top:10px;flex-wrap:wrap">' +
    '<span><span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:var(--red);margin-right:4px;vertical-align:middle"></span>Vencido o ≤ 7 días</span>' +
    '<span><span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:var(--amber);margin-right:4px;vertical-align:middle"></span>≤ 15 días</span>' +
    '<span><span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:var(--green);margin-right:4px;vertical-align:middle"></span>Más de 15 días</span>' +
  '</div>';
  html += '</div>';

  cont.innerHTML = html;
}

// v1.8.13: abrir modal de parto pre-llenado con datos del servicio
function _reproQuickParto(srvId) {
  if (!Array.isArray(db.reproductive_services)) return;
  var srv = db.reproductive_services.find(function(r){ return r.id === srvId; });
