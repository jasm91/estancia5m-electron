// v1.4.91: Resumen propiedad minimalista en topbar (Idea 11 / Tier 1 Potrero)
// Muestra Cabezas + Valor rodeo + Costo/kg + Estado general.
// Cabezas y Valor rodeo se calculan acá (rápido). Costo/kg viene de window._lastCREAKPIs
// (poblado por renderReporteCREA). Si CREA todavía no se abrió, muestra "—".
// v1.4.95: simplificado y sin try/catch silencioso para detectar errores reales.
// v1.4.100: el topbar se muestra SIEMPRE que haya lotes activos, aunque animal_count=0.
//   Antes se ocultaba si no había animales contables, pero esto pasaba seguido cuando
//   los lotes venían del server con animal_count vacío y todavía no se reconstruía.
function renderTopbarSummary() {
  var el = document.getElementById('topbar-summary');
  if (!el) return;
  // v1.4.101: `db` puede no estar en window (depende del scope donde se declaró).
  // Antes el guard era `if (!window.db || ...)` y eso disparaba "sin db.lots" aunque db existiera.
  if (typeof db === 'undefined' || !db || !Array.isArray(db.lots)) { el.style.display = 'none'; return; }

  var rp = (typeof getRp === 'function') ? getRp() : {};
  var precioRef = parseFloat(rp.precio_venta_ref) || 25;
  var pesoUA = parseFloat(rp.peso_ua) || 400;

  // v1.8.30: incluir lotes en cuarentena en el conteo del header, para que coincida con
  // el Kardex Estancia (los animales en cuarentena ya están físicamente en la propiedad).
  // Se excluyen solo los lotes que ya no representan cabezas vivas: vendido/fusionado/marcado.
  var activeLots = db.lots.filter(function(l){
    if (!l) return false;
    var st = String(l.status || 'activo').toLowerCase();
    if (st === 'sold' || st === 'vendido') return false;
    if (st === 'fusionado' || st === 'merged') return false;
    if (st === 'marcado' || st === 'marcado_completo') return false;
    if (st === 'inactivo') return false;
    return true;
  });

  // Si no hay lotes activos, ocultar
  if (!activeLots.length) { el.style.display = 'none'; return; }

  // Animales DB para fallback si lot.animal_count está vacío
  var animDB = (typeof getAnimalesDB === 'function') ? (getAnimalesDB() || {}) : {};

  var cab = 0;
  var stockKg = 0;
  var lotesConDatos = 0;

  // v1.8.41: peso proyectado a HOY usando GMD. Los pesajes suelen estar desactualizados
  // (ej. ganado pesado hace meses), así que valuar a peso viejo subestima el rodeo.
  // Para cada animal: peso_proyectado = último_peso + GMD × días_desde_ese_pesaje (cap 180 días).
  // GMD híbrido: del propio lote (2+ pesajes) → promedio del rodeo → default del parámetro.
  var pesoVentaObjetivo = parseFloat(rp.peso_venta_objetivo) || 450;
  var gmdDefault = parseFloat(rp.gmd_default) || 0.5;
  var MAX_DIAS_PROY = 180;
  var hoyMs = Date.now();

  // Helper: GMD real de un lote a partir de sus pesajes (primer vs último pesaje del promedio del lote)
  function _gmdDeLote(anims){
    if (!anims || !anims.length) return null;
    // recolectar (fecha, pesoPromedio) por fecha de pesaje del lote
    var primero = null, ultimo = null;
    anims.forEach(function(a){
      if (!a || !a.pesajes || !a.pesajes.length) return;
      a.pesajes.forEach(function(p){
        if (!p || !(p.peso > 0) || !p.fecha) return;
        var t = new Date(p.fecha).getTime();
        if (isNaN(t)) return;
        if (!primero || t < primero.t) primero = { t: t, peso: p.peso };
        if (!ultimo || t > ultimo.t) ultimo = { t: t, peso: p.peso };
      });
    });
    if (!primero || !ultimo || primero.t === ultimo.t) return null;
    var dias = (ultimo.t - primero.t) / 86400000;
    if (dias < 1) return null;
    var gmd = (ultimo.peso - primero.peso) / dias;
    return (gmd > 0 && gmd < 3) ? gmd : null; // descartar valores absurdos
  }

  // Primera pasada: GMD promedio del rodeo (para fallback)
  var sumGmdRodeo = 0, nGmdRodeo = 0;
  activeLots.forEach(function(l){
    if (!l || !l.code) return;
    var g = _gmdDeLote(animDB[l.code]);
    if (g != null) { sumGmdRodeo += g; nGmdRodeo++; }
  });
  var gmdRodeo = nGmdRodeo > 0 ? sumGmdRodeo / nGmdRodeo : gmdDefault;

  activeLots.forEach(function(l){
    if (!l) return;
    // Cuántos animales: lot.animal_count > 0, sino contar en animDB
    var ac = parseInt(l.animal_count, 10) || 0;
    var anims = (l.code && animDB[l.code]) ? animDB[l.code] : null;
    // v1.8.78: contar animales DISTINTOS (un duplicado no infla el header); seguir el real si está individualizado o la caída es chica.
    if (anims && anims.length) {
      var _u={}; anims.forEach(function(a){ var k=String((a&&(a.animal_id||a.id))||''); if(k) _u[k]=1; });
      var _real=Object.keys(_u).length;
      if (_real>0 && (_real>=ac || (ac-_real)<=Math.max(3, ac*0.05))) ac=_real; else if (!ac) ac=_real;
    }
    if (!ac) return;
    cab += ac;
    lotesConDatos++;

    // GMD del lote (propio si hay datos, sino promedio del rodeo)
    var gmdLote = _gmdDeLote(anims);
    if (gmdLote == null) gmdLote = gmdRodeo;

    // Peso promedio proyectado a hoy
    var aw = 0;
    if (anims && anims.length) {
      var sumW = 0, nW = 0;
      for (var i = 0; i < anims.length; i++) {
        var a = anims[i];
        if (a && a.pesajes && a.pesajes.length) {
          var p = a.pesajes[a.pesajes.length - 1];
          if (p && p.peso > 0) {
            var pesoProy = p.peso;
            // proyectar desde la fecha del último pesaje hasta hoy (cap 180 días)
            if (p.fecha) {
              var tP = new Date(p.fecha).getTime();
              if (!isNaN(tP)) {
                var diasTrans = (hoyMs - tP) / 86400000;
                if (diasTrans > 0) {
                  diasTrans = Math.min(diasTrans, MAX_DIAS_PROY);
                  pesoProy = p.peso + gmdLote * diasTrans;
                  // no proyectar por encima del peso objetivo de venta
                  if (pesoProy > pesoVentaObjetivo) pesoProy = pesoVentaObjetivo;
                }
              }
            }
            sumW += pesoProy; nW++;
          }
        }
      }
      if (nW > 0) aw = sumW / nW;
    }
    // fallback si el lote no tiene pesajes: avg_weight del lote, sino pesoUA
    if (!aw) aw = parseFloat(l.avg_weight) || parseFloat(l.peso_actual) || pesoUA;
    stockKg += aw * ac;
  });

  // v1.8.30: "Inversión Total en Ganado" (vigente) reemplaza al "Valor Rodeo" teórico.
  // Para cada lote vivo, se toma el costo de su compra de origen prorrateado por las cabezas
  // que quedan. Así descuenta naturalmente lo vendido/muerto (ya no están en animal_count).
  // Más honesto que kg×precio_referencia: es plata realmente invertida en el ganado vivo.
  var inversionVigente = 0;
  activeLots.forEach(function(l){
    if (!l) return;
    var ac = parseInt(l.animal_count, 10) || 0;
    if (!ac && l.code && animDB[l.code]) ac = animDB[l.code].length;
    if (!ac) return;
    // Buscar la compra de origen del lote
    var compra = null;
    if (l.cost_origin && l.cost_origin.compra_id) {
      compra = (db.compras_ganado || []).find(function(c){ return c.id === l.cost_origin.compra_id; });
    }
    if (!compra) {
      compra = (db.compras_ganado || []).find(function(c){
        return c.lot_code === l.code || (Array.isArray(c.lote_destinos) && c.lote_destinos.indexOf(l.code) >= 0);
      });
    }
    if (compra) {
      var cabsCompra = parseInt(compra.animal_count || compra.cabezas || 0) || 0;
      var totalCompra = parseFloat(compra.total || 0) || 0;
      var costoPorCab = cabsCompra > 0 ? totalCompra / cabsCompra : 0;
      inversionVigente += costoPorCab * ac;
    }
  });

  // v1.8.31: "Valor aproximado" — valor de mercado del rodeo según ventas reales.
  // Precio/kg promedio de las ventas de los últimos 12 meses × kg vivos actuales.
  // Más realista que un precio de referencia fijo: usa lo que realmente pagaron por tu ganado.
  var hace12m = new Date();
  hace12m.setMonth(hace12m.getMonth() - 12);
  var hace12mStr = hace12m.toISOString().slice(0, 10);
  var ventasKg = 0, ventasTotal = 0;
  (db.sales || []).forEach(function(s){
    var fecha = String(s.date || s.fecha || '').slice(0, 10);
    if (!fecha || fecha < hace12mStr) return;
    var kg = parseFloat(s.kg || s.kg_facturados || 0) || 0;
    var total = parseFloat(s.total || 0) || 0;
    if (kg > 0 && total > 0) { ventasKg += kg; ventasTotal += total; }
  });
  var precioKgMercado = ventasKg > 0 ? ventasTotal / ventasKg : 0;
  var valorMercado = precioKgMercado > 0 ? stockKg * precioKgMercado : 0;

  function fmtMoney(n){
    if (n >= 1000000) return 'Bs ' + (Math.round(n/100000)/10) + 'M';
    if (n >= 1000)    return 'Bs ' + (Math.round(n/100)/10) + 'k';
    return 'Bs ' + Math.round(n).toLocaleString();
  }

  // Costo / kg operativo desde caché CREA
  var creaKPIs = window._lastCREAKPIs;
  var costoTxt = '—';
  if (creaKPIs && typeof creaKPIs.costoOperativoKg === 'number' && creaKPIs.costoOperativoKg > 0) {
    costoTxt = 'Bs ' + creaKPIs.costoOperativoKg;
  }

  // Pintar (con guards en cada query por si el DOM se corrompió)
  var elCab = document.getElementById('tbs-cab');
  var elVal = document.getElementById('tbs-valor');
  var elMer = document.getElementById('tbs-mercado');
  var elCos = document.getElementById('tbs-costo');

  // v1.4.100: si no hay cabezas contabilizadas, mostrar conteo de lotes como fallback informativo
  if (elCab) elCab.textContent = cab > 0 ? cab.toLocaleString() : (activeLots.length + ' lotes');
  if (elVal) elVal.textContent = inversionVigente > 0 ? fmtMoney(inversionVigente) : '—';
  if (elMer) elMer.textContent = valorMercado > 0 ? fmtMoney(valorMercado) : '—';
  if (elCos) elCos.textContent = costoTxt;

  el.style.display = 'flex';
}

function renderDashboard() {
  // v1.4.57: Dashboard fusionado con Reporte CREA.
  // Esta función ahora cumple 2 roles:
  //  1) Actualizar los badges del menú lateral y del header (siguen existiendo fuera del dashboard)
  //  2) Re-renderizar el contenido CREA en #crea-content
  // Se llama desde +20 sitios (post-save de ventas, compras, etc.) — todos siguen funcionando.

  updateHeaderBranding();

  // ── Actualizar badges del menú lateral y header (elementos que sobrevivieron al rediseño) ──
  try {
    // Recalcular animal_count desde e5m_animals (igual que antes, para consistencia con renderLotes)
    var _dashAnimDB = (typeof getAnimalesDB === 'function') ? getAnimalesDB() : {};
    if (db && db.lots) {
      db.lots.forEach(function(lt) {
        var anims = _dashAnimDB[lt.code];
        if (anims && anims.length > 0) {
          // FIX header pegado: e5m_animals es la fuente de verdad de animales presentes.
          // Math.max solo SUBÍA el conteo y nunca lo bajaba, así que tras una baja/venta el
          // header quedaba clavado (ej. 590 en vez de 589). Ahora seguimos el conteo real cuando
          // creció, o cuando bajó poco (lote individualizado: baja/venta de pocas cabezas). Si la
          // diferencia es grande, conservamos el valor (lote sin todos los animales cargados uno a uno).
          var _cur = lt.animal_count || 0;
          if (anims.length >= _cur || (_cur - anims.length) <= Math.max(3, _cur * 0.05)) lt.animal_count = anims.length;
          var ws = anims.map(function(a){ return a.pesajes && a.pesajes.length ? a.pesajes[a.pesajes.length-1].peso : 0; }).filter(function(w){ return w > 0; });
          if (ws.length) lt.avg_weight = Math.round(ws.reduce(function(s,w){return s+w;},0)/ws.length*10)/10;
        }
      });

      var activeLots = db.lots.filter(function(l){ return !l.status || l.status === 'activo' || l.status === 'active'; });
      var activeAlerts = (db.alerts || []).filter(function(a){ return !a.resolved; }).length;

      // v1.4.85: incluir alertas críticas detectadas automáticamente por el Centro de Atención
      var criticasCentro = 0;
      try {
        if (typeof _detectarAlertas === 'function') {
          var detectadas = _detectarAlertas();
          criticasCentro = detectadas.filter(function(a){return a.severity === 'critico';}).length;
        }
      } catch(e) {}
      // Tomar el mayor para que el badge refleje algo realista (no sumamos por riesgo de doble conteo)
      var badgeCount = Math.max(activeAlerts, criticasCentro);

      // Badges que SÍ siguen existiendo en el header y menú lateral
      var badge = document.getElementById('alertCountBadge');
      if (badge) badge.textContent = badgeCount + ' alerta' + (badgeCount !== 1 ? 's' : '');
      var nbAlertas = document.getElementById('nb-alertas');
      if (nbAlertas) nbAlertas.textContent = badgeCount;
      var nbLotes = document.getElementById('nb-lotes');
      if (nbLotes) nbLotes.textContent = activeLots.length;
    }
  } catch(e) { /* defensive: no romper si algo cambió de estructura */ }

  // ── Delegar el render del contenido a CREA ──
  try {
    if (typeof renderReporteCREA === 'function') renderReporteCREA();
  } catch(e) { console.warn('renderReporteCREA falló:', e); }

  // v1.4.92: Refrescar topbar AL FINAL (después de recomputar animal_count desde e5m_animals)
  // Si lo llamamos antes, db.lots todavía tiene animal_count=0 del server y el topbar se oculta.
  renderTopbarSummary();
}

