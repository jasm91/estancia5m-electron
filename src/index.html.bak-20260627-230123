  if (!maq) return;
  var diesel = db.diesel || [];
  var aceite = db.aceite || [];
  var maint = db.maintenance || [];

  var items = [];
  diesel.filter(function(d){return d.type==='despacho'&&matchMaq(d.vehiculo,maq);}).forEach(function(d){
    items.push({date:d.created_at||d.fecha,icon:'⛽',color:'var(--amber2)',title:'Despacho: '+(parseFloat(d.litros)||0)+' L',sub:d.obs||''});
  });
  diesel.filter(function(d){return d.type==='recarga'&&matchMaq(d.proveedor,maq);}).forEach(function(d){
    items.push({date:d.created_at||d.fecha,icon:'🔄',color:'var(--green)',title:'Recarga: '+(parseFloat(d.litros)||0)+' L — Bs.'+(d.total||0),sub:d.proveedor||''});
  });
  aceite.filter(function(a){return matchMaq(a.vehiculo||a.equipo,maq);}).forEach(function(a){
    items.push({date:a.created_at||a.fecha,icon:'🛢',color:'var(--blue)',title:'Cambio aceite'+(a.tipo?' — '+a.tipo:''),sub:(a.kmhr?a.kmhr+' hrs/km':'')+(a.costo?' Bs.'+a.costo:'')});
