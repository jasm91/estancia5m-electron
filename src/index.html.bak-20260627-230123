function openModal(id) {
  var el = document.getElementById(id);
  if (!el) { console.warn('Modal not found:', id); return; }
  populateSelects();
  el.classList.add('open');
  var todayVal = localDate();
  var dtl = localDate()+'T'+new Date().toLocaleTimeString('en-US',{hour12:false,hour:'2-digit',minute:'2-digit'});
  // FIX v1.4.34: prevenir registros con fecha futura. Los inputs de transacción
  // (fecha de compra, venta, pesaje, etc.) reciben max=today para que el datepicker
  // no permita seleccionar fechas posteriores a hoy. Excluimos los inputs cuya finalidad
  // es justamente programar algo a futuro (vencimientos, próximas aplicaciones, fechas
  // pactadas de ingreso) y los filtros de rango.
  var FUTURE_OK_IDS = ['task-due','tr-next','prod-expiry','emp-hire'];
  var FILTER_ID_PATTERNS = [/-from$/, /-to$/, /-desde$/, /-hasta$/, /^range-/, /^kardex-fecha-/, /^crea-f-/, /^rp-fecha-(inicio|fin)$/, /^cont-f-/, /^mnt-(from|to)$/, /^adv-range-/];
  function _isFilterOrFutureOk(inputId){
    if (!inputId) return false;
    if (FUTURE_OK_IDS.indexOf(inputId) >= 0) return true;
    for (var i=0; i<FILTER_ID_PATTERNS.length; i++){ if (FILTER_ID_PATTERNS[i].test(inputId)) return true; }
    return false;
  }
  // v1.8.61: campos de fecha OPCIONALES que NO deben auto-rellenarse con hoy.
  // emp-term (fecha de baja): si se rellenara con hoy, daría de baja al empleado
  // al crearlo o al editarlo. Debe quedar vacío salvo baja real.
  var NO_AUTOFILL_DATE_IDS = ['emp-term'];
  el.querySelectorAll('input[type="date"]').forEach(function(d){
    if(!d.value && NO_AUTOFILL_DATE_IDS.indexOf(d.id) < 0) d.value=todayVal;
    if(!_isFilterOrFutureOk(d.id)) d.max = todayVal;
  });
  el.querySelectorAll('input[type="datetime-local"]').forEach(function(d){
    if(!d.value) d.value=dtl;
    if(!_isFilterOrFutureOk(d.id)) d.max = dtl;
  });
  if (id === 'modal-pesaje' && typeof populatePesajeModal === 'function') populatePesajeModal();
  // v1.4.61: resetear checkboxes "retroactive" al abrir cualquier modal (evitar arrastrar estado)
  ['tr-retroactive', 'sal-retroactive', 'alimento-retroactive'].forEach(function(cbId) {
    var cb = el.querySelector('#' + cbId);
    if (cb && cb.checked) {
      cb.checked = false;
      // Repoblar el dropdown asociado (solo activos)
      var targetId = cbId.replace('-retroactive', '-lot');
      if (typeof onRetroactiveToggle === 'function') onRetroactiveToggle(targetId, false);
    }
  });
}

