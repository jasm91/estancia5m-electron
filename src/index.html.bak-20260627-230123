function _renderCentroAtencionSecciones() {
  var el = document.getElementById('alertas-secciones');
  if (!el) return;
  var alerts = window._centroAtencionState.alerts_cache;
  var filter = window._centroAtencionState.current_filter;
  var filtered = filter === 'all' ? alerts : alerts.filter(function(a){return a.severity === filter;});

  if (filtered.length === 0) {
    el.innerHTML = '<div style="background:var(--sur);border:1px solid var(--bor);border-radius:10px;padding:48px 20px;text-align:center">' +
      '<div style="font-size:48px;margin-bottom:12px">' + (alerts.length === 0 ? '✅' : '🔍') + '</div>' +
      '<div style="font-size:14px;color:var(--text);margin-bottom:4px">' + (alerts.length === 0 ? '¡Todo en orden!' : 'Sin alertas en esta categoría') + '</div>' +
      '<div style="font-size:11px;color:var(--muted)">' + (alerts.length === 0 ? 'No hay nada que requiera tu atención ahora mismo' : 'Probá otro filtro') + '</div>' +
    '</div>';
    return;
  }

  // Agrupar por severidad y renderizar
  var sevLabels = {
    'critico':    { label: '🔴 CRÍTICO — Acción hoy', color: 'var(--red)' },
    'atencion':   { label: '🟡 ATENCIÓN — Esta semana', color: 'var(--amber2)' },
    'sugerencia': { label: '🔵 SUGERENCIA — Cuando puedas', color: 'var(--blue)' }
  };
  var html = '';
  ['critico','atencion','sugerencia'].forEach(function(sev) {
    var grupo = filtered.filter(function(a){return a.severity === sev;});
    if (!grupo.length) return;
    var meta = sevLabels[sev];
    html += '<div style="margin-bottom:18px">' +
      '<div style="font-family:DM Mono,monospace;font-size:10px;letter-spacing:.12em;color:' + meta.color + ';margin-bottom:8px;font-weight:700">' + meta.label + '</div>' +
      '<div style="display:flex;flex-direction:column;gap:6px">' +
        grupo.map(function(a){ return _renderAlertCard(a, sev); }).join('') +
      '</div>' +
    '</div>';
  });
  el.innerHTML = html;
}

function _renderAlertCard(a, sev) {
