// ─── F-08: PREDICCIONES DE FECHAS ─────────────────────────────
var REPRO_GESTATION_DAYS = 280;

function _reproExpectedPartoDate(servicio) {
  if (!servicio || !servicio.date || servicio.result !== 'preñada') return null;
  try {
    var d = new Date(servicio.date);
    d.setDate(d.getDate() + REPRO_GESTATION_DAYS);
    return d;
  } catch(e) { return null; }
}

function _reproDaysUntil(targetDate) {
  if (!targetDate) return null;
  try {
    var now = new Date();
    now.setHours(0, 0, 0, 0);
    var t = new Date(targetDate);
    t.setHours(0, 0, 0, 0);
    return Math.round((t - now) / 86400000);
  } catch(e) { return null; }
}

function _reproFmtDateObj(d) {
  if (!d) return '—';
  try {
    return d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0') + '-' + String(d.getDate()).padStart(2, '0');
  } catch(e) { return '—'; }
}

// Pill para columna "Esperado parto" en tabla Servicios
function _reproExpectedPartoPill(servicio) {
  var d = _reproExpectedPartoDate(servicio);
  if (!d) {
    if (servicio.result === 'vacia') return '<span style="color:var(--muted);font-size:11px">—</span>';
    if (servicio.result === 'preñada') return '<span style="color:var(--muted);font-size:11px">—</span>';
    return '<span style="color:var(--muted);font-size:11px">—</span>';
  }
  var days = _reproDaysUntil(d);
  var color, label;
  if (days < 0) { color = 'var(--red)'; label = 'Vencido'; }
  else if (days <= 15) { color = 'var(--red)'; label = days + 'd ⚠'; }
  else if (days <= 30) { color = 'var(--amber)'; label = days + 'd'; }
  else { color = 'var(--green)'; label = days + 'd'; }
  return '<div style="font-family:DM Mono,monospace;font-size:11px">' + _reproFmtDateObj(d) + '</div>' +
    '<div style="font-size:10px;color:' + color + ';margin-top:1px">' + label + '</div>';
}

// ─── F-11: PRÓXIMOS PARTOS ────────────────────────────────────
function renderReproProxPartos() {
  var windowEl = document.getElementById('repro-prox-window');
  var maxDays = windowEl ? parseInt(windowEl.value, 10) : 60;
  var tbody = document.getElementById('repro-prox-tbody');
  if (!tbody) return;

  var servicios = _reproGetServicios();
  var partos = _reproGetPartos();

  // Servicios con preñada Y sin parto vinculado todavía
  var serviciosConParto = {};
  partos.forEach(function(p) { if (p.servicio_id) serviciosConParto[p.servicio_id] = true; });

  var prenadas = servicios.filter(function(s) {
    return s.result === 'preñada' && !serviciosConParto[s.id];
  }).map(function(s) {
    var d = _reproExpectedPartoDate(s);
    var days = _reproDaysUntil(d);
    return { s: s, expected: d, days: days };
  }).filter(function(x) {
    if (x.days == null) return false;
    return x.days <= maxDays;
  }).sort(function(a, b) { return (a.days || 9999) - (b.days || 9999); });

  if (!prenadas.length) {
    tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;padding:30px;color:var(--muted);font-size:12px">No hay partos esperados en los próximos ' + maxDays + ' días.</td></tr>';
    return;
  }

  tbody.innerHTML = prenadas.map(function(x) {
    var s = x.s;
    var color, label, action;
    if (x.days < 0) {
      color = 'var(--red)';
      label = '⚠ Vencido hace ' + Math.abs(x.days) + 'd';
      action = '<span style="font-size:10.5px;color:var(--red)">Revisar — pudo haber parido</span>';
    } else if (x.days <= 15) {
      color = 'var(--red)';
      label = 'Inminente';
      action = '<span style="font-size:10.5px;color:var(--red)">🚨 Apartar al paridero ya</span>';
    } else if (x.days <= 30) {
      color = 'var(--amber)';
      label = 'Próximo';
      action = '<span style="font-size:10.5px;color:var(--amber)">Preparar paridero</span>';
    } else if (x.days <= 60) {
      color = 'var(--blue)';
      label = 'En espera';
      action = '<span style="font-size:10.5px;color:var(--blue)">Monitoreo</span>';
    } else {
      color = 'var(--green)';
      label = 'Lejano';
      action = '<span style="font-size:10.5px;color:var(--muted)">—</span>';
    }
    return '<tr>' +
      '<td style="font-family:DM Mono,monospace;font-size:11.5px">' + escH(s.animal_id || '—') + '</td>' +
      '<td style="font-family:DM Mono,monospace;font-size:11.5px">' + escH(s.lot_code || '—') + '</td>' +
      '<td style="font-family:DM Mono,monospace;font-size:11.5px">' + _reproFmtDate(s.date) + '</td>' +
      '<td>' + _reproTipoPill(s.tipo_servicio) + '</td>' +
      '<td style="font-family:DM Mono,monospace;font-size:11.5px">' + _reproFmtDateObj(x.expected) + '</td>' +
      '<td style="font-family:DM Mono,monospace;font-size:11.5px;color:' + color + ';font-weight:600">' + x.days + 'd</td>' +
      '<td><span style="color:' + color + ';font-weight:500;font-size:11.5px">' + label + '</span> · ' + action + '</td>' +
      '</tr>';
  }).join('');
}

// ─── F-09: ALERTAS REPRODUCTIVAS ──────────────────────────────
function _reproDetectarAlertas() {
  var alerts = [];
  var servicios = _reproGetServicios();
  var partos = _reproGetPartos();
  var obj = _reproGetObjetivos();

  // 1) Partos inminentes (≤15d)
  var serviciosConParto = {};
  partos.forEach(function(p) { if (p.servicio_id) serviciosConParto[p.servicio_id] = true; });
  var prenadasProx = servicios.filter(function(s) {
    if (s.result !== 'preñada' || serviciosConParto[s.id]) return false;
    var d = _reproExpectedPartoDate(s);
    var days = _reproDaysUntil(d);
    return days != null && days >= 0 && days <= 15;
  });
  if (prenadasProx.length) {
    alerts.push({
      severity: 'critico', icon: '🐣',
      title: prenadasProx.length + ' vaca' + (prenadasProx.length > 1 ? 's' : '') + ' a parir en ≤15 días',
      msg: prenadasProx.slice(0, 5).map(function(s) {
        var days = _reproDaysUntil(_reproExpectedPartoDate(s));
        return escH(s.animal_id) + ' (' + days + 'd)';
      }).join(', ') + (prenadasProx.length > 5 ? '...' : '') + ' — apartar al paridero',
      action: 'switchTab(\'repro\',document.querySelector(\'[onclick*=repro-tab-inteligencia]\'),\'repro-tab-inteligencia\')',
      action_label: 'Ver lista'
    });
  }

  // 2) Partos vencidos (días > 280+10, sin parto registrado)
  var vencidas = servicios.filter(function(s) {
    if (s.result !== 'preñada' || serviciosConParto[s.id]) return false;
    var d = _reproExpectedPartoDate(s);
    var days = _reproDaysUntil(d);
    return days != null && days < -10;
  });
  if (vencidas.length) {
    alerts.push({
      severity: 'critico', icon: '⚠',
      title: vencidas.length + ' parto' + (vencidas.length > 1 ? 's' : '') + ' vencido' + (vencidas.length > 1 ? 's' : '') + ' sin registrar',
      msg: vencidas.slice(0, 3).map(function(s) {
        var days = _reproDaysUntil(_reproExpectedPartoDate(s));
        return escH(s.animal_id) + ' (' + Math.abs(days) + 'd atrás)';
      }).join(', ') + ' — posible aborto / parto no registrado / error de diagnóstico',
      action: 'switchTab(\'repro\',document.querySelector(\'[onclick*=repro-tab-servicios]\'),\'repro-tab-servicios\')',
      action_label: 'Ver servicios'
    });
  }

  // 3) Diagnósticos pendientes hace >30 días
  var hoyMs = Date.now();
  var pendOld = servicios.filter(function(s) {
    if (s.result && s.result !== 'pendiente') return false;
    if (!s.date) return false;
    var diff = (hoyMs - new Date(s.date).getTime()) / 86400000;
    return diff > 30;
  });
  if (pendOld.length) {
    alerts.push({
      severity: 'alto', icon: '🔬',
      title: pendOld.length + ' servicio' + (pendOld.length > 1 ? 's' : '') + ' sin diagnóstico hace >30 días',
      msg: 'Ya deberían poder diagnosticarse por tacto/eco. Ejemplos: ' +
        pendOld.slice(0, 3).map(function(s) { return escH(s.animal_id) + ' (' + _reproFmtDate(s.date) + ')'; }).join(', '),
      action: 'openReproDiagnostico()',
      action_label: '+ Diagnosticar'
    });
  }

  // 4) Toro / pajuela con baja tasa de preñez
  var perfToro = _reproPerfData('toro');
  var perfSemen = _reproPerfData('semen');
  var problematicos = perfToro.concat(perfSemen).filter(function(p) {
    return p.servicios >= 5 && p.efectivos >= 3 && p.tasa != null && p.tasa < 40;
  });
  if (problematicos.length) {
    alerts.push({
      severity: 'alto', icon: '📉',
      title: problematicos.length + ' entidad' + (problematicos.length > 1 ? 'es con' : ' con') + ' tasa preñez <40%',
      msg: problematicos.slice(0, 4).map(function(p) {
        return escH(p.key) + ' (' + p.tasa + '% en ' + p.servicios + ' serv.)';
      }).join(' · ') + ' — considerar revisión andrológica / cambio de pajuela',
      action: 'switchTab(\'repro\',document.querySelector(\'[onclick*=repro-tab-inteligencia]\'),\'repro-tab-inteligencia\')',
      action_label: 'Ver performance'
    });
  }

  // 5) Vacas con 3+ servicios sin preñar (repetición)
  var byVaca = {};
  servicios.forEach(function(s) {
    if (!s.animal_id) return;
    if (!byVaca[s.animal_id]) byVaca[s.animal_id] = { total: 0, prenada: false, last_date: '' };
    byVaca[s.animal_id].total++;
    if (s.result === 'preñada') byVaca[s.animal_id].prenada = true;
    if (s.date > byVaca[s.animal_id].last_date) byVaca[s.animal_id].last_date = s.date;
  });
  var repetidoras = Object.keys(byVaca).filter(function(k) {
    return byVaca[k].total >= 3 && !byVaca[k].prenada;
  });
  if (repetidoras.length) {
    alerts.push({
      severity: 'alto', icon: '🔁',
      title: repetidoras.length + ' vaca' + (repetidoras.length > 1 ? 's' : '') + ' con ≥3 servicios sin preñar',
      msg: repetidoras.slice(0, 5).map(escH).join(', ') + ' — candidatas a descarte o revisión veterinaria',
      action: '',
      action_label: ''
    });
  }

  // 6) Tasa preñez global bajo objetivo
  var ind = _reproIndicadoresCompute(12);
  if (ind.prenezPct != null && obj.prenez_pct && ind.prenezPct < obj.prenez_pct - 15) {
    alerts.push({
      severity: 'alto', icon: '📊',
      title: 'Tasa de preñez global ' + ind.prenezPct + '% — bajo objetivo (' + obj.prenez_pct + '%)',
      msg: 'Brecha de ' + (obj.prenez_pct - ind.prenezPct) + ' puntos. Revisá performance por toro/pajuela/técnico y condición corporal del rodeo.',
      action: 'switchTab(\'repro\',document.querySelector(\'[onclick*=repro-tab-indicadores]\'),\'repro-tab-indicadores\')',
      action_label: 'Ver indicadores'
    });
  }

  // 7) Mortalidad neonatal alta
  var partos12 = _reproPartosFilterPeriodo(partos, 12);
  if (partos12.length >= 10) {
    var muertos = partos12.filter(function(p) { return p.estado === 'muerto'; }).length;
    var pct = (muertos / partos12.length) * 100;
    if (pct > 5) {
      alerts.push({
        severity: 'medio', icon: '⚠',
        title: 'Mortalidad neonatal ' + pct.toFixed(1) + '% (' + muertos + '/' + partos12.length + ')',
        msg: 'Por encima del 5% típico — revisar nutrición preparto, asistencia al parto, parasitismo',
        action: '', action_label: ''
      });
    }
  }

  return alerts;
}

function renderReproAlertas() {
  var body = document.getElementById('repro-alertas-body');
  if (!body) return;
  var alerts = _reproDetectarAlertas();
  if (!alerts.length) {
