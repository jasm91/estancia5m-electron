  if(!confirm('¿Eliminar este producto del stock veterinario?' + (_depT ? '\n\nOjo: ' + _depT + ' curación(es) usan este producto y quedarán sin referencia (no se borran).' : ''))) return;
  
  // FIX v1.4.35: audit log para deleteProduct
