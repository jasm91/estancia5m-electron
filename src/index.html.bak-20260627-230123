function bulkRefreshBar() {
  var bar = document.getElementById('animales-bulk-bar');
  if (!bar) return;
  var keys = Object.keys(window._bulkSelected);
  var count = keys.length;
  if (count === 0) {
    bar.style.display = 'none';
    return;
  }
  bar.style.display = 'flex';
  document.getElementById('bulk-count-badge').textContent = count + (count === 1 ? ' animal seleccionado' : ' animales seleccionados');
  // Stats
  var weights = keys.map(function(k) { return window._bulkSelected[k].weight || 0; }).filter(function(w){return w>0;});
  if (weights.length > 0) {
    var avg = weights.reduce(function(a,b){return a+b;}, 0) / weights.length;
    var total = weights.reduce(function(a,b){return a+b;}, 0);
    var lots = {};
    keys.forEach(function(k){ lots[window._bulkSelected[k].lot] = true; });
    document.getElementById('bulk-stats').textContent =
      'Peso prom: ' + avg.toFixed(1) + ' kg · Total: ' + Math.round(total).toLocaleString() + ' kg' +
      ' · ' + Object.keys(lots).length + ' lote' + (Object.keys(lots).length === 1 ? '' : 's') + ' origen';
  } else {
    document.getElementById('bulk-stats').textContent = '';
  }
