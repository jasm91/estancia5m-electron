    potrero = val.substring(4);
  }

  if (!db.pasture_evals) db.pasture_evals = [];
  var rec = {
    id: 'eval_' + Date.now(),
    potrero: potrero,
    lot_code: lotCode,
    lot: lotCode,
    date: new Date().toISOString(),
    evaluated_at: new Date().toISOString(),
    created_at: new Date().toISOString(),
    type: 'completed',
