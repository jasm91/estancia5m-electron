  // v1.4.67: filtrar lotes vacíos (cuarentena ya traspasada) — no mostrar en Detalle por Lote
  var lotesDetalle = lotsAtPeriodStart.slice().filter(function(l) {
    var st = (l.status || '').toLowerCase();
