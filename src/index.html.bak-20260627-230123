  summary += '✓ ' + lotesNuevos.length + ' lotes' + (lotesExistentes ? ' <span style="color:var(--muted)">(' + lotesExistentes + ' ya existen)</span>' : '') + '<br>';
  summary += '✓ ' + animalesNuevos.length + ' animales' + (animalesExistentes ? ' <span style="color:var(--muted)">(' + animalesExistentes + ' ya existen)</span>' : '') + '<br>';
  summary += '✓ ' + prodNuevos.length + ' productos veterinarios' + (prodExistentes ? ' <span style="color:var(--muted)">(' + prodExistentes + ' ya existen)</span>' : '') + '<br>';
  summary += '✓ ' + maqNuevas.length + ' maquinarias<br>';
