function guardarKardex(){
  var lote=(document.getElementById('kx-lote')||{}).value||'';
  var tipo=(document.getElementById('kx-tipo')||{}).value||'compra';
  var fecha=(document.getElementById('kx-fecha')||{}).value||'';
  var cab=parseInt((document.getElementById('kx-cabezas')||{}).value)||0;
  var precio=parseFloat((document.getElementById('kx-precio')||{}).value)||0;
  var desc=((document.getElementById('kx-desc')||{}).value||'').trim();
  if(!lote||!fecha||!cab){toast('Completa lote, fecha y cabezas','error');return;}
  // FIX v1.4.34: no permitir fechas futuras
  if(!validateNotFuture(fecha, 'fecha del asiento')) return;
  if(!db.kardex)db.kardex=[];

  db.kardex.push({
    id:Date.now(),lote:lote,tipo:tipo,fecha:fecha,
    cabezas:cab,precio:precio,total:Math.round(cab*precio),
    desc:desc,by:'Desktop',created_at:new Date().toISOString()
  });

  // Si es compra, agregar animales a e5m_animals y actualizar lot
  if(tipo==='compra') {
    var raza=(document.getElementById('kx-raza')||{}).value||'';
    var pesoProm=parseFloat((document.getElementById('kx-peso-compra')||{}).value)||0;
    var animalesDB=getAnimalesDB();
    if(!animalesDB[lote])animalesDB[lote]=[];

    // Leer IDs y pesos de la tabla
    var idInputs=document.querySelectorAll('.kx-animal-id');
    var pesoInputs=document.querySelectorAll('.kx-animal-peso');

    for(var i=0;i<cab;i++){
      var rawId='';
      var rawPeso=pesoProm;
      if(i<idInputs.length){
        rawId=(idInputs[i].value||'').trim();
        var pesoVal=parseFloat(pesoInputs[i].value);
        if(!isNaN(pesoVal)&&pesoVal>0)rawPeso=pesoVal;
      }
      var animalId=rawId||'N/A';
      var entry={
        id:animalId,
        raza:raza,
        pesajes:[],
        lot_code:lote,
        fecha_ingreso:fecha,
        source:'kardex'
      };
      if(rawPeso>0){
        entry.pesajes.push({fecha:fecha,peso:rawPeso});
      }
      animalesDB[lote].push(entry);
    }
    localStorage.setItem('e5m_animals',JSON.stringify(animalesDB));

    // Actualizar animal_count del lote
    var lot=db.lots.find(function(l){return l.code===lote;});
    if(lot){
      lot.animal_count=(lot.animal_count||0)+cab;
      // Recalcular avg_weight si hay pesos
      if(pesoProm>0)lot.avg_weight=pesoProm;
    }
  }

  saveDB(true); // lotChanged=true para trigger sync
  closeModal('modal-kardex');
  renderKardex();
  renderLotes();

  var idMsg=tipo==='compra'?' — animales agregados al lote':'';
  toast(capFirst(tipo)+' '+lote+' - '+cab+' cab.'+idMsg,'success');
}

function deleteKardex(id){
  var mov = (db.kardex || []).find(function(r){ return r.id === id; });
  if (!mov) { toast('Movimiento no encontrado', 'error'); return; }
  var msg = 'Eliminar este movimiento del kardex?\n\n' +
    'Fecha: ' + (mov.fecha || '-') + '\n' +
    'Lote: ' + (mov.lote || '-') + '\n' +
    'Tipo: ' + capFirst(mov.tipo || '') + '\n' +
    'Cabezas: ' + (mov.cabezas || 0) + '\n' +
    'Total: Bs. ' + (mov.total || 0).toLocaleString() + '\n' +
    (mov.desc ? 'Detalle: ' + mov.desc + '\n' : '') +
    '\nNota: Solo se elimina el registro contable. Los animales, ventas o compras asociadas NO se modifican.\n\n' +
    'Esta acción no se puede deshacer.';
  if(!confirm(msg))return;
  trackDeletion(id, 'kardex');
  db.kardex=db.kardex.filter(function(r){return r.id!==id;});
  saveDB();renderKardex();toast('Movimiento eliminado','success');
  replaceTableInRailway('kardex', db.kardex || []);
  try { auditLog('delete', 'kardex', id, 'Movimiento ' + (mov.tipo||'') + ' de ' + (mov.lote||'') + ' (' + (mov.fecha||'') + ')'); } catch(e){}
}

