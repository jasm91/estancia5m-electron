// Formatear fecha+hora para mostrar en todos los registros
function fmtDT(str) {
  if (!str) return '';
  var s = str.toString();
  if (s.length > 10 && s[10] === 'T') {
    var dt = new Date(s);
    if (!isNaN(dt)) {
      var pad = function(n){ return n.toString().padStart(2,'0'); };
      // Usar fecha local (getFullYear/getMonth/getDate) NO el slice del string UTC,
      // porque al cruzar medianoche UTC el día se desfasa respecto al horario local.
      return dt.getFullYear() + '-' + pad(dt.getMonth()+1) + '-' + pad(dt.getDate()) + ' ' + pad(dt.getHours()) + ':' + pad(dt.getMinutes());
    }
  }
  if (s.length >= 16 && s[10] === ' ') return s.slice(0,16);
  return s.slice(0,10);
}
// v1.8.69: mostrar la FECHA ELEGIDA por el usuario (no el día de registro). Muestra hora solo si
// el registro se cargó el mismo día (no retro-fechado). Usado en Pluviometría y Aceite (igual que
// el combustible). Antes mostraban created_at → una lectura con fecha pasada salía con la fecha de hoy.
function _fechaRegDisplay(r){
  var f = String((r && r.fecha) || '');
  if (f && r && r.created_at && fmtDT(r.created_at).slice(0,10) === f) return fmtDT(r.created_at);
  return f || fmtDT((r && r.created_at) || '');
}
