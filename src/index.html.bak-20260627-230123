var _moverAnimalId = null;
var _moverFromLot = null;

function openMoverAnimal(animalId, fromLot) {
  _moverAnimalId = animalId;
  _moverFromLot = fromLot;
  var infoEl = document.getElementById('mover-animal-info');
  var fromEl = document.getElementById('mover-from-lot');
  var toLotSel = document.getElementById('mover-to-lot');
  var dateEl = document.getElementById('mover-date');
  if(infoEl) infoEl.textContent = 'Animal #' + animalId;
  if(fromEl) fromEl.textContent = fromLot;
  if(dateEl) dateEl.value = localDate();
  // Poblar lotes destino (excluir el lote actual)
  if(toLotSel) {
    toLotSel.innerHTML = '<option value="">Seleccionar lote destino...</option>';
    (db.lots||[]).filter(function(l){ return l.code !== fromLot && (!l.status || l.status==='activo' || l.status==='active'); })
      .forEach(function(l){
        var o = document.createElement('option');
        o.value = l.code;
        o.textContent = l.code + ' - ' + (l.category||'') + ' (' + l.animal_count + ' cab.)';
        toLotSel.appendChild(o);
      });
  }
  openModal('modal-mover-animal');
}

function confirmarMoverAnimal() {
  var toLot = (document.getElementById('mover-to-lot')||{}).value || '';
  var date = (document.getElementById('mover-date')||{}).value || localDate();
  var motivo = (document.getElementById('mover-motivo')||{}).value || '';
  if(!toLot) { toast('Selecciona el lote destino','error'); return; }
  // FIX v1.4.34: no permitir fechas futuras
  if(!validateNotFuture(date, 'fecha de movimiento')) return;
  if(!_moverAnimalId || !_moverFromLot) return;

  // Validar capacidad del potrero destino
  var capCheck = checkPotreroCapacity(toLot, 1);
  if (!capCheck.ok) { toast(capCheck.msg, 'error'); return; }

  // 1. Mover en localStorage
  var adb = getAnimalesDB();
  var fromAnimals = adb[_moverFromLot] || [];
  var animal = fromAnimals.find(function(a){ return (a.id||a.animal_id||'').toString() === _moverAnimalId.toString(); });
  if(!animal) { toast('Animal no encontrado','error'); return; }

  // v1.8.66: estampar el movimiento granular en el animal (igual que el bulk-mover).
  // Sin esto, la "Trazabilidad completa" no mostraba los traslados hechos de a uno.
  if (!animal._movements) animal._movements = [];
  var _lastPesoMov = (animal.pesajes && animal.pesajes.length) ? (parseFloat(animal.pesajes[animal.pesajes.length-1].peso) || 0) : 0;
  animal._movements.push({
    date: date,
    from_lot: _moverFromLot,
    to_lot: toLot,
    weight_at_move: _lastPesoMov,
    reason: motivo
  });

  // Quitar del lote origen
  adb[_moverFromLot] = fromAnimals.filter(function(a){ return (a.id||a.animal_id||'').toString() !== _moverAnimalId.toString(); });
  // Agregar al lote destino
  if(!adb[toLot]) adb[toLot] = [];
  adb[toLot].push(animal);
  saveAnimalesDB(adb);

  // 2. Actualizar animal_count de los lotes
  var fromLotObj = db.lots.find(function(l){ return l.code === _moverFromLot; });
  var toLotObj = db.lots.find(function(l){ return l.code === toLot; });
  if(fromLotObj && fromLotObj.animal_count > 0) fromLotObj.animal_count--;
  if(toLotObj) toLotObj.animal_count++;
  saveDB();

  // 3. Registrar en Railway via endpoint dedicado
  var apiUrl = getApiUrl();
  var token = localStorage.getItem('e5m_api_token') || '';
  fetch(apiUrl + '/animal-move', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
    body: JSON.stringify({
      animal_id: _moverAnimalId,
      from_lot: _moverFromLot,
      to_lot: toLot,
      date: date,
      by: _desktopAuthor(),
      source: 'desktop',
      motivo: motivo
    })
  }).then(function(r){ return r.json(); })
    .then(function(d){ if(d.ok) toast('Animal '+_moverAnimalId+' movido a '+toLot,'success'); })
    .catch(function(){ toast('Movido localmente. Sync pendiente.','success'); });

  // 4. Registrar en actividades
  addActivity('Sistema','movimiento',toLot,'Animal #'+_moverAnimalId+' movido de '+_moverFromLot+' a '+toLot+(motivo?' - '+motivo:''),date);
  saveDB();

  closeModal('modal-mover-animal');
  renderAnimalesLote();
  renderLotes();
}

