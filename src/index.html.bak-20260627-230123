      '<div style="font-size:22px">' + a.icon + '</div>' +
      '<div style="flex:1;min-width:200px">' +
        '<div style="font-size:13px;font-weight:600;color:' + sevColor[a.severity] + ';margin-bottom:2px">' + a.title + '</div>' +
        '<div style="font-size:11.5px;color:var(--text);line-height:1.4;opacity:.85">' + a.msg + '</div>' +
      '</div>' +
      actionBtn +
      '</div>';
  }).join('');
}

// ─── F-10: PERFORMANCE POR ENTIDAD ────────────────────────────
function _reproPerfData(kind) {
  // kind: 'toro' | 'semen' | 'tecnico'
  var servicios = _reproGetServicios();
  var byKey = {};
  servicios.forEach(function(s) {
    var k = '';
    if (kind === 'toro') {
      if (s.tipo_servicio !== 'monta') return;
      k = (s.toro_id || '').trim();
      if (!k) k = '(toro suelto sin identificar)';
    } else if (kind === 'semen') {
      if (s.tipo_servicio !== 'IA') return;
      k = (s.semen_lote || '').trim();
      if (!k) return; // descartamos vacías porque IA sin pajuela es data sucia
    } else if (kind === 'tecnico') {
      if (s.tipo_servicio !== 'IA') return;
      k = (s.technician || '').trim();
      if (!k) return;
    }
    if (!byKey[k]) byKey[k] = { key: k, servicios: 0, prenadas: 0, vacias: 0, pendientes: 0 };
    byKey[k].servicios++;
    if (s.result === 'preñada') byKey[k].prenadas++;
    else if (s.result === 'vacia') byKey[k].vacias++;
    else byKey[k].pendientes++;
  });
  return Object.keys(byKey).map(function(k) {
    var r = byKey[k];
    r.efectivos = r.prenadas + r.vacias;
    r.tasa = r.efectivos > 0 ? Math.round((r.prenadas / r.efectivos) * 100) : null;
    return r;
  });
}

var _reproPerfCurrent = 'toro';
function _reproPerfSwitch(kind) {
  _reproPerfCurrent = kind;
  ['toro', 'semen', 'tecnico'].forEach(function(k) {
    var btn = document.getElementById('repro-perf-tab-' + k);
    if (btn) btn.classList.toggle('active', k === kind);
  });
  renderReproPerformance();
}

function renderReproPerformance() {
  var tbody = document.getElementById('repro-perf-tbody');
  var noteEl = document.getElementById('repro-perf-note');
  var colNameEl = document.getElementById('repro-perf-col-name');
  if (!tbody) return;

  var kind = _reproPerfCurrent || 'toro';
  var colLabels = { toro: '🐂 Toro', semen: '💧 Pajuela', tecnico: '👨‍⚕️ Técnico' };
  if (colNameEl) colNameEl.textContent = colLabels[kind] || 'Entidad';

  var data = _reproPerfData(kind);
  if (!data.length) {
    tbody.innerHTML = '<tr><td colspan="8" style="text-align:center;padding:30px;color:var(--muted);font-size:12px">Sin datos de ' + colLabels[kind] + ' aún</td></tr>';
    if (noteEl) noteEl.textContent = '';
    return;
  }

  // Promedio global (ponderado por servicios efectivos)
  var totalEf = 0, totalPren = 0;
  data.forEach(function(d) { totalEf += d.efectivos; totalPren += d.prenadas; });
  var avg = totalEf > 0 ? Math.round((totalPren / totalEf) * 100) : null;

  // Sort por tasa descendente (los mejores primero)
  data.sort(function(a, b) {
    var ta = a.tasa != null ? a.tasa : -1;
    var tb = b.tasa != null ? b.tasa : -1;
    return tb - ta;
  });

  tbody.innerHTML = data.map(function(r) {
    var diff = (r.tasa != null && avg != null) ? (r.tasa - avg) : null;
    var diffStr = '', diffColor = 'var(--muted)';
    if (diff != null) {
      if (diff > 0) { diffStr = '+' + diff + ' pts'; diffColor = 'var(--green)'; }
      else if (diff < 0) { diffStr = diff + ' pts'; diffColor = 'var(--red)'; }
      else { diffStr = '='; diffColor = 'var(--muted)'; }
    }
    // Estado: bueno (>=avg-5), atención (avg-15..avg-5), bajo (<avg-15)
    var estado, estadoColor, estadoBg;
    if (r.tasa == null || r.efectivos < 3) {
      estado = 'Poca data'; estadoColor = 'var(--muted)'; estadoBg = 'rgba(255,255,255,.05)';
    } else if (avg == null || r.tasa >= avg - 5) {
      estado = '✓ Bueno'; estadoColor = 'var(--green)'; estadoBg = 'rgba(63,185,80,.12)';
    } else if (r.tasa >= avg - 15) {
      estado = '⚠ Atención'; estadoColor = 'var(--amber)'; estadoBg = 'rgba(212,160,23,.12)';
    } else {
      estado = '✗ Bajo'; estadoColor = 'var(--red)'; estadoBg = 'rgba(248,81,73,.12)';
    }
    return '<tr>' +
      '<td style="font-family:DM Mono,monospace;font-size:11.5px"><b>' + escH(r.key) + '</b></td>' +
      '<td style="font-family:DM Mono,monospace;font-size:11.5px">' + r.servicios + '</td>' +
      '<td style="font-family:DM Mono,monospace;font-size:11.5px;color:var(--green)">' + r.prenadas + '</td>' +
      '<td style="font-family:DM Mono,monospace;font-size:11.5px;color:var(--red)">' + r.vacias + '</td>' +
      '<td style="font-family:DM Mono,monospace;font-size:11.5px;color:var(--amber)">' + r.pendientes + '</td>' +
      '<td style="font-family:DM Mono,monospace;font-size:13px;font-weight:600">' + (r.tasa != null ? r.tasa + '%' : '—') + '</td>' +
      '<td style="font-family:DM Mono,monospace;font-size:11.5px;color:' + diffColor + '">' + diffStr + '</td>' +
      '<td><span style="background:' + estadoBg + ';color:' + estadoColor + ';font-size:11px;padding:3px 8px;border-radius:10px">' + estado + '</span></td>' +
      '</tr>';
  }).join('');

  if (noteEl) {
    noteEl.textContent = 'Promedio del rebaño: ' + (avg != null ? avg + '%' : 'sin datos') +
      ' · ' + data.length + ' ' + colLabels[kind].toLowerCase() + (data.length === 1 ? '' : 's') +
      ' · "Poca data" = menos de 3 servicios diagnosticados, no se compara';
  }
}

// ─── F-13: ASISTENTE IA (Gemini) ──────────────────────────────
function _reproAiPreset(text) {
  var input = document.getElementById('repro-ai-input');
  if (input) {
    input.value = text;
    input.focus();
  }
  askReproAI();
}

function _reproBuildAiContext() {
  var servicios = _reproGetServicios().map(function(s) {
    // Recortar campos a lo esencial para reducir tokens
    return {
      date: s.date, animal_id: s.animal_id, tipo_servicio: s.tipo_servicio,
      semen_lote: s.semen_lote || '', toro_id: s.toro_id || '',
      technician: s.technician || '', lot_code: s.lot_code || '',
      result: s.result || 'pendiente',
      diagnosis_method: s.diagnosis_method || '', diagnosis_date: s.diagnosis_date || ''
    };
  });
  var partos = _reproGetPartos().map(function(p) {
    return {
      date: p.date, madre_id: p.madre_id || '', padre_id: p.padre_id || '',
      sexo: p.sexo, peso: p.peso, estado: p.estado,
      cria_id: p.cria_id || '', lot_code: p.lot_code || '',
      servicio_id: p.servicio_id || ''
    };
  });
  var lots = (db && Array.isArray(db.lots) ? db.lots : []).filter(function(l) {
    var s = (l.status || '').toLowerCase();
    return s !== 'sold' && s !== 'vendido';
  }).map(function(l) {
    return { code: l.code, paddock: l.paddock || '', animal_count: l.animal_count || 0, status: l.status || 'activo' };
  });
  var objetivos = _reproGetObjetivos();
  var ind = _reproIndicadoresCompute(12);
  var resumen = {
    prenez_pct: ind.prenezPct,
    iep: ind.iep,
    sc: ind.sc != null ? Number(ind.sc.toFixed(2)) : null,
    paricion_pct: ind.paricionPct,
    total_servicios: servicios.length,
    total_partos: partos.length,
    vacas_prenadas_pendientes_parto: servicios.filter(function(s) { return s.result === 'preñada'; }).length -
      partos.filter(function(p) { return p.servicio_id; }).length
  };
  return { servicios: servicios, partos: partos, lots: lots, objetivos: objetivos, resumen: resumen };
}

function askReproAI() {
  var input = document.getElementById('repro-ai-input');
  var btn = document.getElementById('repro-ai-btn');
  var resultEl = document.getElementById('repro-ai-result');
  if (!input || !resultEl) return;
  var question = (input.value || '').trim();
  if (!question || question.length < 3) {
    resultEl.innerHTML = '<div style="padding:10px;color:var(--amber);font-size:12px">Escribí una pregunta primero</div>';
    return;
  }

  // Loading state
  if (btn) { btn.disabled = true; btn.textContent = '⏳ Pensando...'; }
  resultEl.innerHTML = '<div style="padding:14px;background:rgba(212,160,23,.06);border:1px solid rgba(212,160,23,.2);border-radius:8px;color:var(--muted);font-size:12.5px;display:flex;align-items:center;gap:10px"><div class="spinner" style="width:14px;height:14px;border:2px solid var(--border);border-top-color:var(--amber);border-radius:50%;animation:spin 1s linear infinite"></div>Analizando tu rebaño con Gemini...</div>';

  var apiUrl = (typeof getApiUrl === 'function') ? getApiUrl() : (localStorage.getItem('e5m_api_url') || 'https://estancia5m-api-production.up.railway.app/api');
  var token = localStorage.getItem('e5m_api_token') || '';
  if (!token) {
    resultEl.innerHTML = '<div style="padding:10px;color:var(--red);font-size:12px">Sin token de API — no se puede consultar al asistente. Sincronizá primero.</div>';
    if (btn) { btn.disabled = false; btn.textContent = '✨ Preguntar'; }
    return;
  }

  var context = _reproBuildAiContext();
  var t0 = Date.now();

  fetch(apiUrl + '/repro-asistente', {
    method: 'POST',
    headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' },
    body: JSON.stringify({ question: question, context: context })
  }).then(function(r) {
    return r.json().then(function(d) { return { ok: r.ok, status: r.status, data: d }; });
  }).then(function(resp) {
    if (btn) { btn.disabled = false; btn.textContent = '✨ Preguntar'; }
    if (!resp.ok || !resp.data || !resp.data.answer) {
      var errMsg = (resp.data && resp.data.error) ? resp.data.error : ('HTTP ' + resp.status);
      var detail = (resp.data && resp.data.detail) ? ('<br><span style="font-size:10.5px;opacity:.7">' + escH(resp.data.detail) + '</span>') : '';
      resultEl.innerHTML = '<div style="padding:12px;background:rgba(248,81,73,.08);border:1px solid rgba(248,81,73,.3);border-radius:8px;color:var(--red);font-size:12.5px">⚠ Error: ' + escH(errMsg) + detail + '</div>';
      return;
    }
    var answer = resp.data.answer;
    var ms = resp.data.ms || (Date.now() - t0);
    var ctxSize = resp.data.context_size || {};
    // Markdown lite: bullets, negritas, listas numeradas
    var formatted = _reproAiFormatAnswer(answer);
    resultEl.innerHTML =
      '<div style="background:rgba(127,119,221,0.06);border:1px solid rgba(127,119,221,0.25);border-radius:8px;padding:14px 16px">' +
        '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;padding-bottom:8px;border-bottom:1px solid var(--border)">' +
          '<div style="font-size:11px;color:var(--purple);font-family:DM Mono,monospace;text-transform:uppercase;letter-spacing:.5px">✨ Respuesta de Gemini</div>' +
          '<div style="font-size:10px;color:var(--muted);font-family:DM Mono,monospace">' + (ms/1000).toFixed(1) + 's · ' + (ctxSize.servicios || 0) + ' serv · ' + (ctxSize.partos || 0) + ' partos</div>' +
        '</div>' +
        '<div style="font-size:13px;color:var(--text);line-height:1.6">' + formatted + '</div>' +
        '<div style="margin-top:10px;padding-top:8px;border-top:1px solid var(--border);font-size:10px;color:var(--muted);font-style:italic">IA puede equivocarse. Verificá con datos reales antes de tomar decisiones críticas.</div>' +
      '</div>';
  }).catch(function(e) {
    if (btn) { btn.disabled = false; btn.textContent = '✨ Preguntar'; }
    resultEl.innerHTML = '<div style="padding:12px;background:rgba(248,81,73,.08);border:1px solid rgba(248,81,73,.3);border-radius:8px;color:var(--red);font-size:12.5px">⚠ Sin conexión al asistente: ' + escH(e.message) + '</div>';
  });
}

function _reproAiFormatAnswer(text) {
  // Markdown-lite → HTML seguro
  var safe = escH(text);
  // **bold**
  safe = safe.replace(/\*\*([^*]+)\*\*/g, '<b>$1</b>');
  // *italic* (single asterisk)
  safe = safe.replace(/(^|[^*])\*([^*]+)\*/g, '$1<i>$2</i>');
  // bullets
  var lines = safe.split('\n');
  var html = '';
  var inList = false;
  lines.forEach(function(line) {
    var trimmed = line.trim();
    if (/^[\-\*•]\s+/.test(trimmed)) {
      if (!inList) { html += '<ul style="margin:6px 0 6px 18px;padding:0">'; inList = true; }
      html += '<li style="margin:2px 0">' + trimmed.replace(/^[\-\*•]\s+/, '') + '</li>';
    } else if (/^\d+\.\s+/.test(trimmed)) {
      if (!inList) { html += '<ol style="margin:6px 0 6px 18px;padding:0">'; inList = true; }
      html += '<li style="margin:2px 0">' + trimmed.replace(/^\d+\.\s+/, '') + '</li>';
    } else {
      if (inList) { html += inList === 'ol' ? '</ol>' : '</ul>'; inList = false; }
      if (trimmed) html += '<p style="margin:6px 0">' + trimmed + '</p>';
    }
  });
  if (inList) html += '</ul>';
  return html;
}

// CSS spinner animation
(function() {
  if (document.getElementById('repro-spinner-css')) return;
  var style = document.createElement('style');
  style.id = 'repro-spinner-css';
  style.textContent = '@keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }';
  document.head.appendChild(style);
})();

// ─── Render principal de la sub-tab Inteligencia ──────────────
function renderReproInteligencia() {
  try { renderReproProxPartos(); } catch(e) { console.warn('[Repro] proxPartos', e); }
  try { renderReproAlertas(); } catch(e) { console.warn('[Repro] alertas', e); }
  try { renderReproPerformance(); } catch(e) { console.warn('[Repro] performance', e); }
}

// Hook switchTab para refrescar al entrar a Inteligencia
(function() {
  var _origSwitchTab = window.switchTab;
  if (typeof _origSwitchTab !== 'function') return;
  var _prev = window.switchTab;
  window.switchTab = function(prefix, btn, tabId) {
    var ret = _prev.apply(this, arguments);
    if (prefix === 'repro' && tabId === 'repro-tab-inteligencia') {
      setTimeout(renderReproInteligencia, 50);
    }
    return ret;
  };
})();

// Enter para enviar pregunta en el textarea
(function() {
  document.addEventListener('keydown', function(e) {
    if (e.target && e.target.id === 'repro-ai-input' && e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      askReproAI();
    }
  });
})();

</script>


