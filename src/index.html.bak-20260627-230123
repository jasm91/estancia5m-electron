// v1.4.89: calcular cuántos animales tendrá la plantilla según el contexto
function _bpGetTemplateN() {
  if (_bpContext === 'mc' && typeof _mcLoteCuarentena !== 'undefined' && _mcLoteCuarentena) {
    var tope = _mcLoteCuarentena.animal_count || 0;
    var yaMarcados = (typeof _mcAnimals !== 'undefined') ? _mcAnimals.length : 0;
    return Math.max(0, tope - yaMarcados);
  }
  if (_bpContext === 'cg') {
    var el = document.getElementById('cg-cuarentena-count');
    return el ? (parseInt(el.value) || 0) : 0;
  }
  if (_bpContext === 'newlot') {
    return 10;  // default para nuevo lote (sin tope conocido)
  }
  return 0;
}

// v1.4.89: genera el string CSV de la plantilla
function _bpBuildTemplateCSV() {
  var n = _bpGetTemplateN();
  if (n <= 0) n = 10;
  var lines = ['#,ID,Raza,Peso'];
  for (var i = 1; i <= n; i++) {
    lines.push(i + ',,,');
  }
  return lines.join('\n');
}

// v1.4.89: descargar plantilla CSV
function bpDownloadTemplate() {
  var csv = _bpBuildTemplateCSV();
  var n = _bpGetTemplateN() || 10;
  var ctx = _bpContext === 'mc' ? 'marcaje' : _bpContext === 'cg' ? 'compra' : 'lote';
  var lotName = '';
  if (_bpContext === 'mc' && typeof _mcLoteCuarentena !== 'undefined' && _mcLoteCuarentena && _mcLoteCuarentena.code) {
    lotName = '_' + String(_mcLoteCuarentena.code).replace(/[^A-Za-z0-9\-_]/g, '');
  }
  var today = localDate ? localDate() : new Date().toISOString().slice(0,10);
  var filename = 'plantilla_' + ctx + lotName + '_' + n + 'animales_' + today + '.csv';
  var blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
  var url = URL.createObjectURL(blob);
  var a = document.createElement('a');
  a.href = url;
  a.download = filename;
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  setTimeout(function(){ URL.revokeObjectURL(url); }, 1000);
  toast('Plantilla descargada: ' + filename, 'success');
}

// v1.4.89: copiar plantilla al portapapeles (versión TSV para pegado directo en Excel/Numbers)
function bpCopyTemplate() {
  var n = _bpGetTemplateN();
  if (n <= 0) n = 10;
  // TSV (tab-separated) para que se pegue limpio en columnas separadas en Excel/Numbers/Sheets
  var lines = ['#\tID\tRaza\tPeso'];
  for (var i = 1; i <= n; i++) {
    lines.push(i + '\t\t\t');
  }
  var tsv = lines.join('\n');
  // Compat con browsers sin Clipboard API moderna
  if (navigator.clipboard && navigator.clipboard.writeText) {
    navigator.clipboard.writeText(tsv).then(function(){
      toast('Plantilla copiada (' + n + ' filas) — pegala en Excel o Numbers', 'success');
    }, function(){
      _bpFallbackCopy(tsv, n);
    });
  } else {
    _bpFallbackCopy(tsv, n);
  }
}

function _bpFallbackCopy(text, n) {
  var ta = document.createElement('textarea');
  ta.value = text;
  ta.style.position = 'fixed';
  ta.style.opacity = '0';
  document.body.appendChild(ta);
  ta.select();
  try {
    document.execCommand('copy');
    toast('Plantilla copiada (' + n + ' filas)', 'success');
  } catch(e) {
    toast('No se pudo copiar', 'error');
  }
  document.body.removeChild(ta);
}

