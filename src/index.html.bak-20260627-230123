// Renderiza la lista (agrupada si "Todos", plana si una categoría)
function _stockRenderList(items) {
  var container = document.getElementById('stock-list-container');
  if (!container) return;

  if (!items.length) {
    container.innerHTML = '<div style="padding:40px 20px;text-align:center;color:var(--muted);font-size:13px">No hay productos que coincidan con los filtros</div>';
    return;
  }

  // Si una categoría está seleccionada -> lista plana
  if (_stockSelectedCategory !== 'all') {
    var rows = items.map(_stockRenderRow).join('');
    container.innerHTML = '<div style="border:1px solid var(--border);border-radius:10px;overflow:hidden">'+rows+'</div>';
    return;
  }

  // Si "Todos" -> agrupar por categoría
  var groups = { veterinario:[], sal:[], aceite:[], herramienta:[], otros:[] };
  items.forEach(function(p){
    var cat = _stockGetCategory(p);
    if (groups[cat.type]) groups[cat.type].push(p);
  });

  // v1.4.63: colores adaptados al dark theme (consistentes con _stockRenderHub)
  var order = [
    { key:'veterinario', icon:'💉', label:'Veterinario',           bg:'rgba(248,113,113,.10)', fg:'#fca5a5', fgMuted:'#8b949e' },
    { key:'sal',         icon:'🧂', label:'Sal y suplementos',     bg:'rgba(251,191,36,.10)',  fg:'#fcd34d', fgMuted:'#8b949e' },
    { key:'aceite',      icon:'🛢️', label:'Aceites y lubricantes', bg:'rgba(96,165,250,.10)',  fg:'#93c5fd', fgMuted:'#8b949e' },
    { key:'herramienta', icon:'🔧', label:'Herramientas',          bg:'rgba(167,139,250,.10)', fg:'#c4b5fd', fgMuted:'#8b949e' },
    { key:'otros',       icon:'📦', label:'Otros',                 bg:'rgba(48,54,61,.5)',     fg:'#c9d1d9', fgMuted:'#8b949e' }
  ];

  var html = '';
  order.forEach(function(g){
    var list = groups[g.key];
    if (!list.length) return;
    var alerts = list.filter(function(p){ return _stockGetHealth(p).priority <= 3; }).length;
    var alertBadge = alerts > 0 ? '<span style="font-size:10px;padding:2px 7px;background:rgba(163,45,45,.15);color:#A32D2D;border-radius:8px;margin-left:8px;font-weight:500">'+alerts+' alerta'+(alerts!==1?'s':'')+'</span>' : '';
    var totalValue = list.reduce(function(s,p){ return s + (parseFloat(p.stock_qty)||0)*(parseFloat(p.cost)||0); }, 0);
    var rows = list.map(_stockRenderRow).join('');
    html += '<details open style="margin-bottom:10px;border:1px solid var(--border);border-radius:10px;overflow:hidden">' +
      '<summary style="list-style:none;display:flex;align-items:center;gap:10px;padding:10px 12px;cursor:pointer;background:'+g.bg+';color:'+g.fg+'">' +
        '<span style="font-size:14px">'+g.icon+'</span>' +
        '<span style="font-size:13px;font-weight:600;flex:1">'+escH(g.label)+'</span>' +
        alertBadge +
        '<span style="font-size:11px;color:'+g.fgMuted+'">'+list.length+' producto'+(list.length!==1?'s':'')+' · Bs. '+_fmtNum(Math.round(totalValue))+'</span>' +
      '</summary>' +
      rows +
    '</details>';
  });

  container.innerHTML = html;
}

// Renderiza la alerta global
function _stockRenderGlobalAlert() {
  var products = db.products || [];
  var counts = { 'sin-stock':0, 'bajo':0, 'vencido':0, 'por-vencer':0 };
  products.forEach(function(p){
    var h = _stockGetHealth(p);
    if (counts[h.status] !== undefined) counts[h.status]++;
  });
  var total = counts['sin-stock'] + counts['bajo'] + counts['vencido'] + counts['por-vencer'];
  var el = document.getElementById('stock-global-alert');
  if (!el) return;
  if (total === 0) { el.style.display = 'none'; return; }
  var parts = [];
  if (counts['sin-stock']) parts.push(counts['sin-stock']+' sin stock');
  if (counts['bajo']) parts.push(counts['bajo']+' bajo'+(counts['bajo']!==1?'s':''));
  if (counts['vencido']) parts.push(counts['vencido']+' vencido'+(counts['vencido']!==1?'s':''));
  if (counts['por-vencer']) parts.push(counts['por-vencer']+' por vencer');
  document.getElementById('stock-global-alert-text').innerHTML = '⚠️ <strong>'+total+' producto'+(total!==1?'s':'')+' requiere'+(total!==1?'n':'')+' atención:</strong> ' + parts.join(' · ');
  el.style.display = 'flex';
}

// Helper formato de números
function _fmtNum(n) {
  if (typeof n !== 'number') n = parseFloat(n) || 0;
  if (n === 0) return '0';
  if (n >= 1000) return n.toLocaleString('es-BO', { maximumFractionDigits: 0 });
  if (n % 1 === 0) return String(n);
  return n.toFixed(1).replace(/\.0$/, '');
}

