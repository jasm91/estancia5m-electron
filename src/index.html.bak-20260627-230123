function _reproComputeStats(records) {
  var total = records.length;
  var ia = records.filter(function(r) { return r.tipo_servicio === 'IA'; }).length;
  var monta = records.filter(function(r) { return r.tipo_servicio === 'monta'; }).length;
  var prenadas = records.filter(function(r) { return r.result === 'preñada'; }).length;
  var vacias = records.filter(function(r) { return r.result === 'vacia'; }).length;
  var pendientes = records.filter(function(r) { return !r.result || r.result === 'pendiente'; }).length;
  // Servicios efectivos = con diagnóstico (preñada o vacia)
  var efectivos = prenadas + vacias;
  var prenezPct = efectivos > 0 ? Math.round((prenadas / efectivos) * 100) : null;
  // Servicios / concepción: total servicios contados / vacas únicas preñadas
  var uniqPrenadas = {};
  records.forEach(function(r) {
    if (r.result === 'preñada' && r.animal_id) uniqPrenadas[r.animal_id] = true;
  });
  var uniqPrenadasCount = Object.keys(uniqPrenadas).length;
  var sc = uniqPrenadasCount > 0 ? (total / uniqPrenadasCount).toFixed(2) : null;
  // Pendientes con ≥30d sin diagnóstico
  var now = new Date();
  var pendOld = records.filter(function(r) {
    if (r.result === 'preñada' || r.result === 'vacia') return false;
    if (!r.date) return false;
    var d = new Date(r.date);
    return (now - d) > (30 * 86400000);
  }).length;
  return {
    total: total, ia: ia, monta: monta,
    prenadas: prenadas, vacias: vacias, pendientes: pendientes,
    efectivos: efectivos, prenezPct: prenezPct, sc: sc,
    pendOld: pendOld
  };
}

function _reproRenderStats(stats) {
  var el = function(id) { return document.getElementById(id); };
  if (el('repro-stat-total')) el('repro-stat-total').textContent = stats.total;
  if (el('repro-stat-total-sub')) el('repro-stat-total-sub').textContent = stats.ia + ' IA · ' + stats.monta + ' monta';
  if (el('repro-stat-prenez')) {
    el('repro-stat-prenez').textContent = stats.prenezPct != null ? (stats.prenezPct + '%') : '—';
  }
  if (el('repro-stat-prenez-sub')) {
    el('repro-stat-prenez-sub').textContent = stats.efectivos > 0 ?
      (stats.prenadas + ' confirmadas / ' + stats.efectivos) : 'Sin diagnósticos aún';
  }
  if (el('repro-stat-sc')) el('repro-stat-sc').textContent = stats.sc != null ? stats.sc : '—';
  if (el('repro-stat-sc-sub')) {
    el('repro-stat-sc-sub').textContent = stats.sc != null ? 'Serv / concepción' : 'Sin concepciones';
  }
  if (el('repro-stat-pendientes')) el('repro-stat-pendientes').textContent = stats.pendientes;
}

function renderReproServicios() {
  var all = _reproGetServicios();

  // Aplicar filtros
  var tipoF = (document.getElementById('repro-filter-tipo') || {}).value || '';
  var periodoF = (document.getElementById('repro-filter-periodo') || {}).value || '';
  var loteF = (document.getElementById('repro-filter-lote') || {}).value || '';
  var resultF = (document.getElementById('repro-filter-result') || {}).value || '';

  var filtered = all.slice();
  if (tipoF) filtered = filtered.filter(function(r) { return r.tipo_servicio === tipoF; });
  if (periodoF) filtered = _reproFilterPeriodo(filtered, periodoF);
  if (loteF) filtered = filtered.filter(function(r) { return r.lot_code === loteF; });
  if (resultF) {
    filtered = filtered.filter(function(r) {
      if (resultF === 'pendiente') return !r.result || r.result === 'pendiente';
      return r.result === resultF;
    });
  }

  // Stats SOBRE los filtrados (excluyendo filtro de resultado para que las stats sean coherentes)
  var statsBase = all.slice();
  if (tipoF) statsBase = statsBase.filter(function(r) { return r.tipo_servicio === tipoF; });
  if (periodoF) statsBase = _reproFilterPeriodo(statsBase, periodoF);
  if (loteF) statsBase = statsBase.filter(function(r) { return r.lot_code === loteF; });
  _reproRenderStats(_reproComputeStats(statsBase));

  // Sort: más recientes primero
  filtered.sort(function(a, b) {
    var da = a.date || a.created_at || '';
    var db_ = b.date || b.created_at || '';
    return db_.localeCompare(da);
  });

  // Badge contador
  var badge = document.getElementById('repro-count-badge');
  if (badge) badge.textContent = filtered.length + ' / ' + all.length;

  // Render tabla
  var tbody = document.getElementById('repro-tbody');
  if (!tbody) return;
  if (!filtered.length) {
    tbody.innerHTML = '<tr><td colspan="10" style="text-align:center;padding:30px;color:var(--muted);font-size:12px">' +
      (all.length ? 'No hay servicios con los filtros seleccionados' : 'Aún no hay servicios registrados. Usá <b>+ Servicio</b> arriba.') +
      '</td></tr>';
    return;
  }

  tbody.innerHTML = filtered.map(function(r) {
    var toroSemen = '';
    if (r.tipo_servicio === 'IA') {
      toroSemen = r.semen_lote ? r.semen_lote : '<span style="color:var(--muted)">—</span>';
    } else {
      toroSemen = r.toro_id ? r.toro_id : '<span style="color:var(--muted)">Toro suelto</span>';
    }
    var diagText = '';
    if (r.diagnosis_method) {
      diagText = _reproDiagLabel(r.diagnosis_method) + ' ' + _reproFmtDate(r.diagnosis_date);
    } else {
      diagText = '<span style="color:var(--muted)">—</span>';
    }
    var techText = r.tipo_servicio === 'IA' ? (r.technician || '<span style="color:var(--muted)">—</span>')
                                            : '<span style="color:var(--muted)">—</span>';
    // v1.8.0: columna "Esperado parto" — usa _reproExpectedPartoPill si está disponible
    var expectedPartoCell = (typeof _reproExpectedPartoPill === 'function')
      ? _reproExpectedPartoPill(r)
      : '<span style="color:var(--muted)">—</span>';
    return '<tr>' +
      '<td style="font-family:DM Mono,monospace;font-size:11.5px">' + _reproFmtDate(r.date) + '</td>' +
      '<td style="font-family:DM Mono,monospace;font-size:11.5px">' + (r.animal_id || '<span style="color:var(--muted)">—</span>') + '</td>' +
      '<td>' + _reproTipoPill(r.tipo_servicio) + '</td>' +
      '<td style="font-size:11.5px">' + toroSemen + '</td>' +
      '<td style="font-family:DM Mono,monospace;font-size:11.5px">' + (r.lot_code || '<span style="color:var(--muted)">—</span>') + '</td>' +
      '<td style="font-size:11.5px">' + techText + '</td>' +
      '<td style="font-size:11.5px">' + diagText + '</td>' +
      '<td>' + _reproResultPill(r.result, r.id) + '</td>' +
      '<td>' + expectedPartoCell + '</td>' +
      '<td><button class="btn btn-ghost" style="padding:3px 8px;font-size:11px" onclick="openReproEditarServicio(\'' + r.id + '\')">✎</button></td>' +
      '</tr>';
  }).join('');
}

