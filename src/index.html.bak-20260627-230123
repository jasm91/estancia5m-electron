  var refEl = document.getElementById('conteo-ref');
  if (refEl) refEl.value = lot ? lot.animal_count+' animales' : '-';
  calcConteoDiff();
}

function calcConteoDiff() {
  var counted = parseInt((document.getElementById('conteo-count')||{}).value)||0;
  var refEl = document.getElementById('conteo-ref');
  var ref = refEl ? parseInt(refEl.value)||0 : 0;
  var diffEl = document.getElementById('conteo-diff');
  if (diffEl && counted) {
    var diff = counted - ref;
    diffEl.value = (diff>0?'+':'')+diff+(diff===0?' (sin diferencia)':diff>0?' (mas de lo esperado)':' (faltan animales)');
    diffEl.style.color = diff===0?'var(--green)':diff>0?'var(--blue)':'var(--red)';
  }
}

