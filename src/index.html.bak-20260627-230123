        '<div style="width:60px;height:100px;border:3px solid var(--bor);border-radius:8px;margin:0 auto 6px;position:relative;overflow:hidden;background:var(--sur2)">' +
          '<div style="position:absolute;bottom:0;left:0;right:0;height:' + pct + '%;background:' + fillColor + ';transition:height .5s"></div>' +
          '<div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:15px;font-weight:800;color:#fff;text-shadow:0 1px 3px rgba(0,0,0,.5)">' + pct + '%</div>' +
        '</div>' +
        '<div style="font-size:14px;font-weight:700;color:var(--blue)">' + tank.current_level + ' L</div>' +
        '<div style="font-size:10px;color:var(--muted)">de ' + tank.capacity + ' L</div>' +
      '</div>';
    }).join('') +
    '<div style="display:flex;align-items:flex-end;padding-bottom:12px">' +
      '<button class="btn btn-ghost btn-sm" style="font-size:10px" onclick="configTank()">⚙️ Config</button>' +
    '</div>';
  }

  // Stats
  var now = new Date();
  var curYear = now.getFullYear();
  var curMonth = now.getMonth() + 1;
  var monthPrefix = curYear + '-' + String(curMonth).padStart(2,'0');
    var monthRecargas = db.diesel.filter(function(r){ return (r.type||'recarga')==='recarga' && (r.fecha||'').startsWith(monthPrefix); });
    var monthDespachos = db.diesel.filter(function(r){ return (r.type||'')==='despacho' && (r.fecha||'').startsWith(monthPrefix); });
    var monthAjustes = db.diesel.filter(function(r){ return (r.type||'')==='ajuste' && (r.fecha||'').startsWith(monthPrefix); });
  var totalRecarga = monthRecargas.reduce(function(s,r){ return s+(parseFloat(r.litros)||0); },0);
  var totalDespacho = monthDespachos.reduce(function(s,r){ return s+(parseFloat(r.litros)||0); },0);
  var totalMermaL = monthAjustes.filter(function(a){return a.ajuste_direccion==='merma';}).reduce(function(s,r){ return s+(parseFloat(r.litros)||0); },0);
  var lastAjuste = monthAjustes.length ? monthAjustes.slice().sort(function(a,b){return dieselCmpAsc(b,a);})[0] : null; // v1.8.66: por fecha efectiva
  var mermaPctKPI = lastAjuste && lastAjuste.ajuste_direccion==='merma' ? (lastAjuste.merma_pct||0) : 0;
  var totalGasto = monthRecargas.reduce(function(s,r){ return s+(parseFloat(r.total)||0); },0);
  var diasMes = monthDespachos.length ? (function(){ var fechas={}; monthDespachos.forEach(function(r){fechas[r.fecha]=1;}); return Object.keys(fechas).length; })() : 1;
  var promDiario = totalDespacho / Math.max(1, diasMes);
  var totalLevel = tanks.reduce(function(s,t){ return s + t.current_level; },0);
  var diasRestantes = promDiario > 0 ? Math.round(totalLevel / promDiario) : '∞';

  // Vehiculos for filter
  var vehiculos = {};
  db.diesel.forEach(function(r){ if(r.vehiculo) vehiculos[r.vehiculo]=true; });
  var dl = document.getElementById('diesel-vehiculos-list');
  if (dl) dl.innerHTML = Object.keys(vehiculos).map(function(v){ return '<option value="'+escH(v)+'">'; }).join('');
  // Populate vehiculo filter from data + maquinaria
  var fv = document.getElementById('diesel-f-vehiculo');
  if (fv && fv.options.length <= 1) {
    var allVehiculos = Object.keys(vehiculos);
    getMaqList().forEach(function(m){ if(!vehiculos[m.nombre]) allVehiculos.push(m.nombre); });
    allVehiculos.forEach(function(v){ var o=document.createElement('option');o.value=v;o.textContent=v;fv.appendChild(o); });
  }

  var resEl = document.getElementById('diesel-resumen');
  if (resEl) {
    resEl.innerHTML = [
      {label:'Recargado (mes)',val:totalRecarga.toFixed(0)+' L',color:'var(--green)'},
      {label:'Consumido (mes)',val:totalDespacho.toFixed(0)+' L',color:'var(--blue)'},
      {label:'Merma (mes)',val:totalMermaL.toFixed(0)+' L',color:totalMermaL>0?'var(--red)':'var(--green)'},
      {label:'Merma %',val:mermaPctKPI+'%',color:mermaPctKPI>3?'var(--red)':mermaPctKPI>0?'var(--amber2)':'var(--green)'},
      {label:'Gasto (mes)',val:'Bs. '+Math.round(totalGasto).toLocaleString(),color:'var(--amber2)'},
      {label:'Prom. diario',val:promDiario.toFixed(1)+' L/día',color:'var(--muted)'},
