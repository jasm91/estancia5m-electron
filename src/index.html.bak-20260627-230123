// ═════════════════════════════════════════════════════════════
// v1.6.0 — Reproducción Fase 2: Sub-tab Partos + integración
// Lee de db.partos (tabla existente) + agrega campos opcionales:
//   madre_id, padre_id, servicio_id (genealogía, no rompen retrocompat)
// Modal "+ Parto" rico desde Reproducción:
//   - Selector Madre desde vacas preñadas (filtrado por reproductive_services con result='preñada')
//   - Auto-completa padre_id desde el servicio
//   - Crea cría en e5m_animals + suma animal_count del lote
//   - Marca el servicio_id como "consumido" (result='preñada' ya estaba, no se cambia)
//   - La madre pasa a reproductive_status='parida_lactando' (campo nuevo en e5m_animals[lote][i])
// ═════════════════════════════════════════════════════════════

function _reproGetPartos() {
  return (db && Array.isArray(db.partos)) ? db.partos : [];
}

function _reproPartosFilterPeriodo(records, months) {
  if (!months) return records;
  var now = new Date();
  var cutoff = new Date(now.getFullYear(), now.getMonth() - parseInt(months, 10), now.getDate());
  return records.filter(function(r) {
    if (!r.date) return false;
    return new Date(r.date) >= cutoff;
  });
}

function _reproPartoEstadoPill(estado) {
  if (estado === 'sano') {
    return '<span style="background:rgba(63,185,80,.15);color:var(--green);font-size:11px;padding:3px 8px;border-radius:10px;white-space:nowrap">✅ Sano</span>';
  } else if (estado === 'debil') {
    return '<span style="background:rgba(212,160,23,.15);color:var(--amber);font-size:11px;padding:3px 8px;border-radius:10px;white-space:nowrap">⚠ Débil</span>';
  } else if (estado === 'muerto') {
    return '<span style="background:rgba(248,81,73,.15);color:var(--red);font-size:11px;padding:3px 8px;border-radius:10px;white-space:nowrap">❌ Mortinato</span>';
  }
  return '<span style="color:var(--muted);font-size:11px">—</span>';
}

function _reproPartoSexoLabel(s) {
  if (s === 'macho') return '🐂 Macho';
  if (s === 'hembra') return '🐄 Hembra';
  return '—';
}

// ─── Populadores de filtros y selectores ──────────────────────
function _reproPartosPopulateLoteFilter() {
  var sel = document.getElementById('repro-partos-filter-lote');
  if (!sel) return;
  var current = sel.value;
  var lots = (db && Array.isArray(db.lots)) ? db.lots : [];
  // v1.8.12: excluir cuarentena/marcado/fusionado/vendido y los CUAR-xxx
  var activeLots = lots.filter(function(l) {
    var s = (l.status || '').toLowerCase();
    if (s === 'sold' || s === 'vendido' || s === 'fusionado' || s === 'merged') return false;
    if (s === 'cuarentena' || s === 'marcado' || s === 'marcado_completo' || s === 'inactivo') return false;
    if (/^CUAR-\d+$/i.test(l.code || '')) return false;
    return true;
  }).map(function(l) { return l.code; }).filter(Boolean).sort();
  sel.innerHTML = '<option value="">Todos</option>' +
    activeLots.map(function(code) {
      return '<option value="' + code + '"' + (code === current ? ' selected' : '') + '>' + code + '</option>';
    }).join('');
}

// ─── KPIs Partos ──────────────────────────────────────────────
function _reproPartosComputeStats(records) {
  var total = records.length;
  var machos = records.filter(function(r) { return r.sexo === 'macho'; }).length;
  var hembras = records.filter(function(r) { return r.sexo === 'hembra'; }).length;
  var muertos = records.filter(function(r) { return r.estado === 'muerto'; }).length;
  var mortalidadPct = total > 0 ? Math.round((muertos / total) * 1000) / 10 : null;

  // % parición = partos del año / vacas preñadas año anterior (servicios con result='preñada')
  var now = new Date();
  var thisYearStart = new Date(now.getFullYear(), 0, 1);
  var lastYearStart = new Date(now.getFullYear() - 1, 0, 1);
  var lastYearEnd = thisYearStart;
  var partosThisYear = records.filter(function(r) {
    if (!r.date) return false;
    return new Date(r.date) >= thisYearStart;
  }).length;
  var servicios = _reproGetServicios();
  var prenadasLastYear = servicios.filter(function(s) {
    if (s.result !== 'preñada') return false;
    if (!s.date) return false;
    var d = new Date(s.date);
    return d >= lastYearStart && d < lastYearEnd;
  }).length;
  var paricionPct = prenadasLastYear > 0 ? Math.round((partosThisYear / prenadasLastYear) * 100) : null;

  // IEP = promedio de días entre partos consecutivos por vaca (madre_id)
  var byMadre = {};
  records.forEach(function(r) {
    if (!r.madre_id || !r.date) return;
    if (!byMadre[r.madre_id]) byMadre[r.madre_id] = [];
    byMadre[r.madre_id].push(new Date(r.date));
  });
  var intervalos = [];
  Object.keys(byMadre).forEach(function(m) {
    var dates = byMadre[m].sort(function(a, b) { return a - b; });
    for (var i = 1; i < dates.length; i++) {
      var diffMs = dates[i] - dates[i-1];
      var diffDays = Math.round(diffMs / 86400000);
      if (diffDays > 200 && diffDays < 600) intervalos.push(diffDays); // filtro sanity
    }
  });
  var iep = intervalos.length > 0 ?
    Math.round(intervalos.reduce(function(s, x) { return s + x; }, 0) / intervalos.length) : null;

  return {
    total: total, machos: machos, hembras: hembras,
    muertos: muertos, mortalidadPct: mortalidadPct,
    paricionPct: paricionPct, partosThisYear: partosThisYear,
    iep: iep, intervalos: intervalos.length
  };
}

function _reproPartosRenderStats(stats) {
  var el = function(id) { return document.getElementById(id); };
  if (el('repro-partos-stat-total')) el('repro-partos-stat-total').textContent = stats.total;
  if (el('repro-partos-stat-total-sub')) el('repro-partos-stat-total-sub').textContent = stats.machos + ' machos · ' + stats.hembras + ' hembras';
  if (el('repro-partos-stat-paricion')) {
    el('repro-partos-stat-paricion').textContent = stats.paricionPct != null ? (stats.paricionPct + '%') : '—';
  }
  if (el('repro-partos-stat-paricion-sub')) {
    el('repro-partos-stat-paricion-sub').textContent = stats.paricionPct != null ?
      ('partos año / preñadas año previo') : 'sin datos previos';
  }
  if (el('repro-partos-stat-iep')) {
    el('repro-partos-stat-iep').innerHTML = stats.iep != null ?
      (stats.iep + ' <span style="font-size:12px;color:var(--muted);font-weight:400">d</span>') : '—';
  }
  if (el('repro-partos-stat-iep-sub')) {
    el('repro-partos-stat-iep-sub').textContent = stats.iep != null ?
      (stats.intervalos + ' intervalos') : 'sin múltiples partos por vaca';
  }
  if (el('repro-partos-stat-mortalidad')) {
    el('repro-partos-stat-mortalidad').textContent = stats.mortalidadPct != null ? (stats.mortalidadPct + '%') : '—';
    el('repro-partos-stat-mortalidad').style.color = (stats.mortalidadPct != null && stats.mortalidadPct > 5) ? 'var(--red)' : 'var(--amber)';
  }
}

// ─── Chart Partos/mes stacked ──────────────────────────────────
var _reproPartosChartInstance = null;
function _reproPartosRenderChart(records) {
  var canvas = document.getElementById('repro-partos-chart');
  if (!canvas || typeof Chart === 'undefined') return;

  // Agrupar por mes
  var byMonth = {};
  records.forEach(function(r) {
    if (!r.date) return;
    var d = new Date(r.date);
    var key = d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0');
    if (!byMonth[key]) byMonth[key] = { macho: 0, hembra: 0 };
    if (r.sexo === 'macho') byMonth[key].macho++;
    else if (r.sexo === 'hembra') byMonth[key].hembra++;
  });

  var keys = Object.keys(byMonth).sort();
  var labels = keys.map(function(k) {
    var p = k.split('-');
    var meses = ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];
    return meses[parseInt(p[1], 10) - 1] + ' ' + p[0].slice(2);
  });
  var machos = keys.map(function(k) { return byMonth[k].macho; });
  var hembras = keys.map(function(k) { return byMonth[k].hembra; });

  if (_reproPartosChartInstance) {
    try { _reproPartosChartInstance.destroy(); } catch(e) {}
  }
  _reproPartosChartInstance = new Chart(canvas.getContext('2d'), {
    type: 'bar',
    data: {
      labels: labels,
      datasets: [
        { label: '🐂 Machos', data: machos, backgroundColor: 'rgba(88,166,255,0.7)', borderRadius: 4 },
        { label: '🐄 Hembras', data: hembras, backgroundColor: 'rgba(188,140,255,0.7)', borderRadius: 4 }
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { position: 'top', labels: { color: '#ddd', font: { size: 11 } } } },
      scales: {
        x: { stacked: true, ticks: { color: '#aaa', font: { size: 10 } }, grid: { display: false } },
        y: { stacked: true, beginAtZero: true, ticks: { color: '#aaa', font: { size: 10 }, precision: 0 }, grid: { color: 'rgba(255,255,255,0.05)' } }
      }
    }
  });
}

// ─── Render principal Partos ───────────────────────────────────
function renderReproPartos() {
  // v1.8.13: render panel de partos esperados arriba
  try { _reproRenderPartosEsperados(); } catch(e) { console.warn('[partos esperados]', e); }

