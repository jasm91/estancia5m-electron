// ── v1.4.54 Multi-item stock para mantenimiento ──────────────
// Estado en memoria del modal: array de {product_id, qty} (qty puede ser '' mientras edita)
var _mntStockRows = [];
// Cuando se está editando un registro existente, mostrar items en readonly
var _mntStockRowsReadonly = false;

function _mntProductsAvailable() {
  return (db.products || []).slice().sort(function(a,b){ return (a.name||'').localeCompare(b.name||''); });
}

function renderMntStockRows() {
  var list = document.getElementById('mnt-stock-items-list');
  var addBtn = document.getElementById('mnt-add-stock-row');
  var note = document.getElementById('mnt-stock-readonly-note');
  if (!list) return;
  list.innerHTML = '';

  if (_mntStockRowsReadonly) {
    // Modo readonly: render compacto, sin selects
    if (addBtn) addBtn.style.display = 'none';
    if (note) note.style.display = 'block';
    if (!_mntStockRows.length) {
      list.innerHTML = '<div style="font-size:11px;color:var(--muted);font-style:italic">Sin insumos descontados</div>';
      return;
    }
    _mntStockRows.forEach(function(row) {
      var p = (db.products||[]).find(function(x){ return x.id == row.product_id; });
      var name = (p && p.name) || row.product_name || ('Producto #' + row.product_id);
      var unit = (p && p.unit) || row.unit || '';
      var line = document.createElement('div');
      line.style.cssText = 'padding:6px 8px;background:var(--sur);border:1px solid var(--bor);border-radius:6px;margin-bottom:4px;font-size:12px;display:flex;justify-content:space-between';
      var l = document.createElement('span'); l.textContent = '📦 ' + name;
      var r = document.createElement('strong'); r.style.color = 'var(--amber2)'; r.textContent = row.qty + ' ' + unit;
      line.appendChild(l); line.appendChild(r);
      list.appendChild(line);
    });
    return;
  }

  // Modo editable
  if (addBtn) addBtn.style.display = '';
  if (note) note.style.display = 'none';

  if (!_mntStockRows.length) {
    var empty = document.createElement('div');
    empty.style.cssText = 'font-size:11px;color:var(--muted);font-style:italic;padding:4px 0';
    empty.textContent = 'Ningún insumo agregado. Click en "+ Agregar insumo" para usar productos del stock.';
    list.appendChild(empty);
    return;
  }

  // Productos disponibles que NO estén ya en otras filas, para evitar duplicados
  var usedIds = {};
  _mntStockRows.forEach(function(r){ if (r.product_id) usedIds[r.product_id] = true; });
  var allProds = _mntProductsAvailable();

  _mntStockRows.forEach(function(row, idx) {
    var rowEl = document.createElement('div');
    rowEl.style.cssText = 'display:grid;grid-template-columns:1fr 110px 32px;gap:8px;align-items:end;margin-bottom:6px';

    // Select de producto
    var selWrap = document.createElement('div');
    var selLbl = document.createElement('label');
    selLbl.className = 'form-label';
    selLbl.style.cssText = 'font-size:10px;color:var(--muted)';
    selLbl.textContent = idx === 0 ? 'Producto' : '';
    var sel = document.createElement('select');
    sel.className = 'form-select';
    sel.dataset.idx = idx;
    sel.onchange = function() { onMntStockRowProductChange(parseInt(this.dataset.idx)); };
    var optDefault = document.createElement('option');
    optDefault.value = ''; optDefault.textContent = '— Selecciona producto —';
    sel.appendChild(optDefault);
    allProds.forEach(function(p) {
      // Solo mostrar si: tiene stock > 0 Y (no está usado en otra fila O es el de esta fila)
      if ((p.stock_qty || 0) <= 0 && row.product_id != p.id) return;
      if (usedIds[p.id] && row.product_id != p.id) return;
      var o = document.createElement('option');
      o.value = p.id;
      o.textContent = p.name + ' · ' + (p.stock_qty||0) + ' ' + (p.unit||'');
      if (row.product_id == p.id) o.selected = true;
      sel.appendChild(o);
    });
    selWrap.appendChild(selLbl); selWrap.appendChild(sel);

    // Input de cantidad
    var qtyWrap = document.createElement('div');
    var qtyLbl = document.createElement('label');
    qtyLbl.className = 'form-label';
    qtyLbl.style.cssText = 'font-size:10px;color:var(--muted)';
    qtyLbl.textContent = idx === 0 ? 'Cantidad' : '';
    var qtyInput = document.createElement('input');
    qtyInput.type = 'number';
    qtyInput.className = 'form-input';
    qtyInput.step = '0.01'; qtyInput.min = '0';
    qtyInput.value = row.qty || '';
    qtyInput.dataset.idx = idx;
    var prodForRow = (db.products||[]).find(function(x){ return x.id == row.product_id; });
    if (prodForRow) {
      qtyInput.placeholder = 'Máx ' + prodForRow.stock_qty + ' ' + (prodForRow.unit||'');
    } else {
      qtyInput.placeholder = '0';
      qtyInput.disabled = true;
    }
    qtyInput.oninput = function() { _mntStockRows[parseInt(this.dataset.idx)].qty = this.value; };
    qtyWrap.appendChild(qtyLbl); qtyWrap.appendChild(qtyInput);

    // Botón eliminar fila
    var delWrap = document.createElement('div');
    var delLbl = document.createElement('label');
    delLbl.className = 'form-label';
