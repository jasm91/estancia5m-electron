function _reproFmtDate(d) {
  if (!d) return '—';
  try {
    return String(d).slice(0, 10);
  } catch(e) { return '—'; }
}

function _reproUuid() {
  return 'repro_' + Date.now() + '_' + Math.random().toString(36).slice(2, 8);
}

