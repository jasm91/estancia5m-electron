function _formatActivityValue(key, val) {
  if (val === null || val === undefined || val === '') return '';
  if (key === 'date' || key === 'fecha' || key === 'applied_at' || key === 'completed_at') {
    return fmtDT(val);
  }
  // Timestamps ISO completos (created_at, updated_at, last_seen, first_seen, etc.) → formato local legible
  if ((key === 'created_at' || key === 'updated_at' || key === 'last_seen' || key === 'first_seen' || key === 'fecha_pago' || key === 'timestamp') && typeof val === 'string' && val.indexOf('T') > 0) {
    try {
      var d = new Date(val);
      if (!isNaN(d.getTime())) {
        var pad = function(n){return String(n).padStart(2,'0');};
        return d.getFullYear() + '-' + pad(d.getMonth()+1) + '-' + pad(d.getDate()) + ' ' + pad(d.getHours()) + ':' + pad(d.getMinutes());
      }
    } catch(e){}
  }
  if (typeof val === 'boolean') return val ? 'Sí' : 'No';
  if (typeof val === 'object') {
    try { return JSON.stringify(val); } catch(e){ return String(val); }
  }
  return String(val);
}

