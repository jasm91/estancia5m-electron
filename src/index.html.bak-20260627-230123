function saveSubmodule(type) {
  var cfg = SUBMODULE_CONFIG[type];
  if (!cfg) return;
  var prefix = cfg.id_prefix;

  var lot    = (document.getElementById(prefix+'-lot')||{}).value||'';
  var date   = (document.getElementById(prefix+'-date')||{}).value||today();
  var obs    = (document.getElementById(prefix+'-obs')||{}).value||'';
  var by     = (document.getElementById(prefix+'-by')||{}).value||'Cesar Moreno';
  // v1.4.61: detectar carga retroactiva (lote vendido)
  var isRetroactive = (document.getElementById(prefix+'-retroactive')||{}).checked || false;

  if (!lot) { toast('Selecciona un lote','error'); return; }
  // FIX v1.4.34: no permitir fechas futuras (cubre agua, sal, conteo, parto, alimento)
  if (!validateNotFuture(date, 'fecha del registro')) return;

  if (!db[cfg.table]) db[cfg.table] = [];
  if (!db.next_ids[type]) db.next_ids[type] = 1;

  var record = { id: db.next_ids[type]++, lot_code: lot, date: date, obs: obs, by: by, created_at: new Date().toISOString(), retroactive: isRetroactive };

  // Extra fields per type
  if (type==='agua') {
    record.estado = (document.getElementById('agua-estado')||{}).value||'';
  } else if (type==='sal') {
    var salQty = parseFloat((document.getElementById('sal-qty')||{}).value)||0;
    var salTipo = (document.getElementById('sal-tipo')||{}).value||'sal mineral';
    record.qty  = salQty;
    record.tipo = salTipo;
    // Descontar del stock veterinario si el usuario selecciono producto
    var salStockId = parseInt((document.getElementById('sal-stock-product')||{}).value)||0;
    if (salQty > 0 && salStockId) {
      var salProd = db.products.find(function(p){ return p.id===salStockId; });
      if (salProd) {
        if (salProd.stock_qty < salQty) {
          toast('⚠ Stock insuficiente de '+salProd.name+': disponible '+salProd.stock_qty+' kg', 'error');
          return;
        }
        salProd.stock_qty = Math.round((salProd.stock_qty - salQty)*100)/100;
        if (salProd.stock_qty <= salProd.stock_min) {
          var existing = db.alerts.find(function(a){return !a.resolved&&a.type==='stock_low'&&a.title.includes(salProd.name);});
          if (!existing) db.alerts.push({id:db.next_ids.alert++,type:'stock_low',severity:'warning',title:'Stock bajo: '+salProd.name,message:'Quedan '+salProd.stock_qty+' kg. Minimo: '+salProd.stock_min+'.',resolved:false,created_at:new Date().toISOString()});
        }
        record.stock_product = salProd.name;
        record.stock_descontado = salQty;
      }
    }
  } else if (type==='conteo') {
    var counted = parseInt((document.getElementById('conteo-count')||{}).value)||0;
    var lotObj  = db.lots.find(function(l){return l.code===lot;});
    var ref     = lotObj ? lotObj.animal_count : 0;
    record.counted = counted;
    record.ref     = ref;
    record.diff    = counted - ref;
    if (!counted) { toast('Ingresa la cantidad contada','error'); return; }
    // Alerta si faltan animales
    if (record.diff < 0) {
      if (!db.alerts) db.alerts = [];
      if (!db.next_ids.alert) db.next_ids.alert = 1;
      var alertMsg = 'Conteo del '+date+': '+counted+' cab. contadas, '+ref+' en sistema. Faltan '+Math.abs(record.diff)+' animales.';
      var existingAlert = db.alerts.find(function(a){return !a.resolved&&a.type==='conteo_diff'&&a.lot_code===lot;});
      if (!existingAlert) {
        db.alerts.push({id:db.next_ids.alert++,type:'conteo_diff',severity:'critical',lot_code:lot,title:'⚠ Faltan animales - Lote '+lot,message:alertMsg,resolved:false,created_at:new Date().toISOString()});
      } else {
        existingAlert.message = alertMsg;
        existingAlert.created_at = new Date().toISOString();
      }
      // Auto-crear tarea para investigar
      var tasks = JSON.parse(localStorage.getItem('e5m_tasks')||'[]');
      var existTask = tasks.find(function(t){return t.status==='pendiente' && t.title.indexOf('Faltante Lote '+lot) >= 0;});
      if (!existTask) {
        var faltantes = Math.abs(record.diff);
        var newTask = {id:'task_'+Date.now(),title:'Investigar faltante Lote '+lot+' ('+faltantes+' cab)',desc:'Conteo del '+date+': '+counted+' contadas vs '+ref+' en sistema. Faltan '+faltantes+'. Revisar potrero, alambrados, movimientos no registrados.',assignee:'',priority:'alta',due:date,lot:lot,status:'pendiente',created_at:new Date().toISOString(),by:'Auto'};
        tasks.push(newTask);
        localStorage.setItem('e5m_tasks', JSON.stringify(tasks));
        replaceTableInRailway('tasks', tasks);
        toast('⚠ Tarea creada: Investigar faltante en '+lot,'error');
      }
    } else if (record.diff === 0) {
      // Resolver alerta si el conteo cuadra
      db.alerts = (db.alerts||[]).map(function(a){
        if(a.type==='conteo_diff'&&a.lot_code===lot) return {...a, resolved:true};
        return a;
      });
    }
  } else if (type==='partos') {
    record.sexo   = (document.getElementById('parto-sexo')||{}).value||'';
    record.peso   = parseFloat((document.getElementById('parto-peso')||{}).value)||0;
    record.estado = (document.getElementById('parto-estado')||{}).value||'sano';
    record.cria_id= (document.getElementById('parto-id')||{}).value||'';
    // Auto increment lot animal count + add animal to registry
    var partoLot = db.lots.find(function(l){return l.code===lot;});
    if (partoLot && record.estado !== 'muerto') {
      // Validar capacidad del potrero
      var partoCapCheck = checkPotreroCapacity(lot, 1);
      if (!partoCapCheck.ok) { toast(partoCapCheck.msg, 'error'); return; }
      partoLot.animal_count++;
      // Add cría to animales DB
      var animDB = getAnimalesDB();
      if (!animDB[lot]) animDB[lot] = [];
      var criaId = record.cria_id || 'N/A';
      var newAnimal = {
        id: criaId,
        raza: record.sexo === 'macho' ? 'Torillo' : 'Ternera',
        pesajes: record.peso ? [{ fecha: date, peso: record.peso }] : []
      };
      animDB[lot].push(newAnimal);
      saveAnimalesDB(animDB);
      // Register activity
      addActivity(by, 'parto', lot, '🐣 Parto: ' + (record.sexo==='macho'?'Torillo':'Ternera') + ' #' + criaId + (record.peso ? ' — ' + record.peso + ' kg' : '') + ' — ' + record.estado, date);
    } else if (partoLot && record.estado === 'muerto') {
      addActivity(by, 'parto', lot, '❌ Mortinato: ' + (record.sexo==='macho'?'Macho':'Hembra') + (record.peso ? ' — ' + record.peso + ' kg' : ''), date);
    }
  } else if (type==='alimento') {
    var aliTipo = (document.getElementById('alimento-tipo')||{}).value||'';
    var aliQty  = parseFloat((document.getElementById('alimento-qty')||{}).value)||0;
    record.tipo = aliTipo;
    record.qty  = aliQty;
    // Descontar del stock si el usuario selecciono producto
    var aliStockId = parseInt((document.getElementById('alimento-stock-product')||{}).value)||0;
    if (aliQty > 0 && aliStockId) {
      var aliProd = db.products.find(function(p){ return p.id===aliStockId; });
      if (aliProd) {
        if (aliProd.stock_qty < aliQty) {
          if (!confirm('Stock insuficiente de '+aliProd.name+' (disponible: '+aliProd.stock_qty+' '+aliProd.unit+'). ¿Registrar igual?')) return;
        } else {
          aliProd.stock_qty = Math.round((aliProd.stock_qty - aliQty)*100)/100;
          if (aliProd.stock_qty <= aliProd.stock_min) {
            var aliExisting = db.alerts.find(function(a){return !a.resolved&&a.type==='stock_low'&&a.title.includes(aliProd.name);});
            if (!aliExisting) db.alerts.push({id:db.next_ids.alert++,type:'stock_low',severity:'warning',title:'Stock bajo: '+aliProd.name,message:'Quedan '+aliProd.stock_qty+' '+aliProd.unit+'. Minimo: '+aliProd.stock_min+'.',resolved:false,created_at:new Date().toISOString()});
          }
          record.stock_product = aliProd.name;
          record.stock_descontado = aliQty;
        }
      }
    }
  }

  db[cfg.table].push(record);
  saveDB();
  closeModal(cfg.modal);
  renderSubmodule(type);
  if (type==='partos') renderLotes();
  // v1.4.113: refrescar dashboards de Sal cuando se añade un registro nuevo
  if (type === 'sal' && typeof renderSalDashboards === 'function') {
    try { renderSalDashboards(); } catch(e){}
  }
  toast('Registro guardado', 'success');
  // FIX v1.4.35: audit log para submódulos (agua/sal/conteo/parto/alimento)
  try {
    var subMsg = '';
    if (type === 'agua') subMsg = 'Agua: Lote ' + lot + ' · ' + (record.estado||'?');
    else if (type === 'sal') subMsg = 'Sal: Lote ' + lot + ' · ' + (record.qty||0) + ' kg ' + (record.tipo||'');
    else if (type === 'conteo') subMsg = 'Conteo: Lote ' + lot + ' · ' + (record.counted||0) + '/' + (record.ref||0) + ' (diff ' + (record.diff||0) + ')';
    else if (type === 'partos') subMsg = 'Parto: Lote ' + lot + ' · ' + (record.sexo||'') + (record.estado==='muerto'?' (mortinato)':' #' + (record.cria_id||'?'));
    else if (type === 'alimento') subMsg = 'Alimento: Lote ' + lot + ' · ' + (record.qty||0) + ' kg ' + (record.tipo||'');
    auditLog('create', cfg.table, record.id, subMsg);
  } catch(e){}
}

function renderSubmodule(type) {
  var data = db[type] || [];
  var tbody = document.getElementById(type+'-tbody');
  if (!tbody) return;

  if (!data.length) {
    // v1.4.113: sal ahora tiene 8 columnas (se añadió Tipo)
    var cols = {agua:6,sal:8,conteo:8,partos:8,alimento:7};
    tbody.innerHTML = '<tr><td colspan="'+cols[type]+'" style="text-align:center;padding:20px;color:var(--muted);font-size:12px">Sin registros aun</td></tr>';
    return;
  }
  tbody.innerHTML = '';
  data.slice().sort(function(a,b){ return ((b.date||b.created_at||'').localeCompare(a.date||a.created_at||'')); }).forEach(function(r) {
    var tr = document.createElement('tr');
    var cells = [];

    if (type==='agua') {
      var estadoColors = {lleno:'var(--green)',medio:'var(--amber2)',bajo:'var(--red)',seco:'var(--red)',roto:'var(--muted)'};
      var estadoLabels = {lleno:'✅ Lleno',medio:'⚠️ Medio',bajo:'🔴 Bajo',seco:'❌ Seco',roto:'🔧 Roto'};
      cells = [(r.date||r.fecha||'-'), escH(r.lot_code), '<span style="color:'+estadoColors[r.estado]+'">'+estadoLabels[r.estado]+'</span>', escH(r.obs||'-'), escH(r.by||'-')];
    } else if (type==='sal') {
      // v1.4.113: añadir pill de Tipo entre Cantidad y Observaciones
      var tipoNorm = (typeof _salNormalizeTipo === 'function') ? _salNormalizeTipo(r.tipo) : '';
      var tipoLbl  = (typeof _salTipoLabel === 'function') ? _salTipoLabel(tipoNorm) : (r.tipo || '-');
      var tipoCol  = (typeof _salTipoColor === 'function') ? _salTipoColor(tipoNorm) : '#888780';
      var tipoCell = '<span style="background:' + tipoCol + '26;color:' + tipoCol + ';font-size:10px;padding:2px 7px;border-radius:8px;white-space:nowrap">' + escH(tipoLbl) + '</span>';
      cells = [(r.date||r.fecha||'-'), escH(r.lot_code), escH(r.paddock||'-'), (r.qty||0)+' kg', tipoCell, escH(r.obs||'-'), escH(r.by||'-')];
    } else if (type==='conteo') {
      var diff = r.diff||0;
      var diffColor = diff===0?'var(--green)':diff>0?'var(--blue)':'var(--red)';
      cells = [(r.date||r.fecha||'-'), escH(r.lot_code), r.counted, r.ref, '<span style="color:'+diffColor+';">'+(diff>0?'+':'')+diff+'</span>', escH(r.obs||'-'), escH(r.by||'-')];
    } else if (type==='partos') {
      var sexoLabel = r.sexo==='macho'?'🐂 Macho':'🐄 Hembra';
      var estadoParto = {sano:'✅ Sano',debil:'⚠️ Debil',muerto:'❌ Mortinato'}[r.estado]||r.estado;
      cells = [(r.date||r.fecha||'-'), escH(r.lot_code), sexoLabel, (r.peso||'-')+' kg', estadoParto, escH(r.obs||'-'), escH(r.by||'-')];
    } else if (type==='alimento') {
      cells = [(r.date||r.fecha||'-'), escH(r.lot_code), capFirst((r.tipo||'').replace(/_/g,' ')), (r.qty||0)+' kg', escH(r.obs||'-'), escH(r.by||'-')];
    }

    tr.innerHTML = cells.map(function(c){ return '<td>'+c+'</td>'; }).join('') + '<td></td>';
    var delBtn = document.createElement('button');
    delBtn.className='btn btn-ghost btn-sm'; delBtn.style.color='var(--red)'; delBtn.textContent='✕';
    delBtn.onclick=(function(id,t){ return function(){ deleteSubmodule(id,t); }; })(r.id, type);
    tr.lastElementChild.appendChild(delBtn);
    tbody.appendChild(tr);
  });
}

function deleteSubmodule(id, type) {
  if (!confirm('00bfEliminar este registro?')) return;
  trackDeletion(id, type);
  db[type] = (db[type]||[]).filter(function(r){return r.id!==id;});
  saveDB(); renderSubmodule(type);
  // v1.4.113: refrescar dashboards de Sal cuando se elimina un registro
  if (type === 'sal' && typeof renderSalDashboards === 'function') {
    try { renderSalDashboards(); } catch(e){}
  }
  pushTableToRailway(type, db[type]);
  toast('Registro eliminado','success');
}

