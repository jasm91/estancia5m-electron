      delBtn.className='btn btn-ghost btn-sm';
      delBtn.style.cssText='color:var(--red);flex-shrink:0';
      delBtn.textContent='✕';
      delBtn.onclick=(function(id){return function(){ deleteActivity(id); };})(a.id);
      div.appendChild(delBtn);
    }

    al.appendChild(div);
  });
}

function renderAdvances() {
  if (!db.advances) db.advances = [];
  if (!db.lluvias) db.lluvias = [];

  // Populate dropdown de meses (solo la primera vez)
  var monthSel = document.getElementById('adv-month-sel');
  if (monthSel && !monthSel.options.length) {
    populateAdvMonthSelect();
  }

  // Populate employee filter
  var empFilter = document.getElementById('adv-filter-emp');
  if (empFilter) {
    var curEmp = empFilter.value;
    empFilter.innerHTML = '<option value="">Todos los empleados</option>';
    db.employees.filter(function(e){return e.active;}).forEach(function(e){
      var o = document.createElement('option'); o.value=e.name; o.textContent=e.name;
      if (e.name===curEmp) o.selected=true;
      empFilter.appendChild(o);
    });
  }

  // Get filters
  var filterEmp    = (document.getElementById('adv-filter-emp')||{}).value || '';
  var advFrom      = _advFrom;
  var advTo        = _advTo;

  // Filter advances
  var filtered = db.advances.slice();
  if (filterEmp) filtered = filtered.filter(function(a){ return a.employee===filterEmp; });
  if (advFrom)   filtered = filtered.filter(function(a){ return a.date>=advFrom; });
  if (advTo)     filtered = filtered.filter(function(a){ return a.date<=advTo; });

  // -- Balance cards per employee ----------------------------
  var cardsEl = document.getElementById('adv-balance-cards');
  if (cardsEl) {
    cardsEl.innerHTML = '';
    var employees = filterEmp
      ? db.employees.filter(function(e){ return e.name===filterEmp; })
      : db.employees.filter(function(e){ return e.active; });

    employees.forEach(function(emp) {
      var empAdvances = filtered.filter(function(a){ return a.employee===emp.name; });
      var totalAdv = empAdvances.reduce(function(s,a){ return s+(a.amount||0); },0);
      var pendiente = empAdvances.filter(function(a){ return a.status==='pendiente'; }).reduce(function(s,a){ return s+(a.amount||0); },0);
      var salary = emp.salary || 0;
      // balance calculado abajo en rows

      var card = document.createElement('div');
      card.style.cssText = 'background:var(--sur);border:1px solid var(--bor);border-radius:12px;padding:14px';

      var nameEl = document.createElement('div');
      nameEl.style.cssText = 'font-family:Inter,sans-serif;font-size:13px;font-weight:700;margin-bottom:2px';
      nameEl.textContent = emp.name;

      var roleEl = document.createElement('div');
      roleEl.style.cssText = 'font-size:10px;color:var(--muted);margin-bottom:12px';
      roleEl.textContent = roleLabel(emp.role);

      var descontado = empAdvances.filter(function(a){ return a.status==='descontado'; }).reduce(function(s,a){ return s+(a.amount||0); },0);
      // v1.8.58: la deuda solo aplica al período correcto, no a todos los meses.
      // - Mes actual en curso → cálculo en vivo con emp.deuda_arrastrada.
      // - Mes cerrado con el feature (tiene deuda_previa/resultante en historial) → esos valores.
      // - Mes histórico sin datos / Semana / Todo / Rango → sin deuda (neto = salario − adelantos).
      var _now = new Date();
      var mesActualYM = _now.getFullYear()+'-'+String(_now.getMonth()+1).padStart(2,'0');
      var mesEnFocoYM = ((_advPeriod==='mes'||_advPeriod==='month-pick') && _advFrom) ? String(_advFrom).slice(0,7) : null;
      var deudaPrevia = null;   // null → se muestra "-"
      var balancePagar;
      var deudaAcum = null;     // null → se muestra "-"
      if (mesEnFocoYM) {
        var regHist = (db.historial_sueldos||[]).find(function(r){ return r.empleado===emp.name && r.mes===mesEnFocoYM && r.estado==='pagado'; });
        if (regHist && (regHist.deuda_previa != null || regHist.deuda_resultante != null)) {
          // mes ya cerrado CON datos de deuda (feature activo)
          deudaPrevia  = parseFloat(regHist.deuda_previa) || 0;
          balancePagar = parseFloat(regHist.pago_neto) || 0;
          deudaAcum    = parseFloat(regHist.deuda_resultante) || 0;
        } else if (mesEnFocoYM === mesActualYM) {
          // mes actual en curso (no cerrado): cálculo en vivo
          deudaPrevia = parseFloat(emp.deuda_arrastrada) || 0;
          var balanceReal = salary - deudaPrevia - totalAdv;
          balancePagar = Math.max(0, balanceReal);
          deudaAcum = balanceReal < 0 ? Math.abs(balanceReal) : 0;
        } else {
          // mes histórico sin datos de deuda (pagos previos al feature): sin deuda
          balancePagar = Math.max(0, salary - totalAdv);
        }
      } else {
        // Semana / Todo / Rango: no aplica lógica de deuda
        balancePagar = Math.max(0, salary - totalAdv);
      }
      var rows = [
        {label:'Salario base', val:'Bs. '+salary.toLocaleString(), color:'var(--text)'},
        {label:'Deuda mes anterior', val: (deudaPrevia!=null && deudaPrevia>0)?'Bs. '+deudaPrevia.toLocaleString():'-', color: (deudaPrevia!=null && deudaPrevia>0)?'var(--red)':'var(--muted)'},
        {label:'Adelantos del mes', val:'Bs. '+totalAdv.toLocaleString(), color: totalAdv>0?'var(--amber2)':'var(--muted)'},
        {label:'Ya descontados', val:'Bs. '+descontado.toLocaleString(), color: descontado>0?'var(--green)':'var(--muted)'},
        {label:'Pendiente descontar', val:'Bs. '+pendiente.toLocaleString(), color: pendiente>0?'var(--red)':'var(--green)'},
        {label:'Pago neto fin de mes', val:'Bs. '+balancePagar.toLocaleString(), color: balancePagar>0?'var(--green)':'var(--muted)'},
        {label:'Deuda acumulada', val: (deudaAcum!=null && deudaAcum>0)?'Bs. '+deudaAcum.toLocaleString()+' DEBE':'-', color: (deudaAcum!=null && deudaAcum>0)?'var(--red)':'var(--muted)'},
      ];

      card.appendChild(nameEl);
      card.appendChild(roleEl);

      rows.forEach(function(r){
        var row = document.createElement('div');
        row.style.cssText = 'display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px solid rgba(48,54,61,.3);font-size:12px';
        var lbl = document.createElement('span'); lbl.style.color='var(--muted)'; lbl.textContent=r.label;
