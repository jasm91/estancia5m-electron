// v1.5.0 — Reproducción (Fase 1: Servicios)
// Tabla: reproductive_services (JSONB en server vía makeCRUD)
// Estructura registro: { id, animal_id, tipo_servicio: 'IA'|'monta',
//   toro_id?, semen_lote?, technician?, lot_code, paddock, date,
//   diagnosis_method?: 'tacto'|'eco'|'retorno_celo', diagnosis_date?,
//   result: 'preñada'|'vacia'|'pendiente', notes?, by, created_at, updated_at }
// ═════════════════════════════════════════════════════════════

function _reproGetServicios() {
  return (db && Array.isArray(db.reproductive_services)) ? db.reproductive_services : [];
}

function _reproFilterPeriodo(records, months) {
  if (!months) return records;
  var now = new Date();
  var cutoff = new Date(now.getFullYear(), now.getMonth() - parseInt(months, 10), now.getDate());
  return records.filter(function(r) {
    if (!r.date) return false;
    return new Date(r.date) >= cutoff;
  });
}

function _reproTipoLabel(t) {
  if (t === 'IA') return 'IA';
  if (t === 'monta') return 'Monta';
  return t || '—';
}

function _reproResultPill(result, srvId) {
  // v1.8.13: pill clickable que abre menú emergente para quick-diagnóstico
  // Si srvId está presente, se hace interactiva. Si no, render legacy (sin click).
  var base = 'font-size:11px;padding:3px 8px;border-radius:10px;white-space:nowrap;';
  var styles = {
    'preñada': 'background:rgba(63,185,80,.15);color:var(--green);',
    'vacia':   'background:rgba(248,81,73,.15);color:var(--red);',
    'pendiente': 'background:rgba(212,160,23,.15);color:var(--amber);'
  };
  var labels = {
    'preñada': '✓ Preñada',
    'vacia': '✗ Vacía',
    'pendiente': '⌛ Pendiente'
  };
  var key = (result === 'preñada' || result === 'vacia') ? result : 'pendiente';
  var style = styles[key];
  var label = labels[key];

  if (!srvId) {
    // Render legacy (sin interacción) — para listados de solo lectura
    return '<span style="' + base + style + '">' + label + '</span>';
  }

  // Clickable: el span entero abre el menú
  return '<span onclick="event.stopPropagation();_reproQuickDiagMenu(\'' + srvId + '\',this)" ' +
    'style="' + base + style + 'cursor:pointer;user-select:none;transition:transform .15s" ' +
    'title="Click para cambiar resultado" ' +
    'onmouseover="this.style.transform=\'scale(1.05)\'" ' +
    'onmouseout="this.style.transform=\'scale(1)\'">' + label + ' ▾</span>';
}

// v1.8.13: menú emergente de quick-diagnóstico
function _reproQuickDiagMenu(srvId, anchorEl) {
  // Cerrar cualquier menú abierto
  var prev = document.getElementById('repro-quick-menu');
  if (prev) prev.remove();

  if (!Array.isArray(db.reproductive_services)) return;
  var srv = db.reproductive_services.find(function(r){ return r.id === srvId; });
  if (!srv) return;
  var current = srv.result || 'pendiente';

  // Opciones según estado actual
  var items = [];
  if (current !== 'preñada') items.push({ key:'preñada', label:'✓ Preñada', color:'var(--green)' });
  if (current !== 'vacia') items.push({ key:'vacia', label:'✗ Vacía', color:'var(--red)' });
  if (current === 'preñada' || current === 'vacia') items.push({ key:'pendiente', label:'⌛ Volver a Pendiente', color:'var(--amber)' });

  // Construir menú
  var menu = document.createElement('div');
  menu.id = 'repro-quick-menu';
  menu.style.cssText = 'position:absolute;background:var(--sur);border:1px solid var(--bor);border-radius:8px;padding:4px;min-width:160px;box-shadow:0 4px 16px rgba(0,0,0,.4);z-index:9999;font-size:12px';
  items.forEach(function(it){
    var mi = document.createElement('div');
    mi.style.cssText = 'padding:7px 10px;border-radius:5px;cursor:pointer;color:' + it.color + ';transition:background .12s';
    mi.textContent = it.label;
    mi.onmouseover = function(){ this.style.background = 'var(--sur2)'; };
    mi.onmouseout = function(){ this.style.background = 'transparent'; };
    mi.onclick = function(e){
      e.stopPropagation();
      _reproQuickDiag(srvId, it.key);
      menu.remove();
    };
    menu.appendChild(mi);
  });
  // Separador + opción detallado
  var sep = document.createElement('div');
  sep.style.cssText = 'border-top:1px solid var(--bor);margin:3px 0';
  menu.appendChild(sep);
  var detail = document.createElement('div');
  detail.style.cssText = 'padding:7px 10px;border-radius:5px;cursor:pointer;color:var(--muted);font-size:11px;transition:background .12s';
  detail.textContent = '⚙ Diagnóstico detallado…';
  detail.onmouseover = function(){ this.style.background = 'var(--sur2)'; };
  detail.onmouseout = function(){ this.style.background = 'transparent'; };
  detail.onclick = function(e){
    e.stopPropagation();
    menu.remove();
    if (typeof openReproDiagnostico === 'function') openReproDiagnostico(srvId);
  };
  menu.appendChild(detail);

  // Posicionar cerca del anchor
  document.body.appendChild(menu);
  var rect = anchorEl.getBoundingClientRect();
  var mh = menu.offsetHeight;
  var mw = menu.offsetWidth;
  var top = rect.bottom + 4;
  // Si no entra abajo, abrir arriba
  if (top + mh > window.innerHeight) top = rect.top - mh - 4;
  var left = rect.left;
  if (left + mw > window.innerWidth) left = window.innerWidth - mw - 8;
  menu.style.top = top + 'px';
  menu.style.left = left + 'px';

  // Cerrar al hacer click fuera
  setTimeout(function(){
    var closer = function(ev){
      if (!menu.contains(ev.target)) { menu.remove(); document.removeEventListener('click', closer); }
    };
    document.addEventListener('click', closer);
  }, 50);
}

// v1.8.13: aplicar quick-diagnóstico con defaults razonables
function _reproQuickDiag(srvId, newResult) {
  if (!Array.isArray(db.reproductive_services)) return;
  var idx = db.reproductive_services.findIndex(function(r){ return r.id === srvId; });
  if (idx === -1) return;
  var srv = db.reproductive_services[idx];
  var nowIso = new Date().toISOString();
  var today = nowIso.slice(0, 10);

  if (newResult === 'pendiente') {
    // Volver a pendiente: limpiar resultado + diagnóstico
    db.reproductive_services[idx] = Object.assign({}, srv, {
      result: '', diagnosis_method: '', diagnosis_date: '', updated_at: nowIso
    });
    if (typeof toast === 'function') toast('Resultado vuelto a pendiente', 'success');
  } else {
    // Preñada o Vacía: setear con defaults (tacto + hoy) si no había datos previos
    var diagMethod = srv.diagnosis_method || 'tacto';
    var diagDate = srv.diagnosis_date || today;
    db.reproductive_services[idx] = Object.assign({}, srv, {
      result: newResult,
      diagnosis_method: diagMethod,
      diagnosis_date: diagDate,
      updated_at: nowIso
    });
    if (typeof toast === 'function') {
      if (newResult === 'preñada' && srv.date) {
        var esperada = new Date(new Date(srv.date).getTime() + 280*86400000).toISOString().slice(0,10);
        toast('✓ Marcada Preñada · Esperado parto: ' + _reproFmtDate(esperada), 'success');
      } else if (newResult === 'preñada') {
        toast('✓ Marcada Preñada', 'success');
      } else {
        toast('✗ Marcada Vacía', 'success');
      }
    }
  }

  try { localStorage.setItem(DB_KEY, JSON.stringify(db)); } catch(e) {}
  _reproPushServicio(db.reproductive_services[idx]);
  renderReproServicios();
}

