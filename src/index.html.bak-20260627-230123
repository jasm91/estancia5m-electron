function exportBackup() {
  var backup = {
    version: '1.0',
    app: 'EstanciaPro',
    exported_at: new Date().toISOString(),
    db: JSON.parse(localStorage.getItem('estancia5m_v1') || '{}'),
    animals: JSON.parse(localStorage.getItem('e5m_animals') || '{}'),
    tasks: JSON.parse(localStorage.getItem('e5m_tasks') || '[]'),
    report_params: JSON.parse(localStorage.getItem('e5m_report_params') || '{}'),
    api_url: localStorage.getItem('e5m_api_url') || '',
    api_token: localStorage.getItem('e5m_api_token') || '',
  };
  var json = JSON.stringify(backup, null, 2);
  var blob = new Blob([json], {type: 'application/json'});
  var url = URL.createObjectURL(blob);
  var a = document.createElement('a');
  var fecha = localDate();
  a.href = url;
  a.download = 'backup_estanciapro_' + fecha + '.json';
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  URL.revokeObjectURL(url);
  // Registrar fecha del ultimo backup
  localStorage.setItem('e5m_last_backup', new Date().toLocaleString('es-BO'));
  var lbl = document.getElementById('cfg-last-backup');
  if(lbl) lbl.textContent = 'Ultimo backup: ' + localStorage.getItem('e5m_last_backup');
  toast('Backup exportado correctamente', 'success');
}

function importBackup(input) {
  var file = input.files[0];
  if(!file) return;
  var statusEl = document.getElementById('backup-status');
  if(statusEl){ statusEl.style.display='block'; statusEl.textContent='Leyendo archivo...'; statusEl.style.color='var(--muted)'; }
  var reader = new FileReader();
  reader.onload = function(e) {
    try {
      var backup = JSON.parse(e.target.result);
      // Validar que sea un backup valido
      if(!backup.app || backup.app !== 'EstanciaPro') {
        if(statusEl){ statusEl.textContent='Error: el archivo no es un backup valido de EstanciaPro.'; statusEl.style.color='var(--red)'; }
        toast('Archivo invalido', 'error');
        return;
      }
      if(!confirm('Vas a restaurar un backup del ' + (backup.exported_at||'').slice(0,10) + '. Esto reemplazara TODOS los datos actuales. Continuar?')) {
        if(statusEl) statusEl.style.display='none';
        input.value='';
        return;
      }
      // Restaurar datos
      if(backup.db) localStorage.setItem('estancia5m_v1', JSON.stringify(backup.db));
      if(backup.animals) localStorage.setItem('e5m_animals', JSON.stringify(backup.animals));
      if(backup.tasks) localStorage.setItem('e5m_tasks', JSON.stringify(backup.tasks));
      if(backup.report_params) localStorage.setItem('e5m_report_params', JSON.stringify(backup.report_params));
      if(backup.api_url) localStorage.setItem('e5m_api_url', backup.api_url);
      if(backup.api_token) localStorage.setItem('e5m_api_token', backup.api_token);
      if(statusEl){ statusEl.textContent='Backup restaurado. Recargando la aplicacion...'; statusEl.style.color='var(--green)'; }
      toast('Backup restaurado correctamente', 'success');
      setTimeout(function(){ location.reload(); }, 1500);
    } catch(err) {
      if(statusEl){ statusEl.textContent='Error al leer el backup: ' + err.message; statusEl.style.color='var(--red)'; }
      toast('Error al restaurar backup', 'error');
    }
    input.value='';
  };
  reader.readAsText(file);
}

</script>

<script>
// ── HISTORIAL ANIMALES ────────────────────────────────────────
function fmtFechaHora(str) {
  if(!str) return '';
  var d = new Date(str);
  if(isNaN(d)) return str.slice(0,10);
  var fecha = str.slice(0,10);
  var h = d.getHours().toString().padStart(2,'0');
  var m = d.getMinutes().toString().padStart(2,'0');
  // Si tiene componente de hora distinto de 00:00, mostrarla
  if(str.length > 10 && (h !== '00' || m !== '00')) return fecha + ' ' + h + ':' + m;
  return fecha;
}
function renderHistorialAnimales() {
  // Poblar selector de lote
  var lotSel = document.getElementById('historial-lot-filter');
  if(lotSel && lotSel.options.length <= 1) {
    var activeLots = (db.lots||[]).filter(function(l){ return !l.status||l.status==='activo'||l.status==='active'; });
    lotSel.innerHTML = '<option value="">Todos los lotes...</option>' +
      activeLots.map(function(l){ return '<option value="'+l.code+'">'+l.code+' - '+l.category+'</option>'; }).join('');
  }
  var lotCode = (document.getElementById('historial-lot-filter')||{}).value||'';
  var search = ((document.getElementById('historial-search')||{}).value||'').toLowerCase();

  var animalesDB = getAnimalesDB();
  var animals = [];
  if(lotCode) {
    animals = (animalesDB[lotCode]||[]).map(function(a){ return {a:a, lotCode:lotCode}; });
  } else {
    Object.keys(animalesDB).forEach(function(code){
      (animalesDB[code]||[]).forEach(function(a){ animals.push({a:a, lotCode:code}); });
    });
  }
  if(search) animals = animals.filter(function(x){ var aid=(x.a.animal_id||x.a.id||'').toString(); return aid.toLowerCase().indexOf(search)>=0; });

  var sub = document.getElementById('historial-subtitle');
  if(sub) sub.textContent = animals.length+' animales'+( lotCode?' en '+lotCode:'');

  var el = document.getElementById('historial-list');
  if(!el) return;
  if(!animals.length) {
    el.innerHTML='<div style="padding:32px;text-align:center;color:var(--muted)">Sin animales. Selecciona un lote.</div>';
    return;
  }

  // Armar historial de curaciones por animal
  var trByAnimal = {};
  (db.treatments||[]).filter(function(t){ return t.scope==='individual'&&t.animal_id; }).forEach(function(t){
    if(!trByAnimal[t.animal_id]) trByAnimal[t.animal_id]=[];
    trByAnimal[t.animal_id].push(t);
  });

  // Armar ventas individuales por animal
  var saleByAnimal = {};
  (db.sales||[]).filter(function(s){ return s.animal_ids&&s.animal_ids.length; }).forEach(function(s){
    s.animal_ids.forEach(function(id){
      saleByAnimal[id]={date:s.date,buyer:s.buyer,price_per_kg:s.price_per_kg,total:s.total,lot_code:s.lot_code};
    });
  });

  el.innerHTML = animals.map(function(item){
    var a = item.a; var lotC = item.lotCode;
    var lastP = a.pesajes&&a.pesajes.length ? a.pesajes[a.pesajes.length-1].peso : null;
    var firstP = a.pesajes&&a.pesajes.length ? a.pesajes[0].peso : null;
    var gmd = 0;
    if(a.pesajes&&a.pesajes.length>=2) {
      var p0=a.pesajes[0]; var p1=a.pesajes[a.pesajes.length-1];
      var dias=Math.round((new Date(p1.fecha)-new Date(p0.fecha))/86400000);
      if(dias>0) gmd=Math.round((p1.peso-p0.peso)/dias*1000)/1000;
    }
    var _aid = a.animal_id||a.id||'';
    var sold = saleByAnimal[_aid];
    var curas = trByAnimal[_aid]||[];

    // Armar eventos de timeline
    var events = [];
    (a.pesajes||[]).forEach(function(p,i){
      events.push({date:p.fecha,type:'pesaje',peso:p.peso,idx:i});
    });
    curas.forEach(function(c){
      events.push({date:c.applied_at||c.created_at||'',type:'curacion',product:c.product_name,dose:c.dose,cost:c.cost,diag:c.diagnosis});
    });
    if(sold) events.push({date:sold.date,type:'venta',buyer:sold.buyer,price:sold.price_per_kg});
    events.sort(function(a,b){ return (a.created_at||a.date||'').localeCompare(b.created_at||b.date||''); });

    var evHtml = events.map(function(ev,i){
      var prevPesaje = null;
      if(ev.type==='pesaje' && i>0) {
        for(var j=i-1;j>=0;j--) { if(events[j].type==='pesaje'){prevPesaje=events[j];break;} }
      }
      var gmdLine='';
      if(ev.type==='pesaje' && prevPesaje) {
        var dias2=Math.round((new Date(ev.date)-new Date(prevPesaje.date))/86400000);
        var g=dias2>0?Math.round((ev.peso-prevPesaje.peso)/dias2*1000)/1000:0;
        gmdLine='<span style="color:var(--green);margin-left:8px;font-size:10px">GMD: '+g+' kg/d</span>';
      }
      if(ev.type==='pesaje') return (
        '<div style="display:flex;gap:10px;align-items:flex-start;padding:6px 0;border-bottom:1px solid rgba(48,54,61,.25)">'+
          '<div style="width:10px;height:10px;border-radius:50%;background:var(--amber2);margin-top:3px;flex-shrink:0"></div>'+
          '<div style="flex:1">'+
            '<span style="font-family:DM Mono,monospace;font-size:11px;font-weight:700">'+ev.peso+' kg</span>'+
            gmdLine+
            '<span style="float:right;font-size:10px;color:var(--muted)">'+fmtFechaHora(ev.date)+'</span>'+
          '</div>'+
        '</div>'
      );
      if(ev.type==='curacion') return (
        '<div style="display:flex;gap:10px;align-items:flex-start;padding:6px 0;border-bottom:1px solid rgba(48,54,61,.25)">'+
          '<div style="width:10px;height:10px;border-radius:50%;background:#58A6FF;margin-top:3px;flex-shrink:0"></div>'+
          '<div style="flex:1">'+
            '<span style="font-size:11px;color:#58A6FF;font-weight:600">Curacion: </span>'+
            '<span style="font-size:11px">'+escH(ev.product||'')+(ev.diag?' - '+escH(ev.diag):'')+'</span>'+
            '<span style="float:right;font-size:10px;color:var(--muted)">'+fmtFechaHora(ev.date)+'</span>'+
          '</div>'+
        '</div>'
      );
      if(ev.type==='venta') return (
        '<div style="display:flex;gap:10px;align-items:flex-start;padding:6px 0">'+
          '<div style="width:10px;height:10px;border-radius:50%;background:var(--green);margin-top:3px;flex-shrink:0"></div>'+
          '<div style="flex:1">'+
            '<span style="font-size:11px;color:var(--green);font-weight:600">Vendido: </span>'+
            '<span style="font-size:11px">'+escH(ev.buyer||'')+(ev.price?' a Bs '+ev.price+'/kg':'')+'</span>'+
            '<span style="float:right;font-size:10px;color:var(--muted)">'+fmtFechaHora(ev.date)+'</span>'+
          '</div>'+
        '</div>'
      );
      return '';
    }).join('');

    var statusBadge = sold
      ? '<span style="background:var(--green2);color:var(--green);padding:2px 7px;border-radius:4px;font-size:10px;font-family:DM Mono,monospace">VENDIDO</span>'
      : '<span style="background:var(--sur2);color:var(--muted);padding:2px 7px;border-radius:4px;font-size:10px;font-family:DM Mono,monospace">ACTIVO</span>';

    return (
      '<div style="border-bottom:2px solid var(--bor);padding:14px 18px">'+
        '<div style="display:flex;align-items:center;gap:12px;margin-bottom:10px;flex-wrap:wrap">'+
          '<span style="font-family:DM Mono,monospace;font-size:14px;font-weight:700;color:var(--amber2)">'+(a.animal_id||a.id||'?')+'</span>'+
          statusBadge+
          '<span style="font-size:12px;color:var(--muted)">'+escH(a.breed||a.raza||'')+'</span>'+
          '<span style="margin-left:auto;font-size:11px;font-family:DM Mono,monospace;color:var(--muted)">'+escH(lotC)+'</span>'+
          (lastP?'<span style="font-size:12px;font-weight:700">'+lastP+' kg</span>':'')+
          (gmd?'<span style="font-size:11px;color:var(--green)">GMD '+gmd+' kg/d</span>':'')+
        '</div>'+
        (evHtml ? '<div style="padding-left:8px">'+evHtml+'</div>' : '<div style="color:var(--muted);font-size:11px;padding:4px 8px">Sin eventos registrados</div>')+
      '</div>'
    );
  }).join('');
}
</script>

