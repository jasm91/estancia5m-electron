function renderCGAnimalsTable() {
  var tbody = document.getElementById('cg-animals-tbody');
  if (!_cgAnimals.length) {
    tbody.innerHTML = '<tr><td colspan="4" style="text-align:center;color:var(--muted);padding:16px;font-size:12px">Agrega animales con el boton + Agregar animal</td></tr>';
