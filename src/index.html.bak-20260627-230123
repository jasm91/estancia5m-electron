function saveAdvance() {
  // Guard contra doble-click / submits múltiples
  if (_saveAdvanceInProgress) { console.warn('[saveAdvance] Ya está en progreso, ignorando'); return; }
  _saveAdvanceInProgress = true;
  // Desactivar el botón visualmente
  var btn = document.querySelector('#modal-advance .btn-primary');
  if (btn) { btn.disabled = true; btn.textContent = 'Guardando...'; }

  function _release() {
    _saveAdvanceInProgress = false;
    if (btn) { btn.disabled = false; btn.textContent = 'Registrar adelanto'; }
  }

  try {
    var emp = document.getElementById('adv-employee').value;
    var amount = parseFloat(document.getElementById('adv-amount').value);
    var date = document.getElementById('adv-date').value;
    var status = document.getElementById('adv-status').value;
    var reason = document.getElementById('adv-reason').value.trim();
    if (!emp || !amount || !date) { toast('Completa empleado, monto y fecha', 'error'); _release(); return; }
    // FIX v1.4.34: no permitir fechas futuras
    if (!validateNotFuture(date, 'fecha del adelanto')) { _release(); return; }
    // v1.8.59: bloquear adelantos solo si a ESTE empleado ya se le pagó el sueldo de ese mes
    var mesAdv = (date||'').slice(0,7);
    if (_empMesPagado(emp, mesAdv)) {
      toast('A '+emp.split(' ')[0]+' ya se le pagó el sueldo de '+mesAdv+'. No se pueden registrar adelantos de ese mes para este empleado.', 'error');
      _release(); return;
    }
    if (!db.advances) db.advances = [];
    if (!db.lluvias) db.lluvias = [];
    // v1.8.57: alerta (no bloqueo) si el adelanto deja al trabajador en saldo negativo,
    // considerando la deuda arrastrada de meses anteriores.
    var employee = db.employees.find(function(e){return e.name===emp;});
    if (employee) {
      var deudaPrevia = parseFloat(employee.deuda_arrastrada) || 0;
      var advMesActual = db.advances.filter(function(a){
        return a.employee===emp && (a.date||'').slice(0,7)===mesAdv;
      }).reduce(function(s,a){return s+(a.amount||0);},0);
      var balanceTrasAdv = (employee.salary||0) - deudaPrevia - advMesActual - amount;
      if (balanceTrasAdv < 0) {
        var faltante = Math.abs(balanceTrasAdv);
        var msg = '⚠ Este adelanto deja a '+emp.split(' ')[0]+' con saldo negativo de Bs. '+faltante.toLocaleString()+'.';
        if (deudaPrevia>0) msg += '\n(Incluye Bs. '+deudaPrevia.toLocaleString()+' de deuda de meses anteriores.)';
        msg += '\nEse saldo se arrastrará como deuda al mes siguiente.\n\n¿Confirmás el adelanto?';
        if (!confirm(msg)) { _release(); return; }
      }
    }
    // Detectar duplicados recientes (mismo emp+monto+fecha en los últimos 60s)
    var nowMs = Date.now();
    var possibleDup = (db.advances || []).find(function(a){
      if (a.employee !== emp || a.amount !== amount || a.date !== date) return false;
      var aTime = a.created_at ? new Date(a.created_at).getTime() : 0;
      return aTime && (nowMs - aTime) < 60000;
    });
    if (possibleDup) {
      if (!confirm('Ya hay un adelanto idéntico hace menos de 1 minuto.\n\n¿Estás seguro de registrar otro?')) { _release(); return; }
    }
    var newAdvance = {
      id: db.next_ids.advance++,
      employee: emp,
      amount: amount,
      date: date,
      status: status,
      reason: reason,
      created_at: new Date().toISOString(),
    };
    db.advances.push(newAdvance);
    saveDB();
    closeModal('modal-advance');
    renderAdvances();
    // Push al server (faltaba)
    replaceTableInRailway('advances', db.advances || []);
    toast('Adelanto de Bs. '+amount.toLocaleString()+' registrado para '+emp.split(' ')[0], 'success');
    // FIX v1.4.35: audit log para adelanto
    try { auditLog('create', 'advances', newAdvance.id, 'Adelanto: ' + emp + ' · Bs ' + amount + (status==='descontado'?' (descontado)':'')); } catch(e){}
  } catch(e) {
    console.error('[saveAdvance] error:', e);
    toast('Error al guardar adelanto: ' + e.message, 'error');
  } finally {
    _release();
  }
}

function toggleAdvance(id) {
  var adv = db.advances.find(function(a){ return a.id===id; });
  if (adv) adv.status = adv.status==='pendiente' ? 'descontado' : 'pendiente';
  saveDB();
  // FIX v1.4.31: toggle de status edita un advance existente. sync-push usa
  // mergeById que ignora actualizaciones, así que el toggle se revertía tras
  // el próximo pull. replaceTableInRailway hace REPLACE total y persiste.
  replaceTableInRailway('advances', db.advances || []);
  renderAdvances();
}

function deleteAdvance(id) {
