function saveEmployee() {
  const name=document.getElementById('emp-name').value.trim();
  if(!name){toast('Ingresa el nombre','error');return;}
  var auditAction = 'create';   // FIX v1.4.35: track action for audit
  var savedEmpId = null;
  var oldSnap = null;
  if(_editingEmployeeId !== null) {
    // Modo edicion
    var emp = db.employees.find(function(e){ return e.id === _editingEmployeeId; });
    if(emp) {
      oldSnap = JSON.parse(JSON.stringify(emp));   // FIX v1.4.35: snapshot pre-edit
      emp.name = name;
      // v1.8.67: al RENOMBRAR un empleado, migrar todos sus registros vinculados por nombre
      // (adelantos, sueldos, actividades, tareas) para que NO se pierdan. Antes estos
      // registros guardaban el nombre como texto y quedaban huérfanos al cambiar el nombre
      // (ej. "Juan" → "Juan Pérez" hacía desaparecer todos los adelantos de Juan).
      window._empRenameInfo = null;
      var _oldNm = (oldSnap && oldSnap.name) ? oldSnap.name : null;
      if (_oldNm && _oldNm !== name) {
        var _nMig = 0;
        (db.advances||[]).forEach(function(a){ if(a.employee===_oldNm){ a.employee=name; _nMig++; } });
        (db.historial_sueldos||[]).forEach(function(s){ if(s.empleado===_oldNm){ s.empleado=name; _nMig++; } });
        (db.activities||[]).forEach(function(a){ if(a.employee===_oldNm){ a.employee=name; _nMig++; } });
        var _tkChanged = false;
        try {
          var _tk = JSON.parse(localStorage.getItem('e5m_tasks')||'[]');
          _tk.forEach(function(t){
            if(t.assignee===_oldNm){ t.assignee=name; _nMig++; _tkChanged=true; }
            if(t.completed_by===_oldNm){ t.completed_by=name; _nMig++; _tkChanged=true; }
          });
          if(_tkChanged) localStorage.setItem('e5m_tasks', JSON.stringify(_tk));
        } catch(e){}
        window._empRenameInfo = { from:_oldNm, to:name, count:_nMig, tasksChanged:_tkChanged };
        if(_nMig) console.log('[Empleado] Renombrado "'+_oldNm+'" → "'+name+'": '+_nMig+' registros migrados');
      }
      emp.role = document.getElementById('emp-role').value;
      emp.phone = document.getElementById('emp-phone').value;
      emp.salary = parseFloat(document.getElementById('emp-salary').value)||0;
      emp.hire_date = document.getElementById('emp-hire').value;
      // v1.8.80: la baja ya NO se setea desde Editar (unico camino = boton "+ Baja").
      // Se preservan term_date/active del empleado para no reactivarlo sin querer.
      var pinVal = (document.getElementById('emp-pin').value||'').trim();
      if(pinVal) emp.pin = pinVal;
      savedEmpId = emp.id;
      auditAction = 'update';
    }
    _editingEmployeeId = null;
    toast(window._empRenameInfo && window._empRenameInfo.count ? ('Empleado actualizado · '+window._empRenameInfo.count+' registro(s) migrados al nuevo nombre') : 'Empleado actualizado','success');
  } else {
    // Modo nuevo
    var newPin = (document.getElementById('emp-pin').value||'').trim();
    var newEmp = {id:db.next_ids.employee++,name,role:document.getElementById('emp-role').value,phone:document.getElementById('emp-phone').value,salary:parseFloat(document.getElementById('emp-salary').value)||0,hire_date:document.getElementById('emp-hire').value,term_date:null,active:true,pin:newPin||''};
    db.employees.push(newEmp);
    savedEmpId = newEmp.id;
    toast('Empleado agregado','success');
  }
  // Restaurar titulo del modal
  var h2 = document.querySelector('#modal-employee h2');
  if(h2) h2.textContent = 'Nuevo Empleado';
  saveDB(); closeModal('modal-employee'); renderPersonal();
  // Push al server (faltaba — la PWA con cache vieja podía pisar la lista del server)
  replaceTableInRailway('employees', db.employees || []);
  // v1.8.67: si hubo rename, sincronizar también las tablas migradas para que el server
  // refleje el nuevo nombre (si no, el próximo pull podría traer registros con el nombre viejo).
  if (window._empRenameInfo && window._empRenameInfo.count) {
    try { replaceTableInRailway('advances', db.advances || []); } catch(e){}
    try { replaceTableInRailway('historial_sueldos', db.historial_sueldos || []); } catch(e){}
    try { replaceTableInRailway('field_activities', db.activities || []); } catch(e){}
    if (window._empRenameInfo.tasksChanged) {
      try { replaceTableInRailway('tasks', JSON.parse(localStorage.getItem('e5m_tasks')||'[]')); } catch(e){}
    }
    window._empRenameInfo = null;
  }
  // FIX v1.4.35: audit log para empleado
  if (savedEmpId != null) {
    try {
      var current = (db.employees || []).find(function(e){ return e.id === savedEmpId; });
      var diff = (auditAction === 'update' && oldSnap && current) ? _computeDiff(oldSnap, current) : null;
      auditLog(auditAction, 'employees', savedEmpId, _summarizeRecord('employees', current || savedEmpId), diff);
    } catch(e){}
  }
  // v1.8.79: registrar evento de contratación (alta) para la pestaña Contrataciones
  if (savedEmpId != null && auditAction === 'create') {
    try {
      if(!Array.isArray(db.contrataciones)) db.contrataciones=[];
      var _ec=(db.employees||[]).find(function(e){return e.id===savedEmpId;});
      if(_ec){ var _by=(typeof _desktopAuthor==='function'?_desktopAuthor():'Escritorio'); db.contrataciones.push({ id:'contr_'+Date.now(), employee_id:_ec.id, employee:_ec.name, role:_ec.role||'', hire_date:_ec.hire_date||'', salary:_ec.salary||0, by:_by, created_at:new Date().toISOString() }); saveDB(); try{replaceTableInRailway('contrataciones',db.contrataciones);}catch(e2){} try{ if(typeof addActivity==='function') addActivity(_by,'otro','','Contratación: '+_ec.name+(_ec.role?' ('+_ec.role+')':'')); }catch(e2){} }
    } catch(e){}
  }
}

