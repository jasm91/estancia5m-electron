function editSubcuenta(idx) {
  var params = getParams();
  var sub = (params.subcuentas||[])[idx];
  if (!sub) return;

  // Construir lista de cuentas únicas (name + tipo_gasto) que existen en el catálogo
  var cuentaOpts = [];
  var seenKey = {};
  (params.cuentas||[]).forEach(function(c){
    if (!c.name) return;
    var t = c.tipo_gasto || '';
    var key = c.name + '|' + t;
    if (seenKey[key]) return;
    seenKey[key] = true;
    cuentaOpts.push({ cuenta: c.name, tipo: t, label: t ? (c.name + ' (' + t + ')') : c.name });
  });

  // Valor actual de la cuenta padre
  var currentTipo = sub.cuenta_tipo || resolveCuentaTipoGasto(params, sub, '');
  var currentKey = (sub.cuenta || '') + '|' + (currentTipo || '');

  // Quitar overlay anterior si existía
  var oldOv = document.getElementById('overlay-edit-subcuenta');
  if (oldOv) oldOv.remove();

  var o = document.createElement('div');
  o.id = 'overlay-edit-subcuenta';
  o.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:500;display:flex;align-items:center;justify-content:center;padding:20px';
  var b = document.createElement('div');
  b.style.cssText = 'background:var(--sur);border:1px solid var(--bor);border-radius:12px;padding:22px;max-width:480px;width:100%';

  var optsHtml = cuentaOpts.map(function(opt){
    var k = opt.cuenta + '|' + opt.tipo;
    return '<option value="'+escH(k)+'"'+(k===currentKey?' selected':'')+'>'+escH(opt.label)+'</option>';
  }).join('');

  b.innerHTML =
    '<div style="font-size:15px;font-weight:600;color:var(--text);margin-bottom:14px">✎ Editar subcuenta</div>'+
    '<div style="margin-bottom:12px">'+
      '<label style="font-size:11px;color:var(--muted);font-weight:600;display:block;margin-bottom:4px">Nombre</label>'+
      '<input type="text" id="_es_name" class="form-input" value="'+escH(sub.name||'')+'" style="width:100%">'+
    '</div>'+
    '<div style="margin-bottom:14px">'+
      '<label style="font-size:11px;color:var(--muted);font-weight:600;display:block;margin-bottom:4px">Cuenta padre (con tipo de gasto)</label>'+
      '<select id="_es_cuenta" class="form-select" style="width:100%">'+optsHtml+'</select>'+
      '<div style="font-size:10px;color:var(--muted);margin-top:4px">Cambios afectan TODOS los registros con esta subcuenta (resolución dinámica). Si necesitás otro tipo, edita primero la cuenta en el catálogo.</div>'+
    '</div>'+
    '<div style="display:flex;gap:8px;justify-content:flex-end">'+
      '<button id="_es_cancel" class="btn btn-ghost">Cancelar</button>'+
      '<button id="_es_save" class="btn btn-primary">Guardar</button>'+
    '</div>';

  o.appendChild(b);
  document.body.appendChild(o);

  var nameInp = document.getElementById('_es_name');
  nameInp.focus(); nameInp.select();

  document.getElementById('_es_cancel').onclick = function(){ o.remove(); };
  o.addEventListener('click', function(e){ if(e.target===o) o.remove(); });

  document.getElementById('_es_save').onclick = function() {
    var newName = (nameInp.value || '').trim();
    var rawKey = document.getElementById('_es_cuenta').value || '';
    if (!newName) { toast('Ingresa un nombre', 'error'); return; }
    if (!rawKey) { toast('Selecciona una cuenta padre', 'error'); return; }
    var parts = rawKey.split('|');
    var newCuenta = parts[0] || '';
    var newTipo = parts[1] || '';
    if (!newCuenta) { toast('Cuenta inválida', 'error'); return; }

    // Validar que no quede duplicada (mismo nombre + cuenta + tipo) excepto si es ella misma
    var dup = (params.subcuentas||[]).some(function(s, i){
      if (i === idx) return false;
      return (s.name||'').toLowerCase() === newName.toLowerCase()
          && s.cuenta === newCuenta
          && (s.cuenta_tipo || '') === newTipo;
    });
    if (dup) { toast('Ya existe una subcuenta igual', 'error'); return; }

    var updated = { name: newName, cuenta: newCuenta };
    if (newTipo) updated.cuenta_tipo = newTipo;
    var _oldSubName = sub.name || '';
    params.subcuentas[idx] = updated;
    saveParams(params);
    // v1.8.68: las compras (y kardex) guardan la subcuenta como TEXTO → al renombrar hay que
    // reescribirlas o los registros viejos dejan de agruparse/resolver su cuenta en el reporte.
    var _subMig = 0;
    if (_oldSubName) {
      (db.purchases||[]).forEach(function(p){ if((p.subcuenta||'')===_oldSubName){ if(newName!==_oldSubName) p.subcuenta=newName; if(newCuenta) p.cuenta=newCuenta; _subMig++; } });
      (db.kardex||[]).forEach(function(k){ if((k.subcuenta||'')===_oldSubName){ if(newName!==_oldSubName) k.subcuenta=newName; if(newCuenta) k.cuenta=newCuenta; _subMig++; } });
      if (_subMig) { saveDB(); try { replaceTableInRailway('purchases', db.purchases||[]); } catch(e){} try { replaceTableInRailway('kardex', db.kardex||[]); } catch(e){} }
    }
    o.remove();
    renderParams();
    toast(_subMig ? ('Subcuenta actualizada · '+_subMig+' registro(s) migrados') : 'Subcuenta actualizada', 'success');
  };

  // Enter en el nombre = guardar
  nameInp.addEventListener('keydown', function(e){
    if (e.key === 'Enter') document.getElementById('_es_save').click();
    if (e.key === 'Escape') o.remove();
  });
}

function addSubcuentaParam() {
  var name = (document.getElementById('param-sub-name')||{}).value||'';
  var rawVal = (document.getElementById('param-sub-cuenta')||{}).value||'';
  if (!name.trim()) { toast('Ingresa nombre de subcuenta','error'); return; }
  if (!rawVal) { toast('Selecciona la cuenta padre','error'); return; }
  // El value puede ser JSON {n,t} (formato nuevo) o solo el nombre (legacy)
  var cuenta = '', cuenta_tipo = '';
  try {
    var parsed = JSON.parse(rawVal);
    if (parsed && parsed.n) { cuenta = parsed.n; cuenta_tipo = parsed.t || ''; }
  } catch(e) { cuenta = rawVal; }
  if (!cuenta) { toast('Cuenta padre inválida','error'); return; }
  var params = getParams();
  if (!params.subcuentas) params.subcuentas = [];
  // Duplicado = mismo nombre+cuenta+tipo
  if (params.subcuentas.find(function(s){
    return s.name.toLowerCase() === name.trim().toLowerCase()
        && s.cuenta === cuenta
        && (s.cuenta_tipo || '') === cuenta_tipo;
  })) {
    toast('Ya existe esa subcuenta','error'); return;
  }
  var newSub = { name: name.trim(), cuenta: cuenta };
  if (cuenta_tipo) newSub.cuenta_tipo = cuenta_tipo;
  params.subcuentas.push(newSub);
  saveParams(params);
  document.getElementById('param-sub-name').value = '';
  renderParams();
  toast('Subcuenta agregada','success');
}

function addParam(key, item) {
  if (!item.name || !item.name.trim()) { toast('Ingresa un nombre','error'); return; }
  var params = getParams();
  if (!params[key]) params[key]=[];
  // Avoid duplicates
  if (params[key].find(function(p){ return p.name.toLowerCase()===item.name.trim().toLowerCase(); })) {
    toast('Ya existe ese elemento','error'); return;
  }
  params[key].push({name: item.name.trim(), capacity: item.capacity||undefined});
  saveParams(params);
  // Clear input
  var inputMap = {potreros:'param-potrero-name', categorias:'param-cat-name', razas:'param-raza-name', actividades:'param-act-name'};
  var inp = document.getElementById(inputMap[key]);
  if (inp) inp.value='';
  var capInp = document.getElementById('param-potrero-cap');
  if (capInp && key==='potreros') capInp.value='';
  renderParams();
  toast(item.name.trim()+' agregado', 'success');
}

function deleteParam(key, idx) {
  var params = getParams();
  var name = params[key][idx].name;
  if (!confirm('Eliminar ' + name + '?')) return;
  params[key].splice(idx, 1);
  saveParams(params);
  renderParams();
  toast(name+' eliminado', 'success');
}

