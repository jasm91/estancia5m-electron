// v1.8.17: usar mini-modal en lugar de prompt() (deprecado en Electron)
var _reproPesarPartoId = null;
function _reproQuickPesarParto(partoId) {
  if (!Array.isArray(db.partos)) return;
  var p = db.partos.find(function(x){ return String(x.id) === String(partoId); });
  if (!p) { if (typeof toast === 'function') toast('Parto no encontrado', 'error'); return; }
  _reproPesarPartoId = partoId;

  var ctxEl = document.getElementById('repro-pesar-context');
  if (ctxEl) {
    ctxEl.innerHTML = 'Madre <b style="color:var(--text)">' + escH(p.madre_id || '?') + '</b> · ' +
      _reproPartoSexoLabel(p.sexo) + ' · ' + escH(p.lot_code || 's/lote') + ' · ' + _reproFmtDate(p.date);
  }
  // Precargar ID de cría existente (si lo tiene, distinto de N/A)
  var idInp = document.getElementById('repro-pesar-cria-id');
  if (idInp) idInp.value = (p.cria_id && p.cria_id !== 'N/A') ? p.cria_id : '';
  var inp = document.getElementById('repro-pesar-input');
  if (inp) inp.value = (p.peso && p.peso > 0) ? p.peso : '';
  openModal('modal-repro-pesar-parto');
  // Foco en el primer campo vacío
  setTimeout(function(){
    if (idInp && !idInp.value) idInp.focus();
    else if (inp) inp.focus();
  }, 100);
}

function _reproConfirmarPesarParto() {
  var partoId = _reproPesarPartoId;
  if (!partoId) { closeModal('modal-repro-pesar-parto'); return; }

  // ID de cría (opcional)
  var idInp = document.getElementById('repro-pesar-cria-id');
  var criaId = (idInp && idInp.value || '').trim();

  // Peso (opcional, pero si se ingresa debe ser válido)
  var inp = document.getElementById('repro-pesar-input');
  var pesoStr = (inp && inp.value || '').trim().replace(',', '.');
  var peso = null;
  if (pesoStr) {
    peso = parseFloat(pesoStr);
    if (isNaN(peso) || peso <= 0 || peso > 100) {
      if (typeof toast === 'function') toast('Peso inválido (debe ser un número entre 0 y 100 kg)', 'error');
      return;
    }
  }

  // Debe ingresar al menos uno de los dos
  if (!criaId && peso === null) {
    if (typeof toast === 'function') toast('Ingresá el ID de la cría y/o el peso', 'error');
    return;
  }

  if (!Array.isArray(db.partos)) return;
  var idx = db.partos.findIndex(function(x){ return String(x.id) === String(partoId); });
  if (idx === -1) { if (typeof toast === 'function') toast('Parto no encontrado', 'error'); closeModal('modal-repro-pesar-parto'); return; }
  var parto = db.partos[idx];
  var nowIso = new Date().toISOString();
  var criaIdViejo = parto.cria_id; // para encontrar el animal en e5m_animals

  var updates = { updated_at: nowIso };
  if (criaId) updates.cria_id = criaId;
  if (peso !== null) { updates.peso = peso; updates.peso_pendiente = false; }
  db.partos[idx] = Object.assign({}, parto, updates);

  // v1.8.20: sincronizar el animal correspondiente en e5m_animals
  try {
    var animDB = (typeof getAnimalesDB === 'function') ? getAnimalesDB() : null;
    if (animDB && parto.lot_code && animDB[parto.lot_code]) {
      var arr = animDB[parto.lot_code];
      // Matcheo robusto: 1) por parto_id (estable), 2) por cria_id viejo, 3) cría de esta madre origin=parto
      var aIdx = arr.findIndex(function(a){ return a.parto_id && String(a.parto_id) === String(parto.id); });
      if (aIdx === -1) {
        aIdx = arr.findIndex(function(a){
          var aid = String(a.animal_id || a.id || '');
          return aid === String(criaIdViejo) && criaIdViejo;
        });
      }
      if (aIdx === -1) {
        // Último recurso: cría de esta madre, mismo origin, sin parto_id asignado
        aIdx = arr.findIndex(function(a){
          return a.origin === 'parto' && String(a.madre_id||'') === String(parto.madre_id||'') &&
                 !a.parto_id && String(a.entry_date||'') === String(parto.date||'');
        });
      }
      if (aIdx !== -1) {
        // Asegurar el vínculo estable para futuras ediciones
        arr[aIdx].parto_id = parto.id;
        if (criaId) { arr[aIdx].animal_id = criaId; delete arr[aIdx].id; delete arr[aIdx]._needs_id; }
        if (peso !== null) {
          if (!Array.isArray(arr[aIdx].pesajes)) arr[aIdx].pesajes = [];
          var pjIdx = arr[aIdx].pesajes.findIndex(function(pj){ return pj.fecha === parto.date; });
          if (pjIdx !== -1) arr[aIdx].pesajes[pjIdx].peso = peso;
          else arr[aIdx].pesajes.push({ fecha: parto.date, peso: peso });
        }
        if (typeof saveAnimalesDB === 'function') saveAnimalesDB(animDB);
      } else {
        console.warn('[Repro] no se encontró el animal en e5m_animals para parto', parto.id);
      }
    }
  } catch(e) { console.warn('[Repro] sync e5m_animals al pesar', e); }

  try { localStorage.setItem(DB_KEY, JSON.stringify(db)); } catch(e) {}
  if (typeof saveDB === 'function') saveDB(true);
  closeModal('modal-repro-pesar-parto');
  _reproPesarPartoId = null;
  renderReproPartos();
  var msg = '✓ Registrado';
  if (criaId && peso !== null) msg = '✓ Cría ' + criaId + ' · ' + peso + ' kg';
  else if (criaId) msg = '✓ Cría ' + criaId + ' registrada';
  else if (peso !== null) msg = '✓ Peso registrado: ' + peso + ' kg';
  if (typeof toast === 'function') toast(msg, 'success');
}

// Abrir modal en modo edición — pre-llena con datos del parto existente
function openReproEditarParto(partoId) {
  if (!Array.isArray(db.partos)) return;
  var p = db.partos.find(function(x){ return String(x.id) === String(partoId); });
  if (!p) { if (typeof toast === 'function') toast('Parto no encontrado', 'error'); return; }

  // Llenar el modal manualmente (sin disparar populates que dependen de modo creación)
  document.getElementById('modal-repro-parto-title').textContent = '✎ Editar parto';
  document.getElementById('repro-parto-id').value = p.id;
  document.getElementById('repro-parto-servicio-id').value = p.servicio_id || '';
  document.getElementById('repro-parto-date').value = p.date || '';
  document.getElementById('repro-parto-padre').value = p.padre_id || '';
  document.getElementById('repro-parto-sexo').value = p.sexo || 'macho';
  document.getElementById('repro-parto-peso').value = (p.peso && p.peso > 0) ? p.peso : '';
  document.getElementById('repro-parto-estado').value = p.estado || 'sano';
  document.getElementById('repro-parto-cria-id').value = p.cria_id && p.cria_id !== 'N/A' ? p.cria_id : '';
  document.getElementById('repro-parto-notes').value = p.obs || '';

  // Poblar selectors y luego setear valores
  if (typeof _reproPartoPopulateMadres === 'function') _reproPartoPopulateMadres();
  if (typeof _reproPartoPopulateLoteSelector === 'function') _reproPartoPopulateLoteSelector();

  setTimeout(function(){
    // En edición la madre del select no estará en la lista de "preñadas no consumidas"
    // (porque ya generó este parto). Agregamos su opción a mano para mostrarla.
    var madreSel = document.getElementById('repro-parto-madre');
    if (madreSel && p.servicio_id) {
      var exists = Array.prototype.some.call(madreSel.options, function(o){ return o.value === p.servicio_id; });
      if (!exists) {
        var o = document.createElement('option');
        o.value = p.servicio_id;
        o.textContent = (p.madre_id || '?') + ' · servicio ' + (p.date || '?') + ' (este parto)';
        madreSel.appendChild(o);
      }
      madreSel.value = p.servicio_id;
    }
    var loteSel = document.getElementById('repro-parto-lote');
    if (loteSel) loteSel.value = p.lot_code || '';
    var contextEl = document.getElementById('repro-parto-context');
    if (contextEl) contextEl.innerHTML = 'Editando parto del <b>' + (p.date || '?') + '</b> · madre <b>' + (p.madre_id || '?') + '</b>';
  }, 60);

  openModal('modal-repro-parto');
}


