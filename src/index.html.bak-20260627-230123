function saveReproServicio() {
  var tipo = document.getElementById('repro-srv-tipo').value;
  var date = document.getElementById('repro-srv-date').value;
  var animalId = (document.getElementById('repro-srv-animal').value || '').trim();
  var loteCode = document.getElementById('repro-srv-lote').value || '';
  var semen = (document.getElementById('repro-srv-semen').value || '').trim();
  var technician = (document.getElementById('repro-srv-technician').value || '').trim();
  var toro = (document.getElementById('repro-srv-toro').value || '').trim();
  var notes = (document.getElementById('repro-srv-notes').value || '').trim();
  var id = document.getElementById('repro-srv-id').value;

  // Validación
  if (!date) { alert('Falta la fecha del servicio'); return; }
  if (!loteCode) { alert('Falta elegir el lote'); return; }
  if (!animalId) { alert('Falta identificar la vaca (caravana o ID)'); return; }
  if (tipo === 'IA') {
    if (!semen) { alert('Para IA: falta la pajuela / lote de semen'); return; }
    if (!technician) { alert('Para IA: falta el técnico / veterinario'); return; }
  }

  // Inferir paddock desde lote
  var paddock = '';
  if (loteCode && db && Array.isArray(db.lots)) {
    var lot = db.lots.find(function(l) { return l.code === loteCode; });
    if (lot) paddock = lot.paddock || lot.potrero || '';
  }

  var nowIso = new Date().toISOString();
  var existing = id ? _reproGetServicios().find(function(r) { return r.id === id; }) : null;

  var record = {
    id: id || _reproUuid(),
    tipo_servicio: tipo,
    animal_id: animalId,
    lot_code: loteCode,
    paddock: paddock,
    date: date,
    notes: notes,
    by: '',
    created_at: existing ? existing.created_at : nowIso,
    updated_at: nowIso,
    // Preservar diagnóstico existente al editar
    diagnosis_method: existing ? existing.diagnosis_method : null,
    diagnosis_date: existing ? existing.diagnosis_date : null,
    result: existing ? existing.result : 'pendiente'
  };
  if (tipo === 'IA') {
    record.semen_lote = semen;
    record.technician = technician;
    record.toro_id = null;
  } else {
    record.toro_id = toro || null;
    record.semen_lote = null;
    record.technician = null;
  }

  // Persistir en db
  if (!Array.isArray(db.reproductive_services)) db.reproductive_services = [];
  var idx = db.reproductive_services.findIndex(function(r) { return r.id === record.id; });
  if (idx >= 0) db.reproductive_services[idx] = record;
  else db.reproductive_services.push(record);

  // v1.8.75: si al editar el servicio cambió la vaca (animal_id), re-sincronizar la madre de los
  // partos ya vinculados a este servicio. Sin esto, el IEP y la genealogía por madre descuadraban.
  if (existing && existing.animal_id && existing.animal_id !== animalId && Array.isArray(db.partos)) {
    db.partos.forEach(function(p){
      if (String(p.servicio_id||'') === String(record.id) && String(p.madre_id||'') === String(existing.animal_id)) p.madre_id = animalId;
    });
  }

  try { localStorage.setItem(DB_KEY, JSON.stringify(db)); } catch(e) { console.error('[Repro] save localStorage', e); }

  // Push al server
  _reproPushServicio(record);

  closeModal('modal-repro-servicio');
  renderReproServicios();
}

function deleteReproServicio() {
  var id = document.getElementById('repro-srv-id').value;
  if (!id) return;
  var _depP = (db.partos||[]).filter(function(p){return String(p.servicio_id||'')===String(id);}).length;   // v1.8.75
  if (!confirm('¿Eliminar este servicio reproductivo?' + (_depP ? '\n\nHay ' + _depP + ' parto(s) vinculados a este servicio que quedarán huérfanos.' : '') + '\nEsta acción no se puede deshacer.')) return;
  if (!Array.isArray(db.reproductive_services)) return;
  var rec = db.reproductive_services.find(function(r) { return r.id === id; });
  db.reproductive_services = db.reproductive_services.filter(function(r) { return r.id !== id; });
  try { localStorage.setItem(DB_KEY, JSON.stringify(db)); } catch(e) {}
  // Tracking de borrado para sync
  if (typeof trackDeletion === 'function') {
    try { trackDeletion(id, 'reproductive_services'); } catch(e) { console.warn('[Repro] trackDeletion', e); }
  }
  // DELETE al server
  _reproDeleteServicio(id);
  closeModal('modal-repro-servicio');
  renderReproServicios();
}

function _reproPushServicio(record) {
  var apiUrl = (typeof getApiUrl === 'function') ? getApiUrl() : (localStorage.getItem('e5m_api_url') || 'https://estancia5m-api-production.up.railway.app/api');
  var token = localStorage.getItem('e5m_api_token') || '';
  if (!token) {
    console.log('[Repro] sin token, queda local — sync-push lo subirá luego');
    return;
  }
  fetch(apiUrl + '/reproductive-services', {
    method: 'POST',
    headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' },
    body: JSON.stringify(record)
  }).then(function(r) { return r.json(); })
    .then(function(resp) { console.log('[Repro] POST OK', resp && resp.id); })
    .catch(function(e) { console.warn('[Repro] POST fail (sync push retomará)', e); });
}

function _reproDeleteServicio(id) {
  var apiUrl = (typeof getApiUrl === 'function') ? getApiUrl() : (localStorage.getItem('e5m_api_url') || 'https://estancia5m-api-production.up.railway.app/api');
  var token = localStorage.getItem('e5m_api_token') || '';
  if (!token) return;
  fetch(apiUrl + '/reproductive-services/' + encodeURIComponent(id), {
    method: 'DELETE',
    headers: { 'Authorization': 'Bearer ' + token }
  }).then(function(r) { return r.json(); })
    .then(function(resp) { console.log('[Repro] DELETE OK', resp); })
    .catch(function(e) { console.warn('[Repro] DELETE fail', e); });
}

