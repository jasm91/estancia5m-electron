  if(listEl)listEl.innerHTML='<span style="color:var(--muted)">Cargando...</span>';
  fetch(apiUrl+'/cloud-backup/list',{headers:{'Authorization':'Bearer '+token}})
  .then(function(r){return r.json();})
  .then(function(list){
    if(!listEl)return;
    if(!list.length){listEl.innerHTML='<span style="color:var(--muted)">Sin snapshots guardados</span>';return;}
