}

function confirmBulkAnimals() {
  var lotCode = (document.getElementById('bulk-lot-select') || {}).value;
  var date = (document.getElementById('bulk-pesaje-date') || {}).value || today();
  if (!lotCode) { toast('Selecciona un lote destino', 'error'); return; }
  // FIX v1.4.34: no permitir fechas futuras
  if (!validateNotFuture(date, 'fecha del pesaje')) return;
  if (!_bulkAnimals.length) { toast('No hay animales para cargar', 'error'); return; }
  var lot = db.lots.find(function(l) { return l.code === lotCode; });
  if (!lot) { toast('Lote no encontrado', 'error'); return; }
  if (!confirm('Cargar ' + _bulkAnimals.length + ' animales al lote ' + lotCode + '?')) return;
  // Get or create animals DB
  var animalesDB = getAnimalesDB();
  if (!animalesDB[lotCode]) animalesDB[lotCode] = [];
  var existing = {};
  animalesDB[lotCode].forEach(function(a) { existing[String(a.id || a.animal_id || '')] = true; });
  var added = 0, skipped = 0;
  _bulkAnimals.forEach(function(a) {
    if (existing[a.id]) { skipped++; return; }
    var animal = {
      id: a.id,
      animal_id: a.id,
      raza: a.raza || '',
      breed: a.raza || '',
      pesajes: []
    };
    if (a.peso > 0) {
      animal.pesajes.push({ fecha: date, peso: a.peso, tipo: 'entrada', nota: 'Carga masiva' });
    }
    animalesDB[lotCode].push(animal);
    added++;
  });
  // Save animals
  localStorage.setItem('e5m_animals', JSON.stringify(animalesDB));
  // Update lot count
  lot.animal_count = animalesDB[lotCode].length;
  // Calculate avg weight
  var totalPeso = 0, conPeso = 0;
  animalesDB[lotCode].forEach(function(a) {
    if (a.pesajes && a.pesajes.length) { totalPeso += a.pesajes[a.pesajes.length - 1].peso; conPeso++; }
  });
  if (conPeso > 0) lot.avg_weight = Math.round(totalPeso / conPeso * 10) / 10;
  saveDB();
  // Push to Railway
  pushTableToRailway('animals', animalesDB);
  closeModal('modal-bulk-animals');
  renderLotes();
  toast('✅ ' + added + ' animales cargados al lote ' + lotCode + (skipped ? ' (' + skipped + ' duplicados omitidos)' : ''), 'success');
}

