  if (!items.length) {
    content.innerHTML = '<div style="text-align:center;padding:24px;color:var(--muted)">Sin registros asociados a este equipo</div>';
  } else {
    content.innerHTML = items.map(function(i){
      return '<div style="display:flex;gap:10px;padding:8px 0;border-bottom:1px solid rgba(48,54,61,.3)">'+
        '<div style="width:28px;height:28px;border-radius:6px;background:var(--sur2);display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0">'+i.icon+'</div>'+
        '<div style="flex:1"><div style="display:flex;justify-content:space-between"><span style="font-weight:600;font-size:12px;color:'+i.color+'">'+escH(i.title)+'</span><span style="font-size:10px;color:var(--muted);font-family:DM Mono,monospace">'+fmtDT(i.date)+'</span></div>'+(i.sub?'<div style="font-size:10px;color:var(--muted)">'+escH(i.sub)+'</div>':'')+'</div>'+
      '</div>';
    }).join('');
  }
  openModal('modal-maq-historial');
}

function renderDieselDesktop() {
