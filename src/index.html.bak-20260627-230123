// ─── Semáforo: clasificar KPI vs objetivo ─────────────────────
// dir = 'higher' (mayor es mejor: preñez, parición) o 'lower' (menor es mejor: IEP, SC)
function _reproSemaforo(actual, objetivo, dir) {
  if (actual == null || objetivo == null) return { level: 'none', label: 'sin datos', color: 'var(--muted)' };
  var delta = dir === 'higher' ? (actual - objetivo) : (objetivo - actual);
  var ratio = Math.abs(delta) / objetivo;
  if (delta >= 0) {
    // En o sobre objetivo
    if (ratio < 0.05) return { level: 'bueno', label: '✓ Bueno', color: 'var(--green)' };
    return { level: 'excelente', label: '✓ Excelente', color: 'var(--green)' };
  } else {
    // Bajo objetivo
    if (ratio <= 0.05) return { level: 'bueno', label: '✓ Bueno', color: 'var(--green)' };
    if (ratio <= 0.15) return { level: 'atencion', label: '⚠ Atención', color: 'var(--amber)' };
    return { level: 'bajo', label: '✗ Bajo', color: 'var(--red)' };
  }
}

function _reproSemaforoBar(actual, objetivo, dir) {
  // Devuelve % width 0-100 para la barra de progreso
  if (actual == null || objetivo == null) return 0;
  if (dir === 'higher') {
    var p = (actual / objetivo) * 100;
    return Math.min(100, Math.max(0, p));
  } else {
    // Menor es mejor: si actual <= objetivo → 100%; si peor, escala
    if (actual <= objetivo) return 100;
    var penalty = ((actual - objetivo) / objetivo) * 100;
    return Math.max(0, 100 - penalty);
  }
}

function _reproSemaforoPill(sem) {
  var bgMap = {
    excelente: 'rgba(63,185,80,.18)',
    bueno: 'rgba(63,185,80,.12)',
    atencion: 'rgba(212,160,23,.18)',
    bajo: 'rgba(248,81,73,.18)',
    none: 'rgba(255,255,255,.05)'
  };
  return '<span style="background:' + (bgMap[sem.level] || bgMap.none) + ';color:' + sem.color + ';font-size:11px;padding:3px 8px;border-radius:10px;white-space:nowrap">' + sem.label + '</span>';
}

// ─── Cómputo KPIs globales y por lote ─────────────────────────
function _reproIndicadoresCompute(periodoMonths) {
  var todos = _reproGetServicios();
  var partos = _reproGetPartos();

  // Filtrar por período si aplica
  var servicios = periodoMonths ? _reproFilterPeriodo(todos, periodoMonths) : todos.slice();
  var partosF = periodoMonths ? _reproPartosFilterPeriodo(partos, periodoMonths) : partos.slice();

  // KPI global tasa preñez
  var efectivos = servicios.filter(function(s) { return s.result === 'preñada' || s.result === 'vacia'; });
  var prenadas = servicios.filter(function(s) { return s.result === 'preñada'; });
  var prenezPct = efectivos.length > 0 ? Math.round((prenadas.length / efectivos.length) * 100) : null;

  // KPI S/C global
  var uniqPrenadas = {};
  servicios.forEach(function(s) {
    if (s.result === 'preñada' && s.animal_id) uniqPrenadas[s.animal_id] = true;
  });
  var uniqCount = Object.keys(uniqPrenadas).length;
  var sc = uniqCount > 0 ? (servicios.length / uniqCount) : null;

  // KPI IEP global
  var byMadre = {};
  partosF.forEach(function(p) {
    if (!p.madre_id || !p.date) return;
    if (!byMadre[p.madre_id]) byMadre[p.madre_id] = [];
    byMadre[p.madre_id].push(new Date(p.date));
  });
  var intervalos = [];
  Object.keys(byMadre).forEach(function(m) {
    var dates = byMadre[m].sort(function(a, b) { return a - b; });
    for (var i = 1; i < dates.length; i++) {
      var diff = Math.round((dates[i] - dates[i-1]) / 86400000);
      if (diff > 200 && diff < 600) intervalos.push(diff);
    }
  });
  var iep = intervalos.length > 0 ?
    Math.round(intervalos.reduce(function(s, x) { return s + x; }, 0) / intervalos.length) : null;

  // KPI % parición: partos del período / preñadas confirmadas del período anterior equivalente
  // Aproximación práctica: partos del período / preñadas confirmadas en el mismo período
  // (más estable para períodos chicos)
  var paricionPct = prenadas.length > 0 ? Math.round((partosF.length / prenadas.length) * 100) : null;

  // Por lote — v1.8.15: excluir cuarentena/marcado/fusionado/vendido/CUAR-xxx (igual que resto del módulo)
  var lots = (db && Array.isArray(db.lots)) ? db.lots : [];
  var perLot = lots.filter(function(l) {
    var s = (l.status || '').toLowerCase();
    if (s === 'sold' || s === 'vendido' || s === 'fusionado' || s === 'merged') return false;
    if (s === 'cuarentena' || s === 'marcado' || s === 'marcado_completo' || s === 'inactivo') return false;
    if (/^CUAR-\d+$/i.test(l.code || '')) return false;
    return true;
  }).map(function(l) {
    var srvLot = servicios.filter(function(s) { return s.lot_code === l.code; });
    var partLot = partosF.filter(function(p) { return p.lot_code === l.code; });
    var efL = srvLot.filter(function(s) { return s.result === 'preñada' || s.result === 'vacia'; });
    var prL = srvLot.filter(function(s) { return s.result === 'preñada'; });
    var prenezLot = efL.length > 0 ? Math.round((prL.length / efL.length) * 100) : null;
    var uniqL = {};
    srvLot.forEach(function(s) { if (s.result === 'preñada' && s.animal_id) uniqL[s.animal_id] = true; });
    var uCount = Object.keys(uniqL).length;
    var scLot = uCount > 0 ? Math.round((srvLot.length / uCount) * 100) / 100 : null;
    var byMadreLot = {};
    partLot.forEach(function(p) {
      if (!p.madre_id || !p.date) return;
      if (!byMadreLot[p.madre_id]) byMadreLot[p.madre_id] = [];
      byMadreLot[p.madre_id].push(new Date(p.date));
    });
    var intLot = [];
    Object.keys(byMadreLot).forEach(function(m) {
      var dates = byMadreLot[m].sort(function(a, b) { return a - b; });
      for (var i = 1; i < dates.length; i++) {
        var diff = Math.round((dates[i] - dates[i-1]) / 86400000);
        if (diff > 200 && diff < 600) intLot.push(diff);
      }
    });
    var iepLot = intLot.length > 0 ?
      Math.round(intLot.reduce(function(s, x) { return s + x; }, 0) / intLot.length) : null;
    return {
      code: l.code,
      animal_count: l.animal_count || 0,
      servicios: srvLot.length,
      partos: partLot.length,
      prenez: prenezLot,
      sc: scLot,
      iep: iepLot
    };
  });

  return { prenezPct: prenezPct, sc: sc, iep: iep, paricionPct: paricionPct, perLot: perLot, periodoMonths: periodoMonths };
}

function _reproIndScoreLote(row, obj) {
  // Devuelve el peor semáforo (excelente/bueno/atencion/bajo) entre los 3 KPIs presentes
  var rank = { excelente: 3, bueno: 2, atencion: 1, bajo: 0, none: 4 };
  var sems = [];
  if (row.prenez != null) sems.push(_reproSemaforo(row.prenez, obj.prenez_pct, 'higher'));
  if (row.sc != null) sems.push(_reproSemaforo(row.sc, obj.sc_max, 'lower'));
  if (row.iep != null) sems.push(_reproSemaforo(row.iep, obj.iep_dias, 'lower'));
  if (!sems.length) return { level: 'none', label: 'sin datos', color: 'var(--muted)' };
  // Mínimo (peor)
  return sems.reduce(function(prev, cur) {
    return (rank[cur.level] || 4) < (rank[prev.level] || 4) ? cur : prev;
  });
}

// ─── Render Indicadores ───────────────────────────────────────
function renderReproIndicadores() {
  var periodoFEl = document.getElementById('repro-ind-filter-periodo');
  var periodoF = periodoFEl ? (parseInt(periodoFEl.value, 10) || 0) : 12;
  var ind = _reproIndicadoresCompute(periodoF);
  var obj = _reproGetObjetivos();

  // Label período
  var lblEl = document.getElementById('repro-ind-period-label');
  if (lblEl) {
    lblEl.textContent = periodoF ? ('últimos ' + periodoF + ' meses') : 'todo el historial';
  }

  // KPI cards
  var el = function(id) { return document.getElementById(id); };

  // Preñez
  var semPrenez = _reproSemaforo(ind.prenezPct, obj.prenez_pct, 'higher');
  el('repro-kpi-prenez').textContent = ind.prenezPct != null ? (ind.prenezPct + '%') : '—';
  el('repro-kpi-prenez').style.color = semPrenez.color;
  el('repro-kpi-prenez-obj').textContent = 'obj ' + obj.prenez_pct + '%';
  el('repro-kpi-prenez-bar').style.width = _reproSemaforoBar(ind.prenezPct, obj.prenez_pct, 'higher') + '%';
  el('repro-kpi-prenez-status').textContent = semPrenez.label;
  el('repro-kpi-prenez-status').style.color = semPrenez.color;

  // IEP
  var semIep = _reproSemaforo(ind.iep, obj.iep_dias, 'lower');
  el('repro-kpi-iep').innerHTML = ind.iep != null ? (ind.iep + ' <span style="font-size:12px;color:var(--muted);font-weight:400">d</span>') : '—';
  el('repro-kpi-iep').style.color = semIep.color;
  el('repro-kpi-iep-obj').textContent = 'obj ≤' + obj.iep_dias + 'd';
  el('repro-kpi-iep-bar').style.width = _reproSemaforoBar(ind.iep, obj.iep_dias, 'lower') + '%';
  el('repro-kpi-iep-status').textContent = semIep.label;
  el('repro-kpi-iep-status').style.color = semIep.color;

  // S/C
  var semSc = _reproSemaforo(ind.sc, obj.sc_max, 'lower');
  el('repro-kpi-sc').textContent = ind.sc != null ? ind.sc.toFixed(2) : '—';
  el('repro-kpi-sc').style.color = semSc.color;
  el('repro-kpi-sc-obj').textContent = 'obj ≤' + obj.sc_max;
  el('repro-kpi-sc-bar').style.width = _reproSemaforoBar(ind.sc, obj.sc_max, 'lower') + '%';
  el('repro-kpi-sc-status').textContent = semSc.label;
  el('repro-kpi-sc-status').style.color = semSc.color;

  // Parición
  var semPar = _reproSemaforo(ind.paricionPct, obj.paricion_pct, 'higher');
  el('repro-kpi-paricion').textContent = ind.paricionPct != null ? (ind.paricionPct + '%') : '—';
  el('repro-kpi-paricion').style.color = semPar.color;
  el('repro-kpi-paricion-obj').textContent = 'obj ' + obj.paricion_pct + '%';
  el('repro-kpi-paricion-bar').style.width = _reproSemaforoBar(ind.paricionPct, obj.paricion_pct, 'higher') + '%';
  el('repro-kpi-paricion-status').textContent = semPar.label;
  el('repro-kpi-paricion-status').style.color = semPar.color;

  // Tabla por lote
  var tbody = el('repro-ind-tbody');
  if (!tbody) return;
  if (!ind.perLot.length) {
    tbody.innerHTML = '<tr><td colspan="8" style="text-align:center;padding:30px;color:var(--muted);font-size:12px">No hay lotes activos para mostrar</td></tr>';
    return;
  }

  // Ordenar por estado: peores primero
  var rank = { bajo: 0, atencion: 1, none: 2, bueno: 3, excelente: 4 };
  var rows = ind.perLot.map(function(r) {
    r._sem = _reproIndScoreLote(r, obj);
    return r;
  }).sort(function(a, b) { return (rank[a._sem.level] || 5) - (rank[b._sem.level] || 5); });

  tbody.innerHTML = rows.map(function(r) {
    return '<tr>' +
      '<td style="font-family:DM Mono,monospace;font-size:11.5px"><b>' + r.code + '</b></td>' +
      '<td style="font-family:DM Mono,monospace;font-size:11.5px">' + r.animal_count + '</td>' +
      '<td style="font-family:DM Mono,monospace;font-size:11.5px">' + r.servicios + '</td>' +
      '<td style="font-family:DM Mono,monospace;font-size:11.5px">' + r.partos + '</td>' +
      '<td style="font-family:DM Mono,monospace;font-size:11.5px;color:' + _reproSemaforo(r.prenez, obj.prenez_pct, 'higher').color + '">' +
        (r.prenez != null ? (r.prenez + '%') : '<span style="color:var(--muted)">—</span>') + '</td>' +
      '<td style="font-family:DM Mono,monospace;font-size:11.5px;color:' + _reproSemaforo(r.sc, obj.sc_max, 'lower').color + '">' +
        (r.sc != null ? r.sc : '<span style="color:var(--muted)">—</span>') + '</td>' +
      '<td style="font-family:DM Mono,monospace;font-size:11.5px;color:' + _reproSemaforo(r.iep, obj.iep_dias, 'lower').color + '">' +
        (r.iep != null ? (r.iep + 'd') : '<span style="color:var(--muted)">—</span>') + '</td>' +
      '<td>' + _reproSemaforoPill(r._sem) + '</td>' +
      '</tr>';
  }).join('');
}

// ─── Export Indicadores ──────────────────────────────────────
function exportReproIndicadores() {
  if (typeof exportCSV !== 'function') { alert('Función de export no disponible'); return; }
  var periodoFEl = document.getElementById('repro-ind-filter-periodo');
  var periodoF = periodoFEl ? (parseInt(periodoFEl.value, 10) || 0) : 12;
  var ind = _reproIndicadoresCompute(periodoF);
  var obj = _reproGetObjetivos();

  if (!ind.perLot.length) {
    if (typeof toast === 'function') toast('Sin datos para exportar', 'error');
    else alert('Sin datos para exportar');
    return;
  }

  var rows = ind.perLot.map(function(r) {
    var sem = _reproIndScoreLote(r, obj);
    return [
      r.code, r.animal_count, r.servicios, r.partos,
      r.prenez != null ? r.prenez + '%' : '',
      r.sc != null ? r.sc : '',
      r.iep != null ? r.iep : '',
      sem.label.replace(/[✓✗⚠]/g, '').trim()
    ];
  });

  // KPIs globales como fila final
  rows.push(['', '', '', '', '', '', '', '']);
  rows.push(['TOTAL', '', '', '', ind.prenezPct != null ? ind.prenezPct + '%' : '',
    ind.sc != null ? ind.sc.toFixed(2) : '', ind.iep != null ? ind.iep : '', '']);
  rows.push(['Objetivo', '', '', '', obj.prenez_pct + '%', obj.sc_max, '≤' + obj.iep_dias + 'd', '']);

  exportCSV('indicadores_reproductivos_estanciapro',
    ['Lote', 'Vacas', 'Servicios', 'Partos', '% Prenez', 'Serv/Concepcion', 'IEP dias', 'Estado'],
    rows);
}

