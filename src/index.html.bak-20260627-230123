  html += '<div style="font-size:11px;color:var(--muted);margin-bottom:8px">Detalle por rubro:</div>';
  html += '<div style="overflow-x:auto"><table class="tbl"><thead><tr><th>Rubro</th><th>Total (Bs)</th><th>% Total</th><th>Por Ha</th><th>Por Cab</th></tr></thead><tbody>';
  gastos.forEach(function(g) {
    var pct = gastTotales > 0 ? Math.round(g.total / gastTotales * 1000) / 10 : 0;
    html += '<tr><td>' + g.rubro + '</td><td style="font-family:DM Mono;font-weight:600">Bs. ' + Math.round(g.total).toLocaleString() + '</td><td style="font-family:DM Mono">' + pct + '%</td><td style="font-family:DM Mono">' + (ha > 0 ? Math.round(g.total / ha) : 0) + '</td><td style="font-family:DM Mono">' + (existMedia > 0 ? Math.round(g.total / existMedia) : 0) + '</td></tr>';
  });
  html += '<tr style="font-weight:700;border-top:2px solid var(--bor)"><td>TOTAL</td><td style="font-family:DM Mono;color:var(--amber2)">Bs. ' + Math.round(gastTotales).toLocaleString() + '</td><td>100%</td><td style="font-family:DM Mono;color:var(--amber2)">' + (ha > 0 ? Math.round(gastTotales / ha) : 0) + '</td><td style="font-family:DM Mono;color:var(--amber2)">' + (existMedia > 0 ? Math.round(gastTotales / existMedia) : 0) + '</td></tr>';
  html += '</tbody></table></div>';

  // Guardar datos para los charts (se renderizan después de innerHTML)
  window._creaGastosData = { gastos: gastos, totalOperativos: totalOperativos, hayCompras: hayCompras };

  // INDICADORES OPERATIVOS
  html += '<div style="font-size:14px;font-weight:700;color:var(--amber2);margin:20px 0 10px;border-bottom:1px solid var(--bor);padding-bottom:6px">📌 Indicadores Operativos del Período</div>';
  html += '<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:10px;margin-bottom:16px">';
  html += kpi('Partos', partosPeriodo, 'en el período', '', 'var(--green)');
  html += kpi('Lluvia Acumulada', Math.round(lluviaPeriodo), 'mm', '', 'var(--blue)');
  html += kpi('Consumo Diesel', Math.round(dieselLitros).toLocaleString(), 'litros', '', 'var(--amber)');
  html += kpi('Sal / Cab', salPorCab, 'kg / cab', 'sal total ÷ exist. media', 'var(--amber)');
  html += kpi('Tratamientos', tratamientosPeriodo, 'aplicaciones', '', 'var(--green)');
  html += kpi('Conteos', conteosPeriodo, 'realizados', '', 'var(--blue)');
  html += kpi('Cab. Compradas', cabCompradas, 'cabezas (' + Math.round(kgComprados).toLocaleString() + ' kg)', '', 'var(--amber)');
  html += kpi('Cab. Vendidas', cabVendidas, 'cabezas (' + Math.round(kgVendidos).toLocaleString() + ' kg)', '', 'var(--green)');
  html += '</div>';

