// FIX v1.4.37: rediseño de renderRotacion
// - KPI header: 4 contadores (Ocupados, Listos, Descansando, A rotar)
// - Jerarquía: acción inmediata → listos → ocupados → descansando agrupado
// - Inferencia automática de zonas por afinidad de palabras del nombre
//   (override opcional via p.zone si está definida en config)
// - Descansando colapsado por zona, chips compactos
// ═══════════════════════════════════════════════════════════════

// Helper: infiere zona del nombre del potrero o usa p.zone si está definida.
// Reglas:
//   1. Si p.zone está definida → ese gana
//   2. Si no, primera palabra del nombre que no sea genérica
//   3. Si la primera es genérica (Lote, Potrero, Sector, Campo, Pradera, Corral) → segunda palabra
//   4. Si nada califica → 'Otros'
function inferZone(p) {
  if (p.zone && String(p.zone).trim()) return String(p.zone).trim();
  var name = String(p.name || '').trim();
  if (!name) return 'Otros';
  // Limpiar separadores y números aislados
  var palabras = name.split(/[\s\-\:\/]+/).filter(function(w){
    return w && !/^\d+$/.test(w);
  });
  if (palabras.length === 0) return 'Otros';
  var GENERICAS = ['lote','potrero','sector','campo','pradera','corral','area','area'];
  var primera = palabras[0];
  if (primera.length < 4 || GENERICAS.indexOf(primera.toLowerCase()) >= 0) {
    return palabras[1] || 'Otros';
  }
  return primera;
}

function renderRotacion() {
  var el = document.getElementById('rotacion-content');
  if (!el) return;
  var params = typeof getParams==='function' ? getParams() : {potreros:[]};
  var potreros = params.potreros || [];
  if (!potreros.length) {
    el.innerHTML = '<div style="text-align:center;padding:30px;color:var(--muted)"><div style="font-size:28px;margin-bottom:8px">📍</div>No hay potreros configurados. Ve a Config > Parámetros para agregarlos.</div>';
    return;
  }
  var history = db.rotation_history || [];
  var lots = db.lots || [];
  var today = new Date();

  // v1.4.103 FIX A: detectar lotes activos con paddock asignado pero SIN entry abierto
  // en rotation_history. Esto pasa cuando:
  //   - Bot v5.5.1 hace lot_split y crea sub-lote con paddock heredado del padre,
  //     pero no inserta entry de rotation_history para el sub-lote.
  //   - Migraciones antiguas o lotes editados manualmente sin pasar por moveLot.
  // Solución temporal: crear entries "virtuales" en memoria (no se persisten en db.rotation_history).
  // Solución de raíz: server v4.5.1 + bot que cree el entry en lot_split (FIX C, pendiente).
  //
  // v1.4.106 FIX: NO crear entry virtual si el lote ya tiene ALGUNA entry abierta en CUALQUIER potrero.
  // Antes solo chequeaba si tenía entry abierta en lot.paddock, pero si lot.paddock estaba desincronizado
  // del rotation_history (caso: bot rotó server-side pero Desktop pull no reflejó el nuevo paddock),
  // se creaba una entry virtual en el potrero viejo, mostrando el lote en 2 lugares.
  // Lección: rotation_history es la fuente de verdad para vista de Rotación, no lot.paddock.
  var historyAugmented = history.slice();
  lots.forEach(function(l) {
    if (!l || !l.code || !l.paddock) return;
    var lotStatus = String(l.status || '').toLowerCase();
    if (lotStatus === 'vendido' || lotStatus === 'sold' || lotStatus === 'inactivo' || lotStatus === 'inactive') return;
    if ((l.animal_count || 0) === 0) return;
    // v1.4.106 FIX: chequear si hay entry abierta en CUALQUIER potrero, no solo en l.paddock.
    // Si la hay (aunque sea en otro potrero — caso: lot.paddock desincronizado tras rotación bot),
    // rotation_history es la verdad y NO creamos entry virtual.
    var hasOpenEntryAnywhere = history.some(function(r) {
      return r && r.lot_code === l.code && !r.exit_date;
    });
    if (hasOpenEntryAnywhere) return;
    var entryDate = (l.cost_origin && l.cost_origin.date) || l.entry_date || (today.toISOString().slice(0,10));
    historyAugmented.push({
      lot_code: l.code,
      potrero: l.paddock,
      entry_date: entryDate,
      exit_date: null,
      cabezas: l.animal_count || 0,
      _virtual: true,
      _reason: 'auto-detected-from-lot-paddock'
    });
  });

  // v1.4.106: dedupe defensivo. Si por algún motivo (race con sync, backfill cruzado, etc)
  // entraron entries duplicadas (mismo lot+paddock con exit_date=null), mostramos UNA SOLA:
  // la más vieja (la real). Las nuevas se ignoran a presentación. Esto evita el conteo
  // inflado de "11/30 días" + "1/30 días" que se veía cuando hay duplicados.
  // Estrategia en 2 pasos:
  //   1) Encontrar la entry abierta más vieja para cada key (lot_code|potrero)
  //   2) Filtrar history dejando esa más vieja + todas las cerradas
  var oldestOpenByKey = {};
  historyAugmented.forEach(function(r) {
    if (!r || r.exit_date) return;
    var key = r.lot_code + '|' + r.potrero;
    var ts = String(r.entry_at || r.entry_date || '');
    if (!oldestOpenByKey[key]) { oldestOpenByKey[key] = { entry: r, ts: ts }; return; }
    if (ts && ts < oldestOpenByKey[key].ts) { oldestOpenByKey[key] = { entry: r, ts: ts }; }
  });
  history = historyAugmented.filter(function(r) {
    if (!r) return false;
    if (r.exit_date) return true;
    var key = r.lot_code + '|' + r.potrero;
    return oldestOpenByKey[key] && oldestOpenByKey[key].entry === r;
  });

  // ─── Procesar cada potrero ────────────────────────────────
  // FIX v1.4.50: soportar MÚLTIPLES lotes en el mismo potrero.
  // FIX v1.4.69: filtrar lotes vendidos / inactivos / con 0 cab que dejaron entry abierta
  //              en rotation_history. La venta no siempre cierra el entry, así que
  //              acá nos protegemos para que un potrero "Vendido" no aparezca como ocupado.
  // Antes: .find() devolvía solo UN entry y los demás lotes desaparecían.
  // Ahora: .filter() acumula todos los lotes activos en `currentLots`.
  // entry_date del potrero = MIN de los lotes; daysOccupied se calcula desde ahí.
  var enriched = potreros.map(function(p) {
    var allEntries = history.filter(function(r) { return r.potrero === p.name && !r.exit_date; });

    // v1.4.69: filtrar entries cuyo lote esté vendido o inactivo
    var activeEntries = allEntries.filter(function(ae) {
      var lotObj = lots.find(function(l){ return l.code === ae.lot_code; });
      if (!lotObj) return false;                                          // lote borrado
      var status = String(lotObj.status || '').toLowerCase();
      if (status === 'vendido' || status === 'sold' || status === 'inactivo' || status === 'inactive') return false;
      // Si el lote sigue activo pero su animal_count está en 0, también se filtra
      // (ej: cuarentena vacía que se reutilizó como destino y nunca se cerró el entry).
      if ((lotObj.animal_count || 0) === 0) return false;
      return true;
    });

    var isOccupied = activeEntries.length > 0;

    // Acumular lotes activos en el potrero con sus datos individuales
    var currentLots = activeEntries.map(function(ae) {
      var lotObj = lots.find(function(l){ return l.code === ae.lot_code; });
      var cab = (lotObj && lotObj.animal_count) || ae.cabezas || 0;
      var lotDays = 0;
      if (ae.entry_date) {
        lotDays = Math.max(1, Math.round((today - new Date(ae.entry_date)) / 86400000));
      }
      return {
        code: ae.lot_code,
        cab: cab,
        days_occupied: lotDays,
        entry_date: ae.entry_date,
        lot_obj: lotObj || null
      };
    });

    // Totales del potrero
    var currentCab = currentLots.reduce(function(s, cl){ return s + (cl.cab || 0); }, 0);

    // Entry date del potrero = MIN de los lotes (el primero que entró marca la ocupación)
    var earliestEntry = null;
    activeEntries.forEach(function(ae) {
      if (ae.entry_date) {
        if (!earliestEntry || ae.entry_date < earliestEntry) earliestEntry = ae.entry_date;
      }
    });
    var daysOccupied = 0;
    if (isOccupied && earliestEntry) {
      daysOccupied = Math.max(1, Math.round((today - new Date(earliestEntry)) / 86400000));
    }
    var maxOcc = p.max_occupation_days || 30;
    var occPct = Math.min(100, Math.round(daysOccupied / maxOcc * 100));

    // Exit date: MAX de todas las salidas (la última)
    var lastExit = null;
    if (!isOccupied) {
      var exits = history.filter(function(r) { return r.potrero === p.name && r.exit_date; });
      if (exits.length) {
        exits.sort(function(a,b) { return (b.exit_date||'').localeCompare(a.exit_date||''); });
        lastExit = exits[0];
      }
    }
    var daysResting = 0;
    if (!isOccupied && lastExit && lastExit.exit_date) {
      daysResting = Math.max(0, Math.round((today - new Date(lastExit.exit_date)) / 86400000));
    }
    var minRest = p.rest_days || 30;
    var isReady = !isOccupied && daysResting >= minRest;
    var isOverdue = isOccupied && daysOccupied > maxOcc;
    var capPct = p.capacity ? Math.round(currentCab / p.capacity * 100) : 0;
    var isOverCap = p.capacity && currentCab > p.capacity;

    var status = isOverdue ? 'overdue' : isOccupied ? 'occupied' : isReady ? 'ready' : 'resting';

    // Legacy fields (mantener para compatibilidad con código que no se actualizó):
    // currentLot/currentCab para casos de 1 solo lote (caso más común)
    var currentLot = currentLots.length === 1 ? currentLots[0].code : (currentLots.length > 1 ? '(' + currentLots.length + ' lotes)' : null);

    return {
      p: p, zone: inferZone(p),
      status: status, isOccupied: isOccupied, isOverdue: isOverdue, isReady: isReady,
      currentLot: currentLot, currentCab: currentCab,
      currentLots: currentLots,  // ← nuevo: array completo con todos los lotes del potrero
      daysOccupied: daysOccupied, maxOcc: maxOcc, occPct: occPct,
      daysResting: daysResting, minRest: minRest,
      capPct: capPct, isOverCap: isOverCap
    };
  });

  // ─── Reagrupar zonas con 1 potrero a "Otros" ──────────────
  var zoneCounts = {};
  enriched.forEach(function(e){ zoneCounts[e.zone] = (zoneCounts[e.zone]||0) + 1; });
  enriched.forEach(function(e){ if (zoneCounts[e.zone] === 1) e.zone = 'Otros'; });

  // ─── Separar por status ───────────────────────────────────
  var overdueList = enriched.filter(function(e){ return e.status === 'overdue'; });
  var readyList = enriched.filter(function(e){ return e.status === 'ready'; });
  var occupiedList = enriched.filter(function(e){ return e.status === 'occupied'; });
  var restingList = enriched.filter(function(e){ return e.status === 'resting'; });
  var totalCabOccupied = occupiedList.concat(overdueList).reduce(function(s,e){ return s + (e.currentCab||0); }, 0);

  var html = '';

  // ─── KPI HEADER ───────────────────────────────────────────
  html += '<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:14px">';
  html += '<div style="background:var(--sur2);border-radius:8px;padding:10px 12px"><div style="font-size:11px;color:var(--muted);margin-bottom:2px">Ocupados</div><div style="font-size:20px;font-weight:600;color:var(--amber2)">'+(occupiedList.length + overdueList.length)+'</div></div>';
  html += '<div style="background:var(--sur2);border-radius:8px;padding:10px 12px"><div style="font-size:11px;color:var(--muted);margin-bottom:2px">Listos</div><div style="font-size:20px;font-weight:600;color:var(--green)">'+readyList.length+'</div></div>';
  html += '<div style="background:var(--sur2);border-radius:8px;padding:10px 12px"><div style="font-size:11px;color:var(--muted);margin-bottom:2px">Descansando</div><div style="font-size:20px;font-weight:600">'+restingList.length+'</div></div>';
  html += '<div style="background:'+(overdueList.length?'rgba(229,75,75,.08)':'var(--sur2)')+';border-radius:8px;padding:10px 12px"><div style="font-size:11px;color:'+(overdueList.length?'var(--red)':'var(--muted)')+';margin-bottom:2px">A rotar</div><div style="font-size:20px;font-weight:600;color:'+(overdueList.length?'var(--red)':'var(--muted)')+'">'+overdueList.length+'</div></div>';
  html += '</div>';

  // ─── ACCIÓN INMEDIATA (overdue) ──────────────────────────
  // FIX v1.4.50: si hay múltiples lotes en el potrero, mostrar todos
  if (overdueList.length) {
    html += '<div style="margin-bottom:14px">';
    html += '<div style="display:flex;align-items:center;gap:6px;margin-bottom:6px"><span style="font-size:12px">⚠️</span><span style="font-size:11px;font-weight:700;color:var(--red);text-transform:uppercase;letter-spacing:.5px">Acción inmediata</span></div>';
    overdueList.forEach(function(e){
      var hasMultiple = e.currentLots && e.currentLots.length > 1;
      html += '<div style="background:rgba(229,75,75,.08);border-left:4px solid var(--red);border-radius:0 8px 8px 0;padding:12px 14px;margin-bottom:6px">';
      // Header del potrero
      html += '<div style="display:flex;justify-content:space-between;align-items:start;gap:12px;'+(hasMultiple?'margin-bottom:8px;padding-bottom:8px;border-bottom:1px solid rgba(229,75,75,.2)':'')+'">';
      html += '<div style="flex:1;min-width:0">';
      html += '<div style="font-size:15px;font-weight:700">'+escH(e.p.name)+'</div>';
      if (hasMultiple) {
        html += '<div style="font-size:12px;color:var(--red);margin-top:2px">'+e.currentLots.length+' lotes · '+e.currentCab+' cab total · '+e.daysOccupied+'/'+e.maxOcc+' días ocupado</div>';
      } else if (e.currentLots && e.currentLots.length === 1) {
        var cl0 = e.currentLots[0];
        html += '<div style="font-size:12px;color:var(--red);margin-top:2px"><b>'+escH(cl0.code||'')+'</b> · '+cl0.cab+' cab · '+e.daysOccupied+'/'+e.maxOcc+' días ocupado</div>';
      }
      html += '<div style="font-size:11px;color:var(--red);margin-top:4px">Excedido por '+(e.daysOccupied-e.maxOcc)+' días — riesgo de degradación del pasto</div>';
      if (e.isOverCap) html += '<div style="font-size:11px;color:var(--red);margin-top:2px">Sobrecarga: '+e.currentCab+'/'+e.p.capacity+' cab ('+e.capPct+'%)</div>';
      html += '</div>';
      // Si hay 1 solo lote, el botón "Rotar" va al lado del header
      if (!hasMultiple && e.currentLots && e.currentLots.length === 1) {
        html += '<button class="btn btn-sm" style="background:var(--red);color:#fff;border:none;white-space:nowrap" onclick="abrirMoverLote(\''+escH(e.currentLots[0].code||'')+'\')">Rotar lote →</button>';
      }
      html += '</div>';

      // Sub-líneas con botón "Rotar →" por cada lote si hay múltiples
      if (hasMultiple) {
        e.currentLots.forEach(function(cl, idx){
          var isLast = idx === e.currentLots.length - 1;
          html += '<div style="padding:6px 0 6px 12px;display:grid;grid-template-columns:1fr 100px 90px;gap:12px;align-items:center;'+(!isLast?'border-bottom:1px dashed rgba(229,75,75,.15)':'')+'">';
          html += '<div style="font-size:12px"><b>'+escH(cl.code||'')+'</b> <span style="color:var(--red);opacity:.8">· '+cl.cab+' cab</span></div>';
          html += '<div style="font-size:10px;color:var(--red);opacity:.7">'+cl.days_occupied+' días en lote</div>';
          html += '<button class="btn btn-sm" style="background:var(--red);color:#fff;border:none;font-size:11px;padding:4px 8px" onclick="abrirMoverLote(\''+escH(cl.code||'')+'\')">Rotar →</button>';
          html += '</div>';
        });
      }
      html += '</div>';
    });
    html += '</div>';
  }

  // ─── LISTOS PARA RECIBIR GANADO ──────────────────────────
  if (readyList.length) {
    html += '<div style="margin-bottom:14px">';
    html += '<div style="display:flex;align-items:center;gap:6px;margin-bottom:6px">';
    html += '<span style="font-size:12px">✅</span><span style="font-size:11px;font-weight:700;color:var(--green);text-transform:uppercase;letter-spacing:.5px">Listos para recibir ganado</span>';
    html += '<span style="font-size:10px;color:var(--muted);margin-left:auto">'+readyList.length+' potreros</span>';
    html += '</div>';
    html += '<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:8px">';
    readyList.forEach(function(e){
      html += '<div style="background:rgba(99,153,34,.08);border-radius:8px;padding:10px 12px">';
      html += '<div style="font-size:14px;font-weight:600">'+escH(e.p.name)+'</div>';
      html += '<div style="font-size:11px;color:var(--green);margin-top:2px">';
      if (e.p.capacity) html += 'Cap: '+e.p.capacity+' · ';
      html += e.daysResting+' días descanso';
      html += '</div>';
      if (e.p.hectares) html += '<div style="font-size:10px;color:var(--muted);margin-top:2px">'+e.p.hectares+' ha</div>';
      html += '</div>';
    });
    html += '</div></div>';
  }

  // ─── OCUPADOS (en buen estado) ────────────────────────────
  // FIX v1.4.50: render jerárquico - 1 fila por potrero con sub-líneas por lote
  if (occupiedList.length) {
    html += '<div style="margin-bottom:14px">';
    html += '<div style="display:flex;align-items:center;gap:6px;margin-bottom:6px">';
    html += '<span style="font-size:12px">🐄</span><span style="font-size:11px;font-weight:700;color:var(--amber2);text-transform:uppercase;letter-spacing:.5px">Ocupados</span>';
    html += '<span style="font-size:10px;color:var(--muted);margin-left:auto">'+occupiedList.length+' potreros · '+totalCabOccupied+' cabezas</span>';
    html += '</div>';
    html += '<div style="display:flex;flex-direction:column;gap:6px">';
    occupiedList.forEach(function(e){
      var barColor = e.occPct > 80 ? 'var(--amber2)' : 'var(--green)';
      var hasMultiple = e.currentLots && e.currentLots.length > 1;
      // === Fila header del potrero ===
      html += '<div style="background:var(--sur);border:1px solid var(--bor);border-left:3px solid var(--amber2);border-radius:0 8px 8px 0;overflow:hidden">';
      html += '<div style="padding:10px 12px;display:grid;grid-template-columns:1fr 140px 90px;gap:12px;align-items:center;'+(hasMultiple?'border-bottom:1px solid var(--bor);background:var(--sur2)':'')+'">';
      html += '<div>';
      html += '<div style="font-size:13px;font-weight:600">'+escH(e.p.name)+'</div>';
      if (hasMultiple) {
        html += '<div style="font-size:11px;color:var(--muted);margin-top:2px">'+e.currentLots.length+' lotes · '+e.currentCab+' cab total</div>';
      } else if (e.currentLots && e.currentLots.length === 1) {
        html += '<div style="font-size:11px;color:var(--muted);margin-top:2px"><b>'+escH(e.currentLots[0].code||'')+'</b> · '+e.currentLots[0].cab+' cab</div>';
      }
      html += '</div>';
      // Días ocupado del POTRERO (desde la primera entrada)
      html += '<div><div style="font-size:11px;color:var(--muted)">'+e.daysOccupied+'/'+e.maxOcc+' días</div>';
      html += '<div style="height:4px;background:var(--sur2);border-radius:2px;margin-top:4px;overflow:hidden"><div style="height:100%;width:'+Math.min(100,e.occPct)+'%;background:'+barColor+';border-radius:2px"></div></div></div>';
      html += '<div style="font-size:11px;color:'+(e.isOverCap?'var(--red)':'var(--muted)')+';text-align:right">'+(e.p.capacity?e.capPct+'% cap':'—')+'</div>';
      html += '</div>';

      // === Sub-líneas: 1 por lote ===
      if (e.currentLots && e.currentLots.length > 0) {
        e.currentLots.forEach(function(cl, idx){
          var isLast = idx === e.currentLots.length - 1;
          html += '<div style="padding:8px 12px 8px 24px;display:grid;grid-template-columns:1fr 100px 90px;gap:12px;align-items:center;'+(!isLast?'border-bottom:1px dashed var(--bor)':'')+'">';
          html += '<div style="font-size:12px"><b>'+escH(cl.code||'')+'</b> <span style="color:var(--muted)">· '+cl.cab+' cab</span></div>';
          html += '<div style="font-size:10px;color:var(--muted)">'+cl.days_occupied+' días en lote</div>';
          html += '<button class="btn btn-sm" style="font-size:11px;padding:4px 8px" onclick="abrirMoverLote(\''+escH(cl.code||'')+'\')">Rotar →</button>';
          html += '</div>';
        });
      }
      html += '</div>';
    });
    html += '</div></div>';
  }

  // ─── DESCANSANDO (agrupado por zona, colapsable) ─────────
  if (restingList.length) {
    // Agrupar por zona
    var byZone = {};
    restingList.forEach(function(e){
      if (!byZone[e.zone]) byZone[e.zone] = [];
      byZone[e.zone].push(e);
    });
    // Ordenar zonas alfabéticamente, "Otros" al final
    var zoneNames = Object.keys(byZone).sort(function(a,b){
      if (a === 'Otros') return 1;
      if (b === 'Otros') return -1;
      return a.localeCompare(b);
    });

    html += '<div style="margin-bottom:14px">';
    html += '<div style="display:flex;align-items:center;gap:6px;margin-bottom:6px">';
    html += '<span style="font-size:12px">💤</span><span style="font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.5px">Descansando</span>';
    html += '<span style="font-size:10px;color:var(--muted);margin-left:auto">'+restingList.length+' potreros · '+zoneNames.length+' zonas</span>';
    html += '</div>';

    zoneNames.forEach(function(zone, zIdx){
      var list = byZone[zone];
      // Solo la primera zona arranca abierta
      var openAttr = zIdx === 0 ? ' open' : '';
      html += '<details'+openAttr+' style="border:1px solid var(--bor);border-radius:8px;margin-bottom:6px;overflow:hidden">';
      html += '<summary style="padding:8px 12px;cursor:pointer;font-size:12px;font-weight:600;background:var(--sur2);list-style:none;display:flex;align-items:center;gap:8px">';
      html += '<span style="font-size:14px">▸</span>';
      html += '<span>'+escH(zone)+'</span><span style="color:var(--muted);font-weight:400">— '+list.length+' potreros</span>';
      html += '</summary>';
      html += '<div style="padding:8px 12px;display:flex;flex-wrap:wrap;gap:6px">';
      list.forEach(function(e){
        var pctRest = Math.min(100, Math.round(e.daysResting / e.minRest * 100));
        var faltan = Math.max(0, e.minRest - e.daysResting);
        var tooltip = faltan > 0 ? 'Faltan '+faltan+' días para que esté listo' : 'Listo';
        html += '<span title="'+tooltip+'" style="background:var(--sur2);padding:3px 8px;border-radius:8px;font-size:11px;border:1px solid var(--bor)">';
        html += escH(e.p.name)+' · <span style="color:var(--muted)">'+e.daysResting+'d</span></span>';
      });
      html += '</div></details>';
    });

    html += '</div>';
  }

  // ─── Link al historial ───────────────────────────────────
  html += '<div style="text-align:center;padding:8px 0">';
  html += '<a href="javascript:void(0)" onclick="toggleHistorialRotacion()" style="font-size:12px;color:var(--muted);text-decoration:none;border-bottom:1px solid var(--bor)">📋 Ver historial completo de rotaciones</a>';
  html += '</div>';

  // ─── Historial (oculto por defecto) ──────────────────────
  var recent = history.slice().sort(function(a,b){return (b.entry_date||'').localeCompare(a.entry_date||'');}).slice(0,20);
  if (recent.length) {
    html += '<div id="historial-rotacion-table" style="display:none;margin-top:14px"><div class="card" style="padding:14px">';
    html += '<div style="font-size:13px;font-weight:700;margin-bottom:10px">📋 Historial de Rotación (últimas 20)</div>';
    html += '<table class="tbl" style="font-size:11px"><thead><tr><th>Entrada</th><th>Potrero</th><th>Lote</th><th>Cab.</th><th>Días</th><th>Salida</th><th>Motivo</th></tr></thead><tbody>';
    recent.forEach(function(r) {
      var rowColor = r.exit_date ? '' : 'background:rgba(245,166,35,.06)';
      html += '<tr style="'+rowColor+'">';
      html += '<td>'+escH(r.entry_date||'')+'</td>';
      html += '<td style="font-weight:600">'+escH(r.potrero||'')+'</td>';
      html += '<td>'+escH(r.lot_code||'')+'</td>';
      html += '<td>'+escH(r.cabezas||'')+'</td>';
      html += '<td>'+(r.exit_date ? (r.days_occupied||'?')+' d' : '<span style="color:var(--amber2);font-weight:600">'+Math.max(1,Math.round((new Date()-new Date(r.entry_date))/86400000))+' d ▶</span>')+'</td>';
      html += '<td>'+(r.exit_date||'<span style="color:var(--amber2)">En curso</span>')+'</td>';
      html += '<td style="font-size:10px;color:var(--muted)">'+escH(r.reason||'')+'</td>';
      html += '</tr>';
    });
    html += '</tbody></table></div></div>';
  }

  el.innerHTML = html;
}

