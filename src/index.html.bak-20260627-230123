// Manejar archivo subido
function handleImportFile(file) {
  if (!file) return;
  if (!window.estancia || !window.estancia.xlsx || !window.estancia.xlsx.readBuffer) {
    toast("Función Excel no disponible", "error");
    return;
  }
  var reader = new FileReader();
  reader.onload = function(e) {
    try {
      var buf = e.target.result;
      var fname = (file.name || "").toLowerCase();

      if (fname.endsWith(".csv")) {
        // CSV: convertir a texto y procesar
        var decoder = new TextDecoder("utf-8");
        var text = decoder.decode(new Uint8Array(buf));
        _ipProcessCSVText(text);
      } else {
        // XLSX/XLS: readBuffer es SÍNCRONO y devuelve {sheetNames, sheets}
        // donde sheets[name] es un ARRAY DE OBJETOS (no array de arrays)
        var result;
        try {
          result = window.estancia.xlsx.readBuffer(buf);
        } catch (err) {
          toast("Error leyendo Excel: " + (err.message || "formato inválido"), "error");
          console.error("[xlsx readBuffer]", err);
          return;
        }
        if (!result || !result.sheets) {
          toast("Archivo Excel inválido o vacío", "error");
          return;
        }
        // Buscar hoja "Pesajes" o usar la primera
        var sheetName = "Pesajes";
        if (!result.sheets[sheetName]) sheetName = result.sheetNames[0];
        var rowObjs = result.sheets[sheetName] || [];
        if (!rowObjs.length) {
          toast("La hoja '" + sheetName + "' está vacía", "error");
          return;
        }
        // Convertir array de objetos {ID:957,Peso:345,...} a array de arrays [['ID','Peso',...],[957,345,...]]
        var headers = Object.keys(rowObjs[0]);
        var rows = [headers];
        rowObjs.forEach(function(obj) {
          rows.push(headers.map(function(h) { return obj[h]; }));
        });
        _ipProcessRows(rows);
      }
    } catch (err) {
      console.error("[handleImportFile]", err);
      toast("Error procesando archivo: " + err.message, "error");
    }
  };
  reader.onerror = function() {
    toast("Error leyendo archivo", "error");
  };
  reader.readAsArrayBuffer(file);
}

// Procesar texto CSV pegado
function processImportText() {
  var text = (document.getElementById("ip-paste-text") || {}).value || "";
  if (!text.trim()) {
    _ipParsed = [];
    document.getElementById("ip-preview").style.display = "none";
    document.getElementById("ip-stats").style.display = "none";
    document.getElementById("ip-confirm-btn").disabled = true;
    return;
  }
  _ipProcessCSVText(text);
}

function _ipProcessCSVText(text) {
  var lines = text.split(/\r?\n/).filter(function(l) { return l.trim().length > 0; });
  var rows = lines.map(function(l) {
    // Detectar separador: tab, coma o punto y coma
    var sep = l.indexOf("\t") >= 0 ? "\t" : (l.indexOf(";") >= 0 ? ";" : ",");
    return l.split(sep).map(function(c) { return c.trim().replace(/^"|"$/g, ""); });
  });
  _ipProcessRows(rows);
}

// Procesar filas crudas (formato Excel descargado o CSV libre)
function _ipProcessRows(rows) {
  if (!rows || !rows.length) {
    toast("Archivo vacío", "error");
    return;
  }

  var all = getAnimalesDB();
  var animals = all[_ipLotCode] || [];

  // Detectar formato: si la primera fila tiene "ID" o "Caravana" → es header
  var firstRow = (rows[0] || []).map(function(c) { return String(c || "").toLowerCase(); });
  var hasHeader = firstRow.some(function(c) {
    return c.indexOf("id") >= 0 || c.indexOf("caravana") >= 0 || c.indexOf("peso") >= 0;
  });

  // Detectar columnas
  var idIdx = 0, pesoIdx = 1, anteriorIdx = -1;
  if (hasHeader) {
    firstRow.forEach(function(c, i) {
      if (c.indexOf("id") >= 0 || c.indexOf("caravana") >= 0) idIdx = i;
      if (c.indexOf("peso nuevo") >= 0) pesoIdx = i;
      else if (pesoIdx === 1 && (c.indexOf("peso") >= 0 && c.indexOf("anterior") < 0)) pesoIdx = i;
      if (c.indexOf("anterior") >= 0) anteriorIdx = i;
    });
  }

  var dataRows = hasHeader ? rows.slice(1) : rows;
  var parsed = [];

  dataRows.forEach(function(r, rowIdx) {
    if (!r || !r.length) return;
    var idRaw = String(r[idIdx] || "").trim();
    var pesoRaw = String(r[pesoIdx] || "").trim().replace(",", ".");
    if (!idRaw || !pesoRaw) {
      // ID sin peso → ignorar silenciosamente (animal no pesado)
      if (idRaw && !pesoRaw) {
        return; // OK, simplemente no se pesó
      }
      return;
    }
    var peso = parseFloat(pesoRaw);
    if (!peso || peso <= 0) return;

    // Buscar animal en el lote
    var animal = animals.find(function(a) {
      return String(a.id || a.animal_id || "").trim() === idRaw;
    });

    var item = {
      row: rowIdx + (hasHeader ? 2 : 1),
      id: idRaw,
      peso: peso,
      animal: animal,
      pesoAnterior: null,
      delta: null,
      warnings: [],
      error: null
    };

    if (!animal) {
      item.error = "ID no encontrado en este lote";
    } else {
      // Calcular peso anterior y delta
      var pesajes = (animal.pesajes || []).slice().sort(function(x, y) { return String(x.fecha).localeCompare(y.fecha); });
      var ultimo = pesajes.length ? pesajes[pesajes.length - 1] : null;
      if (ultimo) {
        item.pesoAnterior = ultimo.peso;
        item.delta = peso - ultimo.peso;

        // Warnings (no bloquean)
        var diasEntre = Math.max(1, Math.round((new Date().getTime() - new Date(ultimo.fecha).getTime()) / 86400000));
        var gmd = item.delta / diasEntre;
        if (item.delta < 0 && Math.abs(item.delta) / ultimo.peso > 0.30) {
          item.warnings.push("Pérdida >30% vs último pesaje");
        }
        if (gmd > 5) {
          item.warnings.push("Ganancia GMD > 5 kg/d (verificar)");
        }
      }

      // Warnings de rango
      if (peso < 50) item.warnings.push("Peso muy bajo (<50kg)");
      if (peso > 700) item.warnings.push("Peso muy alto (>700kg)");
    }

    parsed.push(item);
  });

  _ipParsed = parsed;
  _ipRenderPreview();
}

function _ipRenderPreview() {
  var statsEl = document.getElementById("ip-stats");
  var previewEl = document.getElementById("ip-preview");
  var tbodyEl = document.getElementById("ip-preview-tbody");
  var btnEl = document.getElementById("ip-confirm-btn");
  if (!statsEl || !previewEl || !tbodyEl) return;

  if (!_ipParsed.length) {
    statsEl.style.display = "none";
    previewEl.style.display = "none";
    btnEl.disabled = true;
    return;
  }

  var validos = _ipParsed.filter(function(p) { return !p.error; });
  var conWarnings = _ipParsed.filter(function(p) { return !p.error && p.warnings.length > 0; });
  var errores = _ipParsed.filter(function(p) { return p.error; });

  // Stats
  statsEl.style.display = "grid";
  statsEl.style.gridTemplateColumns = "repeat(3, 1fr)";
  statsEl.style.gap = "8px";
  statsEl.innerHTML =
    '<div style="background:rgba(57,211,83,.06);border:1px solid rgba(57,211,83,.25);border-radius:6px;padding:10px 12px;text-align:center">' +
      '<div style="font-size:18px;font-weight:700;color:var(--green);font-family:\'DM Mono\',monospace">' + validos.length + '</div>' +
      '<div style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em">Válidos</div>' +
    '</div>' +
    '<div style="background:rgba(255,149,0,.06);border:1px solid rgba(255,149,0,.25);border-radius:6px;padding:10px 12px;text-align:center">' +
      '<div style="font-size:18px;font-weight:700;color:var(--orange,#FF9500);font-family:\'DM Mono\',monospace">' + conWarnings.length + '</div>' +
      '<div style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em">Advertencias</div>' +
    '</div>' +
    '<div style="background:rgba(231,76,60,.06);border:1px solid rgba(231,76,60,.25);border-radius:6px;padding:10px 12px;text-align:center">' +
      '<div style="font-size:18px;font-weight:700;color:var(--red);font-family:\'DM Mono\',monospace">' + errores.length + '</div>' +
      '<div style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em">Errores</div>' +
    '</div>';

  // Preview tabla
  previewEl.style.display = "block";
  var html = "";
  _ipParsed.forEach(function(p, idx) {
    var bg = "";
    var estado = "";
    if (p.error) {
      bg = "rgba(231,76,60,.05)";
      estado = '<span style="color:var(--red);font-size:10px">❌ ' + escH(p.error) + '</span>';
    } else if (p.warnings.length) {
      bg = "rgba(255,149,0,.04)";
      estado = '<span style="color:var(--orange,#FF9500);font-size:10px">⚠ ' + escH(p.warnings.join(", ")) + '</span>';
    } else {
      estado = '<span style="color:var(--green);font-size:10px">✅ OK</span>';
    }

    var deltaStr = "—", deltaColor = "var(--muted)";
    if (p.delta != null) {
      var sign = p.delta >= 0 ? "+" : "";
      deltaStr = sign + p.delta.toFixed(1);
      deltaColor = p.delta < 0 ? "var(--red)" : (p.delta > 0 ? "var(--green)" : "var(--muted)");
    }

    html += '<tr style="background:' + bg + ';border-bottom:1px solid var(--bor)">' +
      '<td style="padding:7px 8px;color:var(--muted);font-family:\'DM Mono\',monospace">' + (idx + 1) + '</td>' +
      '<td style="padding:7px 8px;font-family:\'DM Mono\',monospace;font-weight:600">' + escH(p.id) + '</td>' +
      '<td style="padding:7px 8px;text-align:right;font-family:\'DM Mono\',monospace;font-weight:700">' + p.peso.toFixed(1) + ' kg</td>' +
      '<td style="padding:7px 8px;text-align:right;font-family:\'DM Mono\',monospace;color:var(--muted)">' + (p.pesoAnterior != null ? p.pesoAnterior + ' kg' : "—") + '</td>' +
      '<td style="padding:7px 8px;text-align:right;font-family:\'DM Mono\',monospace;color:' + deltaColor + '">' + deltaStr + '</td>' +
      '<td style="padding:7px 8px">' + estado + '</td>' +
    '</tr>';
  });
  tbodyEl.innerHTML = html;

  btnEl.disabled = validos.length === 0;
  btnEl.textContent = validos.length > 0 ? "Guardar " + validos.length + " pesajes válidos" : "Sin pesajes válidos";
}

// Confirmar y guardar todos los pesajes válidos
function confirmImportPesajes() {
  var validos = _ipParsed.filter(function(p) { return !p.error && p.animal; });
  if (!validos.length) { toast("No hay pesajes válidos", "error"); return; }

  var fecha = (document.getElementById("ip-fecha-global") || {}).value || localDate();
  // FIX v1.4.34: no permitir fechas futuras
  if (!validateNotFuture(fecha, 'fecha del pesaje')) return;
  var all = getAnimalesDB();
  var animals = all[_ipLotCode] || [];

  validos.forEach(function(item) {
    var animal = animals.find(function(a) {
      return String(a.id || a.animal_id || "").trim() === item.id;
    });
    if (!animal) return;
    animal.pesajes = animal.pesajes || [];
    var existe = animal.pesajes.find(function(p) { return p.fecha === fecha; });
    if (existe) {
      existe.peso = item.peso;
    } else {
      animal.pesajes.push({ fecha: fecha, peso: item.peso });
    }
    animal.pesajes.sort(function(a, b) { return String(a.fecha).localeCompare(b.fecha); });
  });

  // Actualizar avg_weight del lote
  var lot = (db.lots || []).find(function(l) { return l.code === _ipLotCode; });
  if (lot && animals.length) {
    var ws = animals.map(function(a) {
      return a.pesajes && a.pesajes.length ? a.pesajes[a.pesajes.length - 1].peso : 0;
    });
    lot.avg_weight = Math.round(ws.reduce(function(s, w) { return s + w; }, 0) / ws.length * 10) / 10;
  }

  saveAnimalesDB(all);
  saveDB();

  // Audit log
  try {
    auditLog("update", "pesajes", _ipLotCode, "Pesaje masivo: " + validos.length + " animales en lote " + _ipLotCode);
  } catch(e) {}

  closeModal("modal-import-pesajes");
  closeModal("modal-pesaje-animal");
  if (typeof renderAnimalesLote === "function") renderAnimalesLote();
  if (typeof renderPesajesFromAnimales === "function") renderPesajesFromAnimales();
  toast("✓ " + validos.length + " pesajes guardados", "success");
}

function renderPesajesFromAnimales(){
  var container=document.getElementById("pesajes-from-animals");if(!container) return;
  var all=getAnimalesDB();var lots=db.lots||[];var html="";
  lots.forEach(function(lot){
    var animals=all[lot.code]||[];if(!animals.length) return;
    var lastWeights=[];var lastFechas=[];var gmds=[];
    animals.forEach(function(a){
      var ps=a.pesajes||[];if(!ps.length) return;
      var last=ps[ps.length-1];lastWeights.push(last.peso);lastFechas.push(last.fecha);
      if(ps.length>=2){var p0=ps[0];var p1=ps[ps.length-1];var dias=Math.round((new Date(p1.fecha)-new Date(p0.fecha))/86400000);if(dias>0)gmds.push((p1.peso-p0.peso)/dias);}
    });
    if(!lastWeights.length) return;
    var avg=Math.round(lastWeights.reduce(function(s,w){return s+w;},0)/lastWeights.length*10)/10;
    var mn=Math.min.apply(null,lastWeights);var mx=Math.max.apply(null,lastWeights);
    var lastFecha=lastFechas.slice().sort().pop();
    var avgGmd=gmds.length?(gmds.reduce(function(s,g){return s+g;},0)/gmds.length).toFixed(3):"-";
    var totalKg=Math.round(avg*animals.length);
    html+='<div style="background:var(--sur2);border:1px solid var(--bor);border-radius:10px;padding:16px;margin-bottom:12px">'+
      '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">'+
        '<div><span style="font-family:DM Mono,monospace;font-weight:700;color:var(--amber2);font-size:14px">'+lot.code+'</span><span style="color:var(--muted);font-size:11px;margin-left:8px">'+lot.category+' - '+lot.paddock+'</span></div>'+
        '<span style="font-size:11px;color:var(--muted)">Ultimo pesaje: '+lastFecha+'</span>'+
      '</div>'+
      '<div style="display:flex;gap:12px;flex-wrap:wrap">'+
        '<div style="flex:1;min-width:100px;text-align:center;padding:10px;background:rgba(0,0,0,.15);border-radius:8px"><div style="font-size:10px;color:var(--muted)">PROMEDIO</div><div style="font-size:18px;font-weight:700">'+avg+' kg</div></div>'+
        '<div style="flex:1;min-width:100px;text-align:center;padding:10px;background:rgba(0,0,0,.15);border-radius:8px"><div style="font-size:10px;color:var(--muted)">MINIMO</div><div style="font-size:18px;font-weight:700;color:var(--green)">'+mn+' kg</div></div>'+
        '<div style="flex:1;min-width:100px;text-align:center;padding:10px;background:rgba(0,0,0,.15);border-radius:8px"><div style="font-size:10px;color:var(--muted)">MAXIMO</div><div style="font-size:18px;font-weight:700;color:var(--blue)">'+mx+' kg</div></div>'+
        '<div style="flex:1;min-width:100px;text-align:center;padding:10px;background:rgba(0,0,0,.15);border-radius:8px"><div style="font-size:10px;color:var(--muted)">GMD PROM.</div><div style="font-size:18px;font-weight:700;color:var(--amber2)">'+avgGmd+' kg/d</div></div>'+
        '<div style="flex:1;min-width:100px;text-align:center;padding:10px;background:rgba(0,0,0,.15);border-radius:8px"><div style="font-size:10px;color:var(--muted)">TOTAL KG</div><div style="font-size:18px;font-weight:700;color:var(--green)">'+totalKg.toLocaleString()+'</div></div>'+
        '<div style="flex:1;min-width:100px;text-align:center;padding:10px;background:rgba(0,0,0,.15);border-radius:8px"><div style="font-size:10px;color:var(--muted)">ANIMALES</div><div style="font-size:18px;font-weight:700">'+animals.length+'</div></div>'+
      '</div>'+
    '</div>';
  });
  container.innerHTML=html||'<div style="text-align:center;padding:32px;color:var(--muted);font-size:12px">Sin datos de pesaje</div>';
}
