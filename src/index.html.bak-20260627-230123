  // 3. Stat cards
  var hoy = new Date();
  var mesActualStr = hoy.toISOString().slice(0,7);
  var mesActualRecs = records.filter(function(r){ return _salRecordMonth(r) === mesActualStr; });
  var mesActualKg = mesActualRecs.reduce(function(s,r){ return s + (parseFloat(r.qty||r.total||r.kg||0)||0); }, 0);
  var potrerosMes = {};
  mesActualRecs.forEach(function(r){
    var p = _salGetRecordPaddock(r);
    if (p) potrerosMes[p] = true;
  });
  var tipoLbl = tipoNorm ? _salTipoLabel(tipoNorm) : 'Sal';
  _setText('sal-stat-1-label', 'Mes actual · ' + tipoLbl);
  _setText('sal-stat-1-value', Math.round(mesActualKg).toLocaleString());
  _setText('sal-stat-1-sub',   mesActualRecs.length + ' depósitos · ' + Object.keys(potrerosMes).length + ' potreros');

  var totalKg = records.reduce(function(s,r){ return s + (parseFloat(r.qty||r.total||r.kg||0)||0); }, 0);
  var promMes = period > 0 ? Math.round(totalKg / period) : 0;
  _setText('sal-stat-2-period', period + ' meses');
  _setText('sal-stat-2-value',  Math.round(totalKg).toLocaleString());
  _setText('sal-stat-2-sub',    'Promedio: ' + promMes + ' kg/mes');

  var products = db.vet_products || db.products || [];
  var matching = products.filter(function(p){ return _salIsProductOfCategory(p, 'sal'); });
  var stockTotal = matching.reduce(function(s,p){ return s + (parseFloat(p.stock_qty)||0); }, 0);
  _setText('sal-stat-3-value', Math.round(stockTotal).toLocaleString());
  var mesesRest = (promMes > 0 && stockTotal > 0) ? Math.round(stockTotal / promMes) : null;
  _setText('sal-stat-3-sub', mesesRest ? ('~' + mesesRest + ' meses al ritmo actual') : (matching.length + ' productos en stock'));

  // 4. Donut por tipo (sólo si hay ≥2 tipos en TODOS los registros, no en el filtro actual)
  _salRenderTipoCard(allRecords);

  // 5. Charts
  var subPotreros = tipoNorm
    ? ('Kilogramos depositados — sólo ' + _salTipoLabel(tipoNorm).toLowerCase())
    : 'Kilogramos depositados en cada potrero, mes a mes';
