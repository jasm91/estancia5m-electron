<script>
// ══════════════════════════════════════════════════
// SIDEBAR — v1.4.71 collapse/expand with persistence
// ══════════════════════════════════════════════════
(function initSidebarEarly() {
  // Aplicar estado guardado ANTES del paint para evitar flash
  try {
    var saved = localStorage.getItem('e5m_sidebar_collapsed');
    if (saved === '1') {
      // Esperar a que .app exista (puede no estar al ejecutar inline script en head)
      var apply = function() {
        var app = document.querySelector('.app');
        if (app) app.classList.add('sidebar-collapsed');
      };
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', apply, { once: true });
      } else {
        apply();
      }
    }
  } catch(e) {}
})();

function toggleSidebar() {
  var app = document.querySelector('.app');
  if (!app) return;
  var collapsed = app.classList.toggle('sidebar-collapsed');
  try { localStorage.setItem('e5m_sidebar_collapsed', collapsed ? '1' : '0'); } catch(e){}
  // Actualizar icono del toggle (« cuando expandido, » cuando colapsado)
  var btn = document.getElementById('sidebar-toggle');
  if (btn) btn.textContent = collapsed ? '»' : '«';
  // Forzar resize para que los charts (Chart.js) se reajusten al nuevo ancho
  setTimeout(function() {
    try { window.dispatchEvent(new Event('resize')); } catch(e){}
  }, 280);  // un poco más que la transición CSS (.25s)
}

// Atajo de teclado Cmd/Ctrl + B
document.addEventListener('keydown', function(e) {
  if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'b' && !e.shiftKey && !e.altKey) {
    // Solo si no estás en un input/textarea
    var tag = (e.target && e.target.tagName) || '';
    if (tag === 'INPUT' || tag === 'TEXTAREA' || (e.target && e.target.isContentEditable)) return;
    e.preventDefault();
    toggleSidebar();
  }
});

// Sincronizar el ícono del botón con el estado al cargar
document.addEventListener('DOMContentLoaded', function() {
  var app = document.querySelector('.app');
  var btn = document.getElementById('sidebar-toggle');
  if (app && btn) btn.textContent = app.classList.contains('sidebar-collapsed') ? '»' : '«';
});
</script>

<script>
// ══════════════════════════════════════════════════
// DATA STORE - localStorage persistence
// ══════════════════════════════════════════════════
const DB_KEY = 'estancia5m_v1';

// -- Configuracion del servidor (Railway) ----------------------
const SERVER_CONFIG = {
  url: 'https://estancia5m-api-production.up.railway.app/api',
  token: 'estancia5m-2026-secreto'
};
// Pre-cargar config en localStorage al iniciar
localStorage.setItem('apiUrl', SERVER_CONFIG.url);
localStorage.setItem('apiToken', SERVER_CONFIG.token);


function loadDB() {
  const raw = localStorage.getItem(DB_KEY);
  if (raw) return JSON.parse(raw);
  return initDB();
}

function saveDB(lotChanged) {
  localStorage.setItem(DB_KEY, JSON.stringify(db));
  clearTimeout(window._syncTimer);
  if (lotChanged) {
    // Si cambio un lote (nuevo, editado, movido) hacer pull→merge→push completo
    window._syncTimer = setTimeout(function() { pullThenPush(); }, 2000);
  } else {
    // Para cualquier otro cambio, solo pushear registros del desktop sin tocar lotes
    window._syncTimer = setTimeout(function() { pushDesktopRecords(); }, 2000);
  }
}

// Tracking de IDs borrados para que el merge no los traiga de vuelta
function getDeletedIds(table) {
  try { 
    var all = JSON.parse(localStorage.getItem('e5m_deleted_ids') || '{}');
    if (!table) return all;
    // Filtrar solo los del tabla específica
    var filtered = {};
    Object.keys(all).forEach(function(k) {
      if (k.indexOf(table + ':') === 0) filtered[k.replace(table + ':', '')] = all[k];
    });
    return filtered;
  } catch(e) { return {}; }
}
function trackDeletion(id, table) {
  var deleted = JSON.parse(localStorage.getItem('e5m_deleted_ids') || '{}');
  var key = table ? (table + ':' + String(id)) : String(id);
  deleted[key] = Date.now();
  var keys = Object.keys(deleted);
  if (keys.length > 500) {
    keys.sort(function(a,b){ return deleted[a]-deleted[b]; });
    for (var i = 0; i < keys.length - 500; i++) delete deleted[keys[i]];
  }
  localStorage.setItem('e5m_deleted_ids', JSON.stringify(deleted));
  // Push al server (asíncrono, no bloquea) para que PWA y bot también lo respeten
  try {
    if (navigator.onLine) {
      var apiUrl = (typeof getApiUrl === 'function') ? getApiUrl() : (localStorage.getItem('e5m_api_url') || 'https://estancia5m-api-production.up.railway.app/api');
      var token = localStorage.getItem('e5m_api_token') || '';
      if (token) {
        fetch(apiUrl + '/bulk-push', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
          body: JSON.stringify({ table: '_deleted_ids', records: deleted })
        }).catch(function(){});
      }
    }
  } catch(e) {}
  // Log de auditoría
  try { auditLog('delete', table || 'unknown', id, _summarizeRecord(table, id)); } catch(e){}
}

// ── AUDIT LOG (cliente) ─────────────────────────────────────
// Envía un log al server. Asíncrono, no bloquea. Falla silenciosa.
function auditLog(action, table, recordId, summary, diff) {
  try {
    if (!navigator.onLine) return;  // no encolamos para no inflar localStorage; los logs son best-effort
    var apiUrl = (typeof getApiUrl === 'function') ? getApiUrl() : (localStorage.getItem('e5m_api_url') || 'https://estancia5m-api-production.up.railway.app/api');
    var token = localStorage.getItem('e5m_api_token') || '';
    if (!token) return;
    var user = localStorage.getItem('e5m_operator') || 'Desktop';
    var body = {
      action: action,
      table: table,
      record_id: recordId == null ? '' : String(recordId),
      record_summary: summary || '',
      user: user,
      app_version: (typeof _APP_VERSION !== 'undefined' ? _APP_VERSION : ''),
    };
    if (diff) body.diff = diff;
    fetch(apiUrl + '/audit/log', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': 'Bearer ' + token,
        'X-App-Type': 'desktop',
        'X-App-Version': (typeof _APP_VERSION !== 'undefined' ? _APP_VERSION : '')
      },
      body: JSON.stringify(body)
    }).catch(function(){});
  } catch(e) { /* no crítico */ }
}

// Genera un resumen legible de un registro para logs
function _summarizeRecord(table, idOrObj) {
  try {
    var rec = typeof idOrObj === 'object' ? idOrObj : null;
    if (!rec && typeof db !== 'undefined' && db[table]) {
      rec = (db[table] || []).find(function(r){ return String(r.id) === String(idOrObj); });
    }
    if (!rec) return table + ' #' + idOrObj;
    switch(table) {
      case 'sales':
        return 'Venta: ' + (rec.buyer || '?') + ' · ' + (rec.animals||0) + ' cab · Bs ' + (rec.total||0);
      case 'purchases':
        return 'Compra: ' + (rec.desc || rec.detalle || '?') + ' · Bs ' + (rec.total||0);
      case 'maintenance':
        return 'Mantenimiento: ' + (rec.desc || '?').slice(0, 60) + (rec.equipo ? ' · '+rec.equipo : '');
      case 'lots':
        return 'Lote: ' + (rec.code || '?') + (rec.paddock ? ' · '+rec.paddock : '') + ' · ' + (rec.animal_count||0) + ' cab';
      case 'employees':
        return 'Empleado: ' + (rec.name || '?') + (rec.role ? ' · '+rec.role : '');
      case 'treatments':
        return 'Curación: ' + (rec.product_name || '?') + ' · Lote ' + (rec.lot_code||'?');
      case 'pesajes':
        return 'Pesaje: Lote ' + (rec.lot_code||'?') + ' · ' + (rec.avg_weight||rec.peso||'?') + ' kg';
      case 'aceite':
        return 'Aceite: ' + (rec.vehiculo||'?') + ' · ' + (rec.tipo||'') + ' · Bs ' + (rec.costo||0);
      case 'diesel':
        return 'Diesel: ' + (rec.type||'?') + ' · ' + (rec.litros||0) + ' L';
      case 'compras_ganado':
        return 'Compra ganado: ' + (rec.proveedor||'?') + ' · ' + (rec.animal_count||0) + ' cab';
      case 'cuentas':
        return 'Cuenta contable: ' + (rec.detalle||'?').slice(0,60) + ' · Bs ' + (rec.monto||0);
      case 'pasture_evals':
        return 'Eval pasto: ' + (rec.potrero||'?') + (rec.lot_code?' · Lote '+rec.lot_code:'');
      case 'maquinaria':
        return 'Maquinaria: ' + (rec.nombre||'?') + (rec.modelo?' ('+rec.modelo+')':'');
      case 'partos':
        return 'Parto: Lote ' + (rec.lot_code||'?') + ' · ' + (rec.sexo||'') + (rec.estado==='muerto'?' (mortinato)':'');
      case 'bajas':
        return 'Baja: Animal ' + (rec.animal_id||'?') + ' · ' + (rec.causa||'?');
      default:
        return table + ' #' + (rec.id || idOrObj);
    }
  } catch(e) { return table + ' #' + idOrObj; }
}

// Computa el diff entre dos versiones del mismo objeto, para logs de update
function _computeDiff(oldObj, newObj) {
  if (!oldObj || !newObj) return null;
  var diff = {};
  var keys = {};
  Object.keys(oldObj || {}).forEach(function(k){ keys[k]=true; });
  Object.keys(newObj || {}).forEach(function(k){ keys[k]=true; });
  Object.keys(keys).forEach(function(k){
    if (k === 'updated_at' || k === 'server_updated_at' || k === 'created_at' || k === 'photos' || k === 'photo' || k === 'photo_base64' || k === 'photos_base64') return;
    var ov = oldObj[k], nv = newObj[k];
    if (typeof ov === 'object' || typeof nv === 'object') {
      // Comparación rápida JSON para objetos/arrays
      try {
        if (JSON.stringify(ov) !== JSON.stringify(nv)) diff[k] = [ov, nv];
      } catch(e){}
    } else if (ov !== nv) {
      diff[k] = [ov, nv];
    }
  });
  return Object.keys(diff).length ? diff : null;
}

// Reemplazar una tabla específica en Railway (para que borrados se propaguen a PWA)
//
// FIX v1.4.31: cola persistente de reintentos.
// Antes: si fallaba (offline, sin token, timeout, error server), retornaba false silencioso
// y el cambio en el cliente nunca llegaba al server. Causó pérdida de sync en marcaje offline.
// Ahora: cualquier falla guarda el payload en localStorage['e5m_replace_queue'] y se reintenta
// automáticamente cuando vuelve la conexión o al próximo sync.

function _replaceQueueGet() {
  try { return JSON.parse(localStorage.getItem('e5m_replace_queue') || '[]'); } catch(e) { return []; }
}
function _replaceQueueSet(q) {
  try { localStorage.setItem('e5m_replace_queue', JSON.stringify(q)); } catch(e) { console.error('[ReplaceQueue] localStorage full:', e); }
}
function _replaceQueueEnqueue(tableName, records) {
  var q = _replaceQueueGet();
  // Deduplicar: si hay otro pendiente para la misma tabla, reemplazar (último gana, es REPLACE total).
  q = q.filter(function(it){ return it.table !== tableName; });
  q.push({ table: tableName, records: records, attempts: 0, queued_at: Date.now() });
  _replaceQueueSet(q);
  _updateSyncBadge();
  console.warn('[ReplaceQueue] Encolado push de "' + tableName + '" (queue size: ' + q.length + ')');
}
function _updateSyncBadge() {
  try {
    var q = _replaceQueueGet();
    var btn = document.getElementById('sync-btn');
    if (!btn) return;
    if (q.length > 0) {
      btn.title = q.length + ' push pendientes de sincronizar';
      if (btn.textContent.indexOf('⚠') < 0) btn.textContent = '⚠ Sync (' + q.length + ')';
    } else {
      btn.title = '';
      if (btn.textContent.indexOf('⚠') >= 0) btn.textContent = 'Sync';
    }
  } catch(e) {}
}
// v1.4.40: Lock para evitar ejecuciones concurrentes de flushReplaceQueue
// Antes: tres disparadores (online event, setInterval 60s, setTimeout 3s al load)
// podían correr en paralelo y procesar el mismo queue 2 veces, generando
// double-push al server (visible en logs como cada tabla apareciendo 2x).
var _flushInProgress = false;
function flushReplaceQueue() {
  if (!navigator.onLine) return Promise.resolve(false);
  if (_flushInProgress) {
    console.log('[ReplaceQueue] Flush ya en curso, skip');
    return Promise.resolve(false);
  }
  var q = _replaceQueueGet();
  if (!q.length) return Promise.resolve(true);
  _flushInProgress = true;
  console.log('[ReplaceQueue] Flushing ' + q.length + ' entries');
  // Procesar secuencialmente para no saturar
  var chain = Promise.resolve();
  q.forEach(function(item) {
    chain = chain.then(function() {
      return _doReplace(item.table, item.records, true).then(function(ok) {
        if (ok) {
          // Quitar de la cola
          var q2 = _replaceQueueGet().filter(function(x){ return x.table !== item.table || x.queued_at !== item.queued_at; });
          _replaceQueueSet(q2);
          console.log('[ReplaceQueue] ✓ ' + item.table + ' enviado, queue size: ' + q2.length);
        } else {
          // Incrementar intentos y dejar en cola (o descartar si llegamos al límite)
          var q2 = _replaceQueueGet();
          var idx = q2.findIndex(function(x){ return x.table === item.table && x.queued_at === item.queued_at; });
          if (idx >= 0) {
            q2[idx].attempts = (q2[idx].attempts || 0) + 1;
            if (q2[idx].attempts >= 5) {
              console.error('[ReplaceQueue] Descartando ' + item.table + ' tras 5 intentos fallidos');
              q2.splice(idx, 1);
              try { toast('No se pudo sincronizar ' + item.table + ' al server. Datos locales OK pero pueden no estar en otros dispositivos.', 'error'); } catch(e){}
            }
            _replaceQueueSet(q2);
          }
        }
      });
    });
  });
  return chain.then(function() {
    _updateSyncBadge();
    _flushInProgress = false;
    return true;
  }).catch(function(err) {
    console.error('[ReplaceQueue] flush error:', err);
    _flushInProgress = false;
    return false;
  });
}
// Auto-flush al detectar conexión + cada 60s mientras haya cola
window.addEventListener('online', function() {
  setTimeout(flushReplaceQueue, 1500);
  setTimeout(retryPendingBulkMoves, 2000);  // v1.4.81
});
setInterval(function() {
  if (_replaceQueueGet().length > 0) flushReplaceQueue();
}, 60000);

// v1.4.81: Reintentar bulk moves pendientes de sync
// Se invoca: al cargar la app (después del init), al volver online, y cada 5 min.
function retryPendingBulkMoves() {
  if (!navigator.onLine) return;
  var pending = (db.animal_movements || []).filter(function(m) {
    return m && m._sync_retry_pending && !m._synced;
  });
  if (pending.length === 0) return;
  console.log('[bulk-move retry] ' + pending.length + ' batches pendientes de sync');

  var apiUrl = getApiUrl();
  var token = localStorage.getItem('e5m_api_token') || '';

  pending.forEach(function(batch) {
    var newLotData = batch.created_new_lot
      ? (db.lots || []).find(function(l){return l.code === batch.to_lot;})
      : null;

    // v1.4.84: armar animals_payload para el retry (resiliente a desincronización)
    var adbSnapshot = getAnimalesDB();
    var batchAnimalsArr = (adbSnapshot[batch.to_lot] || []).filter(function(a) {
      return (batch.animal_ids || []).indexOf(String(a.id || a.animal_id || '')) >= 0;
    });
    var animalsPayload = batchAnimalsArr.map(function(a) {
      return {
        animal_id: String(a.id || a.animal_id || ''),
        breed: a.breed || a.raza || '',
        pesajes: a.pesajes || [],
        _movements: a._movements || []
      };
    });

    fetch(apiUrl + '/animal-movements/bulk', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': 'Bearer ' + token,
        'x-app-version': '1.4.84'
      },
      body: JSON.stringify({
        batch_id: batch.id,
        from_lot: batch.from_lot,
        to_lot: batch.to_lot,
        animal_ids: batch.animal_ids,
        animals_payload: animalsPayload,
        date: batch.date,
        motivo: batch.reason,
        created_new_lot: batch.created_new_lot,
        new_lot_data: newLotData,
        by: batch.by,
        source: batch.source
      })
    })
      .then(function(r) { return r.json().then(function(d){ return { ok: r.ok, data: d }; }); })
      .then(function(res) {
        if (res.ok && res.data && res.data.ok) {
          batch._synced = true;
          batch._synced_at = new Date().toISOString();
          delete batch._sync_retry_pending;
          delete batch._sync_error;
          saveDB();
          console.log('[bulk-move retry] OK: ' + batch.id);
        }
      })
      .catch(function(err) {
        console.warn('[bulk-move retry] still failing for ' + batch.id + ':', err.message);
      });
  });
}
// Reintento periódico cada 5 min
setInterval(retryPendingBulkMoves, 5 * 60 * 1000);

// Implementación interna: si fromQueue=true, no re-encolar al fallar (evitar loop).
function _doReplace(tableName, records, fromQueue) {
  if (!navigator.onLine) {
    if (!fromQueue) _replaceQueueEnqueue(tableName, records);
    return Promise.resolve(false);
  }
  var apiUrl = getApiUrl();
  var token = localStorage.getItem('e5m_api_token') || '';
  if (!token) {
    console.warn('_doReplace: sin token, skip ' + tableName);
    if (!fromQueue) _replaceQueueEnqueue(tableName, records);
    return Promise.resolve(false);
  }
  var payloadRecords;
  if (records === null || records === undefined) {
    payloadRecords = [];
  } else if (Array.isArray(records)) {
    payloadRecords = records;
  } else if (typeof records === 'object') {
    payloadRecords = records;
  } else {
    payloadRecords = [];
  }
  return fetch(apiUrl + '/bulk-push', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
    body: JSON.stringify({ table: tableName, records: payloadRecords })
  }).then(function(r){ return r.json(); })
  .then(function(d){
    if (d.ok) { console.log('[Sync] ' + tableName + ': OK'); return true; }
    console.error('[Sync] ' + tableName + ': Error', d.error || d);
    if (!fromQueue) _replaceQueueEnqueue(tableName, records);
    return false;
  })
  .catch(function(e){
    console.error('[Sync] ' + tableName + ': ' + e.message);
    if (!fromQueue) _replaceQueueEnqueue(tableName, records);
    return false;
  });
}

// API pública (compatible con todas las llamadas existentes)
function replaceTableInRailway(tableName, records) {
  return _doReplace(tableName, records, false);
}
// Al cargar, intentar limpiar la cola si quedó algo de la sesión anterior
setTimeout(function() {
  try { _updateSyncBadge(); if (navigator.onLine) flushReplaceQueue(); } catch(e){}
}, 3000);

function mergeArrays(local, remote, idField, tableName) {
  var localIds = {};
  var deleted = getDeletedIds(tableName);
  var localMap = {};
  (local || []).forEach(function(r) {
    localIds[r[idField]] = true;
    localMap[r[idField]] = r;
  });

  // FIX v1.4.30 (12-may-2026): para rotation_history, aceptar actualizaciones de exit_date
  // del remote. Antes mergeArrays solo agregaba registros nuevos, nunca actualizaba existentes.
  // Resultado: cuando la PWA cerraba una rotación en el server (exit_date != null), el Desktop
  // mantenía su versión vieja con exit_date: null, confundiendo el render.
  if (tableName === 'rotation_history') {
    var merged = [];
    var remoteIds = {};
    (remote || []).forEach(function(r) {
      var rid = String(r[idField] || '');
      remoteIds[rid] = true;
      if (deleted[rid]) return;
      var localR = localMap[r[idField]];
      if (!localR) {
        // Solo en remote — agregar
        merged.push(r);
      } else {
        // Existe en ambos — preservar exit_date del lado que lo tenga seteado
        if (!localR.exit_date && r.exit_date) {
          // Remote tiene el cierre, local todavía no — aceptar
          merged.push(r);
        } else if (localR.exit_date && !r.exit_date) {
          // Local tiene cierre, remote no (no debería pasar) — mantener local
          merged.push(localR);
        } else {
          // Ambos cerrados o ambos abiertos — preferir remote (server-wins)
          merged.push(r);
        }
      }
    });
    // Agregar locales que no están en remote (movimientos offline recientes)
    (local || []).forEach(function(r) {
      var rid = String(r[idField] || '');
      if (!remoteIds[rid] && !deleted[rid]) merged.push(r);
    });
    return merged;
  }

  // v1.4.111-fix: para tablas de actividad por lote (sal/agua/alimento/conteo/partos),
  // si el local tiene un registro SIN paddock y el remote (server) tiene el MISMO
  // registro CON paddock, preferir la versión remote (server-wins en este campo).
  // Esto resuelve el caso donde el server v4.5.15+ infiere paddock automáticamente
  // pero el Desktop guardó la versión vieja sin paddock antes del fix.
  // v1.4.113: misma lógica para `tipo` en sal (default 'mineral' aplicado por server v4.5.16+).
  // v1.5.0: extendido a reproductive_services. Además server gana en result/diagnosis_method/
  //   diagnosis_date cuando local sigue en pendiente y server ya marcó preñada/vacía.
  //   Esto cubre el caso: Desktop registró servicio offline, otro Desktop diagnosticó,
  //   primer Desktop hace sync-pull y debe ver el diagnóstico aunque su versión local
  //   sea más reciente en `updated_at`.
  var ACTIVITY_TABLES = ['sal','agua','alimento','conteo','partos','reproductive_services'];
  if (ACTIVITY_TABLES.indexOf(tableName) >= 0) {
    var mergedAct = [];
    var remoteIdsAct = {};
    (remote || []).forEach(function(r) {
      var rid = String(r[idField] || '');
      remoteIdsAct[rid] = true;
      if (deleted[rid]) return;
      var localR = localMap[r[idField]];
      if (!localR) {
        // Solo en remote — agregar
        mergedAct.push(r);
      } else {
        // Existe en ambos — server-wins por campo cuando local viene vacío
        var remoteWinsPaddock = r.paddock && !localR.paddock;
        var remoteWinsTipo    = (tableName === 'sal') && r.tipo && (!localR.tipo || !String(localR.tipo).trim());
        // v1.5.0: server-wins en diagnóstico de reproductive_services
        var remoteWinsResult = false, remoteWinsDiagMethod = false, remoteWinsDiagDate = false;
        if (tableName === 'reproductive_services') {
          var localPending = !localR.result || localR.result === 'pendiente';
          var remoteHasResult = r.result && r.result !== 'pendiente';
          if (localPending && remoteHasResult) {
            remoteWinsResult = true;
            if (r.diagnosis_method) remoteWinsDiagMethod = true;
            if (r.diagnosis_date)   remoteWinsDiagDate   = true;
          }
        }
        if (remoteWinsPaddock || remoteWinsTipo || remoteWinsResult || remoteWinsDiagMethod || remoteWinsDiagDate) {
          // Construir merged: empezar de local, sobreescribir solo los campos donde server gana
          var combined = Object.assign({}, localR);
          if (remoteWinsPaddock)    combined.paddock          = r.paddock;
          if (remoteWinsTipo)       combined.tipo             = r.tipo;
          if (remoteWinsResult)     combined.result           = r.result;
          if (remoteWinsDiagMethod) combined.diagnosis_method = r.diagnosis_method;
          if (remoteWinsDiagDate)   combined.diagnosis_date   = r.diagnosis_date;
          mergedAct.push(combined);
        } else {
          mergedAct.push(localR);
        }
      }
    });
    // Agregar locales que no están en remote (cambios offline recientes)
    (local || []).forEach(function(r) {
      var rid = String(r[idField] || '');
      if (!remoteIdsAct[rid] && !deleted[rid]) mergedAct.push(r);
    });
    return mergedAct;
  }

  // Comportamiento original para otras tablas
  var merged = (local || []).slice();
  (remote || []).forEach(function(r) {
    var rid = String(r[idField] || '');
    if (!localIds[rid] && !deleted[rid]) merged.push(r);
  });
  return merged;
}

// v1.4.40: Banner amarillo dismissible que reporta cambios de lotes hechos
// por otro Desktop (Cesar u otra máquina). Se muestra después del sync-pull
// solo si hubo cambios significativos. Es dismissible y NO bloquea el uso.
function _showLotsSyncBanner(report) {
  if (!report) return;
  var hasChanges = report.added > 0 || report.advanced.length > 0 || report.countChanged.length > 0 || report.removed > 0;
  if (!hasChanges) return;

  // Remover banner viejo si existe
  var existing = document.getElementById('_lots-sync-banner');
  if (existing && existing.parentNode) existing.parentNode.removeChild(existing);

  var lines = [];
  if (report.added > 0) lines.push('• <strong>'+report.added+'</strong> lote'+(report.added!==1?'s':'')+' nuevo'+(report.added!==1?'s':'')+' incorporado'+(report.added!==1?'s':'')+' del server');
  if (report.advanced.length > 0) {
    var advSummary = report.advanced.slice(0,3).map(function(a){ return a.code+' ('+a.from+' → '+a.to+')'; }).join(', ');
    if (report.advanced.length > 3) advSummary += ' y '+(report.advanced.length-3)+' más';
    lines.push('• <strong>'+report.advanced.length+'</strong> lote'+(report.advanced.length!==1?'s':'')+' cambió'+(report.advanced.length!==1?'aron':'')+' de estado: '+advSummary);
  }
  if (report.countChanged.length > 0) {
    var ccSummary = report.countChanged.slice(0,3).map(function(c){ return c.code+' ('+c.from+' → '+c.to+' cab.)'; }).join(', ');
    if (report.countChanged.length > 3) ccSummary += ' y '+(report.countChanged.length-3)+' más';
    lines.push('• <strong>'+report.countChanged.length+'</strong> lote'+(report.countChanged.length!==1?'s':'')+' con conteo actualizado: '+ccSummary);
  }
  if (report.removed > 0) lines.push('• <strong>'+report.removed+'</strong> lote'+(report.removed!==1?'s':'')+' borrado'+(report.removed!==1?'s':'')+' por server');

  var banner = document.createElement('div');
  banner.id = '_lots-sync-banner';
  banner.style.cssText = 'position:fixed;top:60px;left:50%;transform:translateX(-50%);z-index:9000;max-width:680px;width:calc(100% - 40px);padding:12px 16px;background:#FAEEDA;border:1px solid #BA7517;border-left:4px solid #BA7517;border-radius:10px;box-shadow:0 4px 12px rgba(0,0,0,.15);font-family:var(--font-sans,system-ui)';
  banner.innerHTML =
    '<div style="display:flex;align-items:flex-start;gap:10px">' +
      '<div style="font-size:18px;line-height:1">⚠️</div>' +
      '<div style="flex:1">' +
        '<div style="font-size:13px;font-weight:600;color:#412402;margin-bottom:4px">Otro dispositivo hizo cambios en lotes mientras estabas fuera</div>' +
        '<div style="font-size:12px;color:#633806;line-height:1.6">'+lines.join('<br>')+'</div>' +
      '</div>' +
      '<button id="_lots-banner-close" style="background:none;border:none;color:#633806;cursor:pointer;font-size:18px;padding:0;line-height:1;flex-shrink:0">×</button>' +
    '</div>';
  document.body.appendChild(banner);

  document.getElementById('_lots-banner-close').addEventListener('click', function(){
    if (banner.parentNode) banner.parentNode.removeChild(banner);
  });

  // Auto-dismiss después de 25 segundos
  setTimeout(function(){
    if (banner.parentNode) banner.parentNode.removeChild(banner);
  }, 25000);

  // Refrescar UI por las dudas (el sync ya lo hace, pero por si el banner llega tarde)
  if (typeof renderLotes === 'function') try { renderLotes(); } catch(e){}
  if (typeof renderDashboard === 'function') try { renderDashboard(); } catch(e){}
}

function setSyncStatus(state) {
  var btn = document.getElementById('desktop-sync-btn');
  var icon = document.getElementById('desktop-sync-icon');
  var label = document.getElementById('desktop-sync-label');
  var dot = document.getElementById('sync-dot');
  if (state === 'syncing') {
    if (icon) icon.textContent = '⟳';
    if (label) label.textContent = 'Sincronizando...';
    if (btn) btn.style.color = 'var(--amber2)';
    if (dot) dot.style.background = 'var(--amber2)';
  } else if (state === 'ok') {
    if (icon) icon.textContent = '✓';
    if (label) label.textContent = 'Sincronizado';
    if (btn) btn.style.color = 'var(--green)';
    if (dot) dot.style.background = 'var(--green)';
    setTimeout(function() { setSyncStatus('idle'); }, 3000);
  } else if (state === 'error') {
    if (icon) icon.textContent = '✕';
    if (label) label.textContent = 'Sin conexion';
    if (btn) btn.style.color = 'var(--red)';
    if (dot) dot.style.background = 'var(--red)';
    setTimeout(function() { setSyncStatus('idle'); }, 4000);
  } else {
    if (icon) icon.textContent = '↻';
    if (label) label.textContent = 'Sync';
    if (btn) btn.style.color = 'var(--text)';
    if (dot) dot.style.background = '';
  }
}

function manualSync() {
  if (!navigator.onLine) { setSyncStatus('error'); return; }
  setSyncStatus('syncing');
  pullFromRailwayDesktop(false);
}

function pullFromRailwayDesktop(thenPush) {
  window._pullFromRailway_real = pullFromRailwayDesktop;
  if (!navigator.onLine) return;
  var apiUrl = getApiUrl();
  var token  = localStorage.getItem('e5m_api_token') || '';
  if (!token) { if (thenPush) pushToRailway(); return; } // No token → skip pull
  var headers = { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token, 'X-App-Version': _APP_VERSION, 'X-App-Type': 'desktop' };

  fetch(apiUrl + '/sync-pull?include_sold=true', { headers: headers, signal: (function(){ var c=new AbortController(); setTimeout(function(){c.abort();},8000); return c.signal; })() })
    .then(function(r){ return r.json(); })
    .then(function(remote) {
      if (!remote || remote.error) {
        if (thenPush) pushToRailway();
        return;
      }

      // ═══ CHECK DE VERSIÓN MÍNIMA ═══
      // Si el server exige una versión más nueva, mostrar modal bloqueante.
      // No corta el flujo de sync (los datos se cargan igual), pero después bloquea la UI.
      if (remote.desktop_min_version && typeof checkMinVersionRequired === 'function') {
        try {
          checkMinVersionRequired(remote.desktop_min_version, remote.desktop_latest_version);
        } catch(e) { console.warn('[MinVersion] Error chequeando:', e); }
      }

      // ═══ FIX v1.4.40: Sync de lots con server-wins por progresión monotónica ═══
      // Antes: solo se actualizaba paddock. Si Cesar marcaba cuarentena desde otro
      // Desktop, tu Desktop seguía mostrando cuarentena obsoleta + nuevos lotes
      // creados por él no aparecían. Resultado: data inconsistente al abrir.
      //
      // Ahora: el server gana cuando representa "progreso" del lote:
      //   • status avanzó: cuarentena → marcado_completo → activo → vendido
      //   • animal_count bajó (marcaje parcial, venta parcial, bajas)
      // Local gana cuando:
      //   • vos avanzaste algo que server no sabe (push pendiente)
      //   • notas locales NO se pisan
      //   • trackDeletion bloquea resurrección
      //
      // Acumulamos cambios para mostrar banner amarillo al usuario.
      if (remote.lots && remote.lots.length) {
        // Tracking de cambios para banner
        if (!window._lotsSyncReport) window._lotsSyncReport = { added:0, advanced:[], countChanged:[], removed:0 };
        var _report = window._lotsSyncReport;

        // Orden de prioridad de status (monotónico)
        function _statusPriority(s) {
          var n = String(s || '').toLowerCase();
          if (n === 'cuarentena') return 1;
          if (n === 'marcado_completo') return 2;
          if (n === 'activo' || n === 'active' || n === '') return 3;
          if (n === 'vendido' || n === 'sold') return 4;
          return 3; // default activo
        }
        function _statusLabel(s) {
          var n = String(s || '').toLowerCase();
          if (n === 'cuarentena') return 'cuarentena';
          if (n === 'marcado_completo') return 'marcado';
          if (n === 'vendido' || n === 'sold') return 'vendido';
          return 'activo';
        }

        // Mapas server + deleted
        var serverLotIds = {};
        var serverLotCodes = {};
        var serverLotByCode = {};
        remote.lots.forEach(function(rl){
          if (rl.id != null) serverLotIds[String(rl.id)] = true;
          if (rl.code) { serverLotCodes[rl.code] = true; serverLotByCode[rl.code] = rl; }
        });
        var serverDeletedLotIds = {};
        try {
          var _serverDel = remote._deleted_ids || remote.deleted_ids || {};
          Object.keys(_serverDel).forEach(function(k){
            if (k.indexOf('lots:') === 0) serverDeletedLotIds[k.substring(5)] = true;
          });
        } catch(e) {}
        var localDeleted = getDeletedIds('lots');

        // Paso 1: actualizar lotes existentes (local Y server) con reglas server-wins
        (db.lots || []).forEach(function(localLot) {
          var serverLot = serverLotByCode[localLot.code];
          if (!serverLot) return;

          // ═══ v1.4.106: SYNC INDEPENDIENTE DE PADDOCK ═══
          // El paddock debe sincronizarse por timestamp (server vs local), INDEPENDIENTE
          // de status/count/progreso. Antes el paddock se sincronizaba solo si server "ganaba"
          // en alguna de esas tres dimensiones — por eso una rotación del bot (que no cambia
          // status/count/progreso) NO actualizaba lot.paddock localmente, causando que el
          // Desktop mostrara el lote en el potrero viejo.
          // Regla: si server tiene last_paddock_change o paddock_updated_at más nuevo que el local,
          // server-wins en paddock. Si el local no tiene timestamp, asumir que server gana.
          try {
            var srvPadTs = serverLot.last_paddock_change || serverLot.paddock_updated_at || '';
            var lclPadTs = localLot.last_paddock_change || localLot.paddock_updated_at || '';
            var paddockChanged = serverLot.paddock && serverLot.paddock !== localLot.paddock;
            if (paddockChanged) {
              if (!lclPadTs || (srvPadTs && srvPadTs > lclPadTs)) {
                console.log('[Sync paddock] ' + localLot.code + ': "' + (localLot.paddock||'-') + '" → "' + serverLot.paddock + '" (server ts=' + srvPadTs + ' > local ts=' + lclPadTs + ')');
                localLot.paddock = serverLot.paddock;
                if (srvPadTs) localLot.last_paddock_change = srvPadTs;
                if (serverLot.paddock_updated_at) localLot.paddock_updated_at = serverLot.paddock_updated_at;
              }
            }
          } catch(e) {}

          var localPri = _statusPriority(localLot.status);
          var serverPri = _statusPriority(serverLot.status);
          var localCount = parseFloat(localLot.animal_count) || 0;
          var serverCount = parseFloat(serverLot.animal_count) || 0;
          var localProg = parseFloat(localLot.marcaje_progreso) || 0;
          var serverProg = parseFloat(serverLot.marcaje_progreso) || 0;

          // ¿Server gana?
          var serverWinsStatus = serverPri > localPri;
          var serverWinsCount  = (serverPri === localPri) && (serverCount < localCount);
          var serverWinsProg   = (serverPri === localPri) && (serverProg > localProg);
          var serverWins = serverWinsStatus || serverWinsCount || serverWinsProg;

          if (!serverWins) return;

          // Adoptar campos del server (preservar notas locales)
          var oldStatus = localLot.status;
          var oldCount = localLot.animal_count;

          if (serverWinsStatus) {
            localLot.status = serverLot.status;
            _report.advanced.push({ code: localLot.code, from: _statusLabel(oldStatus), to: _statusLabel(serverLot.status) });
          }
          localLot.animal_count = serverCount;
          if (serverLot.avg_weight != null) localLot.avg_weight = serverLot.avg_weight;
          if (serverLot.paddock) localLot.paddock = serverLot.paddock;
          if (serverLot.category) localLot.category = serverLot.category;
          if (serverLot.breed) localLot.breed = serverLot.breed;
          if (serverLot.entry_date) localLot.entry_date = serverLot.entry_date;
          if (serverLot.marcaje_progreso != null) localLot.marcaje_progreso = serverLot.marcaje_progreso;
          if (serverLot.marcaje_completo_at) localLot.marcaje_completo_at = serverLot.marcaje_completo_at;
          if (serverLot.marcaje_lot_destino) localLot.marcaje_lot_destino = serverLot.marcaje_lot_destino;
          // NOTAS LOCALES: NO se pisan (intencional)
          // localLot.notes se preserva

          if (serverWinsCount && !serverWinsStatus) {
            _report.countChanged.push({ code: localLot.code, from: oldCount, to: serverCount });
          }
        });

        // Paso 2: incorporar lotes nuevos del server (no en local, no en trackDeletion)
        remote.lots.forEach(function(rl) {
          if (!rl.code) return;
          var existsLocal = (db.lots || []).some(function(l){ return l.code === rl.code; });
          if (existsLocal) return;
          // Verificar si el usuario lo borró explícitamente
          var ridStr = String(rl.id || '');
          if (localDeleted[ridStr]) {
            console.log('[Sync] Lote ' + rl.code + ' (id ' + rl.id + ') ignorado — está en trackDeletion local');
            return;
          }
          // v1.8.24: proteger contra colisión de id. Si el id que viene del server ya está
          // en uso localmente por OTRO lote (distinto code), reasignar id único antes de push.
          // Los lotes se referencian por code, así que cambiar el id local es seguro.
          var ridNum = parseInt(rl.id);
          var idEnUso = (db.lots || []).some(function(l){ return String(l.id) === String(rl.id) && l.code !== rl.code; });
          if (isNaN(ridNum) || idEnUso || rl.id === undefined || rl.id === null) {
            var maxId = (db.lots||[]).reduce(function(m,l){var n=parseInt(l.id);return (!isNaN(n)&&n>m)?n:m;},0);
            if (!db.next_ids) db.next_ids = {};
            if (!db.next_ids.lot || db.next_ids.lot <= maxId) db.next_ids.lot = maxId + 1;
            console.log('[Sync] Lote ' + rl.code + ' tenía id en conflicto (' + rl.id + ') → reasignado a ' + db.next_ids.lot);
            rl.id = db.next_ids.lot++;
          }
          // Agregar al local
          db.lots.push(rl);
          _report.added++;
          // v1.4.106: REVERT v1.4.105. NO llamar _ensureRotationEntry acá.
          // Razon: db.rotation_history puede no estar actualizado todavía cuando
          // llegan los lots del server (race entre pull de lots y pull de rotation_history),
          // entonces el helper veía "no hay entry abierta" y creaba una nueva, generando
          // duplicados con la entry real que llegaba después en el pull de rotation_history.
          // El server v4.5.1 ya mantiene rotation_history consistente — el Desktop no debe
          // intentar "completarlo" por su cuenta en sync. Para datos legacy de server v4.5.0,
          // usar el endpoint POST /api/admin/backfill-rotation-history.
          console.log('[Sync] Lote nuevo incorporado del server: ' + rl.code + ' (status: ' + (rl.status||'activo') + ')');
        });

        // Paso 3: reconciliación de borrados (solo los marcados explícitamente por server)
        var beforeLen = (db.lots || []).length;
        db.lots = (db.lots || []).filter(function(l){
          // Mantener si está en server
          if (serverLotIds[String(l.id)] || serverLotCodes[l.code]) return true;
          // BORRAR solo si server explícitamente marcó como borrado
          if (serverDeletedLotIds[String(l.id)]) {
            console.log('[Sync] Server marcó como borrado el lote: ' + l.code + ' (id ' + l.id + ')');
            try {
              var _anim = JSON.parse(localStorage.getItem('e5m_animals') || '{}');
              if (_anim[l.code]) { delete _anim[l.code]; localStorage.setItem('e5m_animals', JSON.stringify(_anim)); }
            } catch(e) {}
            _report.removed++;
            return false;
          }
          // Sino, mantener (probablemente push pendiente)
          return true;
        });
        if (beforeLen !== (db.lots || []).length) {
          console.log('[Sync] Reconciliación de lotes: ' + beforeLen + ' → ' + (db.lots || []).length);
        }

        // Mostrar banner si hubo cambios significativos
        try { _showLotsSyncBanner(_report); } catch(e) { console.warn('[Sync] Banner error:', e); }
        window._lotsSyncReport = { added:0, advanced:[], countChanged:[], removed:0 };
      }

      // Re-sincronizar animal_count: respetando ventas (lotes en status 'vendido' deben quedar en 0)
      var _syncAnim = (typeof getAnimalesDB === 'function') ? getAnimalesDB() : {};
      db.lots.forEach(function(lt) {
        // Si el lote fue vendido, no resucitar el count desde el cache de animales
        if (lt.status === 'vendido' || lt.status === 'sold') {
          lt.animal_count = 0;
          return;
        }
        var anims = _syncAnim[lt.code];
        if (anims && anims.length > 0) {
          // FUENTE DE VERDAD: cuenta de animales en e5m_animals[code]
          // El server puede tener animal_count desactualizado (por ej. si un push viejo
          // mandó un valor menor que la cantidad real de animales). Nunca aceptar un valor
          // del server menor que la cantidad real de animales en cache.
          var serverLot = (remote.lots || []).find(function(rl){ return rl.code === lt.code; });
          var serverCount = (serverLot && typeof serverLot.animal_count === 'number') ? serverLot.animal_count : 0;
          // Si server dice MÁS que el cache (caso de venta parcial registrada en otro device), preferir server
          // Si server dice MENOS, usar cache (cache tiene la verdad de los animales reales)
          // v1.8.78: si el server dice MÁS pero por poco (baja/venta local aún no propagada), seguir la realidad local.
          if (anims.length >= serverCount || (serverCount - anims.length) <= Math.max(3, serverCount * 0.05)) lt.animal_count = anims.length; else lt.animal_count = Math.max(serverCount, anims.length);
          var ws = anims.map(function(a){ return a.pesajes && a.pesajes.length ? a.pesajes[a.pesajes.length-1].peso : 0; }).filter(function(w){ return w > 0; });
          if (ws.length) lt.avg_weight = Math.round(ws.reduce(function(s,w){return s+w;},0)/ws.length*10)/10;
        }
      });

      // Merge tablas de campo — mergeArrays usa getDeletedIds() para excluir borrados
      var fieldTables = [
        { local: 'pesajes',    remote: remote.pesajes },
        { local: 'activities', remote: remote.field_activities },
        { local: 'advances',   remote: remote.advances },
        { local: 'treatments', remote: remote.treatments },
        { local: 'maintenance',remote: remote.maintenance },
        { local: 'agua',       remote: remote.agua },
        { local: 'sal',        remote: remote.sal },
        { local: 'conteo',     remote: remote.conteo },
        { local: 'partos',     remote: remote.partos },
        { local: 'alimento',   remote: remote.alimento },
        { local: 'lluvias',    remote: remote.lluvias },
        { local: 'diesel',     remote: remote.diesel },
        { local: 'purchases',  remote: remote.purchases },
        { local: 'aceite',     remote: remote.aceite },
        { local: 'bajas',      remote: remote.bajas },
        { local: 'rotation_history', remote: remote.rotation_history },
        { local: 'pasture_evals', remote: remote.pasture_evals },
        { local: 'reproductive_services', remote: remote.reproductive_services },
        { local: 'maquinaria', remote: remote.maquinaria },
        { local: 'sales',      remote: remote.sales },
        { local: 'inventory_counts', remote: remote.inventory_counts },
        { local: 'compras_ganado', remote: remote.compras_ganado },
        { local: 'kardex',         remote: remote.kardex },
        { local: 'cuentas',        remote: remote.cuentas },
        { local: 'historial_sueldos', remote: remote.historial_sueldos },
        { local: 'bonos', remote: remote.bonos },
        { local: 'bajas_personal', remote: remote.bajas_personal },
        { local: 'contrataciones', remote: remote.contrataciones },
        { local: 'health_alerts',  remote: remote.health_alerts },
        { local: 'employees',      remote: remote.employees },
        // v1.8.66: traer también los movimientos de animales del server (log append-only).
        // Sin esto, los traslados hechos en otro equipo / PWA / botón individual viejo
        // no existían localmente y la Trazabilidad completa no podía mostrarlos.
        { local: 'animal_movements', remote: remote.animal_movements },
      ];
      fieldTables.forEach(function(t) {
        if (t.remote && t.remote.length) {
          db[t.local] = mergeArrays(db[t.local] || [], t.remote, 'id', t.local);
          if (t.local === 'pasture_evals') console.log('[Sync] Pasture evals received:', t.remote.length, '-> merged:', db.pasture_evals.length);
        }
      });
      // Force init pasture_evals if not exist
      if (!db.pasture_evals) db.pasture_evals = [];

      // Products: sincronizar stock_qty desde Railway (bot/PWA pueden descontar)
      // FIX v1.4.51: incorporar productos nuevos del server (antes solo actualizaba existentes,
      // lo cual hacía Stock quedar vacío al cambiar de tenant o arrancar con cache limpio)
      if (remote.products && remote.products.length) {
        if (!db.products) db.products = [];
        var localDeletedProducts = (typeof getDeletedIds === 'function') ? getDeletedIds('products') : {};
        remote.products.forEach(function(rp) {
          var local = db.products.find(function(p) { return p.id == rp.id || p.name === rp.name; });
          if (local) {
            // Railway gana en stock si fue actualizado más recientemente
            var remoteStockAt = rp.stock_updated_at || '';
            var localStockAt = local.stock_updated_at || '';
            if (remoteStockAt >= localStockAt) {
              local.stock_qty = rp.stock_qty;
              local.stock_updated_at = rp.stock_updated_at;
            }
            // Adoptar campos editados en server (nombre, unit, type, min, expiry, cost)
            if (rp.name && rp.name !== local.name) local.name = rp.name;
            if (rp.unit && rp.unit !== local.unit) local.unit = rp.unit;
            if (rp.type && rp.type !== local.type) local.type = rp.type;
            if (rp.stock_min != null) local.stock_min = rp.stock_min;
            if (rp.expiry_date !== undefined) local.expiry_date = rp.expiry_date;
            if (rp.cost != null) local.cost = rp.cost;
          } else {
            // Producto NO está en local. ¿Lo borramos explícitamente?
            var ridStr = String(rp.id || '');
            if (localDeletedProducts[ridStr]) {
              console.log('[Sync] Producto ' + rp.name + ' (id ' + rp.id + ') ignorado — está en trackDeletion local');
              return;
            }
            // Producto nuevo del server: incorporar
            db.products.push(rp);
            console.log('[Sync] Producto nuevo incorporado del server: ' + rp.name + ' (stock: ' + (rp.stock_qty || 0) + ' ' + (rp.unit || 'u') + ')');
          }
        });
      }

      // Tasks: Railway gana, solo preservar tareas locales creadas offline (últimas 2 horas)
      // FIX: Si server devuelve [] (blip), no pisar — preservar copia local
      if (remote.tasks && remote.tasks.length) {
        var remoteTasks = remote.tasks || [];
        var deleted = getDeletedIds('tasks');
        var merged = remoteTasks.filter(function(t) { return !deleted[String(t.id)]; });
        // Solo preservar tareas locales offline MUY recientes (< 2 horas) que no están en Railway
        var localTasks = JSON.parse(localStorage.getItem('e5m_tasks') || '[]');
        var remoteIds = {};
        remoteTasks.forEach(function(t) { remoteIds[t.id] = true; });
        localTasks.forEach(function(t) {
          if (remoteIds[t.id]) return;
          if (deleted[String(t.id)]) return;
          var age = Date.now() - (t.created_at ? new Date(t.created_at).getTime() : 0);
          if (age < 7200000 && t._offline) merged.push(t); // solo si fue creada offline y tiene < 2h
        });
        localStorage.setItem('e5m_tasks', JSON.stringify(merged));
        if (typeof renderTareas === 'function') renderTareas();
      }

      localStorage.setItem(DB_KEY, JSON.stringify(db));
      if (typeof renderBajasDesktop === 'function') try { renderBajasDesktop(); } catch(e){}
      if (typeof renderActividades === 'function') try { renderActividades(); } catch(e){}

      // Aplicar branding si viene en el pull
      // Sincronizar animales desde Railway — server es fuente de verdad
      // (PWA puede registrar bajas/partos que el Desktop debe ver)
      if (remote.animals && typeof remote.animals === 'object' && !Array.isArray(remote.animals)) {
        var localAnimals = (typeof getAnimalesDB === 'function') ? getAnimalesDB() : {};
        var remoteAnimals = remote.animals;
        // Identificar lotes con cambios PENDIENTES locales (compras/ventas no sincronizadas)
        var pendingLots = {};
        try {
          var pending = (typeof getPendingDesktopRecords === 'function') ? getPendingDesktopRecords() : [];
          pending.forEach(function(item){
            if (item && item.record && item.record.lot_code) pendingLots[item.record.lot_code] = true;
            if (item && item.lot_code) pendingLots[item.lot_code] = true;
          });
        } catch(e) {}

        // v1.8.76 (Opción acotada): renames de ID pendientes de confirmar push — lista {lot, oldId, newId}.
        // En vez de preservar el LOTE entero (que ignoraría cambios del server en OTROS animales del lote),
        // protegemos SOLO el animal renombrado hasta que el push confirme (ahí se limpia e5m_pending_renames).
        var renamesByLot = {};
        try {
          var _pr = JSON.parse(localStorage.getItem('e5m_pending_renames')||'[]');
          if (Array.isArray(_pr)) _pr.forEach(function(r){ if (r && r.lot) { (renamesByLot[r.lot] = renamesByLot[r.lot] || []).push(r); } });
        } catch(e) {}

        var merged = {};
        // Server gana por default.
        // v1.8.76 (FIX raíz): arrastrar del animal LOCAL (match por animal_id) los campos que el server NO
        // almacena/devuelve: parto_id, sexo, id_updated_at, _needs_id. Sin esto el merge los borraba en CADA
        // sync → se rompía la trazabilidad cría↔parto (saveReproParto no encontraba el animal por parto_id)
        // y se perdía el sexo. Si el server SÍ los devuelve (round-trip), se respeta el valor del server.
        Object.keys(remoteAnimals).forEach(function(lc) {
          var localById = {};
          (localAnimals[lc]||[]).forEach(function(la){ var k = String(la.animal_id || la.id || ''); if (k) localById[k] = la; });
          merged[lc] = (remoteAnimals[lc]||[]).map(function(a) {
            var aid = a.animal_id || a.id || '';
            var la = localById[String(aid)] || {};
            var obj = { id: aid, animal_id: aid, raza: a.breed || a.raza || la.raza || '', breed: a.breed || a.raza || la.breed || '', pesajes: a.pesajes || [] };
            var partoId = (a.parto_id != null && a.parto_id !== '') ? a.parto_id : la.parto_id;
            if (partoId != null && partoId !== '') obj.parto_id = partoId;
            var sexo = a.sexo || la.sexo;
            if (sexo) obj.sexo = sexo;
            if (la.id_updated_at) obj.id_updated_at = la.id_updated_at;
            if (la._needs_id) obj._needs_id = la._needs_id;
            return obj;
          });
        });
        // v1.8.76 (Opción acotada): aplicar los renames pendientes SOLO al animal afectado, sin tocar el resto del lote.
        // Por cada {oldId→newId}: quitar el id viejo (que el server aún no actualizó) e inyectar el nuevo desde el
        // cache si el server todavía no lo trae. El resto del lote queda con lo que mandó el server (server-wins).
        Object.keys(renamesByLot).forEach(function(lc) {
          if (!Array.isArray(merged[lc])) merged[lc] = [];
          var localByIdLc = {};
          (localAnimals[lc]||[]).forEach(function(la){ var k = String(la.animal_id || la.id || ''); if (k) localByIdLc[k] = la; });
          renamesByLot[lc].forEach(function(r){
            var oldId = String(r.oldId||''), newId = String(r.newId||'');
            if (!newId) return;
            if (oldId && oldId !== newId) merged[lc] = merged[lc].filter(function(x){ return String(x.animal_id||x.id||'') !== oldId; });
            var yaEsta = merged[lc].some(function(x){ return String(x.animal_id||x.id||'') === newId; });
            if (!yaEsta && localByIdLc[newId]) { merged[lc].push(localByIdLc[newId]); console.log('[Sync] Rename protegido (acotado): ' + lc + ' ' + oldId + '→' + newId); }
          });
        });
        // Preservar el LOTE completo solo por cambios pendientes pre-existentes (compras/ventas sin sincronizar).
        Object.keys(localAnimals).forEach(function(lc) {
          if (pendingLots[lc] && localAnimals[lc] && localAnimals[lc].length) {
            console.log('[Sync] Preservando lote completo', lc, 'por pending (compras/ventas)');
            merged[lc] = localAnimals[lc];
          }
        });
        // v1.8.78: dedupe SEGURO por animal_id. Solo colapsa duplicados IDÉNTICOS (mismo id, misma raza y pesajes).
        // Si dos comparten id pero son DISTINTOS (colisión de rename), NO se borra: se re-etiqueta uno y se marca para revisión.
        Object.keys(merged).forEach(function(lc){
          var _byId={}, _out=[];
          (merged[lc]||[]).forEach(function(a){
            var k=String((a&&(a.animal_id||a.id))||'');
            if(!k){ _out.push(a); return; }
            var prev=_byId[k];
            if(!prev){ _byId[k]=a; _out.push(a); return; }
            var igual = String(prev.raza||prev.breed||'')===String(a.raza||a.breed||'') && JSON.stringify(prev.pesajes||[])===JSON.stringify(a.pesajes||[]);
            if(igual){ console.log('[Sync] Duplicado idéntico descartado en '+lc+': '+k); return; }
            var nk=k+'-DUP'+Math.floor(Math.random()*1000);
            a.animal_id=nk; a.id=nk; a._needs_id=true; a._colision_de=k;
            _byId[nk]=a; _out.push(a);
            console.warn('[Sync] COLISIÓN de ID en '+lc+': "'+k+'" (animales distintos) → re-id "'+nk+'" + _needs_id (no se pierde el animal)');
          });
          merged[lc]=_out;
        });
        localStorage.setItem('e5m_animals', JSON.stringify(merged));
        var totalMerged = Object.values(merged).reduce(function(s, a){ return s + (a ? a.length : 0); }, 0);
        console.log('[Sync] Animals OK: ' + Object.keys(merged).length + ' lots, ' + totalMerged + ' animals (server-wins)');
      }

      // FIX v1.4.33: helper de last-write-wins por timestamp 'updated_at'.
      // Antes la regla "Desktop is source of truth" permitía que defaults locales pisaran
      // los reales del server (bug que afectó a César con potreros/categorías). Ahora el más
      // reciente por timestamp gana. Aplica a: branding, diesel_tank, estancia_params,
      // report_params, pluvios_config.
      function _isServerNewer(localTs, serverTs) {
        if (!serverTs) return false;       // server no tiene timestamp → no pisar local
        if (!localTs) return true;          // local no tiene timestamp → server gana
        try { return new Date(serverTs).getTime() > new Date(localTs).getTime(); }
        catch(e) { return false; }
      }
      // FIX v1.4.33: branding usa last-write-wins
      if (remote.branding && remote.branding.name) {
        var localBrand = {};
        try { localBrand = JSON.parse(localStorage.getItem('e5m_branding')||'{}'); } catch(e){}
        var brandEmpty = !localBrand.name;
        var brandServerNewer = _isServerNewer(localBrand.updated_at, remote.branding.updated_at);
        if (brandEmpty || brandServerNewer) {
          localStorage.setItem('e5m_branding', JSON.stringify(remote.branding));
          if (typeof applyBranding === 'function') applyBranding(remote.branding);
          console.log('[Sync] Branding loaded from server (' + (brandEmpty ? 'local was empty' : 'server newer') + ')');
        }
      }
      // FIX v1.4.33: diesel_tank ahora usa last-write-wins (timestamp en clave separada
      // e5m_diesel_tank_updated_at porque diesel_tank es array).
      if (remote.diesel_tank && ((Array.isArray(remote.diesel_tank) && remote.diesel_tank.length) || remote.diesel_tank.capacity)) {
        var localTanks = [];
        try { localTanks = JSON.parse(localStorage.getItem('e5m_diesel_tank')||'[]'); } catch(e){}
        var tanksEmpty = !localTanks.length && !localTanks.capacity;
        var localTanksTs = localStorage.getItem('e5m_diesel_tank_updated_at');
        var remoteTanksTs = remote.diesel_tank_updated_at || null;  // si el server lo expone
        var tanksServerNewer = _isServerNewer(localTanksTs, remoteTanksTs);
        if (tanksEmpty || tanksServerNewer) {
          localStorage.setItem('e5m_diesel_tank', JSON.stringify(remote.diesel_tank));
          if (remoteTanksTs) localStorage.setItem('e5m_diesel_tank_updated_at', remoteTanksTs);
          console.log('[Sync] Diesel tanks loaded from server (' + (tanksEmpty ? 'local was empty' : 'server newer') + ')');
        }
      }
      // FIX v1.4.33: estancia_params, report_params, pluvios_config (mismo patrón)
      // estancia_params
      if (remote.estancia_params && typeof remote.estancia_params === 'object' && !Array.isArray(remote.estancia_params) && Object.keys(remote.estancia_params).length) {
        var localParams = {};
        try { localParams = JSON.parse(localStorage.getItem('e5m_params')||'{}'); } catch(e){}
        var localEmpty = !localParams.potreros || !localParams.potreros.length;
        var serverNewer = _isServerNewer(localParams.updated_at, remote.estancia_params.updated_at);
        if (localEmpty || serverNewer) {
          localStorage.setItem('e5m_params', JSON.stringify(remote.estancia_params));
          console.log('[Sync] Params loaded from server (' + (localEmpty ? 'local was empty' : 'server newer: ' + remote.estancia_params.updated_at + ' > ' + localParams.updated_at) + ')');
        }
      }
      // report_params
      if (remote.report_params && typeof remote.report_params === 'object' && !Array.isArray(remote.report_params) && Object.keys(remote.report_params).length) {
        var localRP = {};
        try { localRP = JSON.parse(localStorage.getItem('e5m_report_params')||'{}'); } catch(e){}
        var rpEmpty = !localRP.whatsapp_phone && !localRP.lat && !localRP.nombre_estancia;
        var rpServerNewer = _isServerNewer(localRP.updated_at, remote.report_params.updated_at);
        if (rpEmpty || rpServerNewer) {
          localStorage.setItem('e5m_report_params', JSON.stringify(remote.report_params));
          console.log('[Sync] Report params loaded from server (' + (rpEmpty ? 'local was empty' : 'server newer') + ')');
        }
      }
      // pluvios_config (es array, timestamp vive en clave separada e5m_pluvios_updated_at)
      if (remote.pluvios_config && Array.isArray(remote.pluvios_config) && remote.pluvios_config.length) {
        var localPluvios = [];
        try { localPluvios = JSON.parse(localStorage.getItem('e5m_pluvios')||'[]'); } catch(e){}
        var localPluviosTs = localStorage.getItem('e5m_pluvios_updated_at');
        var remotePluviosTs = remote.pluvios_config_updated_at || null;  // si el server lo expone
        var pluviosEmpty = !localPluvios.length;
        var pluviosServerNewer = _isServerNewer(localPluviosTs, remotePluviosTs);
        if (pluviosEmpty || pluviosServerNewer) {
          localStorage.setItem('e5m_pluvios', JSON.stringify(remote.pluvios_config));
          if (remotePluviosTs) localStorage.setItem('e5m_pluvios_updated_at', remotePluviosTs);
          console.log('[Sync] Pluvios loaded from server (' + (pluviosEmpty ? 'local was empty' : 'server newer') + ')');
        }
      }
      if (remote.inventory_counts && Array.isArray(remote.inventory_counts) && remote.inventory_counts.length) {
        localStorage.setItem('e5m_inventory_counts', JSON.stringify(remote.inventory_counts));
      }

      // FIX Blindaje IDs: tras aplicar los datos del server, subir los contadores locales
      // por encima del máximo id presente para que ningún "next_ids.X++" reemita un id ya usado.
      if (typeof reconcileNextIds === 'function') reconcileNextIds();

      // Re-render todo
      if (typeof renderLotes === 'function') renderLotes();
      if (typeof renderRotacion === 'function') renderRotacion(); // FIX v1.4.30: el tab Rotación no se re-renderizaba tras pull
      if (typeof renderDashboard === 'function') renderDashboard();
      if (typeof renderStock === 'function') renderStock();
      if (typeof renderCompras === 'function') renderCompras();
      if (typeof renderSubmodule === 'function') {
        ['agua','sal','conteo','partos','alimento'].forEach(function(t){ renderSubmodule(t); });
      }
      if (typeof renderPesajes === 'function') renderPesajes();
      if (typeof renderMantenimiento === 'function') renderMantenimiento();
      if (typeof renderVentas === 'function') renderVentas();
      if (typeof renderComprasGanado === 'function') renderComprasGanado();
      if (typeof renderDieselDesktop === 'function') renderDieselDesktop();
      if (typeof renderPersonal === 'function') renderPersonal();
      if (typeof renderAdvances === 'function') renderAdvances();
      if (typeof renderActividades === 'function') renderActividades();
      if (typeof renderTareas === 'function') renderTareas();
      if (typeof renderContabilidad === 'function') try { renderContabilidad(); } catch(e){}
      if (typeof renderReporteCREA === 'function') try { renderReporteCREA(); } catch(e){}
      // FIX v1.4.31: 9 renderXxx que solo se invocaban en tab-switch.
      // Si el usuario estaba viendo uno de estos tabs durante un pull, los
      // datos nuevos no se reflejaban hasta cambiar de pestaña y volver.
      // El más crítico es renderSanidad porque alerts vienen de la PWA.
      if (typeof renderLluviasDesktop === 'function') try { renderLluviasDesktop(); } catch(e){}
      if (typeof renderBajasDesktop === 'function') try { renderBajasDesktop(); } catch(e){}
      if (typeof renderMaquinaria === 'function') try { renderMaquinaria(); } catch(e){}
      if (typeof renderEvalPasto === 'function') try { renderEvalPasto(); } catch(e){}
      if (typeof renderHistorialSueldos === 'function') try { renderHistorialSueldos(); } catch(e){}
      if (typeof renderKardex === 'function') try { renderKardex(); } catch(e){}
      if (typeof renderSanidad === 'function') try { renderSanidad(); } catch(e){}
      if (typeof renderHistorialAnimales === 'function') try { renderHistorialAnimales(); } catch(e){}
      if (typeof renderConteoHistory === 'function') try { renderConteoHistory(); } catch(e){}

      if (thenPush) {
        setSyncStatus('ok');
        // Push con delay para no congelar la UI después del re-render
        setTimeout(function() { pushToRailway(); }, 2000);
      } else {
        setSyncStatus('ok');
      }
      // Registrar el last_sync_at: este es el timestamp del server al momento del pull.
      // Si el server vuelve a cambiar después, last_modified > last_sync_at y sabremos.
      try {
        if (remote.last_modified) {
          localStorage.setItem('e5m_last_sync_at', remote.last_modified);
        } else {
          localStorage.setItem('e5m_last_sync_at', new Date().toISOString());
        }
      } catch(e){}
    })
    .catch(function() {
      setSyncStatus('error');
      if (thenPush) pushToRailway();
    });
}

function pullThenPush() {
  // Pull datos del campo, luego push solo registros del desktop (no lotes)
  if (!navigator.onLine) return;
  pullFromRailwayDesktop(true);
}

function pushDesktopRecords() {
  // Push solo los registros que maneja el desktop, sin sobreescribir lotes del campo
  if (!navigator.onLine) return;
  if (window._restoreInProgress) { console.log('[PushDesktop] Bloqueado por restore en progreso'); return; }
  if (sessionStorage.getItem('_post_restore') === '1') { console.log('[PushDesktop] Bloqueado por post-restore'); return; }
  var apiUrl = getApiUrl();
  var token  = localStorage.getItem('e5m_api_token') || '';
  var tasks  = JSON.parse(localStorage.getItem('e5m_tasks') || '[]');
  var payload = {
    source: 'desktop',
    preserve_lots: true,
    db: {
      products:         db.products,
      treatments:       db.treatments,
      health_alerts:    db.alerts,
      sales:            db.sales,
      purchases:        db.purchases,
      employees:        db.employees,
      field_activities: db.activities,
      pesajes:          db.pesajes || [],
      advances:         db.advances || [],
      maintenance:      db.maintenance || [],
      agua:             db.agua || [],
      sal:              db.sal || [],
      conteo:           db.conteo || [],
      partos:           db.partos || [],
      alimento:         db.alimento || [],
      lluvias:          db.lluvias || [],
      diesel:           db.diesel || [],
      aceite:           db.aceite || [],
      historial_sueldos: db.historial_sueldos || [],
      bonos:            db.bonos || [],
      bajas_personal:   db.bajas_personal || [],
      contrataciones:   db.contrataciones || [],
      kardex:           db.kardex || [],
      cuentas:          db.cuentas || [],
      compras_ganado:   db.compras_ganado || [],
      bajas:            db.bajas || [],
      maquinaria:       db.maquinaria || [],
      rotation_history: db.rotation_history || [],
      pasture_evals:    db.pasture_evals || [],
      animal_movements: db.animal_movements || [],
      reproductive_services: db.reproductive_services || [],
      tasks_list:       tasks,
    },
    preserve_lots: true
  };
  fetch(apiUrl + '/sync-push', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
    body: JSON.stringify(payload),
  }).then(function(r){
    if (!r.ok) { console.error('pushDesktop HTTP error:', r.status); return r.text().then(function(t){ console.error(t); return {ok:false}; }); }
    return r.json();
  }).then(function(d){
    if (d && d.ok) {
      setSyncStatus('ok');
      console.log('pushDesktop OK:', d.pushed);
      try { localStorage.setItem('e5m_last_sync_at', new Date().toISOString()); } catch(e){}
    }
    else { console.error('pushDesktop failed:', d); }
  }).catch(function(e){ console.error('pushDesktop error:', e); });
}

function pushToRailway() {
  if (!navigator.onLine) return;
  // Bloquear durante restore en progreso o post-restore (primeros 30 seg después del reload)
  if (window._restoreInProgress) { console.log('[Push] Bloqueado por restore en progreso'); return; }
  if (sessionStorage.getItem('_post_restore') === '1') { console.log('[Push] Bloqueado por post-restore'); return; }

  // ═══ #2 PRE-PUSH CHECK: ¿el server tiene cambios más nuevos que mi última sync?
  // Si sí → pullear primero, después pushear (evita pisar cambios de PWA u otra PC)
  var apiUrlPre = getApiUrl();
  var tokenPre  = localStorage.getItem('e5m_api_token') || '';
  var lastSyncAt = localStorage.getItem('e5m_last_sync_at') || '';
  if (tokenPre && lastSyncAt) {
    fetch(apiUrlPre + '/last-modified', {
      headers: { 'Authorization': 'Bearer ' + tokenPre },
      signal: (function(){ var c=new AbortController(); setTimeout(function(){c.abort();},5000); return c.signal; })()
    })
    .then(function(r){ return r.ok ? r.json() : null; })
    .then(function(meta){
      if (meta && meta.last_modified && meta.last_modified > lastSyncAt) {
        console.warn('[PrePushCheck] Server cambió desde mi última sync: server=' + meta.last_modified + ' | local=' + lastSyncAt + ' → pulleando primero');
        toast('Hay cambios en el server, sincronizando antes de subir tus datos...', 'info');
        // Pull primero, después de 2s push
        pullFromRailwayDesktop(false);
        setTimeout(function() { _doPushToRailway(); }, 3500);
      } else {
        // Server no cambió o nunca synceé → push directo
        _doPushToRailway();
      }
    })
    .catch(function(){
      // Si falla el check, push directo (no bloqueamos por error de red)
      _doPushToRailway();
    });
  } else {
    // Sin token o sin last_sync previa → push directo
    _doPushToRailway();
  }
}

function _doPushToRailway() {
  if (!navigator.onLine) return;
  var apiUrl = getApiUrl();
  var token  = localStorage.getItem('e5m_api_token') || '';
  var tasks  = JSON.parse(localStorage.getItem('e5m_tasks') || '[]');
  // FIX continuidad: reconciliar animal_count desde e5m_animals ANTES de armar el push.
  // e5m_animals[code] es la fuente de verdad. Si difiere de lot.animal_count, el cache gana.
  var _reconcAnim = (typeof getAnimalesDB === 'function') ? getAnimalesDB() : {};
  db.lots.forEach(function(lt){
    if (lt.status === 'vendido' || lt.status === 'sold') return;
    var anims = _reconcAnim[lt.code];
    if (anims && anims.length > 0 && anims.length !== (lt.animal_count || 0)) {
      console.log('[Push] Reconciliando '+lt.code+': animal_count '+(lt.animal_count||0)+' → '+anims.length);
      lt.animal_count = anims.length;
    }
  });
  // Para lotes: el desktop solo gestiona metadata (codigo, categoria, raza, notas, status)
  // paddock y animal_count son propiedad del campo (PWA) - no sobreescribir
  var lotsForPush = db.lots.map(function(l) {
    return {
      id: l.id, code: l.code, category: l.category, breed: l.breed,
      entry_date: l.entry_date, status: l.status, notes: l.notes,
      // Incluir paddock y animal_count solo si Railway no tiene datos del campo
      paddock: l.paddock, animal_count: l.animal_count, avg_weight: l.avg_weight
    };
  });
  var payload = {
    source: 'desktop',
    db: {
      lots:             lotsForPush,
      products:         db.products,
      treatments:       db.treatments,
      health_alerts:    db.alerts,
      sales:            db.sales,
      purchases:        db.purchases,
      employees:        db.employees,
      field_activities: db.activities,
      pesajes:          db.pesajes || [],
      advances:         db.advances || [],
      maintenance:      db.maintenance || [],
      agua:             db.agua || [],
      sal:              db.sal || [],
      conteo:           db.conteo || [],
      partos:           db.partos || [],
      alimento:         db.alimento || [],
      lluvias:          db.lluvias || [],
      diesel:           db.diesel || [],
      aceite:           db.aceite || [],
      historial_sueldos: db.historial_sueldos || [],
      bonos:            db.bonos || [],
      bajas_personal:   db.bajas_personal || [],
      contrataciones:   db.contrataciones || [],
      kardex:           db.kardex || [],
      cuentas:          db.cuentas || [],
      compras_ganado:   db.compras_ganado || [],
      bajas:            db.bajas || [],
      maquinaria:       db.maquinaria || [],
      rotation_history: db.rotation_history || [],
      pasture_evals:    db.pasture_evals || [],
      reproductive_services: db.reproductive_services || [],
      tasks_list:       tasks,
      animals: (function(){
        try {
          var raw = JSON.parse(localStorage.getItem('e5m_animals')||'{}');
          // Normalizar: convertir {id, raza} a {animal_id, breed} para la PWA
          var normalized = {};
          Object.keys(raw).forEach(function(lotCode) {
            normalized[lotCode] = (raw[lotCode]||[]).map(function(a) {
              var o = {
                animal_id: a.animal_id || a.id || '',
                breed: a.breed || a.raza || '',
                pesajes: a.pesajes || []
              };
              // v1.8.76: conservar el vínculo cría↔parto y el sexo en el server (si hace round-trip de campos extra)
              if (a.parto_id != null && a.parto_id !== '') o.parto_id = a.parto_id;
              if (a.sexo) o.sexo = a.sexo;
              return o;
            });
          });
          return normalized;
        } catch(e) { return {}; }
      })(),
      report_params: (function(){ try { return JSON.parse(localStorage.getItem('e5m_report_params')||'{}'); } catch(e){ return {}; } })(),
      estancia_params: (function(){ try { return JSON.parse(localStorage.getItem('e5m_params')||'{}'); } catch(e){ return {}; } })(),
      diesel_tank: (function(){ try { return JSON.parse(localStorage.getItem('e5m_diesel_tank')||'[]'); } catch(e){ return []; } })(),
      pluvios_config: (function(){ try { return JSON.parse(localStorage.getItem('e5m_pluvios')||'[]'); } catch(e){ return []; } })(),
    },
    tasks_replace: true  // Desktop es dueno de tasks - siempre reemplazar en Railway
  };
  fetch(apiUrl + '/sync-push', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
    body: JSON.stringify(payload),
  })
  .then(function(r){
    if (!r.ok) { console.error('Push HTTP error:', r.status, r.statusText); return r.text().then(function(t){ console.error('Push body:', t); return {ok:false}; }); }
    return r.json();
  })
  .then(function(d){
    if (d && d.ok) {
      setSyncStatus('ok');
      console.log('Push OK:', d.pushed);
      // Actualizar last_sync_at: después de push exitoso, mi estado local está alineado con el server
      try { localStorage.setItem('e5m_last_sync_at', new Date().toISOString()); } catch(e){}
      // v1.8.76: el push exitoso ya subió los renames de ID → liberar la protección de los animales renombrados.
      try { localStorage.removeItem('e5m_pending_renames'); } catch(e){}
    }
    else { console.error('Push failed:', d); }
  })
  .catch(function(e){ console.error('Push error:', e); });
}

// Safety: ensure db has all required fields
var movingLotId = null;
function ensureDB() {
  if (!db.next_ids) db.next_ids = {lot:10,product:10,treatment:10,alert:10,sale:10,purchase:10,employee:10,activity:10,trace:10};
  // Restaurar animales si se borraron con localStorage.clear()
  // Animals se cargan del servidor via sync-pull, no hardcodeados
  // Sincronizar animal_count: usar MAX para no reducir lotes parcialmente tracked
  var animalsDB = (typeof getAnimalesDB === 'function') ? getAnimalesDB() : {};
  db.lots.forEach(function(lot) {
    var animals = animalsDB[lot.code];
    if (animals && animals.length > 0) {
      // v1.8.78: seguir la realidad también hacia abajo en caídas chicas (baja/venta); MAX solo si la caída es grande (lote por conteo).
      var _cur = lot.animal_count || 0;
      if (animals.length >= _cur || (_cur - animals.length) <= Math.max(3, _cur * 0.05)) lot.animal_count = animals.length; else lot.animal_count = Math.max(_cur, animals.length);
      // Recalcular avg_weight desde el ultimo pesaje de cada animal
      var ws = animals.map(function(a){ return a.pesajes && a.pesajes.length ? a.pesajes[a.pesajes.length-1].peso : 0; }).filter(function(w){ return w > 0; });
      if (ws.length) lot.avg_weight = Math.round(ws.reduce(function(s,w){return s+w;},0)/ws.length*10)/10;
    }
  });
  var tables = {lot:"lots",product:"products",treatment:"treatments",alert:"alerts",sale:"sales",purchase:"purchases",employee:"employees",activity:"activities",trace:"trace_records",advance:"advances",maint:"maintenance",pesaje:"pesajes"};
  if (!db.pesajes) db.pesajes = [];
  if (!db.agua) db.agua = [];
  if (!db.sal) db.sal = [];
  if (!db.conteo) db.conteo = [];
  if (!db.partos) db.partos = [];
  if (!db.alimento) db.alimento = [];
  if (!db.maintenance) db.maintenance = [];
  if (!db.advances) db.advances = [];
  if (!db.bonos) db.bonos = [];
  if (!db.bajas_personal) db.bajas_personal = [];
  if (!db.contrataciones) db.contrataciones = [];
  if (!db.lluvias) db.lluvias = [];
  if (!db.diesel) db.diesel = [];
  if (!db.aceite) db.aceite = [];
  Object.keys(tables).forEach(function(key) {
    var tbl = tables[key];
    if (!db[tbl]) db[tbl] = [];
    var maxId = db[tbl].reduce(function(m,r){ return Math.max(m,r.id||0); },0);
    if (!db.next_ids[key] || db.next_ids[key] <= maxId) db.next_ids[key] = maxId+1;
  });
}


