  if (periodoF) statsBase = _reproPartosFilterPeriodo(statsBase, periodoF);
  if (loteF) statsBase = statsBase.filter(function(r) { return r.lot_code === loteF; });
  _reproPartosRenderStats(_reproPartosComputeStats(statsBase));

