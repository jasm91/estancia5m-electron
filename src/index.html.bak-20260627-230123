// ═══════════════════════════════════════════════════════════

// Estado global de la pestaña
window._salTab    = 'sal';   // mantenido por compat con código viejo, siempre 'sal' aquí
window._salPeriod = 6;        // 3, 6, 12 meses
window._salTipo   = '';       // '' = todas, sino tipo normalizado (ej: 'mineral')
window._salCharts = { potreros: null, lotes: null, tipo: null };

// Helper: infiere paddock de un lote en una fecha dada usando rotation_history
// Devuelve el paddock activo de ese lote en esa fecha (o el actual si no hay history).
function _salGetPaddockAt(lot_code, dateStr) {
  if (!lot_code) return null;
  var target = String(dateStr || '').slice(0, 10);
  if (!target) {
    var lot = (db.lots || []).find(function(l){ return l && l.code === lot_code; });
    return lot ? lot.paddock : null;
  }
  // Buscar la entry de rotation_history activa en esa fecha:
  // entry_date <= target AND (exit_date IS NULL OR exit_date >= target)
  var entries = (db.rotation_history || []).filter(function(r){
    return r && r.lot_code === lot_code &&
      String(r.entry_date || '').slice(0,10) <= target &&
      (!r.exit_date || String(r.exit_date).slice(0,10) >= target);
  });
  if (entries.length > 0) {
    // Si hay varias (raro), tomar la más reciente entry_date
    entries.sort(function(a,b){ return String(b.entry_date||'').localeCompare(String(a.entry_date||'')); });
    return entries[0].potrero || null;
  }
  // Fallback: paddock actual del lote
  var lot2 = (db.lots || []).find(function(l){ return l && l.code === lot_code; });
  return lot2 ? lot2.paddock : null;
}

// Helper: filtra productos por categoria (sal o alimento)
function _salIsProductOfCategory(p, cat) {
  if (!p) return false;
  var t = String(p.type || '').toLowerCase();
  var st = String(p.subtype || p.sub_type || '').toLowerCase();
  var c = String(p.category || '').toLowerCase();
  if (cat === 'sal') {
    return t === 'sal_mineral' || t === 'sal' || st === 'sal_mineral' || st === 'sal' ||
           c === 'sal_mineral' || c === 'sal' || c === 'sal y suplementos' ||
           t === 'sal y suplementos';
  }
  if (cat === 'alimento') {
    return t === 'alimento' || t === 'concentrado' || t === 'racion' ||
           st === 'alimento' || st === 'concentrado' || st === 'racion' ||
           c === 'alimento' || c === 'concentrados' || c === 'alimento y forraje';
  }
  return false;
}

// Helper: devuelve los registros del tab actual (db.sal o db.alimento) en el período
function _salGetRecords(tab, periodMonths) {
  var table = tab === 'sal' ? (db.sal || []) : (db.alimento || []);
  var cutoff = new Date();
  cutoff.setMonth(cutoff.getMonth() - periodMonths);
  var cutoffStr = cutoff.toISOString().slice(0,10);
  return table.filter(function(r){
    if (!r) return false;
    var f = String(r.fecha || r.applied_at || r.date || r.created_at || '').slice(0,10);
    return f >= cutoffStr;
  });
}

// Helper: ¿qué mes (YYYY-MM) corresponde a un registro?
function _salRecordMonth(r) {
  var f = String(r.fecha || r.applied_at || r.date || r.created_at || '').slice(0, 7);
  return f;
}

// Helper: para un registro, devuelve el paddock asociado.
// Si el registro tiene paddock guardado, lo usa.
// Si no, infiere desde lot_code + fecha (rotation_history).
function _salGetRecordPaddock(r) {
  if (r.paddock) return r.paddock;
  if (r.lot_code) return _salGetPaddockAt(r.lot_code, r.fecha || r.applied_at || r.date);
  return null;
}

// Agregación por potrero: {YYYY-MM: {potrero: kg}}
function _salAggregateByPaddock(records) {
  var result = {};
  records.forEach(function(r){
    var month = _salRecordMonth(r);
    if (!month) return;
    var paddock = _salGetRecordPaddock(r) || 'Sin asignar';
    var kg = parseFloat(r.qty || r.total || r.kg || 0);
    if (!kg) return;
    if (!result[month]) result[month] = {};
    if (!result[month][paddock]) result[month][paddock] = 0;
    result[month][paddock] += kg;
  });
  return result;
}

// Agregación por lote con atribución proporcional.
// Para registros con scope=lot y lot_code → asigna 100% a ese lote.
// Para registros sin lot_code pero con paddock → reparte entre los lotes presentes en ese
// potrero en esa fecha, proporcional a cabezas en ese momento.
function _salAggregateByLot(records) {
  var byLot = {};
  records.forEach(function(r){
    var kg = parseFloat(r.qty || r.total || r.kg || 0);
    if (!kg) return;
    var lotCode = r.lot_code;
    var fecha = r.fecha || r.applied_at || r.date;
    if (lotCode) {
      // Directo: asignación 100%
      if (!byLot[lotCode]) byLot[lotCode] = 0;
      byLot[lotCode] += kg;
    } else {
      // Sin lot_code: necesitamos paddock + atribución proporcional
      var paddock = r.paddock || _salGetRecordPaddock(r);
      if (!paddock) return;
      // Buscar lotes que estaban en ese paddock en esa fecha
      var lotesEnPotrero = _salLotsInPaddockAt(paddock, fecha);
      if (lotesEnPotrero.length === 0) return;
      var totalCab = lotesEnPotrero.reduce(function(s,l){ return s + (l.cab || 0); }, 0);
      if (totalCab <= 0) {
        // Reparto equitativo si no hay datos de cabezas
        var perLot = kg / lotesEnPotrero.length;
        lotesEnPotrero.forEach(function(l){
          if (!byLot[l.code]) byLot[l.code] = 0;
          byLot[l.code] += perLot;
        });
      } else {
        lotesEnPotrero.forEach(function(l){
          var share = (l.cab / totalCab) * kg;
          if (!byLot[l.code]) byLot[l.code] = 0;
          byLot[l.code] += share;
        });
      }
    }
  });
  // Convertir a array ordenado descendente
  return Object.keys(byLot).map(function(code){
    return { lot_code: code, kg: byLot[code] };
  }).sort(function(a,b){ return b.kg - a.kg; });
}

// Helper: lotes presentes en un paddock en una fecha, con cabezas en ese momento.
function _salLotsInPaddockAt(paddock, dateStr) {
  if (!paddock) return [];
  var target = String(dateStr || '').slice(0, 10);
  // Buscar rotation_history entries que cubran esa fecha en ese paddock
  var entries = (db.rotation_history || []).filter(function(r){
    if (!r || r.potrero !== paddock) return false;
    var entry = String(r.entry_date || '').slice(0,10);
    var exit = r.exit_date ? String(r.exit_date).slice(0,10) : '9999-12-31';
    return entry <= target && exit >= target;
  });
  // Map a {code, cab}
  return entries.map(function(r){
    return {
      code: r.lot_code,
      cab: parseInt(r.animal_count || r.cabezas || 0, 10) || 0
    };
  });
}

