// v1.4.78: Histograma de pesos en pestaña Animales
// Solo aparece cuando hay un lote específico seleccionado.
// Buckets de 10 kg con colores semáforo según diferencia con el promedio.
// Click en una barra → selecciona automáticamente todos los animales del bucket.
window._animalesHistChart = null;
window._animalesHistBuckets = null;
function renderAnimalesHistograma(animalsArr, lotCode) {
  var card = document.getElementById('animales-histograma-card');
  if (!card) return;

  // Solo mostrar si hay lote específico y datos suficientes
  if (!lotCode || !animalsArr || animalsArr.length < 3) {
    card.style.display = 'none';
    return;
  }

  // Extraer pesos válidos
  var weights = animalsArr.map(function(a) {
    var ps = a.pesajes || [];
    return ps.length ? ps[ps.length-1].peso : 0;
  }).filter(function(w){return w > 0;});

  if (weights.length < 3) {
    card.style.display = 'none';
    return;
  }

  // Calcular bucket size dinámico — 10 kg por defecto, ajustar si rango muy grande/chico
  var mn = Math.min.apply(null, weights);
  var mx = Math.max.apply(null, weights);
  var range = mx - mn;
  var bucketSize = 10;
  if (range > 200) bucketSize = 20;
  else if (range > 100) bucketSize = 10;
  else if (range > 50) bucketSize = 5;
  else bucketSize = 5;

  var firstBucket = Math.floor(mn / bucketSize) * bucketSize;
  var lastBucket = Math.ceil(mx / bucketSize) * bucketSize;
  var nBuckets = (lastBucket - firstBucket) / bucketSize;
  var buckets = [];
  for (var i = 0; i < nBuckets; i++) {
    var min = firstBucket + i * bucketSize;
    buckets.push({ min: min, max: min + bucketSize, count: 0, animals: [] });
  }

  // Asignar animales a buckets
  animalsArr.forEach(function(a) {
    var ps = a.pesajes || [];
    var w = ps.length ? ps[ps.length-1].peso : 0;
    if (!w) return;
    var idx = Math.min(Math.floor((w - firstBucket) / bucketSize), buckets.length - 1);
    if (idx >= 0) {
      buckets[idx].count++;
      buckets[idx].animals.push({ id: a.id, lot: lotCode, weight: w });
    }
  });

  window._animalesHistBuckets = buckets;

  // Stats para evaluar dispersión
  var avg = weights.reduce(function(a,b){return a+b;},0) / weights.length;
  var variance = weights.reduce(function(s,w){return s + Math.pow(w - avg, 2);}, 0) / weights.length;
  var stdev = Math.sqrt(variance);
  var cv = (stdev / avg) * 100;  // Coeficiente de variación

  // Colores semáforo según distancia al promedio
  // - verde: bucket cercano al promedio (±0.5σ)
  // - amarillo: distancia media (±1σ)
  // - rojo: outliers (>1σ)
  var labels = buckets.map(function(b){ return b.min + '-' + b.max + ' kg'; });
  var counts = buckets.map(function(b){ return b.count; });
  var colors = buckets.map(function(b) {
    var center = (b.min + b.max) / 2;
    var dist = Math.abs(center - avg) / stdev;
    if (dist < 0.5) return 'rgba(57,211,83,0.85)';   // verde - core
    if (dist < 1.0) return 'rgba(212,160,23,0.85)';  // amber - desviación moderada
    if (dist < 1.5) return 'rgba(255,140,0,0.85)';   // naranja - alejados
    return 'rgba(248,81,73,0.85)';                    // rojo - outliers
  });

  // Insight automático: ¿conviene separar?
  var insightEl = document.getElementById('animales-hist-insight');
  if (insightEl) {
    var insight, color;
    if (cv < 8) {
      insight = '✓ Lote uniforme (CV ' + cv.toFixed(1) + '%) — no requiere separación';
      color = 'var(--green)';
    } else if (cv < 15) {
      insight = '⚠ Dispersión moderada (CV ' + cv.toFixed(1) + '%) — considerar 2 grupos';
      color = 'var(--amber2)';
    } else {
      insight = '⚠ Alta dispersión (CV ' + cv.toFixed(1) + '%) — recomendable separar';
      color = 'var(--red)';
    }
    insightEl.textContent = insight;
    insightEl.style.color = color;
  }

  // Subtitle
  var subtEl = document.getElementById('animales-hist-subtitle');
  if (subtEl) {
    subtEl.textContent = 'Click una barra para seleccionar el grupo · Prom: ' + avg.toFixed(1) +
      ' kg · σ: ' + stdev.toFixed(1) + ' kg · Min/Max: ' + mn + '/' + mx + ' kg';
  }

  card.style.display = 'block';

  // Destroy previous chart
  if (window._animalesHistChart) {
    try { window._animalesHistChart.destroy(); } catch(e){}
    window._animalesHistChart = null;
  }

  if (typeof Chart === 'undefined') return;
  var ctx = document.getElementById('animales-hist-chart');
  if (!ctx) return;

  window._animalesHistChart = new Chart(ctx, {
    type: 'bar',
    data: {
      labels: labels,
      datasets: [{
        data: counts,
        backgroundColor: colors,
        borderRadius: 6,
        borderSkipped: false
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      onClick: function(evt, elements) {
        if (elements && elements.length > 0) {
          var idx = elements[0].index;
          selectBucketAnimals(idx);
        }
      },
      onHover: function(evt, elements) {
        evt.native.target.style.cursor = elements.length ? 'pointer' : 'default';
      },
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor: 'rgba(13,17,23,0.95)',
          borderColor: 'var(--bor)',
          borderWidth: 1,
          titleFont: { family: 'DM Mono,monospace', size: 11 },
          bodyFont: { family: 'DM Mono,monospace', size: 11 },
          callbacks: {
            label: function(ctx) {
              var b = buckets[ctx.dataIndex];
              var pct = ((b.count / weights.length) * 100).toFixed(1);
              return b.count + ' animales (' + pct + '%) · Click para seleccionar';
            }
          }
        }
      },
      scales: {
        x: {
          grid: { display: false },
          ticks: { font: { size: 10, family: 'DM Mono,monospace' }, color: '#888' }
        },
        y: {
          beginAtZero: true,
          grid: { color: 'rgba(48,54,61,0.3)' },
          ticks: { stepSize: 1, font: { size: 10, family: 'DM Mono,monospace' }, color: '#888' }
        }
      }
    }
  });
}

// Click en barra del histograma → seleccionar todos los animales de ese bucket
function selectBucketAnimals(bucketIdx) {
  var buckets = window._animalesHistBuckets;
  if (!buckets || !buckets[bucketIdx]) return;
  var bucket = buckets[bucketIdx];
  if (bucket.count === 0) return;

  // Marcar el rango en los inputs del modal de rango (preview)
  // y agregar a la selección
  var added = 0;
  bucket.animals.forEach(function(a) {
    var key = a.lot + '::' + a.id;
    if (!window._bulkSelected[key]) {
      window._bulkSelected[key] = a;
      added++;
    }
    // Actualizar el checkbox correspondiente si está visible
    var cb = document.querySelector('.bulk-row-check[data-key="' + key + '"]');
    if (cb && !cb.checked) {
      cb.checked = true;
      var row = cb.closest('tr');
      if (row) row.style.background = 'rgba(212,160,23,.05)';
    }
  });
  bulkRefreshBar();
  toast(bucket.count + ' animales seleccionados · rango ' + bucket.min + '–' + bucket.max + ' kg', 'success');
}

