function startTour() {
  _tourStep = 0;
  showTourStep();
}

function nextTourStep() {
  _tourStep++;
  if (_tourStep >= _TOUR_STEPS.length) {
    addAiMsg('assistant', '🎉 **¡Tour completado!**\nYa conocés todas las secciones de EstanciaPro. Recordá que podés preguntarme en cualquier momento:\n\n• "¿Cómo hago X?" → te guío paso a paso\n• "¿Cómo vamos?" → analizo tus datos\n• "tour guiado" → repetir el recorrido\n\n¡Éxitos con tu estancia! 🐄');
    _tourStep = -1;
    return;
  }
  showTourStep();
}

function prevTourStep() {
  if (_tourStep > 0) _tourStep--;
  showTourStep();
}

function exitTour() {
  _tourStep = -1;
  addAiMsg('assistant', 'Tour cancelado. Podés retomarlo cuando quieras escribiendo "tour guiado". 👋');
}

function showTourStep() {
  var step = _TOUR_STEPS[_tourStep];
  if (!step) return;
  var parts = step.page.split('/');
  var page = parts[0];
  var tab = parts[1] || '';
  var btn = null; try { btn = document.querySelector('.nav-btn[onclick*="'+page+'"]'); } catch(e) {}
  if (typeof showPage === 'function') showPage(page, btn);
  // Páginas que requieren inicialización adicional
  if (page === 'analisis-lote' && typeof initAnalisisLote === 'function') {
    setTimeout(function(){ initAnalisisLote(); }, 150);
  }
  if (tab && typeof showLotesTab === 'function') {
    setTimeout(function(){ showLotesTab('lotes-tab-' + tab, document.getElementById('lotes-tab-' + tab + '-btn')); }, 200);
  }
  var container = document.getElementById('ai-messages');
  if (!container) return;
  var div = document.createElement('div');
  div.style.cssText = 'max-width:90%;padding:12px 14px;border-radius:12px;font-size:12px;line-height:1.6;align-self:flex-start;background:var(--sur2);color:var(--text);border:1px solid var(--bor);border-bottom-left-radius:4px';
  var h = '<div style="font-size:10px;color:var(--amber2);font-weight:700;margin-bottom:4px">PASO ' + (_tourStep+1) + ' DE ' + _TOUR_STEPS.length + '</div>';
  h += '<div style="font-size:14px;font-weight:700;margin-bottom:8px">' + step.title + '</div>';
  h += '<div>' + step.text.replace(/\\n/g,'<br>').replace(/\*\*([^*]+)\*\*/g,'<b>$1</b>') + '</div>';
  h += '<div style="display:flex;gap:6px;margin-top:10px;flex-wrap:wrap">';
  if (_tourStep > 0) h += '<button onclick="prevTourStep()" style="padding:5px 12px;background:var(--sur);border:1px solid var(--bor);border-radius:6px;color:var(--text);font-size:11px;cursor:pointer">⬅️ Anterior</button>';
  if (_tourStep < _TOUR_STEPS.length - 1) h += '<button onclick="nextTourStep()" style="padding:5px 14px;background:rgba(245,166,35,.2);border:1px solid rgba(245,166,35,.4);border-radius:6px;color:var(--amber2);font-size:11px;font-weight:700;cursor:pointer">Siguiente ➡️</button>';
  else h += '<button onclick="nextTourStep()" style="padding:5px 14px;background:rgba(245,166,35,.2);border:1px solid rgba(245,166,35,.4);border-radius:6px;color:var(--amber2);font-size:11px;font-weight:700;cursor:pointer">🎉 Finalizar</button>';
  h += '<button onclick="exitTour()" style="padding:5px 10px;background:none;border:1px solid var(--bor);border-radius:6px;color:var(--muted);font-size:11px;cursor:pointer">✕ Salir</button>';
  h += '</div>';
  div.innerHTML = h;
  container.appendChild(div);
  container.scrollTop = container.scrollHeight;
}

function sendAiMsg() {
  var input = document.getElementById('ai-input');
  var text = (input ? input.value : '').trim();
  if (!text) return;
  input.value = '';
  addAiMsg('user', text);

  // Check for tour command
  var textLower = text.toLowerCase().trim();
  if (textLower === 'iniciar tour guiado') {
    startTour();
    return;
  }

  _aiHistory.push({ role: 'user', parts: [{ text: text }] });

  // v1.4.27: ya no se valida key local; el server maneja la disponibilidad

  var typingDiv = document.createElement('div');
  typingDiv.id = 'ai-typing';
  typingDiv.style.cssText = 'align-self:flex-start;padding:8px 14px;background:var(--sur2);border:1px solid var(--bor);border-radius:12px;font-size:12px;color:var(--muted)';
  typingDiv.innerHTML = '<span style="display:inline-block;animation:pulse 1s infinite">🤖 Pensando...</span>';
  document.getElementById('ai-messages').appendChild(typingDiv);
  document.getElementById('ai-messages').scrollTop = 999999;

  aiGenerate({
    system_instruction: { parts: [{ text: _AI_PROMPT + '\nDATOS ACTUALES DE LA ESTANCIA:\n' + buildAiDataContext() }] },
    contents: _aiHistory.slice(-10),
    generationConfig: { maxOutputTokens: 2048, temperature: 0.3 }
  })
  .then(function(d) {
    var typing = document.getElementById('ai-typing');
    if (typing) typing.remove();
    var reply = '';
    try { reply = d.candidates[0].content.parts[0].text; } catch(e) {
      reply = d.error ? 'Error: ' + (d.error.message||'API error') : 'No pude responder. Intenta de nuevo.';
    }
    _aiHistory.push({ role: 'model', parts: [{ text: reply }] });
    addAiMsg('assistant', reply);
  })
  .catch(function(e) {
    var typing = document.getElementById('ai-typing');
    if (typing) typing.remove();
    addAiMsg('assistant', 'Error: ' + e.message);
  });
}

