    items.push({date:r.created_at||r.date,icon:'🔧',color:'var(--red)',title:(r.title||r.desc||'Mantenimiento'),sub:(r.cost?'Bs.'+r.cost:'')+(r.status?' — '+r.status:'')});
  });
  items.sort(function(a,b){return (b.date||'').localeCompare(a.date||'');});

  var title = document.getElementById('maq-hist-title');
  if (title) title.textContent = '📋 ' + maq.nombre + ' — Historial';
