function setContDate(range) {
  var now = new Date();
  var y = now.getFullYear(), m = now.getMonth(), d = now.getDate();
  var desde = '', hasta = localDate();
  if (range === 'hoy') {
    desde = hasta;
  } else if (range === 'semana') {
    var day = now.getDay() || 7;
    var monday = new Date(now); monday.setDate(d - day + 1);
    desde = localDate(monday);
  } else if (range === 'mes') {
    desde = y + '-' + String(m+1).padStart(2,'0') + '-01';
  } else if (range === 'anio') {
    desde = y + '-01-01';
  } else if (range === 'todo') {
    desde = '';
    hasta = '';
  }
  var dEl = document.getElementById('cont-f-desde'); if(dEl) dEl.value = desde;
  var hEl = document.getElementById('cont-f-hasta'); if(hEl) hEl.value = hasta;
  // Marcar que el usuario eligió un período explícitamente para que renderContabilidad
  // no lo pise con su default
  window._contDateUserChoice = true;
  renderContabilidad();
}

