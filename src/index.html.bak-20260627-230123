function populateCuentaSelects() {
  var params = getParams();
  // Subcuenta dropdown grouped by cuenta
  var sSel = document.getElementById('cu-subcuenta');
  if (sSel) {
    sSel.innerHTML = '<option value="">Seleccionar subcuenta...</option>';
    var grouped = {};
    (params.subcuentas||[]).forEach(function(s){
      var c = s.cuenta || 'OTROS';
      if (!grouped[c]) grouped[c] = [];
      grouped[c].push(s.name);
    });
    // Also add subcuentas already used in db.cuentas
    (db.cuentas||[]).forEach(function(r){
      if(r.subcuenta && r.cuenta) {
        if(!grouped[r.cuenta]) grouped[r.cuenta]=[];
        if(grouped[r.cuenta].indexOf(r.subcuenta)<0) grouped[r.cuenta].push(r.subcuenta);
      }
    });
    Object.keys(grouped).sort().forEach(function(cuenta){
      var optg = document.createElement('optgroup');
      optg.label = cuenta;
      grouped[cuenta].sort().forEach(function(name){
        var o = document.createElement('option'); o.value = name; o.textContent = name;
        optg.appendChild(o);
      });
      sSel.appendChild(optg);
    });
  }
  // Cuenta (readonly, auto-filled)
  var cSel = document.getElementById('cu-cuenta');
  if (cSel) cSel.value = '';
  // Tipo (hidden, will be auto-set)
  var tSel = document.getElementById('cu-tipo');
  if (tSel && tSel.options.length < 2) {
    tSel.innerHTML = '';
    (params.tipos_gasto||[]).forEach(function(t){
      var o = document.createElement('option'); o.value = t.name; o.textContent = t.name;
      tSel.appendChild(o);
    });
  }
}

function autofillCuCuenta() {
  var params = getParams();
  var subName = (document.getElementById('cu-subcuenta')||{}).value || '';
  if (!subName) return;
  var sub = (params.subcuentas||[]).find(function(s){ return s.name === subName; });
  var cuenta = sub ? sub.cuenta : '';
  var cSel = document.getElementById('cu-cuenta');
  if (cSel) {
    cSel.innerHTML = '<option value="'+cuenta+'">'+cuenta+'</option>';
    cSel.value = cuenta;
  }
  var tipo = resolveCuentaTipoGasto(params, sub, '');
  var tSel = document.getElementById('cu-tipo');
  if (tSel) tSel.value = tipo;
}

function refreshContabilidad() {
  var btn = document.getElementById('btn-cont-refresh');
  // Feedback visual: cambiar texto y deshabilitar mientras sincroniza
  var originalLabel = btn ? btn.innerHTML : '';
  if (btn) { btn.innerHTML = '⏳ Sincronizando...'; btn.disabled = true; }

  function doneOk() {
    try { renderContabilidad(); } catch(e){}
    if (btn) { btn.innerHTML = '✓ Actualizado'; setTimeout(function(){ btn.innerHTML = originalLabel || '🔄 Actualizar'; btn.disabled = false; }, 1200); }
  }
  function doneErr() {
    try { renderContabilidad(); } catch(e){}
    if (btn) { btn.innerHTML = originalLabel || '🔄 Actualizar'; btn.disabled = false; }
    toast('Sin conexión — mostrando solo datos locales', 'warn');
  }

  if (!navigator.onLine) { doneErr(); return; }
  var apiUrl = (typeof getApiUrl === 'function') ? getApiUrl() : '';
  var token  = localStorage.getItem('e5m_api_token') || '';
  if (!token || !apiUrl) { doneErr(); return; }

  // Pull directo y al terminar re-renderizamos
  fetch(apiUrl + '/sync-pull?include_sold=true', {
    headers: { 'Content-Type':'application/json', 'Authorization':'Bearer '+token, 'X-App-Type':'desktop' },
    signal: (function(){ var c=new AbortController(); setTimeout(function(){c.abort();},10000); return c.signal; })()
  })
  .then(function(r){ return r.json(); })
  .then(function(remote){
    if (!remote || remote.error) { doneErr(); return; }
    // Mergear las tablas relevantes para Contabilidad: purchases, sales, advances, maintenance, diesel, cuentas
    // Estrategia: agregar/actualizar registros del remote que no estén en local (por id)
    function mergeById(localArr, remoteArr) {
      if (!Array.isArray(remoteArr)) return localArr || [];
      var out = (localArr || []).slice();
      var seen = {};
      out.forEach(function(r){ if (r && r.id != null) seen[String(r.id)] = true; });
      var deleted = (typeof getDeletedIds === 'function') ? getDeletedIds : function(){ return {}; };
      remoteArr.forEach(function(r){
        if (!r || r.id == null) return;
        var k = String(r.id);
        if (!seen[k]) {
          out.push(r);
          seen[k] = true;
        }
      });
      return out;
    }
    var tables = ['purchases','sales','advances','maintenance','diesel','cuentas','treatments','sal','alimento','reproductive_services'];
    tables.forEach(function(t){
      if (Array.isArray(remote[t])) db[t] = mergeById(db[t], remote[t]);
    });
    // Filtrar borrados locales (trackDeletion)
    if (typeof getDeletedIds === 'function') {
      tables.forEach(function(t){
        var del = getDeletedIds(t);
        if (del && Object.keys(del).length && Array.isArray(db[t])) {
          db[t] = db[t].filter(function(r){ return !del[String(r && r.id)]; });
        }
      });
    }
    localStorage.setItem(DB_KEY, JSON.stringify(db));
    doneOk();
  })
  .catch(function(){ doneErr(); });
}

