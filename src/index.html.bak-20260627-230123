function saveSale() {
  var lot_code=(document.getElementById('sale-lot')||{}).value||'';
  var buyer=(document.getElementById('sale-buyer')||{}).value.trim()||'';
  var scope=(document.getElementById('sale-scope')||{}).value||'lot';
  var price=parseFloat((document.getElementById('sale-price')||{}).value)||0;
  var date=(document.getElementById('sale-date')||{}).value||'';
  // Descuento de peso opcional (ej: 5 = 5% menos kg facturados)
  var discountPct=parseFloat((document.getElementById('sale-discount-pct')||{}).value)||0;
  if (discountPct < 0) discountPct = 0;
  if (discountPct > 50) discountPct = 50;
  if(!lot_code||!buyer||!price||!date){toast('Completa todos los campos requeridos','error');return;}
  // FIX v1.4.34: no permitir fechas futuras
  if(!validateNotFuture(date, 'fecha de venta')) return;

  var isMultiLot = lot_code === '__all__';
  if (isMultiLot && scope !== 'individual') {
    toast('Para venta de varios lotes, usá modo individual','error');return;
  }

  var sale={id:db.next_ids.sale++,lot_code:lot_code,buyer:buyer,type:(document.getElementById('sale-type')||{}).value||'frigorifico',price_per_kg:price,date:date,invoice:(document.getElementById('sale-invoice')||{}).value||'',trace_req:(document.getElementById('sale-trace')||{}).checked||false,notes:'',scope:scope,discount_pct:discountPct,created_at:new Date().toISOString()};
  var saleLot = isMultiLot ? null : db.lots.find(function(l){return l.code===lot_code;});
  var animalesDB=getAnimalesDB();

  if(scope==='individual') {
    if(!_saleSelectedAnimals.length){toast('Selecciona al menos un animal','error');return;}


    // Construir mapa { lotCode: [animalId,...] } a partir de la selección
    // En modo multi-lote, cada animal puede estar en un lote distinto — buscar en todos
    var byLot = {};       // lotCode -> [animalIds]
    var animalLotMap = {}; // animalId -> lotCode
    _saleSelectedAnimals.forEach(function(id){
      // PRIORIDAD 1: mapa global persistente (más confiable, no depende del DOM actual)
      if (_saleAnimalLotMap[id]) {
        animalLotMap[id] = _saleAnimalLotMap[id];
        return;
      }
      // PRIORIDAD 2: leer del checkbox actual
      var chk = document.getElementById('chk-'+id);
      var lotFromChk = chk ? chk.getAttribute('data-lot') : '';
      if (lotFromChk) {
        animalLotMap[id] = lotFromChk;
      } else {
        // PRIORIDAD 3: fallback — buscar en animalesDB (puede dar el lote equivocado si el ID se repite)
        Object.keys(animalesDB).some(function(lc){
          if ((animalesDB[lc]||[]).find(function(x){return (x.animal_id||x.id||'').toString()===id;})) {
            animalLotMap[id] = lc;
            return true;
          }
        });
      }
      if (!animalLotMap[id]) {
      }
    });
    Object.keys(animalLotMap).forEach(function(id){
      var lc = animalLotMap[id];
      if (!byLot[lc]) byLot[lc] = [];
      byLot[lc].push(id);
    });


    // FORZAR multi-lote si byLot tiene más de un lote
    if (Object.keys(byLot).length > 1) {
      isMultiLot = true;
    }

    // Guardar para uso del bloque de kardex después del save
    _saleAnimalLotMapForKardex = Object.keys(animalLotMap).map(function(id){return {id:id, lot:animalLotMap[id]};});

    var totalKg=0;
    var fechaVenta=date;
    var allTouchedLots = [];
    // FIX: trabajar sobre el RAW localStorage (no la versión normalizada) para preservar todos los campos
    var rawAnimalsStorage = {};
    try { rawAnimalsStorage = JSON.parse(localStorage.getItem('e5m_animals')||'{}'); } catch(e) { rawAnimalsStorage = {}; }
    console.log('[saveSale] Selección:', _saleSelectedAnimals.length, 'animales total');
    console.log('[saveSale] byLot keys:', Object.keys(byLot), 'animalLotMap entries:', Object.keys(animalLotMap).length);

    Object.keys(byLot).forEach(function(lc){
      var animalsOfLot = animalesDB[lc] || [];
      var rawAnimalsOfLot = rawAnimalsStorage[lc] || [];
      var idsOfLot = byLot[lc];
      console.log('[saveSale] Procesando lote', lc, '— animales en DB:', animalsOfLot.length, ', a vender:', idsOfLot.length);
      // Convertir todos los IDs a strings para comparación consistente
      var idsSet = {};
      idsOfLot.forEach(function(id){ idsSet[String(id)] = true; });

      idsOfLot.forEach(function(id){
        var a = animalsOfLot.find(function(x){return String(x.animal_id||x.id||'')===String(id);});
        if(!a) { console.warn('[saveSale] Animal no encontrado en lote', lc, '— id:', id); return; }
        var pesoReal = _salePesoMap[id]||0;
        if(!pesoReal && a.pesajes && a.pesajes.length) pesoReal = a.pesajes[a.pesajes.length-1].peso;
        totalKg += pesoReal;
        // Registrar pesaje de venta también en el raw storage
        var rawA = rawAnimalsOfLot.find(function(x){return String(x.animal_id||x.id||'')===String(id);});
        if (pesoReal > 0 && rawA) {
          if (!rawA.pesajes) rawA.pesajes = [];
          var yaExiste = rawA.pesajes.find(function(p){return p.fecha===fechaVenta && p.tipo==='venta';});
          if (!yaExiste) rawA.pesajes.push({fecha:fechaVenta,peso:pesoReal,tipo:'venta',nota:'Peso al momento de venta'});
        }
      });

      // FIX: Eliminar vendidos del raw storage (preservando todos los campos originales)
      var remainingRaw = rawAnimalsOfLot.filter(function(a){ return !idsSet[String(a.animal_id||a.id||'')]; });
      rawAnimalsStorage[lc] = remainingRaw;
      console.log('[saveSale] Lote', lc, '— quedan', remainingRaw.length, 'animales (de', rawAnimalsOfLot.length, ')');

      // Update lote count
      var thisLot = db.lots.find(function(l){return l.code===lc;});
      if (thisLot) {
        thisLot.animal_count = remainingRaw.length;
        if (remainingRaw.length) {
          var pesos = remainingRaw.map(function(a){ return a.pesajes && a.pesajes.length ? a.pesajes[a.pesajes.length-1].peso : 0; }).filter(function(p){return p>0;});
          thisLot.avg_weight = pesos.length ? Math.round(pesos.reduce(function(s,p){return s+p;},0)/pesos.length*10)/10 : thisLot.avg_weight;
        } else {
          thisLot.status = 'vendido';
          // v1.4.69: cerrar rotation_history del lote para liberar el potrero
          // (sino el potrero seguía apareciendo como "ocupado" en el tab Rotación)
          (db.rotation_history || []).forEach(function(rh) {
            if (rh.lot_code === lc && !rh.exit_date) {
              rh.exit_date = sale.date || new Date().toISOString().slice(0, 10);
              rh.exit_reason = 'venta';
              console.log('[saveSale] rotation_history cerrado para lote', lc, '— potrero', rh.potrero);
            }
          });
        }
        console.log('[saveSale] Lote', lc, 'actualizado — animal_count:', thisLot.animal_count, 'status:', thisLot.status);
      } else {
        console.warn('[saveSale] No se encontró el lote', lc, 'en db.lots para actualizar');
      }
      allTouchedLots.push(lc);
    });
    // Persistir el raw storage actualizado (preserva todos los campos)
    localStorage.setItem('e5m_animals',JSON.stringify(rawAnimalsStorage));
    console.log('[saveSale] localStorage.e5m_animals actualizado');
    sale.animals = _saleSelectedAnimals.length;
    sale.kg = Math.round(totalKg*10)/10;
    // kg_facturados = kg con descuento aplicado (lo que cobra el frigorífico)
    sale.kg_facturados = discountPct > 0 ? Math.round(totalKg * (1 - discountPct/100) * 10) / 10 : sale.kg;
    sale.total = Math.round(sale.kg_facturados * price * 100) / 100;
    sale.animal_ids = _saleSelectedAnimals.slice();

    // v1.4.61: GUARDAR DESGLOSE POR LOTE en sale.items[] para reportes precisos.
    // Esto se calcula EN BACKEND (sin cambiar UX) sumando los pesos reales de cada animal vendido
    // por lote. La fracción de ingreso se prorratea por kg de cada lote vs kg totales.
    // Ventas single-lote también guardan items (con un solo elemento), uniforme.
    sale.items = Object.keys(byLot).map(function(lc) {
      var idsLot = byLot[lc];
      var kgLot = 0;
      idsLot.forEach(function(id) {
        var pesoReal = _salePesoMap[id] || 0;
        if (!pesoReal) {
          // Fallback: usar último pesaje del animal si _salePesoMap no lo tiene
          var animalEnLote = (animalesDB[lc] || []).find(function(x) { return String(x.animal_id || x.id || '') === String(id); });
          if (animalEnLote && animalEnLote.pesajes && animalEnLote.pesajes.length) {
            pesoReal = animalEnLote.pesajes[animalEnLote.pesajes.length - 1].peso || 0;
          }
        }
        kgLot += pesoReal;
      });
      var fraccion = totalKg > 0 ? (kgLot / totalKg) : (idsLot.length / _saleSelectedAnimals.length);
      var kgFactLot = discountPct > 0 ? kgLot * (1 - discountPct / 100) : kgLot;
      return {
        lot_code: lc,
        animals: idsLot.length,
        kg: Math.round(kgLot * 10) / 10,
        kg_facturados: Math.round(kgFactLot * 10) / 10,
        total: Math.round(kgFactLot * price * 100) / 100,
        animal_ids: idsLot.slice()
      };
    });
    console.log('[saveSale] sale.items[] =', sale.items);

    if (isMultiLot) {
      // Para venta multi-lote, dejamos lot_code como '__all__' pero guardamos info de lotes tocados
      sale.lot_codes = allTouchedLots;
      sale.lot_code = allTouchedLots.join(',');
    }
    // Pesajes de venta para sync
    _saleSelectedAnimals.forEach(function(id){
      var pesoReal = _salePesoMap[id]||0;
      var lc = animalLotMap[id] || lot_code;
      if (pesoReal > 0) {
        db.pesajes.push({
          id: Date.now()+Math.random(),
          lot_code: lc,
          animal_id: id,
          scope: 'individual',
          peso: pesoReal,
          date: date,
          tipo: 'venta',
          nota: 'Peso al momento de venta',
          created_at: new Date().toISOString()
        });
      }
    });
    _saleSelectedAnimals = [];
  } else {
    var animals_count=parseInt((document.getElementById('sale-count')||{}).value)||0;
    var kg=parseFloat((document.getElementById('sale-kg')||{}).value)||0;
    var pesoPorAnimal=parseFloat((document.getElementById('sale-peso-momento')||{}).value)||0;
    if(!animals_count||!kg){toast('Completa animales y peso','error');return;}
    if(saleLot&&animals_count>saleLot.animal_count){toast('No puedes vender mas animales que los del lote','error');return;}
    // FIX v1.4.35 BUG-LOT-4: si el lote tiene animales con historial (pesajes individuales,
    // tratamientos), el modo 'lot' sacará los PRIMEROS N animales del cache sin importar cuáles
    // se vendieron realmente. Esto rompe trazabilidad. Avisar al usuario antes de proceder.
    if (saleLot && animals_count < saleLot.animal_count) {
      var lotAnimalsCheck = (animalesDB[lot_code] || []);
      var conHistoria = lotAnimalsCheck.filter(function(a){
        return (a.pesajes && a.pesajes.length > 0) ||
               (db.treatments||[]).some(function(t){ return t.animal_id && String(t.animal_id) === String(a.id||a.animal_id); });
      }).length;
      if (conHistoria > 0) {
        if (!confirm('⚠ Atención: este lote tiene ' + conHistoria + ' animales con historial individual (pesajes/tratamientos). En modo "Lote" se sacarán ' + animals_count + ' animales al azar del cache, lo que rompe la trazabilidad. Para mantener historial usá modo "Individual". ¿Continuar de todas formas?')) return;
      }
    }
    sale.animals=animals_count;
    sale.kg=kg;
    // kg_facturados = kg con descuento aplicado (lo que cobra el frigorífico)
    sale.kg_facturados = discountPct > 0 ? Math.round(kg * (1 - discountPct/100) * 10) / 10 : kg;
    sale.total=Math.round(sale.kg_facturados*price*100)/100;
    sale.animal_ids=[];

    // v1.4.61: scope='lot' siempre es single-lote (un solo lote en lot_code).
    // Igualmente guardamos sale.items[] para uniformidad y reportes futuros.
    sale.items = [{
      lot_code: lot_code,
      animals: animals_count,
      kg: kg,
      kg_facturados: sale.kg_facturados,
      total: sale.total,
      animal_ids: []
    }];
    // Si se ingresó peso por animal, registrar pesaje en los primeros N animales del lote
    if(pesoPorAnimal>0) {
      var lotAnimals=animalesDB[lot_code]||[];
      var registrados=0;
      for(var i=0;i<lotAnimals.length&&registrados<animals_count;i++){
        var anim=lotAnimals[i];
        if(!anim.pesajes) anim.pesajes=[];
        var yaExiste=anim.pesajes.find(function(p){return p.fecha===date&&p.tipo==='venta';});
        if(!yaExiste){
          anim.pesajes.push({fecha:date,peso:pesoPorAnimal,tipo:'venta',nota:'Peso al momento de venta'});
          registrados++;
        }
      }
      animalesDB[lot_code]=lotAnimals;
      localStorage.setItem('e5m_animals',JSON.stringify(animalesDB));
      // Actualizar avg_weight del lote con el nuevo peso
      if(saleLot) saleLot.avg_weight=pesoPorAnimal;
    }
    if(saleLot) {
      saleLot.animal_count=Math.max(0,saleLot.animal_count-animals_count);
      if(saleLot.animal_count===0) {
        saleLot.status='vendido';
        // v1.4.69: cerrar rotation_history para liberar el potrero
        (db.rotation_history || []).forEach(function(rh) {
          if (rh.lot_code === lot_code && !rh.exit_date) {
            rh.exit_date = date || new Date().toISOString().slice(0, 10);
            rh.exit_reason = 'venta';
            console.log('[saveSale-scope=lot] rotation_history cerrado para lote', lot_code, '— potrero', rh.potrero);
          }
        });
      }
      // FIX: cuando vendes en scope 'lot' (no individual), e5m_animals queda con todos los animales viejos.
      // El server reconcilia animal_count contra e5m_animals[code], así que si no removemos del cache,
      // el lote "resucita" en el próximo pull con la cantidad pre-venta.
      // Removemos los primeros N del cache para mantener consistencia.
      try {
        var rawAnim = JSON.parse(localStorage.getItem('e5m_animals') || '{}');
        if (rawAnim[lot_code] && Array.isArray(rawAnim[lot_code])) {
          var keepCount = Math.max(0, rawAnim[lot_code].length - animals_count);
          rawAnim[lot_code] = rawAnim[lot_code].slice(0, keepCount);
          localStorage.setItem('e5m_animals', JSON.stringify(rawAnim));
          console.log('[saveSale lot-scope] Cache animals['+lot_code+'] reducido a '+keepCount+' (vendidos '+animals_count+')');
        }
      } catch(e) { console.warn('[saveSale lot-scope] Error sync e5m_animals:', e.message); }
    }
  }

  db.sales.push(sale);
  // Auto-Kardex: distribuir entre lotes si es multi-lote
  if (!db.kardex) db.kardex = [];
  if (isMultiLot && sale.lot_codes && sale.lot_codes.length > 1) {
    // Calcular kg y total por cada lote según los animales que aportó
    var byLot = {}; // lc -> { animals, kg, total }
    // Reconstruir mapa animalId→lote desde animal_ids + estado pre-venta
    // (esto se calculó antes en _saleSelectedAnimals; lo recreo)
    var animalLotMap2 = {};
    _saleAnimalLotMapForKardex.forEach(function(item){ animalLotMap2[item.id] = item.lot; });
    sale.animal_ids.forEach(function(id){
      var lc = animalLotMap2[id] || sale.lot_codes[0];
      if (!byLot[lc]) byLot[lc] = { animals: 0, kg: 0 };
      byLot[lc].animals += 1;
      byLot[lc].kg += (_salePesoMap[id] || 0);
    });
    // Crear una entrada de kardex por cada lote
    Object.keys(byLot).forEach(function(lc){
      var slice = byLot[lc];
      var sliceTotal = Math.round(slice.kg * (sale.price_per_kg||0) * 100) / 100;
      db.kardex.push({
        id: Date.now() + Math.random(),
        lote: lc,
        tipo: 'venta',
        fecha: sale.date,
        cabezas: slice.animals,
        precio: sale.price_per_kg || 0,
        total: sliceTotal,
        desc: 'Venta a ' + (buyer||'') + ' — ' + slice.kg.toFixed(1) + ' kg (parte de venta multi-lote, ' + sale.lot_codes.length + ' lotes)',
        sale_id: sale.id,
        multi_lot: true,
        by:'Desktop', created_at: new Date().toISOString(), auto:true
      });
    });
  } else {
    // Comportamiento normal (single lote)
    db.kardex.push({id:Date.now(),lote:lot_code,tipo:'venta',fecha:sale.date,cabezas:sale.animals||0,precio:sale.price_per_kg||0,total:sale.total||0,desc:'Venta a '+(buyer||'')+ ' — '+((sale.kg||0))+' kg',by:'Desktop',created_at:new Date().toISOString(),auto:true});
  }
  addActivity('Sistema','otro',isMultiLot?sale.lot_codes.join(','):lot_code,'Venta: '+sale.animals+' animales a '+buyer+' - Bs. '+sale.total.toLocaleString());
  saveDB(); closeModal('modal-sale'); renderVentas(); renderLotes(); renderDashboard();
  // CRÍTICO: el orden importa. Pushear animals ANTES que lots, secuencialmente.
  // El server reconcilia animal_count de lots contra serverAnimals[code]. Si pusheamos lots primero,
  // el server ve los animals VIEJOS (cantidad pre-venta) y "reconcilia" el lote al valor viejo,
  // ignorando que la venta redujo la cantidad. Esperar a que animals llegue antes de mandar lots.
  var animalsCache = {};
  try { animalsCache = JSON.parse(localStorage.getItem('e5m_animals') || '{}'); } catch(e) {}
  replaceTableInRailway('animals', animalsCache).then(function(){
    return replaceTableInRailway('lots', db.lots || []);
  }).then(function(){
    replaceTableInRailway('sales', db.sales || []);
    if (db.kardex) replaceTableInRailway('kardex', db.kardex || []);
    if (db.pesajes) replaceTableInRailway('pesajes', db.pesajes || []);
  });
  toast('Venta registrada: Bs. '+sale.total.toLocaleString(),'success');
  try { auditLog('create', 'sales', sale.id, _summarizeRecord('sales', sale)); } catch(e){}
}

