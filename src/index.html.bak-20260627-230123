  });
  lotesDetalle.forEach(function(lot) {
    var st = (lot.status || '').toLowerCase();
    var isSold = (st === 'sold' || st === 'vendido');
    var lotGmd = calcLotGmd(lot, animalesDB);
    var lotProdHa = ha > 0 ? Math.round((lot.avg_weight || 0) * (lot.animal_count || 0) / ha * 10) / 10 : 0;

