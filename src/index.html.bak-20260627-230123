    }
    // Store weights for histogram
    if (data.weights.length) window._truTestWeights = data.weights;
    calcPesajeTotals();
    toast('Datos TRU-TEST cargados. Selecciona el lote y guarda.', 'success');
  }, 300);
}

// -- HISTOGRAM ----------------------------------------------------------------

function renderHistogram(pesaje) {
  var card = document.getElementById('pesaje-histogram-card');
  var canvas = document.getElementById('pesaje-histogram-canvas');
  if (!card || !canvas) return;

  if (!pesaje || !pesaje.min_weight || !pesaje.max_weight || !pesaje.animal_count) {
    card.style.display = 'none';
    return;
  }

  card.style.display = 'block';
  var title = document.getElementById('pesaje-histogram-title');
  var sub   = document.getElementById('pesaje-histogram-sub');
  if (title) title.textContent = '📊 Distribucion de pesos - Lote ' + pesaje.lot_code;
  if (sub) sub.textContent = pesaje.date + ' · ' + pesaje.animal_count + ' animales';

  // Build histogram buckets
  var min = pesaje.min_weight;
  var max = pesaje.max_weight;
  var avg = pesaje.avg_weight;
  var range = max - min;
  var buckets = 8;
  var bucketSize = Math.ceil(range / buckets);
  if (bucketSize < 1) bucketSize = 1;

  // Estimate distribution using normal distribution approximation
  var bucketLabels = [];
  var bucketValues = [];
  var total = pesaje.animal_count;

  for (var i = 0; i < buckets; i++) {
    var lo = min + i * bucketSize;
    var hi = lo + bucketSize;
    bucketLabels.push(Math.round(lo) + '-' + Math.round(hi));
    // Approximate count using normal distribution
    var midpoint = (lo + hi) / 2;
    var stddev = (max - min) / 4;
    var z = (midpoint - avg) / Math.max(stddev, 1);
    var density = Math.exp(-0.5 * z * z) / (stddev * Math.sqrt(2 * Math.PI));
    bucketValues.push(Math.max(0, Math.round(density * bucketSize * total)));
  }

  // Draw histogram on canvas
  var ctx = canvas.getContext('2d');
  var W = canvas.offsetWidth || 600;
  var H = 140;
  canvas.width = W;
  canvas.height = H;
  ctx.clearRect(0, 0, W, H);

  var maxVal = Math.max.apply(null, bucketValues);
  var barW = Math.floor((W - 40) / buckets) - 4;
  var colors = ['#3fb950','#3fb950','#58a6ff','#58a6ff','#d4a017','#d4a017','#f85149','#f85149'];

  bucketValues.forEach(function(val, i) {
    var barH = maxVal > 0 ? Math.round((val / maxVal) * (H - 30)) : 0;
    var x = 20 + i * (barW + 4);
    var y = H - 20 - barH;
    ctx.fillStyle = colors[i] || '#58a6ff';
    ctx.fillRect(x, y, barW, barH);
    // Label
    ctx.fillStyle = '#8b949e';
    ctx.font = '9px DM Mono,monospace';
    ctx.textAlign = 'center';
    ctx.fillText(Math.round(parseInt(bucketLabels[i])), x + barW/2, H - 6);
    if (val > 0) {
      ctx.fillStyle = '#e6edf3';
      ctx.fillText(val, x + barW/2, y - 3);
    }
  });

  // Avg line
  var avgX = 20 + ((avg - min) / Math.max(range, 1)) * (W - 40);
  ctx.strokeStyle = '#e3b341';
  ctx.lineWidth = 2;
  ctx.setLineDash([4, 3]);
  ctx.beginPath(); ctx.moveTo(avgX, 0); ctx.lineTo(avgX, H - 20); ctx.stroke();
  ctx.setLineDash([]);
  ctx.fillStyle = '#e3b341';
  ctx.font = 'bold 10px DM Mono,monospace';
  ctx.textAlign = 'center';
  ctx.fillText('Prom: ' + avg + 'kg', avgX, 12);

  // Ranges summary
  var rangesEl = document.getElementById('pesaje-histogram-ranges');
  if (rangesEl) {
    var third = range / 3;
    var r1 = Math.round(min + third);
    var r2 = Math.round(min + 2 * third);
    var c1 = bucketValues.slice(0, 3).reduce(function(s,v){return s+v;},0);
    var c2 = bucketValues.slice(3, 5).reduce(function(s,v){return s+v;},0);
    var c3 = bucketValues.slice(5).reduce(function(s,v){return s+v;},0);
    rangesEl.innerHTML =
      '<span style="background:rgba(248,81,73,.15);color:var(--red);padding:3px 10px;border-radius:20px">' + c1 + ' · Bajo ' + r1 + 'kg</span>' +
      '<span style="background:rgba(88,166,255,.15);color:var(--blue);padding:3px 10px;border-radius:20px">' + c2 + ' · ' + r1 + '-' + r2 + 'kg</span>' +
      '<span style="background:rgba(63,185,80,.15);color:var(--green);padding:3px 10px;border-radius:20px">' + c3 + ' · Sobre ' + r2 + 'kg</span>';
  }
}

