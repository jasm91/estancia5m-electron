    // ruta con modal de confirmación. Tras el reload, el primer paso es un pull limpio.
    if (newToken !== oldToken) {
      console.log('[Config] Token changed → limpieza total + reload (anti-contaminación)');
      localStorage.setItem('apiToken', newToken);
      localStorage.setItem('e5m_api_token', newToken);
      _clearTenantCacheAndReload();
      return;
    }
    localStorage.setItem('apiToken', newToken);
    localStorage.setItem('e5m_api_token', newToken);
  }
  toast('Configuracion guardada', 'success');
  testConnectionSilent();
}

// v1.8.56: helper único de limpieza de cache al cambiar de tenant.
// Borra TODAS las tablas locales del tenant anterior y recarga la app.
// Centralizar acá evita que cada ruta de cambio de token olvide alguna key
// (como pasó en saveServerConfig_real, que dejaba estado vivo y contaminaba).
function _clearTenantCacheAndReload() {
  try {
    var keysToClear = [
      'estancia5m_v1','e5m_animals','e5m_tasks','e5m_pluvios','e5m_maquinaria',
      'e5m_deleted_ids','e5m_report_params','e5m_params','e5m_branding',
      'e5m_gemini_key','e5m_diesel_tank','e5m_pasture_evals','e5m_local_photos',
      'e5m_inventory_counts'
    ];
    keysToClear.forEach(function(k){ try { localStorage.removeItem(k); } catch(e){} });
    // Barrido defensivo: cualquier otra key e5m_* de datos (no de config/sesión)
    var preserve = { 'e5m_api_token':1, 'e5m_api_url':1, 'e5m_dark_mode':1, 'e5m_active_tenant':1, 'e5m_settings':1, 'e5m_personal_tab':1 };
    try {
      Object.keys(localStorage).forEach(function(k){
        if (k.indexOf('e5m_') === 0 && !preserve[k]) localStorage.removeItem(k);
      });
    } catch(e){}
  } catch(e) { console.error('[clearTenantCache]', e); }
  toast('Cambiando de tenant… recargando', 'success');
  setTimeout(function(){ location.reload(); }, 800);
}

