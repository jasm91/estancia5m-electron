  toast(cuenta+': Bs. '+monto.toLocaleString()+' registrado','success');
}

function deleteCuenta(id) {
  if(!confirm('Eliminar este registro?'))return;
  
  // FIX v1.4.35: audit log para deleteCuenta
  var _delRec_deleteCuenta = (db.cuentas || []).find(function(r){ return String(r.id) === String(id); });
  var _delSummary_deleteCuenta = _delRec_deleteCuenta ? _summarizeRecord('cuentas', _delRec_deleteCuenta) : 'Cuenta contable #' + id;
  try { auditLog('delete', 'cuentas', id, _delSummary_deleteCuenta); } catch(e){}
  trackDeletion(id, 'cuentas');
  db.cuentas=db.cuentas.filter(function(r){return r.id!==id;});
  saveDB();renderContabilidad();toast('Eliminado','success');
  replaceTableInRailway('cuentas', db.cuentas || []);
}

function exportCuentas() {
  if(!db.cuentas||!db.cuentas.length){toast('Sin registros para exportar','error');return;}
  var headers=['Fecha','Cuenta','Subcuenta','Tipo','Detalle','Monto Bs.','Registrado por'];
  var rows=db.cuentas.slice().sort(function(a,b){return (b.fecha||'').localeCompare(a.fecha||'');})
    .map(function(r){return [r.fecha||'',r.cuenta||'',r.subcuenta||'',r.tipo||'',r.detalle||'',r.monto||0,r.by||''].join(',');});
  var csv=[headers.join(',')].concat(rows).join('');
  var a=document.createElement('a');
  a.href='data:text/csv;charset=utf-8,﻿'+encodeURIComponent(csv);
  a.download='contabilidad_estanciapro_'+localDate()+'.csv';
  a.click();
  toast('Exportado correctamente','success');
}

// KARDEX FINANCIERO DE LOTES
// ══════════════════════════════════════════════════
function clearKardexFiltros() {
  var ids = ['kardex-lote-sel','kardex-type-sel','kardex-fecha-desde','kardex-fecha-hasta'];
  ids.forEach(function(id){ var el = document.getElementById(id); if (el) el.value = ''; });
  var chk = document.getElementById('kardex-show-vendidos');
  if (chk) chk.checked = true;
  renderKardex();
}

function renderKardex() {
  if (!db.kardex) db.kardex = [];
  if (!db.cuentas) db.cuentas = [];
  var lotSel=document.getElementById('kardex-lote-sel');
  // Repopular SIEMPRE el dropdown (incluye vendidos para histórico) — preservar selección
  if (lotSel) {
    var prevSel = lotSel.value;
    lotSel.innerHTML = '<option value="">Todos los lotes</option>';
    var allLotsSorted = (db.lots || []).slice().sort(function(a,b){
      // Activos primero, después cuarentena, después vendidos
      var orderA = (a.status==='vendido'||a.status==='sold') ? 2 : (a.status==='cuarentena') ? 1 : 0;
      var orderB = (b.status==='vendido'||b.status==='sold') ? 2 : (b.status==='cuarentena') ? 1 : 0;
      if (orderA !== orderB) return orderA - orderB;
      return (a.code || '').localeCompare(b.code || '');
    });
    allLotsSorted.forEach(function(l){
      var o = document.createElement('option');
      o.value = l.code;
      var statusTag = (l.status==='vendido'||l.status==='sold') ? ' [VENDIDO]' : (l.status==='cuarentena' ? ' [CUARENTENA]' : '');
      o.textContent = l.code + ' - ' + capFirst(l.category||'') + ' (' + (l.animal_count||0) + ' cab.)' + statusTag;
      lotSel.appendChild(o);
    });
    if (prevSel) lotSel.value = prevSel;
  }
  var filterLote=(lotSel||{}).value||'';
  var filterType=(document.getElementById('kardex-type-sel')||{}).value||'';
  var filterDesde=(document.getElementById('kardex-fecha-desde')||{}).value||'';
  var filterHasta=(document.getElementById('kardex-fecha-hasta')||{}).value||'';
  var showVendidos=(document.getElementById('kardex-show-vendidos')||{checked:true}).checked;
  var movs=db.kardex.filter(function(m){
    if(filterLote && !lotMatches(m.lote, filterLote))return false;
    if(filterType&&m.tipo!==filterType)return false;
    if(filterDesde && (m.fecha||'') < filterDesde) return false;
    if(filterHasta && (m.fecha||'') > filterHasta) return false;
    return true;
  });
  var resEl=document.getElementById('kardex-resumen');
  if(resEl){
    var lotsToShow;
    if (filterLote) {
      lotsToShow = db.lots.filter(function(l){return l.code===filterLote;});
    } else {
      lotsToShow = db.lots.filter(function(l){
        var isVendido = l.status==='vendido' || l.status==='sold';
        if (isVendido && !showVendidos) return false;
        return l.status==='activo' || l.status==='active' || !l.status || l.status==='cuarentena' || isVendido;
      });
      // Activos primero, vendidos al final
      lotsToShow.sort(function(a,b){
        var orderA = (a.status==='vendido'||a.status==='sold') ? 2 : (a.status==='cuarentena') ? 1 : 0;
        var orderB = (b.status==='vendido'||b.status==='sold') ? 2 : (b.status==='cuarentena') ? 1 : 0;
        if (orderA !== orderB) return orderA - orderB;
        return (a.code || '').localeCompare(b.code || '');
      });
    }
    resEl.innerHTML=lotsToShow.map(function(lot){
      // El resumen del card ignora filtro de fecha (siempre muestra el total histórico del lote)
      var lotMovs=db.kardex.filter(function(m){return m.lote===lot.code;});
      // v1.4.83: incluir 'transferencia_interna' en DEBE/HABER
      // Si el lote es el destino (recibe), el monto va a DEBE.
      // Si el lote es el origen (entrega), el monto va a HABER.
      // El campo m._transfer_role lo seteamos al crear el asiento ('entrada' o 'salida').
      var debe=lotMovs.filter(function(m){
        return m.tipo==='compra' || m.tipo==='ajuste' ||
               (m.tipo==='transferencia_interna' && m._transfer_role==='entrada');
      }).reduce(function(s,m){return s+(m.total||0);},0);
      var haber=lotMovs.filter(function(m){
        return m.tipo==='venta' ||
               (m.tipo==='transferencia_interna' && m._transfer_role==='salida');
      }).reduce(function(s,m){return s+(m.total||0);},0);
      var saldo=debe-haber;
      // Cabezas adquiridas: compras directas + transferencias entrantes
      var cabCompradas=lotMovs.filter(function(m){return m.tipo==='compra';}).reduce(function(s,m){return s+(m.cabezas||0);},0);
      var cabTransferidas=lotMovs.filter(function(m){
        return m.tipo==='transferencia_interna' && m._transfer_role==='entrada';
      }).reduce(function(s,m){return s+(m.cabezas||0);},0);
      var cabTotal=cabCompradas+cabTransferidas;
      var promPorCab=cabTotal?Math.round(debe/cabTotal):0;
      // Linaje contable (de qué compra hereda este lote)
      var costOriginLine='';
      if (lot.cost_origin && lot.cost_origin.from_lot) {
        costOriginLine='<div style="font-size:10px;color:var(--muted);margin-top:3px">' +
          '↩ Origen contable: <span style="color:var(--blue)">' + escH(lot.cost_origin.from_lot) + '</span>' +
          (lot.cost_origin.precio_kg ? ' · ' + lot.cost_origin.precio_kg.toFixed(2) + ' Bs/kg' : '') +
        '</div>';
      }
      var isVendido = lot.status==='vendido' || lot.status==='sold';
      var isCuarentena = lot.status==='cuarentena';
      var statusBadge = '';
      if (isVendido) statusBadge = '<span class="bdg bdg-purple" style="font-size:9px;margin-left:6px">Vendido</span>';
      else if (isCuarentena) statusBadge = '<span class="bdg" style="background:rgba(168,85,247,.15);color:#A855F7;border:1px solid #A855F7;font-size:9px;margin-left:6px">Cuarentena</span>';
      var cardOpacity = isVendido ? 'opacity:0.78;' : '';
      return '<div style="background:var(--sur);border:1px solid var(--bor);border-radius:12px;padding:14px;'+cardOpacity+'">'+
        '<div style="font-family:Inter,sans-serif;font-size:13px;font-weight:700;color:var(--amber2);margin-bottom:8px">'+escH(lot.code)+statusBadge+'</div>'+
        '<div style="display:flex;justify-content:space-between;font-size:11px;padding:3px 0;border-bottom:1px solid rgba(48,54,61,.3)"><span style="color:var(--muted)">DEBE</span><span style="font-weight:600">Bs. '+debe.toLocaleString()+'</span></div>'+
        '<div style="display:flex;justify-content:space-between;font-size:11px;padding:3px 0;border-bottom:1px solid rgba(48,54,61,.3)"><span style="color:var(--muted)">HABER</span><span style="font-weight:600;color:var(--green)">Bs. '+haber.toLocaleString()+'</span></div>'+
        '<div style="display:flex;justify-content:space-between;font-size:12px;padding:5px 0;margin-top:4px"><span style="color:var(--muted);font-weight:600">SALDO</span><span style="font-weight:700;color:'+(saldo>0?'var(--amber2)':'var(--green)')+'">Bs. '+saldo.toLocaleString()+'</span></div>'+
        '<div style="font-size:10px;color:var(--muted);margin-top:6px">Prom/cab: Bs. '+promPorCab.toLocaleString()+' · '+cabTotal+' cab.</div>'+
        costOriginLine +
      '</div>';
    }).join('');
  }
  var tbody=document.getElementById('kardex-tbody');
  if(!tbody)return;
  if(!movs.length){tbody.innerHTML='<tr><td colspan="11" style="text-align:center;padding:24px;color:var(--muted)">Sin movimientos. Registra la compra inicial de cada lote.</td></tr>';return;}
  tbody.innerHTML='';
  var saldoMap={};
  var sorted=movs.slice().sort(function(a,b){return (a.fecha||'').localeCompare(b.fecha||'');});
  sorted.forEach(function(m){
    if(!saldoMap[m.lote])saldoMap[m.lote]=0;
    // v1.4.83: transferencia_interna agrega DEBE en entrada / HABER en salida
    var debe=0, haber=0;
    if (m.tipo==='compra' || m.tipo==='ajuste') debe = m.total||0;
    else if (m.tipo==='venta') haber = m.total||0;
    else if (m.tipo==='transferencia_interna') {
      if (m._transfer_role==='entrada') debe = m.total||0;
      else if (m._transfer_role==='salida') haber = m.total||0;
    }
    saldoMap[m.lote]+=(debe-haber);
    m._saldo=saldoMap[m.lote];m._debe=debe;m._haber=haber;
  });
  sorted.slice().reverse().forEach(function(m){
    var tr=document.createElement('tr');
    // v1.4.83: agregar tipo transferencia_interna (cyan/teal)
    var tipoColor={compra:'var(--blue)',venta:'var(--green)',ajuste:'var(--amber2)',muerte:'var(--red)',transferencia_interna:'#22d3ee'};
    // Etiqueta visual con dirección (↓ entrada / ↑ salida)
    var tipoLabel = m.tipo;
    if (m.tipo === 'transferencia_interna') {
      tipoLabel = m._transfer_role === 'entrada' ? '↓ Transf. entrada' : '↑ Transf. salida';
    }
    m._tipoLabel = tipoLabel;
    var delBtn=document.createElement('button');
    delBtn.className='btn btn-ghost btn-sm';
    delBtn.style.cssText='color:var(--red);border:1px solid var(--red);padding:4px 10px;font-size:12px;font-weight:600;border-radius:6px';
    delBtn.title='Eliminar movimiento';
    delBtn.textContent='🗑 Eliminar';
    delBtn.onclick=(function(id){return function(){deleteKardex(id);};})(m.id);
    tr.innerHTML='<td style="font-family:DM Mono,monospace;font-size:11px">'+escH(m.fecha||'')+'</td>'+
      '<td style="font-weight:600;color:var(--amber2)">'+escH(m.lote||'')+'</td>'+
      '<td><span style="color:'+(tipoColor[m.tipo]||'var(--muted)')+'">'+escH(m._tipoLabel||capFirst(m.tipo||''))+'</span></td>'+
      '<td style="text-align:center">'+((m.cabezas||0))+'</td>'+
      '<td style="font-family:DM Mono,monospace">Bs. '+((m.precio||0).toLocaleString())+'</td>'+
      '<td style="font-family:DM Mono,monospace;font-weight:600">Bs. '+((m.total||0).toLocaleString())+'</td>'+
      '<td style="font-family:DM Mono,monospace;color:var(--blue)">'+(m._debe?'Bs. '+m._debe.toLocaleString():'-')+'</td>'+
      '<td style="font-family:DM Mono,monospace;color:var(--green)">'+(m._haber?'Bs. '+m._haber.toLocaleString():'-')+'</td>'+
      '<td style="font-family:DM Mono,monospace;font-weight:700;color:var(--amber2)">Bs. '+(m._saldo||0).toLocaleString()+'</td>'+
      '<td style="font-size:11px;color:var(--muted)">'+escH(m.desc||'-')+'</td>'+
      '<td style="text-align:center"></td>';
    tr.lastElementChild.appendChild(delBtn);
    tbody.appendChild(tr);
  });
  var subEl=document.getElementById('kardex-sub');
  if(subEl) {
    var subText = movs.length+' movimientos';
    if (filterLote) subText += ' · Lote ' + filterLote;
    if (filterDesde || filterHasta) {
      subText += ' · ' + (filterDesde || 'inicio') + ' → ' + (filterHasta || 'hoy');
    }
    subEl.textContent = subText;
  }
}

// ============================================================
// v1.8.28: KARDEX ESTANCIA — movimiento de cabezas de toda la estancia (automático)
// Lee compras (entrada), nacimientos/partos (entrada), ventas (salida) y bajas (salida).
// NO incluye movimientos entre potreros. Saldo corriente en cabezas desde la compra más antigua.
// Valor promedio de compra y de venta (Bs/cab) como referencia.
// ============================================================

function _keBuildMovimientos() {
  // Devuelve array de movimientos {fecha, tipo, clase('entrada'|'salida'), detalle, cabezas, valor}
  var movs = [];

  // ENTRADAS — Compras de ganado
  (db.compras_ganado || []).forEach(function(c) {
    var fecha = String(c.fecha || '').slice(0, 10);
    if (!fecha) return;
    var cabs = parseInt(c.animal_count || c.cabezas || 0) || 0;
    if (cabs <= 0) return;
    var total = parseFloat(c.total || 0) || 0;
    movs.push({
      fecha: fecha,
      tipo: 'compra',
      clase: 'entrada',
      detalle: 'Compra' + (c.proveedor ? ' a ' + c.proveedor : '') + (c.lot_code ? ' → ' + c.lot_code : ''),
      cabezas: cabs,
      valor: total,
      valorCab: cabs > 0 ? total / cabs : 0,
      _ts: c.created_at || fecha
    });
  });

  // ENTRADAS — Nacimientos (partos)
  (db.partos || []).forEach(function(p) {
    var fecha = String(p.date || p.fecha || '').slice(0, 10);
    if (!fecha) return;
    var cabs = parseInt(p.cabezas || p.count || 1) || 1;
    movs.push({
      fecha: fecha,
      tipo: 'nacimiento',
      clase: 'entrada',
      detalle: 'Nacimiento' + (p.lot_code ? ' en ' + p.lot_code : '') + (p.cria_id && p.cria_id !== 'N/A' ? ' (cría ' + p.cria_id + ')' : ''),
      cabezas: cabs,
      valor: 0,
      valorCab: 0,
      _ts: p.created_at || fecha
    });
  });

  // SALIDAS — Ventas
  (db.sales || []).forEach(function(s) {
    var fecha = String(s.date || s.fecha || '').slice(0, 10);
    if (!fecha) return;
    var cabs = parseInt(s.animals || s.animals_count || 0) || 0;
    if (cabs <= 0) return;
    var total = parseFloat(s.total || 0) || 0;
    var destino = s.buyer || s.comprador || '';
    var loteTxt = s.lot_code || (Array.isArray(s.lot_codes) ? s.lot_codes.join(', ') : '');
    movs.push({
      fecha: fecha,
      tipo: 'venta',
      clase: 'salida',
      detalle: 'Venta' + (destino ? ' a ' + destino : '') + (loteTxt ? ' (' + loteTxt + ')' : ''),
      cabezas: cabs,
      valor: total,
      valorCab: cabs > 0 ? total / cabs : 0,
      _ts: s.created_at || fecha
    });
  });

  // SALIDAS — Bajas (muertes)
  (db.bajas || []).forEach(function(b) {
    var fecha = String(b.fecha || b.date || '').slice(0, 10);
    if (!fecha) return;
    var cabs = parseInt(b.cabezas || 1) || 1;
    movs.push({
      fecha: fecha,
      tipo: 'baja',
      clase: 'salida',
      detalle: 'Baja' + (b.causa ? ': ' + b.causa : '') + (b.lot_code ? ' (' + b.lot_code + ')' : '') + (b.animal_id ? ' — animal ' + b.animal_id : ''),
      cabezas: cabs,
      valor: 0,
      valorCab: 0,
      _ts: b.created_at || fecha
    });
  });

  // INFORMATIVO — Marcajes / traspasos (cuarentena → lote final). No mueven el saldo de la
  // estancia (los animales ya estaban dentro), pero dan trazabilidad de cuándo un lote CUAR
  // pasó a su(s) lote(s) destino.
  // v1.8.49: los datos de César no tienen marcaje_lot_destino/marcaje_completo_at en el lote;
  // la relación CUAR→destino vive en compras_ganado.lote_destinos. Reconstruimos desde ahí.
  // Primero intentamos el camino moderno (campos del lote); si no, el de las compras.
  var _marcajesDesdeCompras = false;
  (db.lots || []).forEach(function(l) {
    var st = String(l.status || '').toLowerCase();
    if (st !== 'marcado_completo' && st !== 'marcado') return;
    if (!l.marcaje_lot_destino) return; // sin destino moderno → se cubre abajo con las compras
    var fecha = String(l.marcaje_completo_at || l.entry_date || '').slice(0, 10);
    if (!fecha) return;
    var cabs = parseInt(l.animal_count || 0) || 0;
    movs.push({
      fecha: fecha,
      tipo: 'marcaje',
      clase: 'info',
      detalle: 'Marcaje: ' + l.code + ' → ' + l.marcaje_lot_destino + (cabs ? ' (' + cabs + ' cab)' : ''),
      cabezas: 0,
      valor: 0,
      valorCab: 0,
      _ts: l.marcaje_completo_at || fecha
    });
    _marcajesDesdeCompras = true; // hubo al menos un marcaje moderno para este lote
  });

  // Camino de respaldo: reconstruir marcajes desde las compras que tienen lote_destinos.
  // Solo para lotes CUAR cuyo marcaje no se haya registrado por el camino moderno.
  var _lotesConMarcajeModerno = {};
  (db.lots || []).forEach(function(l){
    if (l.marcaje_lot_destino) _lotesConMarcajeModerno[l.code] = true;
  });
  (db.compras_ganado || []).forEach(function(c) {
    var origen = c.lot_code;
    if (!origen) return;
    var destinos = Array.isArray(c.lote_destinos) ? c.lote_destinos : [];
    if (!destinos.length) return;                 // sin destino → no hubo marcaje registrado
    if (_lotesConMarcajeModerno[origen]) return;  // ya se mostró por el camino moderno
    var cabs = parseInt(c.animal_count || c.cabezas || 0) || 0;
    // fecha del marcaje: si el lote destino tiene entry_date úsalo; si no, la fecha de la compra
    var loteOrigen = (db.lots || []).find(function(l){ return l.code === origen; });
    var fecha = '';
    // preferir la entry_date del primer destino (cuando arrancó como lote propio)
    var primerDest = (db.lots || []).find(function(l){ return l.code === destinos[0]; });
    if (primerDest && primerDest.entry_date) fecha = String(primerDest.entry_date).slice(0,10);
    if (!fecha && loteOrigen && loteOrigen.entry_date) fecha = String(loteOrigen.entry_date).slice(0,10);
    if (!fecha) fecha = String(c.fecha || '').slice(0,10);
    if (!fecha) return;
    movs.push({
      fecha: fecha,
      tipo: 'marcaje',
      clase: 'info',
      detalle: 'Marcaje: ' + origen + ' → ' + destinos.join(' + ') + (cabs ? ' (' + cabs + ' cab)' : ''),
      cabezas: 0,
      valor: 0,
      valorCab: 0,
      _ts: fecha
    });
  });

  // Orden cronológico (por fecha, y dentro del día por timestamp de creación)
  movs.sort(function(a, b) {
    var fc = a.fecha.localeCompare(b.fecha);
    if (fc !== 0) return fc;
    return String(a._ts).localeCompare(String(b._ts));
  });

  return movs;
}

function renderKardexEstancia() {
  var tbody = document.getElementById('ke-tbody');
  var resumen = document.getElementById('ke-resumen');
  if (!tbody || !resumen) return;

  var todos = _keBuildMovimientos();

  // Calcular saldo corriente sobre TODOS los movimientos (antes de filtrar),
  // para que el saldo sea real aunque se filtre la vista.
  // Los movimientos 'info' (marcajes) NO mueven el saldo: el saldo se arrastra igual.
  var saldoAcum = 0;
  todos.forEach(function(m) {
    if (m.clase === 'entrada') saldoAcum += m.cabezas;
    else if (m.clase === 'salida') saldoAcum -= m.cabezas;
    m.saldo = saldoAcum;
  });

  // Totales globales para tarjetas resumen (sobre todos los movimientos)
  var totEntradas = 0, totSalidas = 0;
  var sumValorCompra = 0, cabCompra = 0, sumValorVenta = 0, cabVenta = 0;
  todos.forEach(function(m) {
    if (m.clase === 'entrada') totEntradas += m.cabezas;
    else if (m.clase === 'salida') totSalidas += m.cabezas;
    if (m.tipo === 'compra' && m.valor > 0) { sumValorCompra += m.valor; cabCompra += m.cabezas; }
    if (m.tipo === 'venta' && m.valor > 0) { sumValorVenta += m.valor; cabVenta += m.cabezas; }
  });
  var saldoActual = saldoAcum;
  var valorPromCompra = cabCompra > 0 ? sumValorCompra / cabCompra : 0;
  var valorPromVenta = cabVenta > 0 ? sumValorVenta / cabVenta : 0;

  // Render tarjetas resumen
  function card(icon, label, value, sub, color, accent) {
    return '<div style="position:relative;background:var(--sur);border:1px solid var(--bor);border-radius:12px;padding:16px 18px;overflow:hidden">' +
      (accent ? '<div style="position:absolute;top:0;left:0;right:0;height:3px;background:' + accent + '"></div>' : '') +
      '<div style="display:flex;align-items:center;gap:7px;margin-bottom:10px">' +
        '<span style="font-size:15px">' + icon + '</span>' +
        '<span style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.07em;font-weight:600">' + label + '</span>' +
      '</div>' +
      '<div style="font-family:\'DM Mono\',monospace;font-size:26px;font-weight:700;line-height:1;color:' + (color || 'var(--text)') + '">' + value + '</div>' +
      (sub ? '<div style="font-size:10px;color:var(--muted);margin-top:6px">' + sub + '</div>' : '') +
      '</div>';
  }
  resumen.innerHTML =
    card('🐄', 'Saldo actual', saldoActual.toLocaleString() + '<span style="font-size:14px;color:var(--muted);font-weight:400"> cab</span>', 'existencia en la estancia', 'var(--amber)', 'var(--amber)') +
    card('📥', 'Total entradas', '+' + totEntradas.toLocaleString(), 'compras + nacimientos', '#3fb950', '#3fb950') +
    card('📤', 'Total salidas', '−' + totSalidas.toLocaleString(), 'ventas + bajas', '#f85149', '#f85149') +
    card('💰', 'Valor prom. compra', valorPromCompra > 0 ? '<span style="font-size:14px;color:var(--muted);font-weight:400">Bs </span>' + Math.round(valorPromCompra).toLocaleString() : '—', 'por cabeza (ref.)', 'var(--text)', '#30363d') +
    card('💵', 'Valor prom. venta', valorPromVenta > 0 ? '<span style="font-size:14px;color:var(--muted);font-weight:400">Bs </span>' + Math.round(valorPromVenta).toLocaleString() : '—', 'por cabeza (ref.)', 'var(--text)', '#30363d');

  // Filtros
  var tipoSel = (document.getElementById('ke-tipo-sel') || {}).value || '';
  var desde = (document.getElementById('ke-fecha-desde') || {}).value || '';
  var hasta = (document.getElementById('ke-fecha-hasta') || {}).value || '';

  var filtrados = todos.filter(function(m) {
    if (tipoSel === 'entrada' && m.clase !== 'entrada') return false;
    if (tipoSel === 'salida' && m.clase !== 'salida') return false;
    if (tipoSel && ['compra','nacimiento','venta','baja','marcaje'].indexOf(tipoSel) >= 0 && m.tipo !== tipoSel) return false;
    if (desde && m.fecha < desde) return false;
    if (hasta && m.fecha > hasta) return false;
    return true;
  });

  // Subtítulo
  var sub = document.getElementById('ke-tabla-sub');
  if (sub) sub.textContent = filtrados.length + ' movimiento' + (filtrados.length === 1 ? '' : 's') + (filtrados.length !== todos.length ? ' (de ' + todos.length + ')' : '');

  if (!filtrados.length) {
    tbody.innerHTML = '<tr><td colspan="6" style="padding:30px;text-align:center;color:var(--muted)">Sin movimientos registrados' + (todos.length ? ' para este filtro' : '') + '</td></tr>';
    return;
  }

  // Mostrar más reciente primero (el saldo ya está calculado cronológicamente)
  var vista = filtrados.slice().reverse();

  // Config visual por tipo de movimiento
  var tipoCfg = {
    compra:     { icon: '📥', label: 'Compra',     color: '#3fb950', bg: 'rgba(63,185,80,0.10)' },
    nacimiento: { icon: '🐣', label: 'Nacimiento', color: '#58A6FF', bg: 'rgba(88,166,255,0.10)' },
    venta:      { icon: '📤', label: 'Venta',      color: '#d29922', bg: 'rgba(210,153,34,0.10)' },
    baja:       { icon: '⚰',  label: 'Baja',        color: '#f85149', bg: 'rgba(248,81,73,0.10)' },
    marcaje:    { icon: '🏷️', label: 'Marcaje',     color: '#a855f7', bg: 'rgba(168,85,247,0.10)' }
  };

  var html = '<div style="display:flex;flex-direction:column">';
  vista.forEach(function(m, idx) {
    var cfg = tipoCfg[m.tipo] || { icon: '•', label: m.tipo, color: 'var(--muted)', bg: 'rgba(125,133,144,0.08)' };
    var esEntrada = m.clase === 'entrada';
    var esInfo = m.clase === 'info';
    var isLast = idx === vista.length - 1;
    var signo = esEntrada ? '+' : '−';
    var cambioColor = esEntrada ? '#3fb950' : '#f85149';

    // Columna de cambio: para marcajes (info) no hay +/−, solo un guión sutil
    var colCambio = esInfo
      ? '<div style="text-align:right;min-width:48px">' +
          '<div style="font-family:\'DM Mono\',monospace;font-size:15px;font-weight:700;color:var(--muted2)">—</div>' +
          '<div style="font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:.05em">s/cambio</div>' +
        '</div>'
      : '<div style="text-align:right;min-width:48px">' +
          '<div style="font-family:\'DM Mono\',monospace;font-size:17px;font-weight:700;color:' + cambioColor + '">' + signo + m.cabezas + '</div>' +
          '<div style="font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:.05em">' + (esEntrada ? 'entran' : 'salen') + '</div>' +
        '</div>';

    html +=
      '<div style="display:flex;align-items:stretch;gap:0;border-bottom:' + (isLast ? 'none' : '1px solid var(--bor)') + ';transition:background .12s' + (esInfo ? ';opacity:.82' : '') + '" ' +
        'onmouseover="this.style.background=\'rgba(255,255,255,0.02)\'" onmouseout="this.style.background=\'transparent\'">' +

        // Columna timeline (ícono + línea conectora)
        '<div style="position:relative;width:56px;flex-shrink:0;display:flex;justify-content:center;padding:14px 0">' +
          (isLast ? '' : '<div style="position:absolute;top:38px;bottom:-1px;left:50%;width:2px;background:var(--bor);transform:translateX(-50%)"></div>') +
          '<div style="position:relative;z-index:1;width:34px;height:34px;border-radius:50%;background:' + cfg.bg + ';border:1.5px solid ' + cfg.color + '40;display:flex;align-items:center;justify-content:center;font-size:15px">' + cfg.icon + '</div>' +
        '</div>' +

        // Columna central (tipo + detalle + fecha)
        '<div style="flex:1;min-width:0;padding:14px 16px 14px 4px;display:flex;flex-direction:column;justify-content:center;gap:3px">' +
          '<div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">' +
            '<span style="font-size:11px;font-weight:700;letter-spacing:.03em;text-transform:uppercase;color:' + cfg.color + '">' + cfg.label + '</span>' +
            '<span style="font-family:\'DM Mono\',monospace;font-size:10px;color:var(--muted)">' + _ahFmtFecha(m.fecha) + '</span>' +
          '</div>' +
          '<div style="font-size:13px;color:var(--text);line-height:1.35;overflow:hidden;text-overflow:ellipsis">' + escH(m.detalle) + '</div>' +
          (m.valor > 0 ? '<div style="font-family:\'DM Mono\',monospace;font-size:10px;color:var(--muted)">Bs ' + Math.round(m.valorCab).toLocaleString() + ' / cabeza</div>' : '') +
        '</div>' +

        // Columna derecha (cambio +/- y saldo)
        '<div style="flex-shrink:0;display:flex;align-items:center;gap:18px;padding:14px 18px 14px 8px">' +
          colCambio +
          '<div style="text-align:right;min-width:62px;background:rgba(210,153,34,0.08);border:1px solid rgba(210,153,34,0.2);border-radius:8px;padding:6px 12px">' +
            '<div style="font-family:\'DM Mono\',monospace;font-size:18px;font-weight:700;color:var(--amber);line-height:1">' + m.saldo.toLocaleString() + '</div>' +
            '<div style="font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;margin-top:2px">saldo</div>' +
          '</div>' +
        '</div>' +
      '</div>';
  });
  html += '</div>';
  tbody.innerHTML = '<tr style="background:transparent!important"><td colspan="6" style="padding:0;background:transparent!important">' + html + '</td></tr>';
}

function clearKardexEstanciaFiltros() {
  var t = document.getElementById('ke-tipo-sel'); if (t) t.value = '';
  var d = document.getElementById('ke-fecha-desde'); if (d) d.value = '';
  var h = document.getElementById('ke-fecha-hasta'); if (h) h.value = '';
  renderKardexEstancia();
}

function exportKardexEstancia() {
  var todos = _keBuildMovimientos();
  var saldoAcum = 0;
  todos.forEach(function(m) { saldoAcum += (m.clase === 'entrada' ? m.cabezas : -m.cabezas); m.saldo = saldoAcum; });

  // Aplicar filtros activos al export
  var tipoSel = (document.getElementById('ke-tipo-sel') || {}).value || '';
  var desde = (document.getElementById('ke-fecha-desde') || {}).value || '';
  var hasta = (document.getElementById('ke-fecha-hasta') || {}).value || '';
  var filtrados = todos.filter(function(m) {
    if (tipoSel === 'entrada' && m.clase !== 'entrada') return false;
    if (tipoSel === 'salida' && m.clase !== 'salida') return false;
    if (tipoSel && ['compra','nacimiento','venta','baja','marcaje'].indexOf(tipoSel) >= 0 && m.tipo !== tipoSel) return false;
    if (desde && m.fecha < desde) return false;
    if (hasta && m.fecha > hasta) return false;
    return true;
  });

  if (!filtrados.length) { toast('No hay movimientos para exportar', 'warning'); return; }

  var rows = [['Fecha', 'Movimiento', 'Detalle', 'Entran', 'Salen', 'Saldo', 'Valor/cab (Bs)']];
  filtrados.forEach(function(m) {
    rows.push([
      m.fecha,
      m.tipo,
      m.detalle,
      m.clase === 'entrada' ? m.cabezas : '',
      m.clase === 'salida' ? m.cabezas : '',
      m.saldo,
      m.valor > 0 ? Math.round(m.valorCab) : ''
    ]);
  });

  var csv = rows.map(function(r) {
    return r.map(function(cell) {
      var s = String(cell == null ? '' : cell);
      if (s.indexOf(',') >= 0 || s.indexOf('"') >= 0 || s.indexOf('\n') >= 0) s = '"' + s.replace(/"/g, '""') + '"';
      return s;
    }).join(',');
  }).join('\n');

  var blob = new Blob(['\ufeff' + csv], { type: 'text/csv;charset=utf-8;' });
  var url = URL.createObjectURL(blob);
  var a = document.createElement('a');
  a.href = url;
  a.download = 'kardex_estancia_' + new Date().toISOString().slice(0, 10) + '.csv';
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  URL.revokeObjectURL(url);
  toast('Kardex exportado (' + filtrados.length + ' movimientos)', 'success');
}



// ============================================================
// v1.8.37: RENTABILIDAD X PROVEEDOR — análisis transversal de rentabilidad del ganado de engorde.
// Para cada proveedor: cruza sus compras con las ventas de los lotes de destino (siguiendo el linaje
// cuarentena→marcaje→lote final). Calcula inversión, ingreso, resultado, margen %, GMD, etc.
// Solo cuenta ciclos CERRADOS (lotes vendidos); las cabezas aún en engorde se muestran como dato aparte.
// ============================================================

function _rpBuildData() {
  var compras = db.compras_ganado || [];
  var ventas = db.sales || [];

  // Agrupar por proveedor
  var porProv = {};

  compras.forEach(function(c) {
    var prov = (c.proveedor || c.cuarentena_origen || '').trim();
    if (!prov) prov = '(sin proveedor)';
    if (!porProv[prov]) {
      porProv[prov] = {
        proveedor: prov,
        cabsCompradas: 0,
        inversionTotal: 0,
        kgIngreso: 0,
        compras: [],
        lotesDestino: {}  // code -> true
      };
    }
    var p = porProv[prov];
    var cabs = parseInt(c.animal_count || c.cabezas || 0) || 0;
    var total = parseFloat(c.total || 0) || 0;
    var kg = parseFloat(c.total_kg || 0) || 0;
    p.cabsCompradas += cabs;
    p.inversionTotal += total;
    p.kgIngreso += kg;
    p.compras.push(c);
    // Lotes de destino de esta compra (directo + lote_destinos + marcaje)
    if (c.lot_code) p.lotesDestino[c.lot_code] = true;
    if (Array.isArray(c.lote_destinos)) c.lote_destinos.forEach(function(ld){ p.lotesDestino[ld] = true; });
  });

  // v1.8.40: ATRIBUCIÓN PROPORCIONAL. Un mismo lote puede recibir ganado de varios proveedores
  // (ej. TROPA 3 recibió cabezas de NELORÍ y de EL CARMEN). Antes cada proveedor se llevaba las
  // ventas COMPLETAS del lote → doble conteo e inversión/ventas infladas. Ahora se reparte cada
  // lote según la fracción de cabezas que cada compra aportó.

  // Paso 1: mapa lote_destino → [{prov, cabs}] (cuántas cabezas aportó cada proveedor a cada lote)
  // v1.8.47: normalizar nombres de lote. Las compras a veces apuntan a "TROPA 1" pero el lote
  // real se llama "Tropa 1" (mayúsculas/espacios distintos). Resolvemos cada código al nombre
  // real del lote para que los aportes caigan en el lote correcto y no en uno fantasma.
  var lotesReales = (db.lots || []).map(function(l){ return l.code; });
  function _normLote(code){
    if (!code) return code;
    var c = String(code).trim();
    // match exacto primero
    if (lotesReales.indexOf(c) >= 0) return c;
    // match case-insensitive ignorando espacios extra
    var cKey = c.toLowerCase().replace(/\s+/g, ' ');
    var found = lotesReales.find(function(lc){ return String(lc).toLowerCase().replace(/\s+/g, ' ') === cKey; });
    return found || c;
  }

  var aportesPorLote = {}; // code -> total cabs aportadas, y por proveedor
  Object.keys(porProv).forEach(function(prov){
    porProv[prov].compras.forEach(function(c){
      var cabs = parseInt(c.animal_count || c.cabezas || 0) || 0;
      if (cabs <= 0) return;
      // destinos de esta compra: lot_code y lote_destinos (normalizados al nombre real)
      var destinos = [];
      if (c.lot_code) destinos.push(_normLote(c.lot_code));
      if (Array.isArray(c.lote_destinos)) c.lote_destinos.forEach(function(ld){ var n = _normLote(ld); if (destinos.indexOf(n) < 0) destinos.push(n); });
      if (!destinos.length) return;
      // repartir las cabezas de la compra entre sus destinos (si hay varios, en partes iguales)
      var cabsPorDestino = cabs / destinos.length;
      destinos.forEach(function(code){
        if (!aportesPorLote[code]) aportesPorLote[code] = { total: 0, porProv: {} };
        aportesPorLote[code].total += cabsPorDestino;
        aportesPorLote[code].porProv[prov] = (aportesPorLote[code].porProv[prov] || 0) + cabsPorDestino;
      });
    });
  });

  // Paso 2: para cada lote final (siguiendo linaje), determinar de qué lotes-destino proviene,
  // y por ende qué fracción corresponde a cada proveedor.
  // fraccionLoteProv[code][prov] = fracción (0..1) de ese lote que es de ese proveedor.
  var fraccionLoteProv = {};
  (db.lots || []).forEach(function(lot){
    if (!lot.code) return;
    var lineage = (typeof _ahGetLineage === 'function') ? _ahGetLineage(lot.code) : [{code:lot.code}];
    // sumar aportes de todos los lotes-destino que aparecen en el linaje de este lote
    var acumProv = {}; var acumTotal = 0;
    lineage.forEach(function(ln){
      var ap = aportesPorLote[ln.code];
      if (!ap) return;
      Object.keys(ap.porProv).forEach(function(prov){
        acumProv[prov] = (acumProv[prov] || 0) + ap.porProv[prov];
        acumTotal += ap.porProv[prov];
      });
    });
    if (acumTotal > 0) {
      fraccionLoteProv[lot.code] = {};
      Object.keys(acumProv).forEach(function(prov){
        fraccionLoteProv[lot.code][prov] = acumProv[prov] / acumTotal;
      });
    }
  });

  // Paso 3: recorrer cada lote y repartir sus ventas / engorde proporcionalmente entre proveedores
  Object.keys(porProv).forEach(function(prov){
    var p = porProv[prov];
    p.cabsVendidas = 0; p.kgVendidos = 0; p.ingresoVenta = 0; p.cabsEnEngorde = 0;
  });

  (db.lots || []).forEach(function(lot){
    if (!lot.code) return;
    var fracMap = fraccionLoteProv[lot.code];
    if (!fracMap) return; // este lote no proviene de ninguna compra rastreable
    var st = String(lot.status || '').toLowerCase();
    var esVendido = (st === 'vendido' || st === 'sold');
    var esVivo = (st !== 'fusionado' && st !== 'merged' && st !== 'marcado' && st !== 'marcado_completo' && st !== 'inactivo' && !esVendido);

    if (esVendido) {
      // sumar ventas del lote (totales) una sola vez
      var lotCabs = 0, lotKg = 0, lotIngreso = 0;
      ventas.forEach(function(v){
        var a = (typeof _ahAtribuirVentaALote === 'function') ? _ahAtribuirVentaALote(v, lot.code) : null;
        if (a && a.cabs > 0) { lotCabs += a.cabs; lotKg += a.kg; lotIngreso += a.ingreso; }
      });
      // repartir entre proveedores según su fracción
      Object.keys(fracMap).forEach(function(prov){
        if (!porProv[prov]) return;
        var f = fracMap[prov];
        porProv[prov].cabsVendidas += lotCabs * f;
        porProv[prov].kgVendidos   += lotKg * f;
        porProv[prov].ingresoVenta += lotIngreso * f;
      });
    } else if (esVivo) {
      var lotCabsVivas = parseInt(lot.animal_count || 0) || 0;
      Object.keys(fracMap).forEach(function(prov){
        if (!porProv[prov]) return;
        porProv[prov].cabsEnEngorde += lotCabsVivas * fracMap[prov];
      });
    }
  });

  // Paso 4: calcular costos y métricas derivadas por proveedor
  Object.keys(porProv).forEach(function(prov) {
    var p = porProv[prov];
    // redondear cabezas (las fracciones pueden dar decimales)
    p.cabsVendidas = Math.round(p.cabsVendidas);
    p.cabsEnEngorde = Math.round(p.cabsEnEngorde);

    // v1.8.47: SALVAGUARDA — un proveedor no puede tener más cabezas (vendidas + en engorde)
    // que las que compró. Los datos de ventas multi-lote a veces mezclan lotes y la atribución
    // puede sobrepasar lo comprado; capar evita resultados imposibles (ej. 4 compradas → 9 vendidas).
    if (p.cabsCompradas > 0) {
      var totalSalidas = p.cabsVendidas + p.cabsEnEngorde;
      if (totalSalidas > p.cabsCompradas) {
        // escalar proporcionalmente vendidas y engorde para que sumen como mucho lo comprado
        var factor = p.cabsCompradas / totalSalidas;
        var nuevasVendidas = Math.round(p.cabsVendidas * factor);
        // escalar también kg e ingreso de las ventas en la misma proporción (coherencia)
        if (p.cabsVendidas > 0) {
          var ratioVendidas = nuevasVendidas / p.cabsVendidas;
          p.kgVendidos *= ratioVendidas;
          p.ingresoVenta *= ratioVendidas;
        }
        p.cabsVendidas = nuevasVendidas;
        p.cabsEnEngorde = p.cabsCompradas - nuevasVendidas;
        if (p.cabsEnEngorde < 0) p.cabsEnEngorde = 0;
        p._capado = true; // marca para mostrar aviso en la UI
      }
    }

    var costoPorCabCompra = p.cabsCompradas > 0 ? p.inversionTotal / p.cabsCompradas : 0;
    var costoVendido = costoPorCabCompra * p.cabsVendidas;

    var pesoPromIngreso = p.cabsCompradas > 0 ? p.kgIngreso / p.cabsCompradas : 0;
    var pesoPromVenta = p.cabsVendidas > 0 ? p.kgVendidos / p.cabsVendidas : 0;

    p.costoVendido = costoVendido;
    p.resultado = p.ingresoVenta - costoVendido;
    p.margen = costoVendido > 0 ? (p.resultado / costoVendido) * 100 : 0;
    p.costoPorCab = costoPorCabCompra;
    p.pesoPromIngreso = pesoPromIngreso;
    p.pesoPromVenta = pesoPromVenta;
    p.precioPromKgVenta = p.kgVendidos > 0 ? p.ingresoVenta / p.kgVendidos : 0;
  });

  // Convertir a array y ordenar por margen (más rentable primero), proveedores con ventas arriba
  var arr = Object.keys(porProv).map(function(k){ return porProv[k]; });
  arr.sort(function(a, b) {
    // Primero los que tienen ventas (ciclo cerrado), luego por margen
    if ((a.cabsVendidas > 0) !== (b.cabsVendidas > 0)) return a.cabsVendidas > 0 ? -1 : 1;
    return b.margen - a.margen;
  });
  return arr;
}

function renderRentabilidadProveedor() {
  var resumen = document.getElementById('rp-resumen');
  var lista = document.getElementById('rp-lista');
  if (!resumen || !lista) return;

  var data = _rpBuildData();

  // Totales globales
  var totInversion = 0, totIngreso = 0, totResultado = 0, totCabsVendidas = 0, totEnEngorde = 0;
  data.forEach(function(p) {
    totInversion += p.costoVendido;
    totIngreso += p.ingresoVenta;
    totResultado += p.resultado;
    totCabsVendidas += p.cabsVendidas;
    totEnEngorde += p.cabsEnEngorde;
  });
  var margenGlobal = totInversion > 0 ? (totResultado / totInversion) * 100 : 0;

  function card(icon, label, value, sub, color, accent) {
    return '<div style="position:relative;background:var(--sur);border:1px solid var(--bor);border-radius:12px;padding:16px 18px;overflow:hidden">' +
      (accent ? '<div style="position:absolute;top:0;left:0;right:0;height:3px;background:' + accent + '"></div>' : '') +
      '<div style="display:flex;align-items:center;gap:7px;margin-bottom:10px"><span style="font-size:15px">' + icon + '</span><span style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.07em;font-weight:600">' + label + '</span></div>' +
      '<div style="font-family:\'DM Mono\',monospace;font-size:24px;font-weight:700;line-height:1;color:' + (color || 'var(--text)') + '">' + value + '</div>' +
      (sub ? '<div style="font-size:10px;color:var(--muted);margin-top:6px">' + sub + '</div>' : '') +
      '</div>';
  }

  var resultColor = totResultado >= 0 ? '#3fb950' : '#f85149';
  var margenColor = margenGlobal >= 0 ? '#3fb950' : '#f85149';
  resumen.innerHTML =
    card('💰', 'Inversión (vendido)', '<span style="font-size:14px;color:var(--muted);font-weight:400">Bs </span>' + Math.round(totInversion).toLocaleString(), 'costo del ganado vendido', 'var(--text)', '#30363d') +
    card('💵', 'Ingreso por venta', '<span style="font-size:14px;color:var(--muted);font-weight:400">Bs </span>' + Math.round(totIngreso).toLocaleString(), 'de ciclos cerrados', '#3fb950', '#3fb950') +
    card('📈', 'Resultado bruto', '<span style="font-size:14px;color:var(--muted);font-weight:400">Bs </span>' + Math.round(totResultado).toLocaleString(), 'ingreso − costo', resultColor, resultColor) +
    card('📊', 'Margen global', margenGlobal.toFixed(1) + '%', 'rentabilidad promedio', margenColor, margenColor) +
    card('🐂', 'En engorde', totEnEngorde.toLocaleString() + '<span style="font-size:14px;color:var(--muted);font-weight:400"> cab</span>', 'aún sin vender', 'var(--amber)', 'var(--amber)');

  if (!data.length) {
    lista.innerHTML = '<div style="background:var(--sur);border:1px solid var(--bor);border-radius:12px;padding:40px;text-align:center;color:var(--muted)">No hay compras de ganado registradas todavía.</div>';
    return;
  }

  // Ranking de proveedores
  var html = '';
  data.forEach(function(p, idx) {
    var tieneVentas = p.cabsVendidas > 0;
    var resultColor = p.resultado >= 0 ? '#3fb950' : '#f85149';
    var margenColor = p.margen >= 0 ? '#3fb950' : '#f85149';
    var medalla = (tieneVentas && idx === 0) ? '🥇 ' : (tieneVentas && idx === 1) ? '🥈 ' : (tieneVentas && idx === 2) ? '🥉 ' : '';

    html += '<div style="background:var(--sur);border:1px solid var(--bor);border-radius:12px;padding:18px;margin-bottom:12px">';

    // Encabezado del proveedor
    html += '<div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:12px;margin-bottom:14px">';
    html += '<div>';
    html += '<div style="font-size:17px;font-weight:700;color:var(--text)">' + medalla + escH(p.proveedor) + '</div>';
    html += '<div style="font-size:11px;color:var(--muted);margin-top:3px">' + p.cabsCompradas + ' cab compradas · Bs ' + Math.round(p.costoPorCab).toLocaleString() + '/cab · ' + (p.pesoPromIngreso > 0 ? p.pesoPromIngreso.toFixed(0) + ' kg ingreso prom' : 'sin peso') + '</div>';
    if (p._capado) {
      html += '<div style="font-size:10.5px;color:#d4a017;margin-top:4px;display:flex;align-items:center;gap:4px" title="Algunas ventas mezclaban varios lotes en un mismo registro, así que las cabezas atribuidas a este proveedor se ajustaron para no superar las que compró. Para mayor precisión, registrá las ventas por lote individual.">⚠️ Cifras ajustadas: ventas de lotes combinados</div>';
    }
    html += '</div>';
    if (tieneVentas) {
      html += '<div style="text-align:right">';
      html += '<div style="font-family:\'DM Mono\',monospace;font-size:26px;font-weight:700;color:' + margenColor + ';line-height:1">' + (p.margen >= 0 ? '+' : '') + p.margen.toFixed(1) + '%</div>';
      html += '<div style="font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:.05em">margen</div>';
      html += '</div>';
    } else {
      html += '<div style="text-align:right"><span style="background:rgba(210,153,34,0.12);color:var(--amber);border:1px solid rgba(210,153,34,0.3);padding:4px 12px;border-radius:12px;font-size:11px;font-weight:600">⏳ En engorde</span></div>';
    }
    html += '</div>';

    if (tieneVentas) {
      // Métricas en grid
      html += '<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:1px;background:var(--bor);border-radius:8px;overflow:hidden">';
      function celda(label, value, color) {
        return '<div style="background:var(--bg);padding:10px 12px"><div style="font-size:9px;color:var(--muted);text-transform:uppercase;letter-spacing:.05em">' + label + '</div><div style="font-family:\'DM Mono\',monospace;font-size:15px;font-weight:600;color:' + (color || 'var(--text)') + ';margin-top:3px">' + value + '</div></div>';
      }
      html += celda('Vendidas', p.cabsVendidas + ' cab', 'var(--text)');
      html += celda('Inversión', 'Bs ' + Math.round(p.costoVendido).toLocaleString(), 'var(--text)');
      html += celda('Ingreso', 'Bs ' + Math.round(p.ingresoVenta).toLocaleString(), '#3fb950');
      html += celda('Resultado', 'Bs ' + Math.round(p.resultado).toLocaleString(), resultColor);
      html += celda('Precio/kg', 'Bs ' + p.precioPromKgVenta.toFixed(2), 'var(--text)');
      var deltaPeso = p.pesoPromVenta - p.pesoPromIngreso;
      html += celda('Δ Peso/cab', (deltaPeso >= 0 ? '+' : '') + deltaPeso.toFixed(0) + ' kg', deltaPeso >= 0 ? '#3fb950' : '#f85149');
      if (p.cabsEnEngorde > 0) {
        html += celda('En engorde', p.cabsEnEngorde + ' cab', 'var(--amber)');
      }
      html += '</div>';
    } else {
      html += '<div style="font-size:12px;color:var(--muted)">' + p.cabsEnEngorde + ' cabezas de este proveedor aún en engorde (sin ventas registradas todavía). La rentabilidad se calculará cuando se vendan.</div>';
    }

    html += '</div>';
  });
  lista.innerHTML = html;
}

function exportRentabilidadProveedor() {
  var data = _rpBuildData();
  if (!data.length) { toast('No hay datos para exportar', 'warning'); return; }

  var rows = [['Proveedor', 'Cab compradas', 'Costo/cab (Bs)', 'Peso ingreso prom (kg)', 'Cab vendidas', 'Inversion vendido (Bs)', 'Ingreso venta (Bs)', 'Resultado (Bs)', 'Margen %', 'Precio/kg venta (Bs)', 'Delta peso/cab (kg)', 'En engorde (cab)']];
  data.forEach(function(p) {
    var deltaPeso = p.pesoPromVenta - p.pesoPromIngreso;
    rows.push([
      p.proveedor,
      p.cabsCompradas,
      Math.round(p.costoPorCab),
      p.pesoPromIngreso > 0 ? p.pesoPromIngreso.toFixed(0) : '',
      p.cabsVendidas,
      Math.round(p.costoVendido),
      Math.round(p.ingresoVenta),
      Math.round(p.resultado),
      p.cabsVendidas > 0 ? p.margen.toFixed(1) : '',
      p.cabsVendidas > 0 ? p.precioPromKgVenta.toFixed(2) : '',
      p.cabsVendidas > 0 ? deltaPeso.toFixed(0) : '',
      p.cabsEnEngorde
    ]);
  });

  var csv = rows.map(function(r) {
    return r.map(function(cell) {
      var s = String(cell == null ? '' : cell);
      if (s.indexOf(',') >= 0 || s.indexOf('"') >= 0 || s.indexOf('\n') >= 0) s = '"' + s.replace(/"/g, '""') + '"';
      return s;
    }).join(',');
  }).join('\n');

  var blob = new Blob(['\ufeff' + csv], { type: 'text/csv;charset=utf-8;' });
  var url = URL.createObjectURL(blob);
  var a = document.createElement('a');
  a.href = url;
  a.download = 'rentabilidad_proveedor_' + new Date().toISOString().slice(0, 10) + '.csv';
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  URL.revokeObjectURL(url);
  toast('Reporte exportado (' + data.length + ' proveedores)', 'success');
}


