// updateSubcuentas removed — now uses autofillCuCuenta

function guardarCuenta() {
  var cuenta=(document.getElementById('cu-cuenta')||{}).value||'';
  var subcuenta=((document.getElementById('cu-subcuenta')||{}).value||'').trim();
  var tipo=(document.getElementById('cu-tipo')||{}).value||'VARIABLE';
  var fecha=(document.getElementById('cu-fecha')||{}).value||'';
  var detalle=((document.getElementById('cu-detalle')||{}).value||'').trim();
