// ═══════════════════════════════════════════════════════════════
// ANÁLISIS HISTÓRICO DE LOTES VENDIDOS (v1.4.56)
// ═══════════════════════════════════════════════════════════════
// Vista de análisis post-venta para lotes con status='vendido' o 'sold'.
// NO depende de e5m_animals[] (que se vacía al vender). Usa datos persistentes:
//   - db.lots (lote con status)
//   - db.pesajes (filtrados por lot_code)
//   - db.treatments (filtrados por lot_code)
//   - db.sales (filtrados por lot_code o items[].lot_code)
//   - db.compras_ganado (filtrados por lot_code)
//   - db.bajas, db.partos, db.conteo (filtrados por lot_code)

var _ahChartPesos = null;

// v1.4.96: Helper para detectar cadena de linaje de un lote.
// Devuelve array de { code, splitDate } desde el más antiguo al actual.
// Si un lote tiene cost_origin.from_lot, se considera sub-lote de ese padre.
// La cadena se construye recursivamente subiendo por cost_origin hasta llegar
// a un lote sin from_lot o hasta detectar un ciclo.
// v1.4.99: FIX — el splitDate pertenece AL HIJO (es cuándo se separó del padre),
// no al padre. Antes lo pegaba al padre y el hijo quedaba con splitDate=null,
// lo que hacía que _ahCollectInheritedEvents saliera temprano con continue.
// v1.4.100: heurística por nombre si cost_origin no existe (lotes legacy).
//   Si el lote se llama "X-A" o "X-B", busca el lote padre "X" en db.lots.
//   No es perfecto (depende de naming convention) pero rescata los casos legacy
//   donde el split se hizo antes de que el server poblara cost_origin.
function _ahGetLineage(lotCode) {
  var raw = [];
  var seen = {};
  var currentCode = lotCode;
  while (currentCode && !seen[currentCode]) {
    seen[currentCode] = true;
    var lot = (db.lots || []).find(function(l) { return l && l.code === currentCode; });
    var splitDate = (lot && lot.cost_origin && lot.cost_origin.date) ? lot.cost_origin.date : null;
    raw.unshift({ code: currentCode, splitDate: splitDate });

    // Caso 1: cost_origin.from_lot poblado (camino limpio del bot v5.4.9+)
    if (lot && lot.cost_origin && lot.cost_origin.from_lot) {
      currentCode = lot.cost_origin.from_lot;
      continue;
    }

    // Caso 2: heurística por nombre. "TEST 123-A" → buscar "TEST 123"
    // Patrón: nombre termina en " -X", "-X", o " X" donde X es 1-3 caracteres alfanuméricos
    var nameMatch = String(currentCode).match(/^(.+?)\s*-\s*[A-Z0-9]{1,3}$/i);
    if (nameMatch && nameMatch[1]) {
      var candidateParent = nameMatch[1].trim();
      var parentLot = (db.lots || []).find(function(l) { return l && l.code === candidateParent; });
      if (parentLot && !seen[candidateParent]) {
        // Inferir splitDate: usar entry_date del hijo (cuando arrancó como lote propio)
        if (raw[0].code === currentCode && !raw[0].splitDate && lot && lot.entry_date) {
          raw[0].splitDate = lot.entry_date;
          raw[0]._inferredFromName = true;
        }
        currentCode = candidateParent;
        continue;
      }
    }

    // No hay más padre identificable
    break;
  }
  return raw;
}

// v1.4.96: Recolecta eventos heredados de los ancestros del lote.
// Para cada padre en la cadena, toma sus eventos que ocurrieron ANTES de la fecha
// del split que generó al sub-lote siguiente. Marca cada evento con _inherited:true
// y _from_lot:codeDelPadre para que el renderer los distinga visualmente.
function _ahCollectInheritedEvents(lineage) {
  // lineage[0] = lote más antiguo, lineage[last] = lote actual
  // Solo recolectamos si hay al menos 2 elementos (sub-lote real)
  var inherited = {
    pesajes: [],
    compras: [],
    treatments: [],
    bajas: [],
    partos: [],
    conteos: [],
    mantenimientos: [],
    sales: [],
    splits: []  // los eventos de split mismos, como hitos en la timeline
  };
  if (lineage.length < 2) return inherited;

  // Para cada padre (todos menos el último que es el lote actual),
  // tomamos eventos hasta la fecha del split del HIJO siguiente.
  for (var i = 0; i < lineage.length - 1; i++) {
    var parentCode = lineage[i].code;
    var childEntry = lineage[i + 1]; // el sub-lote que se creó de parentCode
    var cutoffDate = childEntry.splitDate;
    if (!cutoffDate) continue;

    function _beforeCut(dateStr) {
      if (!dateStr) return false;
      return String(dateStr).slice(0,10) <= cutoffDate.slice(0,10);
    }

    (db.pesajes || []).forEach(function(p) {
      if (p.lot_code === parentCode && _beforeCut(p.date)) {
        inherited.pesajes.push(Object.assign({}, p, { _inherited: true, _from_lot: parentCode }));
      }
    });
    (db.compras_ganado || []).forEach(function(c) {
      var match = (c.lot_code === parentCode) || (Array.isArray(c.lote_destinos) && c.lote_destinos.indexOf(parentCode) >= 0);
      if (match && _beforeCut(c.fecha)) {
        inherited.compras.push(Object.assign({}, c, { _inherited: true, _from_lot: parentCode }));
      }
    });
    (db.treatments || []).forEach(function(t) {
      if (t.lot_code === parentCode && _beforeCut(t.applied_at || t.date)) {
        inherited.treatments.push(Object.assign({}, t, { _inherited: true, _from_lot: parentCode }));
      }
    });
    (db.bajas || []).forEach(function(b) {
      if (b.lot_code === parentCode && _beforeCut(b.fecha || b.date)) {
        inherited.bajas.push(Object.assign({}, b, { _inherited: true, _from_lot: parentCode }));
      }
    });
    (db.partos || []).forEach(function(p) {
      if (p.lot_code === parentCode && _beforeCut(p.fecha || p.date)) {
        inherited.partos.push(Object.assign({}, p, { _inherited: true, _from_lot: parentCode }));
      }
    });
    (db.conteo || []).forEach(function(c) {
      if (c.lot_code === parentCode && _beforeCut(c.fecha || c.date)) {
        inherited.conteos.push(Object.assign({}, c, { _inherited: true, _from_lot: parentCode }));
      }
    });
    (db.mantenimientos || []).forEach(function(m) {
      if (m.lot_code === parentCode && _beforeCut(m.fecha || m.date)) {
        inherited.mantenimientos.push(Object.assign({}, m, { _inherited: true, _from_lot: parentCode }));
      }
    });
    // Eventos de split mismos: el momento en que parentCode dio origen a child
    // v1.4.100: aceptar también el caso heurístico (sin cost_origin) usando entry_date
    var childLot = (db.lots || []).find(function(l) { return l && l.code === childEntry.code; });
    if (childLot) {
      var cabs = 0, totalKg = 0;
      if (childLot.cost_origin) {
        cabs = childLot.cost_origin.animal_count || childLot.animal_count || 0;
        totalKg = childLot.cost_origin.total_kg || 0;
      } else {
        // Heurística: usar datos actuales del child como aproximación
        cabs = childLot.animal_count || 0;
        totalKg = (childLot.avg_weight || 0) * cabs;
      }
      inherited.splits.push({
        date: cutoffDate,
        from_lot: parentCode,
        to_lot: childEntry.code,
        cabs: cabs,
        total_kg: totalKg,
        via: (childLot.cost_origin && childLot.cost_origin.via) ? childLot.cost_origin.via : 'split',
        _inferred: !childLot.cost_origin
      });
    }
  }
  return inherited;
}

function initAnalisisHistorico() {
  var sel = document.getElementById('ah-lot-select');
  if (!sel) return;
  sel.innerHTML = '<option value="">Seleccionar lote vendido...</option>';

  // Filtrar SOLO lotes vendidos
  var lotsVendidos = (db.lots || []).filter(function(l) {
    var st = (l.status || '').toLowerCase();
    return st === 'sold' || st === 'vendido';
  });

  // Ordenar por fecha de venta más reciente (created_at del status o nombre)
  lotsVendidos.sort(function(a, b) {
    var dA = a.sold_at || a.updated_at || a.entry_date || '';
    var dB = b.sold_at || b.updated_at || b.entry_date || '';
    return String(dB).localeCompare(String(dA));
  });

  // Toggle empty states
  var emptyState = document.getElementById('ah-empty-state');
  var noVendidosState = document.getElementById('ah-no-vendidos');
  var content = document.getElementById('ah-content');

  if (lotsVendidos.length === 0) {
    if (emptyState) emptyState.style.display = 'none';
    if (noVendidosState) noVendidosState.style.display = 'block';
    if (content) content.style.display = 'none';
    return;
  } else {
    if (noVendidosState) noVendidosState.style.display = 'none';
    if (emptyState) emptyState.style.display = 'block';
    if (content) content.style.display = 'none';
  }

  lotsVendidos.forEach(function(l) {
    var opt = document.createElement('option');
    opt.value = l.code;
    var label = l.code + ' — ' + (l.category || '');
    // Intentar mostrar fecha de venta
    var fechaVenta = _ahDetectarFechaVenta(l);
    if (fechaVenta) label += ' (vendido ' + _ahFmtFecha(fechaVenta) + ')';
    opt.textContent = label;
    sel.appendChild(opt);
  });
}

function renderAnalisisHistorico() {
  var sel = document.getElementById('ah-lot-select');
  var emptyState = document.getElementById('ah-empty-state');
  var content = document.getElementById('ah-content');
  var pdfBtn = document.getElementById('ah-pdf-btn');
  if (!sel || !emptyState || !content) return;

  var lotCode = sel.value;
  if (!lotCode) {
    emptyState.style.display = 'block';
    content.style.display = 'none';
    if (pdfBtn) pdfBtn.style.display = 'none';
    if (_ahChartPesos) { try { _ahChartPesos.destroy(); } catch(e){} _ahChartPesos = null; }
    return;
  }

  var lot = (db.lots || []).find(function(l) { return l.code === lotCode; });
  if (!lot) return;

  emptyState.style.display = 'none';
  content.style.display = 'block';
  if (pdfBtn) pdfBtn.style.display = 'inline-flex';

  // v1.4.96: Detectar cadena de linaje del lote (sub-lote de split)
  // Si lot tiene cost_origin.from_lot, recolectamos eventos del padre antes del split
  var lineage = _ahGetLineage(lotCode);
  var inherited = _ahCollectInheritedEvents(lineage);
  var hasLineage = lineage.length > 1;

  // Recolectar todos los datos asociados al lote
  var pesajes = (db.pesajes || []).filter(function(p) { return p.lot_code === lotCode; });
  var treatments = (db.treatments || []).filter(function(t) { return t.lot_code === lotCode; });
  // Compras del lote. Incluye:
  //   1. Compras directas (c.lot_code === lotCode)
  //   2. Compras de cuarentena que se traspasaron al lote (lote_destinos contiene lotCode)
  //      Ej: una compra que ingresó a CUAR-006 con lote_destinos:['TROPA 3'] cuenta como
  //      costo de TROPA 3 una vez completado el traspaso.
  var compras = (db.compras_ganado || []).filter(function(c) {
    if (c.lot_code === lotCode) return true;
    if (Array.isArray(c.lote_destinos) && c.lote_destinos.indexOf(lotCode) >= 0) return true;
    return false;
  }).map(function(c) {
    // Marcar las que vinieron por traspaso desde cuarentena (para mostrar nota explicativa)
    if (c.lot_code !== lotCode && Array.isArray(c.lote_destinos) && c.lote_destinos.indexOf(lotCode) >= 0) {
      c = Object.assign({}, c, { _via_traspaso: true, _origen_lote: c.lot_code });
    }
    return c;
  });
  var ventas = (db.sales || []).filter(function(s) {
    if (s.lot_code === lotCode) return true;
    if (Array.isArray(s.lot_codes) && s.lot_codes.indexOf(lotCode) >= 0) return true;
    // Fallback legacy: lot_code podría ser string concatenado con comas
    if (typeof s.lot_code === 'string' && s.lot_code.indexOf(',') >= 0) {
      var parts = s.lot_code.split(',').map(function(x) { return x.trim(); });
      if (parts.indexOf(lotCode) >= 0) return true;
    }
    if (Array.isArray(s.items)) return s.items.some(function(i) { return i.lot_code === lotCode; });
    return false;
  });

  // Clasificar ventas en directas (single-lote) vs compartidas (multi-lote)
  var clasif = _ahClasificarVentas(ventas, lotCode);
  var ventasDirectas = clasif.directas;
  var ventasCompartidas = clasif.compartidas;
  var bajas = (db.bajas || []).filter(function(b) { return b.lot_code === lotCode; });
  var partos = (db.partos || []).filter(function(p) { return p.lot_code === lotCode; });
  var conteos = (db.conteo || []).filter(function(c) { return c.lot_code === lotCode; });
  var mantenimientos = (db.mantenimientos || []).filter(function(m) { return m.lot_code === lotCode; });

  _ahRenderHeader(lot, ventas, compras, inherited);
  // v1.4.64: pasar TODAS las ventas (directas + compartidas con items[]) a los renders económicos.
  // Las funciones ya tienen lógica de items[] que extrae la porción del lote en multi-lote.
  // Antes solo recibían ventasDirectas → ignoraban completamente las multi-lote y desperdiciaban
  // la lógica de items[] que metimos en v1.4.61. La PWA ya hace esto correctamente.
  _ahRenderResumen(lot, pesajes, ventas, compras);
  _ahRenderPerformance(lot, pesajes, ventas, compras);
  _ahRenderCostos(lot, treatments, mantenimientos, ventas, compras);
  // v1.4.96: pasar lineage e inherited a las funciones que muestran historia visual
  _ahRenderPesos(lot, pesajes, compras, ventasDirectas, ventasCompartidas, lineage, inherited);
  _ahRenderEventos(lot, compras, ventasDirectas, ventasCompartidas, pesajes, lineage, inherited);
  _ahRenderSanidad(lot, treatments);
  _ahRenderMovimientos(lot, bajas, partos, conteos, compras);
  _ahRenderVentas(ventasDirectas, ventasCompartidas, lotCode, compras);
  _ahRenderObservaciones(lot, pesajes, treatments, compras, ventasDirectas, ventasCompartidas, bajas, partos, mantenimientos);
}

// v1.8.50/51/52: cuántas cabezas pasaron por un lote (para capar ventas imposibles).
// Un lote puede recibir animales por compras (directo o vía cuarentena) y también por traspasos
// desde otros lotes (ej. juntar T1+T2 en T3 para vender). Para estimar el máximo de cabezas que
// el lote llegó a tener, tomamos el MAYOR de dos señales disponibles en el cliente:
//   A) Compras atribuidas al lote (lote_destinos / lot_code)
//   B) Animales únicos cuyo pesaje de venta registra este lot_code (db.pesajes tipo 'venta' con
//      animal_id) — refleja los animales que físicamente estaban en el lote al venderse, incluidos
//      los que llegaron por traspaso. Es la señal más fiel para lotes de concentración.
// Nota: animal_movements NO existe en el localStorage del cliente (solo en backups del server),
// por eso usamos pesajes, que sí se sincronizan.
// Devuelve 0 (sin cap) si ninguna señal aplica.
function _ahCabezasDelLote(lotCode, compras) {
  var lc = String(lotCode).trim();

  // A) Compras atribuidas
  var totalCompras = 0;
  (compras || []).forEach(function(c) {
    var cc = parseInt(c.animal_count || c.cabezas || c.animals || 0) || 0;
    if (cc <= 0) return;
    var destinos = [];
    if (Array.isArray(c.lote_destinos) && c.lote_destinos.length) {
      c.lote_destinos.forEach(function(d){ var dd=String(d).trim(); if(dd && destinos.indexOf(dd)<0) destinos.push(dd); });
    } else if (c.lot_code) {
      destinos.push(String(c.lot_code).trim());
    }
    if (!destinos.length) return;
    if (destinos.indexOf(lc) < 0) return;
    totalCompras += cc / destinos.length;
  });
  totalCompras = Math.round(totalCompras);

  // B) Animales únicos con pesaje de venta en este lote (incluye los que llegaron por traspaso)
  var animalesVendidosDelLote = {};
  (db.pesajes || []).forEach(function(p) {
    if (p.tipo === 'venta' && String(p.lot_code || '').trim() === lc && p.animal_id) {
      animalesVendidosDelLote[String(p.animal_id)] = true;
    }
  });
  var nPorPesaje = Object.keys(animalesVendidosDelLote).length;

  // El lote tuvo AL MENOS el mayor de las dos señales (un lote de concentración tendrá más
  // animales vendidos que comprados; un lote normal tendrá ambos parecidos).
  return Math.max(totalCompras, nPorPesaje);
}

// v1.4.65: Atribución EXACTA de venta a un lote (sin prorrateo).
// Casos en orden:
//   1. Venta single-lote = ese lote → devolver totales completos
//   2. Venta con items[] = usar item.lot_code === lot.code (estructura moderna, v1.4.61+)
//   3. Venta multi-lote sin items[] pero con animal_ids → usar db.pesajes (tipo:'venta')
//      para identificar EXACTAMENTE qué animales eran de qué lote y sus pesos reales
//   4. Fallback: prorrateo simple por cabezas (último recurso)
//
// Retorna { cabs, kg, kgFacturados, ingreso } o null si la venta no toca este lote.
function _ahAtribuirVentaALote(venta, lotCode) {
  var v = venta;

  // v1.8.47: normalizar lista de lotes de la venta. El multi-lote puede venir como:
  //   - array v.lot_codes
  //   - string v.lot_code con comas "TROPA 1,TROPA 2,TROPA 3"
  //   - string simple v.lot_code "TROPA 3"
  var lotesVenta = [];
  if (Array.isArray(v.lot_codes) && v.lot_codes.length) {
    lotesVenta = v.lot_codes.map(function(x){ return String(x).trim(); });
  } else if (typeof v.lot_code === 'string' && v.lot_code.indexOf(',') >= 0) {
    lotesVenta = v.lot_code.split(',').map(function(x){ return String(x).trim(); });
  } else if (v.lot_code) {
    lotesVenta = [String(v.lot_code).trim()];
  }
  var isMultiLot = lotesVenta.length > 1;
  var tocaEsteLote = lotesVenta.indexOf(String(lotCode).trim()) >= 0;

  // CASO 1: venta single-lote = lote analizado
  if (!isMultiLot && tocaEsteLote) {
    var cabs1 = parseInt(v.animals || v.qty || v.cabezas || v.animal_count || 0) || 0;
    var kg1 = parseFloat(v.kg || v.kg_total || v.peso_total || v.total_kg || 0) || 0;
    var kgFact1 = parseFloat(v.kg_facturados || kg1) || 0;
    var total1 = parseFloat(v.total || 0) || 0;
    return { cabs: cabs1, kg: kg1, kgFacturados: kgFact1, ingreso: total1 };
  }

  // CASO 2: items[] disponibles
  if (Array.isArray(v.items)) {
    var item = v.items.find(function(i) { return i.lot_code === lotCode; });
    if (!item) return null;
    return {
      cabs: parseInt(item.animals || item.qty || item.cabezas || item.animal_count || 0) || 0,
      kg: parseFloat(item.kg || item.kg_total || item.peso_total || item.total_kg || 0) || 0,
      kgFacturados: parseFloat(item.kg_facturados || item.kg || 0) || 0,
      ingreso: parseFloat(item.total || 0) || 0
    };
  }

  // CASO 3: animal_ids + db.pesajes (atribución exacta sin prorrateo)
  if (Array.isArray(v.animal_ids) && v.animal_ids.length > 0) {
    var idsSet = {};
    v.animal_ids.forEach(function(id) { idsSet[String(id)] = true; });
    var ventaFecha = v.date || '';

    // Filtrar pesajes: tipo 'venta' + animal_id en venta + misma fecha (o sin filtro de fecha si no hay match)
    var pesajesVenta = (db.pesajes || []).filter(function(p) {
      return p.tipo === 'venta' &&
             idsSet[String(p.animal_id)] &&
             (!ventaFecha || p.date === ventaFecha);
    });

    // Si no encontramos pesajes con esa fecha, buscar sin restricción de fecha (más permisivo)
    if (pesajesVenta.length === 0) {
      pesajesVenta = (db.pesajes || []).filter(function(p) {
        return p.tipo === 'venta' && idsSet[String(p.animal_id)];
      });
    }

    // Agrupar por lot_code del pesaje (el lote REAL al que pertenecía el animal)
    var cabsLote = 0, kgLote = 0;
    pesajesVenta.forEach(function(p) {
      if (p.lot_code === lotCode) {
        cabsLote++;
        kgLote += parseFloat(p.peso || 0) || 0;
      }
    });

    if (cabsLote === 0) return null;

    // Calcular ingreso atribuible: kg facturados de este lote × price_per_kg
    var discountPct = parseFloat(v.discount_pct || 0) || 0;
    var kgFactLote = discountPct > 0 ? kgLote * (1 - discountPct / 100) : kgLote;
    var pricePerKg = parseFloat(v.price_per_kg || 0) || 0;
    var ingresoLote = 0;
    if (pricePerKg > 0) {
      ingresoLote = kgFactLote * pricePerKg;
    } else if (v.total && v.kg_facturados) {
      // Si no hay price_per_kg, derivarlo del total / kg_facturados
      ingresoLote = kgFactLote * (parseFloat(v.total) / parseFloat(v.kg_facturados));
    }

    return {
      cabs: cabsLote,
      kg: kgLote,
      kgFacturados: kgFactLote,
      ingreso: ingresoLote
    };
  }

  // CASO 4: Fallback prorrateo simple por cabezas (multi-lote sin items ni animal_ids).
  // v1.8.47: ahora reconoce multi-lote por string con comas. Reparte en partes iguales entre
  // los lotes nombrados (no hay info de cuántas cabezas de cada uno, así que se asume equitativo).
  if (!isMultiLot || !tocaEsteLote) return null;
  var fraccion = 1 / lotesVenta.length;
  return {
    cabs: (parseInt(v.animals || v.animal_count || 0) || 0) * fraccion,
    kg: (parseFloat(v.kg || v.total_kg || 0) || 0) * fraccion,
    kgFacturados: (parseFloat(v.kg_facturados || v.kg || 0) || 0) * fraccion,
    ingreso: (parseFloat(v.total || 0) || 0) * fraccion
  };
}

function _ahClasificarVentas(ventas, lotCode) {
  // Una venta es "directa" si involucra SOLO este lote (single-lote).
  // Una venta es "compartida" si involucra este lote PLUS otros lotes.
  var directas = [];
  var compartidas = [];

  (ventas || []).forEach(function(v) {
    var otrosLotes = [];

    // Detectar otros lotes desde lot_codes (estructura moderna)
    if (Array.isArray(v.lot_codes)) {
      otrosLotes = v.lot_codes.filter(function(c) { return c !== lotCode; });
    }
    // Detectar desde lot_code string con comas (estructura legacy)
    else if (typeof v.lot_code === 'string' && v.lot_code.indexOf(',') >= 0) {
      otrosLotes = v.lot_code.split(',').map(function(x) { return x.trim(); }).filter(function(c) { return c !== lotCode; });
    }
    // Detectar desde items
    else if (Array.isArray(v.items)) {
      var lotesEnItems = v.items.map(function(i) { return i.lot_code; }).filter(function(c) { return c && c !== lotCode; });
      otrosLotes = lotesEnItems.filter(function(c, i) { return lotesEnItems.indexOf(c) === i; }); // unique
    }

    if (otrosLotes.length === 0) {
      directas.push(v);
    } else {
      v._otros_lotes = otrosLotes; // guardar referencia para el render
      compartidas.push(v);
    }
  });

  return { directas: directas, compartidas: compartidas };
}

function _ahDetectarFechaVenta(lot) {
  // Buscar la venta más reciente que matchea este lote
  var ventas = (db.sales || []).filter(function(s) {
    if (s.lot_code === lot.code) return true;
    if (Array.isArray(s.items)) return s.items.some(function(i) { return i.lot_code === lot.code; });
    return false;
  });
  if (ventas.length === 0) return lot.sold_at || lot.updated_at || null;
  ventas.sort(function(a, b) { return String(b.date || '').localeCompare(String(a.date || '')); });
  return ventas[0].date;
}

function _ahFmtFecha(d) {
  if (!d) return '-';
  var s = String(d).slice(0, 10);
  var parts = s.split('-');
  if (parts.length === 3) return parts[2] + '/' + parts[1] + '/' + parts[0];
  return s;
}

function _ahFmtNum(n, decimals) {
  if (n == null || isNaN(n)) return '-';
  var d = decimals == null ? 0 : decimals;
  return Number(n).toLocaleString('es-AR', { minimumFractionDigits: d, maximumFractionDigits: d });
}

function _ahMoneda() {
  return (typeof rp !== 'undefined' && rp && rp.moneda) || 'Bs';
}

function _ahKpiCell(label, value, color, subtext) {
  var c = color || 'var(--text)';
  var sub = subtext ? '<div style="font-size:10px;color:var(--muted);margin-top:2px">' + subtext + '</div>' : '';
  return '<div style="background:var(--bg);border:1px solid var(--bor);border-radius:8px;padding:10px"><div style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.05em">' + label + '</div><div style="font-size:18px;font-weight:600;color:' + c + ';margin-top:4px">' + value + '</div>' + sub + '</div>';
}

function _ahRenderHeader(lot, ventas, compras, inherited) {
  var el = document.getElementById('ah-header');
  if (!el) return;
  var fechaVenta = _ahDetectarFechaVenta(lot);

  // v1.8.36: datos enriquecidos — fecha de entrada (primer evento del linaje),
  // proveedor (de la compra de origen) y comprador (de las ventas).
  // La compra de origen puede ser directa o heredada (vía cuarentena → marcaje).
  var comprasTodas = (compras || []).slice();
  if (inherited && Array.isArray(inherited.compras)) {
    inherited.compras.forEach(function(c){ comprasTodas.push(c); });
  }
  // Compra más antigua = origen del lote
  var compraOrigen = null;
  comprasTodas.forEach(function(c){
    var f = String(c.fecha || '').slice(0,10);
    if (!f) return;
    if (!compraOrigen || f < String(compraOrigen.fecha || '').slice(0,10)) compraOrigen = c;
  });
  var fechaEntrada = compraOrigen ? String(compraOrigen.fecha || '').slice(0,10) : (lot.entry_date ? String(lot.entry_date).slice(0,10) : '');
  var proveedor = compraOrigen ? (compraOrigen.proveedor || compraOrigen.cuarentena_origen || '') : '';

  // Comprador: tomar de las ventas (puede haber varios; listar únicos)
  var compradores = [];
  (ventas || []).forEach(function(v){
    var b = (v.buyer || v.comprador || '').trim();
    if (b && compradores.indexOf(b) < 0) compradores.push(b);
  });
  var compradorTxt = compradores.join(', ');

  var html = '<div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:12px">';
  html += '<div>';
  html += '<div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap">';
  html += '<div style="font-size:20px;font-weight:700">' + lot.code + '</div>';
  html += '<span style="background:#7c3aed;color:#fff;padding:3px 10px;border-radius:12px;font-size:10px;font-weight:600;letter-spacing:.05em">🏷️ VENDIDO</span>';
  html += '</div>';
  html += '<div style="color:var(--muted);font-size:12px;margin-top:6px">';
  if (lot.category) html += lot.category + ' · ';
  if (lot.raza) html += lot.raza + ' · ';
  if (lot.potrero) html += '📍 ' + lot.potrero;
  html += '</div>';
  // Proveedor y comprador debajo
  if (proveedor || compradorTxt) {
    html += '<div style="display:flex;gap:18px;flex-wrap:wrap;margin-top:10px">';
    if (proveedor) {
      html += '<div><span style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.05em">🚚 Proveedor</span><div style="font-size:13px;color:var(--text);font-weight:500">' + escH(proveedor) + '</div></div>';
    }
    if (compradorTxt) {
      html += '<div><span style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.05em">🤝 Comprador</span><div style="font-size:13px;color:var(--text);font-weight:500">' + escH(compradorTxt) + '</div></div>';
    }
    html += '</div>';
  }
  html += '</div>';

  // Bloque derecho: fecha de entrada + fecha de venta
  html += '<div style="text-align:right;display:flex;gap:24px;flex-wrap:wrap;justify-content:flex-end">';
  if (fechaEntrada) {
    html += '<div>';
    html += '<div style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.05em">Fecha de entrada</div>';
    html += '<div style="font-size:14px;font-weight:600">' + _ahFmtFecha(fechaEntrada) + '</div>';
    html += '</div>';
  }
  if (fechaVenta) {
    html += '<div>';
    html += '<div style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.05em">Fecha de venta</div>';
    html += '<div style="font-size:14px;font-weight:600">' + _ahFmtFecha(fechaVenta) + '</div>';
    html += '</div>';
  }
  html += '</div>';

  html += '</div>';
  el.innerHTML = html;
}

function _ahRenderResumen(lot, pesajes, ventas, compras) {
  var el = document.getElementById('ah-resumen');
  if (!el) return;

  // Calcular cabezas y kg vendidos.
  // v1.8.48: separar ventas DIRECTAS (100% de este lote) de MIXTAS (compartidas con otros lotes).
  // Las mixtas NO se suman completas: solo la fracción que corresponde a este lote. Antes el
  // resumen sumaba la venta entera, dando cabezas imposibles (ej. 273 en un lote de 122).
  // Esto alinea el Resumen Ejecutivo con la línea de tiempo, que ya las trata como "del conjunto".
  var cabsVendidas = 0;
  var kgVendidos = 0;
  var _clasifVtas = _ahClasificarVentas(ventas, lot.code);
  // Directas: sumar completas
  _clasifVtas.directas.forEach(function(v) {
    var a = _ahAtribuirVentaALote(v, lot.code);
    if (a) { cabsVendidas += a.cabs; kgVendidos += a.kg; }
  });
  // Mixtas: sumar solo la fracción atribuible a este lote
  _clasifVtas.compartidas.forEach(function(v) {
    var a = _ahAtribuirVentaALote(v, lot.code);
    if (a) { cabsVendidas += a.cabs; kgVendidos += a.kg; }
  });
  cabsVendidas = Math.round(cabsVendidas);

  // v1.8.48/50: SALVAGUARDA — un lote no puede vender más cabezas de las que tuvo.
  var _cabsLote = _ahCabezasDelLote(lot.code, compras);
  var _ventasCapadas = false;
  if (_cabsLote > 0 && cabsVendidas > _cabsLote) {
    var _factorCap = _cabsLote / cabsVendidas;
    kgVendidos *= _factorCap;          // escalar kg en la misma proporción
    cabsVendidas = _cabsLote;
    _ventasCapadas = true;
  }

  // Detectar período (entrada → venta)
  var fechaEntrada = lot.entry_date || (compras[0] && compras[0].date) || null;
  var fechaVenta = _ahDetectarFechaVenta(lot);
  var diasLote = null;
  if (fechaEntrada && fechaVenta) {
    var dA = new Date(fechaEntrada);
    var dB = new Date(fechaVenta);
    diasLote = Math.max(1, Math.round((dB - dA) / (1000 * 60 * 60 * 24)));
  }

  // Peso promedio inicial y final desde pesajes (si hay)
  var pesoPromInicial = null;
  var pesoPromFinal = null;
  if (pesajes.length > 0) {
    var pesajesOrdenados = pesajes.slice().sort(function(a, b) { return String(a.date || '').localeCompare(String(b.date || '')); });
    var primero = pesajesOrdenados[0];
    var ultimo = pesajesOrdenados[pesajesOrdenados.length - 1];
    pesoPromInicial = parseFloat(primero.peso_promedio || primero.peso_prom || primero.peso || 0) || null;
    pesoPromFinal = parseFloat(ultimo.peso_promedio || ultimo.peso_prom || ultimo.peso || 0) || null;
  }
  // Si hay venta, el peso promedio final se puede calcular desde kg/cabezas
  if (!pesoPromFinal && cabsVendidas > 0 && kgVendidos > 0) {
    pesoPromFinal = kgVendidos / cabsVendidas;
  }

  // Peso prom de INGRESO: usar la compra principal (más cabezas) de las compras del lote.
  // Esto refleja el peso real al ingresar al lote, mejor que pesajes que pueden no existir.
  var pesoPromIngreso = null;
  var compraIngreso = null;
  var maxCabsIngreso = 0;
  (compras || []).forEach(function(c) {
    var cabs = parseInt(c.animal_count || c.cabezas || 0) || 0;
    var kgTot = parseFloat(c.total_kg || c.kg_total || 0) || 0;
    if (cabs > 0 && kgTot > 0 && cabs > maxCabsIngreso) {
      maxCabsIngreso = cabs;
      compraIngreso = c;
      pesoPromIngreso = kgTot / cabs;
    }
  });

  var html = '';
  html += _ahKpiCell('🐂 Cabezas vendidas', _ahFmtNum(cabsVendidas), null, _ventasCapadas ? '⚠️ ajustado al máximo del lote' : '');
  html += _ahKpiCell('⚖️ Peso total vendido', _ahFmtNum(kgVendidos) + ' kg');
  if (pesoPromIngreso) {
    var subIngreso = compraIngreso && compraIngreso._via_traspaso ? 'vía ' + compraIngreso._origen_lote : 'al ingreso';
    html += _ahKpiCell('📊 Peso prom ingreso', _ahFmtNum(pesoPromIngreso, 1) + ' kg', null, subIngreso);
  }
  if (pesoPromFinal) html += _ahKpiCell('📊 Peso prom final', _ahFmtNum(pesoPromFinal, 1) + ' kg');
  if (diasLote != null) html += _ahKpiCell('📅 Días en el lote', diasLote + ' d', null, fechaEntrada ? _ahFmtFecha(fechaEntrada) + ' → ' + _ahFmtFecha(fechaVenta) : '');
  el.innerHTML = html;
}

function _ahRenderPerformance(lot, pesajes, ventas, compras) {
  var el = document.getElementById('ah-performance');
  if (!el) return;

  // Ingreso total — usa _ahAtribuirVentaALote para atribución exacta (sin prorrateo)
  var ingresoTotal = 0;
  var pesoVenta = 0;
  var cabsVenta = 0;
  // v1.8.48: directas completas + mixtas solo su fracción (consistente con cabezas/kg)
  var _clasifIng = _ahClasificarVentas(ventas, lot.code);
  _clasifIng.directas.concat(_clasifIng.compartidas).forEach(function(v) {
    var a = _ahAtribuirVentaALote(v, lot.code);
    if (a) {
      ingresoTotal += a.ingreso;
      pesoVenta += a.kg;
      cabsVenta += a.cabs;
    }
  });

  // Costo compra (si existe)
  var costoCompra = 0;
  compras.forEach(function(c) {
    costoCompra += parseFloat(c.total || c.precio_total || 0) || 0;
  });

  // GDP del lote — preferimos calcular desde peso de COMPRA → peso de VENTA DIRECTA.
  // Eso da un GDP real del ciclo del lote. Solo fallback a pesajes si no hay compra+venta.
  var gdp = null;
  var gdpReason = null;
  var gdpFuente = null;

  // Intento 1: GDP desde compras (ingreso) → venta directa (egreso)
  // Usamos la compra PRINCIPAL (la que tiene más cabezas) — las compras adicionales pueden ser
  // de animales muy distintos (ej. 2 vacas adultas vs 120 terneros) y distorsionarían el GDP.
  var fechaIngreso = null;
  var pesoIngreso = null;
  var compraPrincipalGdp = null;
  var maxCabs = 0;
  (compras || []).forEach(function(c) {
    if (!c.fecha) return;
    var cabs = parseInt(c.animal_count || c.cabezas || 0) || 0;
    var kgTot = parseFloat(c.total_kg || c.kg_total || 0) || 0;
    if (cabs > 0 && kgTot > 0 && cabs > maxCabs) {
      maxCabs = cabs;
      compraPrincipalGdp = c;
      fechaIngreso = c.fecha.slice(0, 10);
      pesoIngreso = kgTot / cabs;
    }
  });

  var fechaEgreso = null;
  var pesoEgreso = null;
  (ventas || []).forEach(function(v) {
    if (!v.date) return;
    var cabs = parseInt(v.animals || v.qty || v.cabezas || v.animal_count || 0) || 0;
    var kg = parseFloat(v.kg || v.kg_total || v.peso_total || v.total_kg || 0) || 0;
    if (cabs > 0 && kg > 0) {
      // Usar la venta directa MÁS RECIENTE como punto de egreso
      if (!fechaEgreso || v.date > fechaEgreso) {
        fechaEgreso = v.date.slice(0, 10);
        pesoEgreso = kg / cabs;
      }
    }
  });

  if (fechaIngreso && fechaEgreso && pesoIngreso > 0 && pesoEgreso > 0) {
    var dias = Math.max(1, Math.round((new Date(fechaEgreso) - new Date(fechaIngreso)) / (1000 * 60 * 60 * 24)));
    if (dias > 0) {
      gdp = (pesoEgreso - pesoIngreso) / dias;
      gdpFuente = 'compra → venta';
    }
  }

  // Intento 2 (fallback): GDP desde pesajes regulares (no venta), si Intento 1 falló
  if (gdp == null && pesajes && pesajes.length >= 2) {
    var pesajesValidos = pesajes.filter(function(p) {
      return (p.tipo || '').toLowerCase() !== 'venta';
    });
    if (pesajesValidos.length >= 2) {
      var ordenados = pesajesValidos.slice().sort(function(a, b) { return String(a.date || '').localeCompare(String(b.date || '')); });
      var pI = parseFloat(ordenados[0].peso_promedio || ordenados[0].peso_prom || ordenados[0].peso || 0);
      var pF = parseFloat(ordenados[ordenados.length - 1].peso_promedio || ordenados[ordenados.length - 1].peso_prom || ordenados[ordenados.length - 1].peso || 0);
      var dI = new Date(ordenados[0].date);
      var dF = new Date(ordenados[ordenados.length - 1].date);
      var diasP = Math.max(1, Math.round((dF - dI) / (1000 * 60 * 60 * 24)));
      if (pI > 0 && pF > 0 && diasP > 0) {
        gdp = (pF - pI) / diasP;
        gdpFuente = 'pesajes';
      }
    }
  }

  if (gdp == null) {
    if (!fechaIngreso) gdpReason = 'sin compra registrada';
    else if (!fechaEgreso) gdpReason = 'sin venta directa registrada';
    else gdpReason = 'datos insuficientes';
  }

  var precioPromKg = (pesoVenta > 0) ? (ingresoTotal / pesoVenta) : null;
  var moneda = _ahMoneda();

  // Detectar si hay compras vía traspaso (para nota explicativa)
  var comprasViaTraspaso = (compras || []).filter(function(c) { return c._via_traspaso; });
  var hayTraspaso = comprasViaTraspaso.length > 0;
  var notaTraspaso = '';
  if (hayTraspaso) {
    var origenes = comprasViaTraspaso.map(function(c) { return c._origen_lote; }).filter(function(o, i, arr) { return arr.indexOf(o) === i; });
    notaTraspaso = 'incluye traspaso de ' + origenes.join(', ');
  }

  var html = '';
  html += _ahKpiCell('💰 Ingreso total', moneda + ' ' + _ahFmtNum(ingresoTotal), 'var(--green)');
  if (precioPromKg) html += _ahKpiCell('💵 Precio prom kg', moneda + ' ' + _ahFmtNum(precioPromKg, 2));
  if (costoCompra > 0) {
    var roi = ingresoTotal - costoCompra;
    var roiPct = costoCompra > 0 ? (roi / costoCompra * 100) : 0;
    html += _ahKpiCell('🏷️ Costo compra', moneda + ' ' + _ahFmtNum(costoCompra), 'var(--muted)', notaTraspaso);
    html += _ahKpiCell('📈 Resultado bruto', moneda + ' ' + _ahFmtNum(roi), roi >= 0 ? 'var(--green)' : 'var(--red)', _ahFmtNum(roiPct, 1) + '%');
  } else {
    html += _ahKpiCell('🏷️ Costo compra', 'Sin compra registrada', 'var(--muted)');
  }
  if (gdp != null) {
    html += _ahKpiCell('⚡ GDP lote', _ahFmtNum(gdp, 2) + ' kg/día', null, gdpFuente || '');
  } else {
    html += _ahKpiCell('⚡ GDP lote', 'No calculable', 'var(--muted)', gdpReason || '');
  }

  // v1.4.64: Costo/kg y Margen/kg del lote (paridad con PWA)
  // Calcular costo total real del lote: compra + sanidad + mantenimiento + indirectos
  // Reusar lógica de _ahRenderCostos para no duplicar
  var products = db.products || [];
  var costoSanidadLote = 0;
  (db.treatments || []).filter(function(t){ return t.lot_code === lot.code; }).forEach(function(t){
    var costoT = parseFloat(t.cost || 0);
    if (costoT > 0) { costoSanidadLote += costoT; return; }
    var prod = products.find(function(p){ return p.id === t.product_id || p.name === t.product_name; });
    var uc = prod ? parseFloat(prod.unit_cost || prod.cost || 0) : 0;
    if (uc > 0) {
      var q = parseFloat(t.count || t.quantity || 0) || 0;
      costoSanidadLote += q * uc;
    }
  });
  var costoMantLote = 0;
  (db.maintenance || []).filter(function(m){ return m.lot_code === lot.code; }).forEach(function(m){
    if (Array.isArray(m.stock_items)) {
      m.stock_items.forEach(function(si){
        var prod = products.find(function(p){ return p.id === si.product_id || p.name === si.product_name; });
        var uc = prod ? parseFloat(prod.unit_cost || prod.cost || 0) : 0;
        var q = parseFloat(si.quantity || si.count || 0) || 0;
        costoMantLote += q * uc;
      });
    } else {
      costoMantLote += parseFloat(m.total || m.costo || 0) || 0;
    }
  });
  var indirectosLote = _ahCalcularIndirectos(lot, ventas, compras);
  var costoTotalLote = costoCompra + costoSanidadLote + costoMantLote + indirectosLote.total;
  var costoPorKgLote = pesoVenta > 0 ? (costoTotalLote / pesoVenta) : 0;
  var margenPorKgLote = (precioPromKg && costoPorKgLote > 0) ? (precioPromKg - costoPorKgLote) : null;

  if (costoPorKgLote > 0) {
    html += _ahKpiCell('💵 Costo/kg', moneda + ' ' + _ahFmtNum(costoPorKgLote, 2), 'var(--amber)', 'compra + sanidad + indirectos');
  }
  if (margenPorKgLote != null) {
    html += _ahKpiCell('📊 Margen/kg', moneda + ' ' + _ahFmtNum(margenPorKgLote, 2),
      margenPorKgLote >= 0 ? 'var(--green)' : 'var(--red)',
      'precio − costo por kg');
  }

  el.innerHTML = html;
}

function _ahRenderPesos(lot, pesajes, compras, ventasDirectas, ventasCompartidas, lineage, inherited) {
  var statsEl = document.getElementById('ah-pesos-stats');
  var emptyEl = document.getElementById('ah-pesos-empty');
  var wrapEl = document.getElementById('ah-pesos-chart-wrap');

  if (_ahChartPesos) { try { _ahChartPesos.destroy(); } catch(e){} _ahChartPesos = null; }

  // v1.4.96: defaults para que las llamadas viejas no rompan
  lineage = lineage || [];
  inherited = inherited || { pesajes: [], compras: [], splits: [] };
  var hasLineage = lineage.length > 1;

  // ──────────────────────────────────────────────────────────────
  // CONSTRUIR PUNTOS DEL TIMELINE
  // ──────────────────────────────────────────────────────────────
  //
  // Línea principal (peso del lote):
  //   - Punto de ingreso (compra): peso promedio inicial al ingresar
  //   - Pesajes que NO son tipo 'venta' (los reales del lote)
  //   - Punto final: peso promedio de la última venta DIRECTA
  //
  // Puntos separados (ventas mixtas):
  //   - Cada venta mixta como punto suelto, sin línea conectora

  var puntosLote = []; // {date, peso, label} — línea principal
  var puntosVentaMixta = []; // {date, peso, label, buyer} — ventas mixtas (triángulos)
  var puntosCompraExtra = []; // {date, peso, label} — compras secundarias (triángulos)

  // 1. Identificar la compra PRINCIPAL del lote (la que tiene más cabezas)
  // Las compras adicionales se muestran como puntos sueltos, no parte de la línea de evolución.
  var comprasValidas = (compras || []).filter(function(c) {
    if (!c.fecha) return false;
    var cabs = parseInt(c.animal_count || c.cabezas || 0) || 0;
    var kgTot = parseFloat(c.total_kg || c.kg_total || 0) || 0;
    return cabs > 0 && kgTot > 0;
  });

  var compraPrincipal = null;
  if (comprasValidas.length > 0) {
    compraPrincipal = comprasValidas.slice().sort(function(a, b) {
      var cabsA = parseInt(a.animal_count || a.cabezas || 0) || 0;
      var cabsB = parseInt(b.animal_count || b.cabezas || 0) || 0;
      return cabsB - cabsA; // descendente por cabezas
    })[0];
  }

  // Agregar la compra principal a la línea del lote
  if (compraPrincipal) {
    var cabsP = parseInt(compraPrincipal.animal_count || compraPrincipal.cabezas || 0) || 0;
    var kgTotP = parseFloat(compraPrincipal.total_kg || compraPrincipal.kg_total || 0) || 0;
    var pesoIngresoP = kgTotP / cabsP;
    var labelP = 'Ingreso: ' + cabsP + ' cab @ ' + pesoIngresoP.toFixed(1) + ' kg';
    if (compraPrincipal._via_traspaso) labelP += ' (vía ' + compraPrincipal._origen_lote + ')';
    puntosLote.push({
      date: compraPrincipal.fecha.slice(0, 10),
      peso: pesoIngresoP,
      label: labelP,
      cabs: cabsP
    });
  }

  // Las otras compras van como puntos sueltos (no entran en la línea de evolución)
  comprasValidas.forEach(function(c) {
    if (c === compraPrincipal) return; // ya agregada a la línea
    var cabs = parseInt(c.animal_count || c.cabezas || 0) || 0;
    var kgTot = parseFloat(c.total_kg || c.kg_total || 0) || 0;
    var pesoIngreso = kgTot / cabs;
    var label = 'Compra adicional: ' + cabs + ' cab @ ' + pesoIngreso.toFixed(1) + ' kg';
    if (c._via_traspaso) label += ' (vía ' + c._origen_lote + ')';
    puntosCompraExtra.push({
      date: c.fecha.slice(0, 10),
      peso: pesoIngreso,
      label: label
    });
  });

  // 2. Pesajes que NO son de venta (pesajes regulares del lote)
  var pesajesRegulares = (pesajes || []).filter(function(p) {
    return (p.tipo || '').toLowerCase() !== 'venta';
  });

  // Agrupar pesajes regulares por fecha
  var pesajesPorFecha = {};
  pesajesRegulares.forEach(function(p) {
    var d = String(p.date || '').slice(0, 10);
    if (!d) return;
    if (!pesajesPorFecha[d]) pesajesPorFecha[d] = { suma: 0, count: 0 };
    var peso = parseFloat(p.peso_promedio || p.peso_prom || p.peso || 0) || 0;
    if (peso > 0) {
      pesajesPorFecha[d].suma += peso;
      pesajesPorFecha[d].count += 1;
    }
  });
  Object.keys(pesajesPorFecha).forEach(function(d) {
    var info = pesajesPorFecha[d];
    if (info.count > 0) {
      puntosLote.push({
        date: d,
        peso: info.suma / info.count,
        label: 'Pesaje del lote (' + info.count + ' registros)'
      });
    }
  });

  // 3. Punto final desde ventas DIRECTAS (peso promedio de la venta)
  (ventasDirectas || []).forEach(function(v) {
    if (!v.date) return;
    var cabs = parseInt(v.animals || v.qty || v.cabezas || v.animal_count || 0) || 0;
    var kg = parseFloat(v.kg || v.kg_total || v.peso_total || v.total_kg || 0) || 0;
    if (cabs > 0 && kg > 0) {
      var pesoProm = kg / cabs;
      puntosLote.push({
        date: v.date.slice(0, 10),
        peso: pesoProm,
        label: 'Venta directa: ' + cabs + ' cab @ ' + pesoProm.toFixed(1) + ' kg',
        cabs: cabs,
        esVenta: true
      });
    }
  });

  // Ordenar puntos del lote por fecha
  puntosLote.sort(function(a, b) { return a.date.localeCompare(b.date); });

  // 4. Ventas mixtas como puntos sueltos (NO entran en la línea)
  (ventasCompartidas || []).forEach(function(v) {
    if (!v.date) return;
    var cabsTotales = parseInt(v.animals || v.qty || 0) || 0;
    var kgTotales = parseFloat(v.kg || 0) || 0;
    if (cabsTotales > 0 && kgTotales > 0) {
      var pesoPromAll = kgTotales / cabsTotales;
      puntosVentaMixta.push({
        date: v.date.slice(0, 10),
        peso: pesoPromAll,
        label: 'Venta mixta (' + cabsTotales + ' cab del conjunto)',
        buyer: v.buyer || v.comprador || '',
        lotes: (v._otros_lotes || []).concat([lot.code])
      });
    }
  });

  // ──────────────────────────────────────────────────────────────
  // CASOS ESPECIALES — empty states
  // ──────────────────────────────────────────────────────────────
  if (puntosLote.length === 0 && puntosVentaMixta.length === 0 && puntosCompraExtra.length === 0) {
    if (statsEl) statsEl.textContent = '';
    if (emptyEl) {
      emptyEl.style.display = 'block';
      emptyEl.textContent = 'Sin datos de pesos para este lote (ni compras, ni pesajes, ni ventas).';
    }
    if (wrapEl) wrapEl.style.display = 'none';
    return;
  }

  // ──────────────────────────────────────────────────────────────
  // CONSTRUIR CHART (escala temporal usando type='line' con eje x lineal)
  // ──────────────────────────────────────────────────────────────
  if (emptyEl) emptyEl.style.display = 'none';
  if (wrapEl) wrapEl.style.display = 'block';

  // v1.4.96: Si hay linaje, construir puntos del padre (línea heredada en chart)
  // Cada padre aporta su compra principal y pesajes previos al split.
  var puntosPadre = []; // {date, peso, label, parentCode}
  var splitMarkers = []; // {date, label} — para marcar visualmente el momento del split
  if (hasLineage) {
    // Compra principal del padre (la más grande)
    var ancestralBuy = null;
    var ancestralCabs = 0;
    (inherited.compras || []).forEach(function(c) {
      var cabs = parseInt(c.animal_count || c.cabezas || 0) || 0;
      if (cabs > ancestralCabs) { ancestralCabs = cabs; ancestralBuy = c; }
    });
    if (ancestralBuy) {
      var ck = parseFloat(ancestralBuy.total_kg || ancestralBuy.kg_total || 0) || 0;
      var ccab = parseInt(ancestralBuy.animal_count || ancestralBuy.cabezas || 0) || 0;
      if (ck > 0 && ccab > 0) {
        puntosPadre.push({
          date: String(ancestralBuy.fecha).slice(0,10),
          peso: ck / ccab,
          label: 'Ingreso del padre ' + ancestralBuy._from_lot + ': ' + ccab + ' cab @ ' + (ck/ccab).toFixed(1) + ' kg',
          parentCode: ancestralBuy._from_lot
        });
      }
    }
    // Pesajes regulares del padre
    (inherited.pesajes || []).filter(function(p) {
      return (p.tipo || '').toLowerCase() !== 'venta';
    }).forEach(function(p) {
      var peso = parseFloat(p.peso_promedio || p.peso_prom || p.peso || 0) || 0;
      var d = String(p.date || '').slice(0,10);
      if (peso > 0 && d) {
        puntosPadre.push({
          date: d,
          peso: peso,
          label: 'Pesaje del padre ' + p._from_lot + ': ' + peso.toFixed(1) + ' kg',
          parentCode: p._from_lot
        });
      }
    });
    // Marcadores de split: una entrada por cada evento de split en la cadena
    (inherited.splits || []).forEach(function(s) {
      splitMarkers.push({
        date: String(s.date).slice(0,10),
        label: 'Separación: ' + s.cabs + ' cab @ ' + (s.total_kg && s.cabs ? (s.total_kg/s.cabs).toFixed(1) : '?') + ' kg → ' + s.to_lot,
        from_lot: s.from_lot,
        to_lot: s.to_lot
      });
    });
    // Agrupar puntosPadre por fecha (un punto por fecha — promedio si hay varios)
    var byDate = {};
    puntosPadre.forEach(function(p) {
      if (!byDate[p.date]) byDate[p.date] = { sum: 0, n: 0, labels: [] };
      byDate[p.date].sum += p.peso;
      byDate[p.date].n += 1;
      byDate[p.date].labels.push(p.label);
    });
    puntosPadre = Object.keys(byDate).map(function(d) {
      var b = byDate[d];
      return { date: d, peso: b.sum / b.n, label: b.labels.join(' · ') };
    });
  }

  // Construir set unificado de fechas para labels
  var todasFechas = {};
  puntosLote.forEach(function(p) { todasFechas[p.date] = true; });
  puntosVentaMixta.forEach(function(p) { todasFechas[p.date] = true; });
  puntosCompraExtra.forEach(function(p) { todasFechas[p.date] = true; });
  // v1.4.96: incluir fechas del padre y de splits si hay linaje
  puntosPadre.forEach(function(p) { todasFechas[p.date] = true; });
  splitMarkers.forEach(function(p) { todasFechas[p.date] = true; });
  var fechasOrd = Object.keys(todasFechas).sort();
  var labels = fechasOrd.map(function(d) { return _ahFmtFecha(d); });

  // Mapear puntos a posiciones del label
  var posPorFecha = {};
  fechasOrd.forEach(function(d, i) { posPorFecha[d] = i; });

  // Data del lote (línea principal): null donde no hay punto
  var dataLote = fechasOrd.map(function(d) {
    var match = puntosLote.find(function(p) { return p.date === d; });
    return match ? Math.round(match.peso * 10) / 10 : null;
  });

  // Data de ventas mixtas (puntos sueltos sin línea)
  var dataMixtas = fechasOrd.map(function(d) {
    var match = puntosVentaMixta.find(function(p) { return p.date === d; });
    return match ? Math.round(match.peso * 10) / 10 : null;
  });

  // Data de compras adicionales (puntos sueltos sin línea)
  var dataCompraExtra = fechasOrd.map(function(d) {
    var match = puntosCompraExtra.find(function(p) { return p.date === d; });
    return match ? Math.round(match.peso * 10) / 10 : null;
  });

  // v1.4.96: Data del lote padre (línea dashed gris si hay linaje)
  var dataPadre = fechasOrd.map(function(d) {
    var match = puntosPadre.find(function(p) { return p.date === d; });
    return match ? Math.round(match.peso * 10) / 10 : null;
  });

  // Stats
  if (statsEl) {
    var partes = [];
    if (puntosLote.length > 0) partes.push(puntosLote.length + ' puntos del lote');
    // v1.4.96: incluir puntos del padre en stats
    if (puntosPadre.length > 0) partes.push(puntosPadre.length + ' puntos del padre (' + lineage[0].code + ')');
    if (puntosCompraExtra.length > 0) partes.push(puntosCompraExtra.length + ' compras adicionales');
    if (puntosVentaMixta.length > 0) partes.push(puntosVentaMixta.length + ' ventas mixtas');
    partes.push(labels[0] + ' → ' + labels[labels.length - 1]);
    statsEl.textContent = partes.join(' · ');
  }

  var ctx = document.getElementById('ah-chart-pesos');
  if (!ctx) return;

  // Guardar info para tooltips
  var tooltipInfoLote = fechasOrd.map(function(d) {
    var match = puntosLote.find(function(p) { return p.date === d; });
    return match ? match.label : '';
  });
  var tooltipInfoMixtas = fechasOrd.map(function(d) {
    var match = puntosVentaMixta.find(function(p) { return p.date === d; });
    return match ? match.label + (match.buyer ? ' a ' + match.buyer : '') : '';
  });
  var tooltipInfoExtra = fechasOrd.map(function(d) {
    var match = puntosCompraExtra.find(function(p) { return p.date === d; });
    return match ? match.label : '';
  });
  // v1.4.96: tooltip del padre
  var tooltipInfoPadre = fechasOrd.map(function(d) {
    var match = puntosPadre.find(function(p) { return p.date === d; });
    return match ? match.label : '';
  });

  _ahChartPesos = new Chart(ctx, {
    type: 'line',
    data: {
      labels: labels,
      datasets: [
        // v1.4.96: Dataset del padre — solo si hay linaje. Se dibuja primero (capa inferior)
        ...(hasLineage && puntosPadre.length > 0 ? [{
          label: 'Lote padre ' + lineage[0].code + ' (pre-split)',
          data: dataPadre,
          borderColor: '#9CA3AF',
          backgroundColor: 'rgba(156,163,175,0.05)',
          borderDash: [6, 4],
          borderWidth: 1.8,
          tension: 0.2,
          fill: false,
          pointBackgroundColor: '#9CA3AF',
          pointRadius: 4,
          pointHoverRadius: 6,
          spanGaps: true
        }] : []),
        {
          label: 'Peso del lote (kg/cab)',
          data: dataLote,
          borderColor: '#7c3aed',
          backgroundColor: 'rgba(124,58,237,0.1)',
          tension: 0.2,
          fill: false,
          pointBackgroundColor: '#7c3aed',
          pointRadius: 6,
          pointHoverRadius: 8,
          spanGaps: true
        },
        {
          label: 'Compra adicional (ref.)',
          data: dataCompraExtra,
          borderColor: 'transparent',
          backgroundColor: '#3b82f6',
          showLine: false,
          pointBackgroundColor: '#3b82f6',
          pointBorderColor: '#3b82f6',
          pointStyle: 'rectRot',
          pointRadius: 7,
          pointHoverRadius: 9
        },
        {
          label: 'Venta mixta (ref.)',
          data: dataMixtas,
          borderColor: 'transparent',
          backgroundColor: '#f59e0b',
          showLine: false,
          pointBackgroundColor: '#f59e0b',
          pointBorderColor: '#f59e0b',
          pointStyle: 'triangle',
          pointRadius: 7,
          pointHoverRadius: 9
        }
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { display: true, position: 'bottom', labels: { font: { size: 11 } } },
        tooltip: {
          callbacks: {
            label: function(context) {
              var idx = context.dataIndex;
              var datasetLabel = context.dataset.label;
              if (datasetLabel.indexOf('mixta') >= 0) {
                return tooltipInfoMixtas[idx] || datasetLabel + ': ' + context.parsed.y + ' kg';
              }
              if (datasetLabel.indexOf('Compra adicional') >= 0) {
                return tooltipInfoExtra[idx] || datasetLabel + ': ' + context.parsed.y + ' kg';
              }
              if (datasetLabel.indexOf('padre') >= 0 || datasetLabel.indexOf('pre-split') >= 0) {
                return tooltipInfoPadre[idx] || datasetLabel + ': ' + context.parsed.y + ' kg';
              }
              return tooltipInfoLote[idx] || datasetLabel + ': ' + context.parsed.y + ' kg';
            }
          }
        }
      },
      scales: {
        y: { title: { display: true, text: 'kg/cab' } }
      }
    }
  });
}

function _ahRenderEventos(lot, compras, ventasDirectas, ventasCompartidas, pesajes, lineage, inherited) {
  var el = document.getElementById('ah-eventos-lista');
  if (!el) return;

  // v1.4.96: defaults para compatibilidad con llamadas viejas
  lineage = lineage || [];
  inherited = inherited || { pesajes: [], compras: [], treatments: [], bajas: [], partos: [], conteos: [], mantenimientos: [], splits: [] };
  var hasLineage = lineage.length > 1;

  var eventos = [];

  // 1. Identificar compra principal (más cabezas) — va con punto morado ●
  var comprasValidas = (compras || []).filter(function(c) {
    if (!c.fecha) return false;
    var cabs = parseInt(c.animal_count || c.cabezas || 0) || 0;
    var kgTot = parseFloat(c.total_kg || c.kg_total || 0) || 0;
    return cabs > 0 && kgTot > 0;
  });
  var compraPrincipal = null;
  if (comprasValidas.length > 0) {
    compraPrincipal = comprasValidas.slice().sort(function(a, b) {
      return (parseInt(b.animal_count || b.cabezas || 0) || 0) - (parseInt(a.animal_count || a.cabezas || 0) || 0);
    })[0];
  }

  // Compras a la lista
  comprasValidas.forEach(function(c) {
    var cabs = parseInt(c.animal_count || c.cabezas || 0) || 0;
    var kgTot = parseFloat(c.total_kg || c.kg_total || 0) || 0;
    var pesoProm = kgTot / cabs;
    var esPrincipal = (c === compraPrincipal);
    var desc = (esPrincipal ? 'Ingreso' : 'Compra adicional') + ': ' + cabs + ' cab @ ' + pesoProm.toFixed(1) + ' kg';
    if (c._via_traspaso) desc += ' (vía ' + c._origen_lote + ')';
    if (c.proveedor) desc += ' — ' + c.proveedor;
    eventos.push({
      date: c.fecha.slice(0, 10),
      tipo: esPrincipal ? 'lote' : 'compra_extra',
      desc: desc
    });
  });

  // 2. Pesajes regulares (no de venta) — punto morado
  var pesajesPorFecha = {};
  (pesajes || []).filter(function(p) {
    return (p.tipo || '').toLowerCase() !== 'venta';
  }).forEach(function(p) {
    var d = String(p.date || '').slice(0, 10);
    if (!d) return;
    if (!pesajesPorFecha[d]) pesajesPorFecha[d] = { suma: 0, count: 0 };
    var peso = parseFloat(p.peso_promedio || p.peso_prom || p.peso || 0) || 0;
    if (peso > 0) {
      pesajesPorFecha[d].suma += peso;
      pesajesPorFecha[d].count += 1;
    }
  });
  Object.keys(pesajesPorFecha).forEach(function(d) {
    var info = pesajesPorFecha[d];
    if (info.count > 0) {
      eventos.push({
        date: d,
        tipo: 'lote',
        desc: 'Pesaje del lote: ' + (info.suma / info.count).toFixed(1) + ' kg prom (' + info.count + ' registros)'
      });
    }
  });

  // 3. Ventas directas — punto morado ●
  (ventasDirectas || []).forEach(function(v) {
    if (!v.date) return;
    var cabs = parseInt(v.animals || v.qty || v.cabezas || v.animal_count || 0) || 0;
    var kg = parseFloat(v.kg || v.kg_total || v.peso_total || v.total_kg || 0) || 0;
    var total = parseFloat(v.total || 0) || 0;
    if (cabs > 0) {
      var pesoProm = kg > 0 ? (kg / cabs) : null;
      var desc = 'Venta directa: ' + cabs + ' cab';
      if (pesoProm) desc += ' @ ' + pesoProm.toFixed(1) + ' kg';
      if (v.buyer || v.comprador) desc += ' a ' + (v.buyer || v.comprador);
      if (total) desc += ' — ' + _ahMoneda() + ' ' + _ahFmtNum(total);
      eventos.push({
        date: v.date.slice(0, 10),
        tipo: 'lote',
        desc: desc
      });
    }
  });

  // 4. Ventas mixtas — triángulo amarillo ▲
  (ventasCompartidas || []).forEach(function(v) {
    if (!v.date) return;
    var cabsTotales = parseInt(v.animals || v.qty || 0) || 0;
    var lotesStr = (v._otros_lotes || []).concat([lot.code]).join(' + ');
    var desc = 'Venta mixta: ' + cabsTotales + ' cab del conjunto (' + lotesStr + ')';
    if (v.buyer || v.comprador) desc += ' a ' + (v.buyer || v.comprador);
    eventos.push({
      date: v.date.slice(0, 10),
      tipo: 'venta_mixta',
      desc: desc
    });
  });

  // v1.4.96: Eventos heredados del padre + hitos de split
  if (hasLineage) {
    // Compras del padre (sólo la principal, las extras dispersan demasiado el timeline)
    var parentBuy = null, parentBuyCabs = 0;
    (inherited.compras || []).forEach(function(c) {
      var cabs = parseInt(c.animal_count || c.cabezas || 0) || 0;
      if (cabs > parentBuyCabs) { parentBuyCabs = cabs; parentBuy = c; }
    });
    if (parentBuy) {
      var pCabs = parseInt(parentBuy.animal_count || parentBuy.cabezas || 0) || 0;
      var pKg = parseFloat(parentBuy.total_kg || parentBuy.kg_total || 0) || 0;
      var pProm = pKg > 0 && pCabs > 0 ? (pKg/pCabs).toFixed(1) : '?';
      var pDesc = 'Ingreso original (' + parentBuy._from_lot + '): ' + pCabs + ' cab @ ' + pProm + ' kg';
      if (parentBuy.proveedor) pDesc += ' — ' + parentBuy.proveedor;
      eventos.push({
        date: String(parentBuy.fecha).slice(0,10),
        tipo: 'ingreso',
        desc: pDesc,
        _inherited: true,
        _from_lot: parentBuy._from_lot
      });
    }
    // Pesajes heredados — agruparlos por fecha (igual que los propios)
    var inhPesajesPorFecha = {};
    (inherited.pesajes || []).filter(function(p) {
      return (p.tipo || '').toLowerCase() !== 'venta';
    }).forEach(function(p) {
      var d = String(p.date || '').slice(0,10);
      if (!d) return;
      if (!inhPesajesPorFecha[d]) inhPesajesPorFecha[d] = { suma:0, count:0, from: p._from_lot };
      var peso = parseFloat(p.peso_promedio || p.peso_prom || p.peso || 0) || 0;
      if (peso > 0) { inhPesajesPorFecha[d].suma += peso; inhPesajesPorFecha[d].count += 1; }
    });
    Object.keys(inhPesajesPorFecha).forEach(function(d) {
      var info = inhPesajesPorFecha[d];
      if (info.count > 0) {
        eventos.push({
          date: d,
          tipo: 'heredado',
          desc: 'Pesaje heredado (' + info.from + '): ' + (info.suma/info.count).toFixed(1) + ' kg prom (' + info.count + ' registros)',
          _inherited: true,
          _from_lot: info.from
        });
      }
    });
    // Tratamientos heredados (resumen, no uno por uno)
    var inhTratamientosPorFecha = {};
    (inherited.treatments || []).forEach(function(t) {
      var d = String(t.applied_at || t.date || '').slice(0,10);
      if (!d) return;
      if (!inhTratamientosPorFecha[d]) inhTratamientosPorFecha[d] = { n:0, from: t._from_lot };
      inhTratamientosPorFecha[d].n += 1;
    });
    Object.keys(inhTratamientosPorFecha).forEach(function(d) {
      var info = inhTratamientosPorFecha[d];
      eventos.push({
        date: d,
        tipo: 'heredado',
        desc: 'Tratamiento sanitario heredado (' + info.from + '): ' + info.n + ' aplicación' + (info.n>1?'es':''),
        _inherited: true,
        _from_lot: info.from
      });
    });
    // Splits — el HITO de la separación, marcado de manera prominente
    (inherited.splits || []).forEach(function(s) {
      var prom = s.total_kg && s.cabs ? (s.total_kg/s.cabs).toFixed(1) : '?';
      // v1.8.25: distinguir marcaje de cuarentena vs separación real
      var descS = (s.via === 'marcaje')
        ? ('Marcado desde cuarentena ' + s.from_lot + ': ' + s.cabs + ' cab @ ' + prom + ' kg → ' + s.to_lot)
        : ('Separado de ' + s.from_lot + ': ' + s.cabs + ' cab @ ' + prom + ' kg → ' + s.to_lot);
      eventos.push({
        date: String(s.date).slice(0,10),
        tipo: 'split',
        desc: descS,
        _split: true
      });
    });
  }

  // Ordenar cronológicamente
  // v1.8.25: orden secundario por tipo cuando es el mismo día (igual que Análisis Lote)
  var _ordenTipoAH = { ingreso: 0, heredado: 1, split: 2, sanidad: 3, pesaje: 4, conteo: 5, parto: 6, baja: 7, fusion: 8, venta: 9, sale: 9 };
  eventos.sort(function(a, b) {
    var fc = a.date.localeCompare(b.date);
    if (fc !== 0) return fc;
    var oa = (_ordenTipoAH[a.tipo] != null) ? _ordenTipoAH[a.tipo] : 5;
    var ob = (_ordenTipoAH[b.tipo] != null) ? _ordenTipoAH[b.tipo] : 5;
    return oa - ob;
  });

  if (eventos.length === 0) {
    el.innerHTML = '<div style="font-size:12px;color:var(--muted);font-style:italic">Sin eventos registrados.</div>';
    return;
  }

  // v1.4.100: Render como TIMELINE VERTICAL VISUAL — no lista plana.
  var lineStyleAH = 'position:absolute;left:6px;top:6px;bottom:6px;width:2px;background:#3b3b4f;border-radius:1px;';
  var html = '<div style="position:relative;padding-left:22px">';
  html += '<div style="' + lineStyleAH + '"></div>';

  eventos.forEach(function(e, idx) {
    var isLast = idx === eventos.length - 1;
    var dotBg, dotBorder = '#0D1117', dotSize = 14, dotShadow = '', extraEvStyle = '', descColor = '#E6EDF3', descWeight = '400', dateColor = '#7D8590', opacity = 1;

    if (e.tipo === 'ingreso') {
      dotBg = '#3fb950'; dotSize = 16; dotShadow = 'box-shadow:0 0 0 3px rgba(63,185,80,.25);';
      extraEvStyle = 'background:rgba(63,185,80,.08);border-left:2px solid #3fb950;padding:8px 12px;margin-left:-2px;border-radius:0 6px 6px 0;';
      descColor = '#7ee787'; descWeight = '500'; dateColor = '#3fb950';
    } else if (e.tipo === 'split') {
      dotBg = '#a855f7'; dotSize = 16; dotShadow = 'box-shadow:0 0 0 3px rgba(168,85,247,.3);';
      extraEvStyle = 'background:rgba(168,85,247,.08);border-left:2px solid #a855f7;padding:8px 12px;margin-left:-2px;border-radius:0 6px 6px 0;';
      descColor = '#c4a4f9'; descWeight = '500'; dateColor = '#a855f7';
    } else if (e.tipo === 'heredado') {
      dotBg = '#0D1117'; dotBorder = '#9CA3AF'; descColor = '#9CA3AF'; opacity = 0.8;
    } else if (e.tipo === 'lote') {
      dotBg = '#7c3aed'; dotShadow = 'box-shadow:0 0 0 2px rgba(124,58,237,.25);';
    } else if (e.tipo === 'compra_extra') {
      dotBg = '#3b82f6';
    } else if (e.tipo === 'venta_mixta') {
      dotBg = '#f59e0b';
    } else {
      dotBg = '#7D8590';
    }

    var dotLeft = e.tipo === 'split' ? -23 : -22;
    var dotTop = e.tipo === 'split' ? 3 : 4;

    html += '<div style="position:relative;padding-bottom:' + (isLast ? '0' : '18') + 'px;opacity:' + opacity + ';' + extraEvStyle + '">';
    html += '<div style="position:absolute;left:' + dotLeft + 'px;top:' + dotTop + 'px;width:' + dotSize + 'px;height:' + dotSize + 'px;border-radius:50%;background:' + dotBg + ';border:2px solid ' + dotBorder + ';box-sizing:border-box;' + dotShadow + '"></div>';
    html += '<div style="font-family:\'DM Mono\',monospace;font-size:10px;color:' + dateColor + ';text-transform:uppercase;letter-spacing:.3px;margin-bottom:3px">' + _ahFmtFecha(e.date) + (e.tipo === 'split' ? ' · separación' : '') + '</div>';
    html += '<div style="font-size:13px;line-height:1.4;color:' + descColor + ';font-weight:' + descWeight + '">' + (e.tipo === 'split' ? '✂ ' : '') + e.desc + '</div>';
    html += '</div>';
  });

  html += '</div>';
  el.innerHTML = html;
}

function _ahRenderSanidad(lot, treatments) {
  var resEl = document.getElementById('ah-sanidad-resumen');
  var tablaEl = document.getElementById('ah-sanidad-tabla');
  if (!resEl || !tablaEl) return;

  if (!treatments || treatments.length === 0) {
    resEl.innerHTML = _ahKpiCell('Tratamientos', '0');
    tablaEl.innerHTML = '<div style="padding:20px;text-align:center;color:var(--muted);font-size:13px">Sin tratamientos registrados.</div>';
    return;
  }

  // Calcular costo
  var products = db.products || [];
  var costoTotal = 0;
  var ultVacuna = '-';
  var ultDespara = '-';
  treatments.slice().sort(function(a, b) { return String(b.date || '').localeCompare(String(a.date || '')); }).forEach(function(t) {
    var pname = String(t.product_name || '').toLowerCase();
    if (ultDespara === '-' && (pname.indexOf('iverme') >= 0 || pname.indexOf('parasit') >= 0 || pname.indexOf('despara') >= 0)) ultDespara = t.date;
    if (ultVacuna === '-' && pname.indexOf('vacuna') >= 0) ultVacuna = t.date;
    // Costo: usar t.cost si existe, sino calcular desde producto
    var costoT = parseFloat(t.cost || 0);
    if (costoT > 0) {
      costoTotal += costoT;
    } else {
      var prod = products.find(function(p) { return p.id === t.product_id || p.name === t.product_name; });
      var unitCost = prod ? parseFloat(prod.unit_cost || prod.cost || 0) : 0;
      if (unitCost > 0) {
        var qty = parseFloat(t.count || t.quantity || 0) || 0;
        costoTotal += qty * unitCost;
      }
    }
  });

  var moneda = _ahMoneda();
  var html = '';
  html += _ahKpiCell('Tratamientos', _ahFmtNum(treatments.length));
  html += _ahKpiCell('Última vacuna', ultVacuna === '-' ? '-' : _ahFmtFecha(ultVacuna));
  html += _ahKpiCell('Último desparasitado', ultDespara === '-' ? '-' : _ahFmtFecha(ultDespara));
  html += _ahKpiCell('Costo total', costoTotal > 0 ? (moneda + ' ' + _ahFmtNum(costoTotal, 2)) : '-');
  resEl.innerHTML = html;

  // Tabla detalle
  var tablaHTML = '<div style="overflow-x:auto"><table style="width:100%;border-collapse:collapse;font-size:12px">';
  tablaHTML += '<thead><tr style="border-bottom:1px solid var(--bor);color:var(--muted);text-transform:uppercase;font-size:10px;letter-spacing:.05em">';
  tablaHTML += '<th style="text-align:left;padding:8px">Fecha</th>';
  tablaHTML += '<th style="text-align:left;padding:8px">Producto</th>';
  tablaHTML += '<th style="text-align:left;padding:8px">Tipo</th>';
  tablaHTML += '<th style="text-align:right;padding:8px">Cantidad</th>';
  tablaHTML += '<th style="text-align:left;padding:8px">Registrado por</th>';
  tablaHTML += '</tr></thead><tbody>';
  treatments.slice().sort(function(a, b) { return String(b.date || '').localeCompare(String(a.date || '')); }).forEach(function(t) {
    tablaHTML += '<tr style="border-bottom:1px solid var(--bor)">';
    tablaHTML += '<td style="padding:8px">' + _ahFmtFecha(t.date) + '</td>';
    tablaHTML += '<td style="padding:8px">' + (t.product_name || '-') + '</td>';
    tablaHTML += '<td style="padding:8px">' + (t.scope === 'individual' ? '🐂 Individual' : '📦 Lote') + '</td>';
    tablaHTML += '<td style="padding:8px;text-align:right">' + (t.quantity || '-') + ' ' + (t.unit || '') + '</td>';
    tablaHTML += '<td style="padding:8px;color:var(--muted)">' + (t.by || '-') + '</td>';
    tablaHTML += '</tr>';
  });
  tablaHTML += '</tbody></table></div>';
  tablaEl.innerHTML = tablaHTML;
}

function _ahRenderMovimientos(lot, bajas, partos, conteos, compras) {
  var el = document.getElementById('ah-movimientos');
  if (!el) return;

  // Calcular cabezas iniciales (de la compra o de animal_count original del lote)
  var cabsIniciales = 0;
  compras.forEach(function(c) {
    cabsIniciales += parseInt(c.cabezas || c.qty || 0) || 0;
  });
  // Si no hay compras, intentar usar lot.initial_count o sumar venta+bajas como fallback
  if (cabsIniciales === 0 && lot.initial_count) {
    cabsIniciales = parseInt(lot.initial_count) || 0;
  }

  var mortalidadPct = null;
  var natalidadPct = null;
  if (cabsIniciales > 0) {
    mortalidadPct = (bajas.length / cabsIniciales) * 100;
    natalidadPct = (partos.length / cabsIniciales) * 100;
  }

  var html = '';
  html += _ahKpiCell('💀 Bajas', _ahFmtNum(bajas.length), null,
    mortalidadPct != null ? _ahFmtNum(mortalidadPct, 1) + '% mortalidad' : 'sin base de cálculo');
  html += _ahKpiCell('🐮 Partos', _ahFmtNum(partos.length), null,
    natalidadPct != null ? _ahFmtNum(natalidadPct, 1) + '% natalidad' : 'sin base de cálculo');
  html += _ahKpiCell('🔢 Conteos', _ahFmtNum(conteos.length));
  if (cabsIniciales > 0) {
    html += _ahKpiCell('🐂 Cabs iniciales', _ahFmtNum(cabsIniciales), 'var(--muted)', 'según compras');
  }
  el.innerHTML = html;
}

function _ahRenderCostos(lot, treatments, mantenimientos, ventas, compras) {
  var el = document.getElementById('ah-costos-resumen');
  if (!el) return;

  var moneda = _ahMoneda();
  var products = db.products || [];

  // ─── COSTOS DIRECTOS DEL LOTE ───
  // 1. Sanidad (treatments × cost de productos)
  var costoSanidad = 0;
  (treatments || []).forEach(function(t) {
    var costoT = parseFloat(t.cost || 0);
    if (costoT > 0) { costoSanidad += costoT; return; }
    var prod = products.find(function(p) { return p.id === t.product_id || p.name === t.product_name; });
    var unitCost = prod ? parseFloat(prod.unit_cost || prod.cost || 0) : 0;
    if (unitCost > 0) {
      var qty = parseFloat(t.count || t.quantity || 0) || 0;
      costoSanidad += qty * unitCost;
    }
  });

  // 2. Mantenimientos del lote
  var costoMantenimiento = 0;
  (mantenimientos || []).forEach(function(m) {
    if (Array.isArray(m.stock_items)) {
      m.stock_items.forEach(function(si) {
        var prod = products.find(function(p) { return p.id === si.product_id || p.name === si.product_name; });
        var cost = prod ? parseFloat(prod.unit_cost || prod.cost || 0) : 0;
        var qty = parseFloat(si.quantity || si.count || 0) || 0;
        costoMantenimiento += qty * cost;
      });
    } else {
      costoMantenimiento += parseFloat(m.total || m.costo || 0) || 0;
    }
  });

  var costoDirecto = costoSanidad + costoMantenimiento;

  // ─── COSTOS INDIRECTOS PRORRATEADOS (Idea 38) ───
  var indirectos = _ahCalcularIndirectos(lot, ventas, compras);

  var costoTotal = costoDirecto + indirectos.total;

  // ─── INGRESOS y COSTO COMPRA ───
  var ingresoTotal = 0;
  // v1.8.48: directas completas + mixtas solo su fracción
  var _clasifIng2 = _ahClasificarVentas(ventas, lot.code);
  _clasifIng2.directas.concat(_clasifIng2.compartidas).forEach(function(v) {
    var a = _ahAtribuirVentaALote(v, lot.code);
    if (a) ingresoTotal += a.ingreso;
  });

  var costoCompra = 0;
  compras.forEach(function(c) {
    costoCompra += parseFloat(c.total || c.precio_total || 0) || 0;
  });

  // ─── MARGEN NETO ───
  var margenNeto = null, margenPct = null;
  if (costoCompra > 0) {
    margenNeto = ingresoTotal - costoCompra - costoTotal;
    margenPct = (margenNeto / costoCompra) * 100;
  }

  // ─── CABEZAS VENDIDAS para costo/cab ───
  // v1.8.48: igual que el resumen, las mixtas cuentan solo su fracción del lote (no completas).
  var cabsVendidas = 0;
  var _clasifCab = _ahClasificarVentas(ventas, lot.code);
  _clasifCab.directas.forEach(function(v) {
    var a = _ahAtribuirVentaALote(v, lot.code);
    if (a) cabsVendidas += a.cabs;
  });
  _clasifCab.compartidas.forEach(function(v) {
    var a = _ahAtribuirVentaALote(v, lot.code);
    if (a) cabsVendidas += a.cabs;
  });
  cabsVendidas = Math.round(cabsVendidas);

  // ─── EXPLICACIÓN del prorrateo ───
  var elExpl = document.getElementById('ah-costos-explicacion');
  if (elExpl) {
    if (indirectos.cabDiasLote > 0 && indirectos.cabDiasTotal > 0) {
      elExpl.innerHTML =
        '<strong>Directos:</strong> sanidad y mantenimiento atribuidos a este lote.&nbsp;&nbsp;' +
        '<strong>Indirectos:</strong> sueldos, diesel, mantenimiento general, compras de insumos y maquinaria del período del lote, ' +
        'prorrateados por <strong>cabezas-días</strong> (este lote: ' +
        _ahFmtNum(indirectos.cabDiasLote, 0) + ' cab-días de ' + _ahFmtNum(indirectos.cabDiasTotal, 0) + ' totales del rebaño · ' +
        '<strong>' + indirectos.fraccionPct.toFixed(2) + '%</strong>).';
    } else {
      elExpl.innerHTML =
        '<strong>Directos:</strong> sanidad y mantenimiento atribuidos a este lote.&nbsp;&nbsp;' +
        '<strong>Indirectos:</strong> ' + (indirectos.razon || 'no disponibles');
    }
  }

  // ─── RENDER UNIFICADO (una sola card, directos + indirectos juntos) ───
  var html = '';

  // v1.4.67: 2 DONUTS al inicio — visión global y operativa (paridad con CREA)
  // El donut "Total" compara compra ganado vs operativos del lote.
  // El donut "Operativos" desglosa por categoría.
  // Muestra todas las categorías aunque estén en 0, para indicar dónde faltan datos.
  var operativosLote = costoDirecto + indirectos.total;  // todo menos compra de ganado
  var hayCompra = costoCompra > 0;

  html += '<div style="grid-column:1/-1;display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:14px;margin-bottom:8px">';

  // Donut 1: Costos totales del lote
  html += '<div style="background:rgba(48,54,61,.3);border:1px solid var(--bor);border-radius:10px;padding:14px">';
  html += '<div style="font-size:10px;font-weight:700;color:var(--muted);margin-bottom:6px;text-transform:uppercase;letter-spacing:.05em">💰 Costos totales del lote</div>';
  html += '<div style="font-size:18px;font-weight:700;color:var(--amber2);margin-bottom:10px;font-family:DM Mono,monospace">' + moneda + ' ' + _ahFmtNum(costoCompra + operativosLote) + '</div>';
  html += '<div style="position:relative;height:170px"><canvas id="ah-chart-costos-total"></canvas></div>';
  html += '</div>';

  // Donut 2: Operativos detalle
  html += '<div style="background:rgba(48,54,61,.3);border:1px solid var(--bor);border-radius:10px;padding:14px">';
  html += '<div style="font-size:10px;font-weight:700;color:var(--muted);margin-bottom:6px;text-transform:uppercase;letter-spacing:.05em">⚙️ Operativos del lote (detalle)</div>';
  html += '<div style="font-size:18px;font-weight:700;color:var(--amber2);margin-bottom:10px;font-family:DM Mono,monospace">' + moneda + ' ' + _ahFmtNum(operativosLote) + '</div>';
  if (operativosLote > 0) {
    html += '<div style="position:relative;height:170px"><canvas id="ah-chart-operativos"></canvas></div>';
  } else {
    html += '<div style="height:170px;display:flex;align-items:center;justify-content:center;color:var(--muted);font-size:11px;text-align:center;padding:0 20px">Sin gastos operativos cargados en el período del lote</div>';
  }
  html += '</div>';

  html += '</div>';  // fin grid donuts

  // Guardar datos para render asíncrono de los charts
  window._ahCostosData = {
    costoCompra: costoCompra,
    operativosLote: operativosLote,
    operativos: [
      { label: '🩹 Sanidad',         value: costoSanidad,         color: '#f87171' },
      { label: '🔧 Mantenimiento',   value: costoMantenimiento,   color: '#34d399' },
      { label: '👷 Sueldos',         value: indirectos.sueldos,   color: '#fbbf24' },
      { label: '⛽ Diesel',          value: indirectos.diesel,    color: '#a3e635' },
      { label: '🍽️ Alimentación',    value: indirectos.alimento,  color: '#fb923c' },
      { label: '🔧 Mant. general',   value: indirectos.mantGeneral, color: '#60a5fa' },
      { label: '📦 Insumos s/lote',  value: indirectos.compras,   color: '#22d3ee' }
    ]
  };

  // GRUPO 1: DIRECTOS (subtítulo + KPIs)
  html += '<div style="grid-column:1/-1;font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-top:4px;padding-bottom:4px;border-bottom:1px solid var(--bor)">Directos</div>';
  html += _ahKpiCell('🩹 Sanidad', moneda + ' ' + _ahFmtNum(costoSanidad, 2), null,
    (treatments || []).length + ' tratamiento(s)');
  html += _ahKpiCell('🔧 Mantenimiento', moneda + ' ' + _ahFmtNum(costoMantenimiento, 2), null,
    (mantenimientos || []).length + ' registros');
  html += _ahKpiCell('💸 Subtotal directo', moneda + ' ' + _ahFmtNum(costoDirecto, 2), 'var(--amber)',
    cabsVendidas > 0 ? moneda + ' ' + _ahFmtNum(costoDirecto / cabsVendidas, 2) + '/cab' : '');

  // GRUPO 2: INDIRECTOS — v1.4.67: muestra TODAS las categorías aunque estén en 0
  // (antes solo se mostraba si total > 0; ahora siempre se muestra el bloque para
  // que el usuario vea dónde podría agregar datos retroactivamente)
  // v1.4.70: agregada subcategoría Alimentación (sal+suplementos+balanceado+heno+etc) —
  // paridad conceptual con CREA donde subcuenta='Sal'/'Alimento' va a categoría alimento.
  html += '<div style="grid-column:1/-1;font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-top:12px;padding-bottom:4px;border-bottom:1px solid var(--bor)">Indirectos prorrateados' + (indirectos.fraccionPct > 0 ? ' (' + indirectos.fraccionPct.toFixed(2) + '%)' : '') + '</div>';
  function _ahIndirCell(label, valor, valorTotal) {
    if (valor > 0) {
      return _ahKpiCell(label, moneda + ' ' + _ahFmtNum(valor, 2), null,
        'de ' + moneda + ' ' + _ahFmtNum(valorTotal, 0));
    }
    return _ahKpiCell(label, moneda + ' 0', 'var(--muted)', 'sin registros en el período');
  }
  html += _ahIndirCell('👷 Sueldos', indirectos.sueldos, indirectos.sueldos_total);
  html += _ahIndirCell('⛽ Diesel', indirectos.diesel, indirectos.diesel_total);
  html += _ahIndirCell('🍽️ Alimentación', indirectos.alimento, indirectos.alimento_total);
  html += _ahIndirCell('🔧 Mant. general', indirectos.mantGeneral, indirectos.mantGeneral_total);
  html += _ahIndirCell('📦 Insumos s/lote', indirectos.compras, indirectos.compras_total);
  html += _ahKpiCell('📊 Subtotal indirecto', moneda + ' ' + _ahFmtNum(indirectos.total, 2), 'var(--amber)',
    cabsVendidas > 0 ? moneda + ' ' + _ahFmtNum(indirectos.total / cabsVendidas, 2) + '/cab' : '');

  // GRUPO 3: TOTAL + MARGEN
  html += '<div style="grid-column:1/-1;font-size:10px;color:var(--amber2);text-transform:uppercase;letter-spacing:.08em;margin-top:12px;padding-bottom:4px;border-bottom:1px solid var(--amber2);font-weight:600">Resultado del lote</div>';
  html += _ahKpiCell('💵 Costo total', moneda + ' ' + _ahFmtNum(costoTotal, 2), 'var(--amber2)',
    cabsVendidas > 0 ? moneda + ' ' + _ahFmtNum(costoTotal / cabsVendidas, 2) + '/cab' : '');
  if (margenNeto != null) {
    html += _ahKpiCell('🎯 Margen neto real', moneda + ' ' + _ahFmtNum(margenNeto),
      margenNeto >= 0 ? 'var(--green)' : 'var(--red)',
      _ahFmtNum(margenPct, 1) + '% s/inversión');
  } else {
    html += _ahKpiCell('🎯 Margen neto real', 'N/D', 'var(--muted)', 'sin compra registrada');
  }
  if (ingresoTotal > 0) {
    var costoSobreIngreso = (costoTotal / ingresoTotal) * 100;
    var colorRatio = costoSobreIngreso < 50 ? 'var(--green)' : (costoSobreIngreso < 80 ? 'var(--amber)' : 'var(--red)');
    html += _ahKpiCell('📉 Costos / ingreso', _ahFmtNum(costoSobreIngreso, 1) + '%', colorRatio, '');
  }

  el.innerHTML = html;

  // v1.4.67: renderizar los donuts después del innerHTML
  _ahRenderCostosDonuts();
}

// v1.4.67: Renderiza los 2 donuts de Costos del Lote (paridad con CREA)
function _ahRenderCostosDonuts() {
  if (typeof Chart === 'undefined') return;
  var data = window._ahCostosData;
  if (!data) return;

  try { if (window._ahChartCostosTotal) window._ahChartCostosTotal.destroy(); } catch(e){}
  try { if (window._ahChartCostosOperativos) window._ahChartCostosOperativos.destroy(); } catch(e){}

  var commonOptions = {
    responsive: true,
    maintainAspectRatio: false,
    cutout: '60%',
    plugins: {
      legend: {
        position: 'right',
        labels: {
          color: '#c9d1d9',
          font: { size: 10 },
          boxWidth: 12,
          padding: 4,
          filter: function(item, chartData) {
            var val = chartData.datasets[0].data[item.index] || 0;
            return val > 0;
          }
        }
      },
      tooltip: {
        callbacks: {
          label: function(ctx) {
            var lbl = ctx.label || '';
            var val = ctx.parsed || 0;
            var tot = ctx.dataset.data.reduce(function(a, b){ return a + b; }, 0);
            var pct = tot > 0 ? (val / tot * 100).toFixed(1) : 0;
            return lbl + ': Bs. ' + Math.round(val).toLocaleString() + ' (' + pct + '%)';
          }
        }
      }
    }
  };

  // Donut 1: Costos totales del lote
  var canvas1 = document.getElementById('ah-chart-costos-total');
  if (canvas1 && (data.costoCompra > 0 || data.operativosLote > 0)) {
    var labels1 = [];
    var values1 = [];
    var colors1 = [];
    if (data.operativosLote > 0) {
      labels1.push('💼 Operativos lote');
      values1.push(data.operativosLote);
      colors1.push('#60a5fa');
    }
    if (data.costoCompra > 0) {
      labels1.push('🐄 Compra de ganado');
      values1.push(data.costoCompra);
      colors1.push('#fb7185');
    }
    window._ahChartCostosTotal = new Chart(canvas1, {
      type: 'doughnut',
      data: { labels: labels1, datasets: [{ data: values1, backgroundColor: colors1, borderColor: '#0d1117', borderWidth: 2 }] },
      options: commonOptions
    });
  }

  // Donut 2: Operativos detalle (incluye categorías con 0 — para que se vea qué falta)
  var canvas2 = document.getElementById('ah-chart-operativos');
  if (canvas2 && data.operativosLote > 0) {
    var operativosOrdenados = data.operativos.slice().sort(function(a, b){ return b.value - a.value; });
    window._ahChartCostosOperativos = new Chart(canvas2, {
      type: 'doughnut',
      data: {
        labels: operativosOrdenados.map(function(o){ return o.label; }),
        datasets: [{
          data: operativosOrdenados.map(function(o){ return o.value; }),
          backgroundColor: operativosOrdenados.map(function(o){ return o.color; }),
          borderColor: '#0d1117',
          borderWidth: 2
        }]
      },
      options: commonOptions
    });
  }
}

// v1.4.62 (Idea 38): Calcular costos indirectos prorrateados por cabezas-días.
// Método estándar AACREA. Categorías: sueldos, diesel, mantenimiento general,
// compras de insumos sin lote, maquinaria.
function _ahCalcularIndirectos(lot, ventas, compras) {
  var result = {
    sueldos: 0, sueldos_total: 0,
    diesel: 0, diesel_total: 0,
    alimento: 0, alimento_total: 0,
    mantGeneral: 0, mantGeneral_total: 0,
    compras: 0, compras_total: 0,
    maquinaria: 0, maquinaria_total: 0,
    total: 0,
    cabDiasLote: 0, cabDiasTotal: 0,
    fraccionPct: 0,
    razon: null
  };

  // ── 1. Determinar período del lote ──
  var fechaEntrada = null;
  if (Array.isArray(compras) && compras.length > 0) {
    compras.forEach(function(c) {
      var f = c.date || c.fecha;
      if (f && (!fechaEntrada || f < fechaEntrada)) fechaEntrada = f;
    });
  }
  if (!fechaEntrada) fechaEntrada = lot.entry_date;

  var fechaEgreso = null;
  if (Array.isArray(ventas) && ventas.length > 0) {
    ventas.forEach(function(v) {
      var f = v.date || v.fecha;
      if (f && (!fechaEgreso || f > fechaEgreso)) fechaEgreso = f;
    });
  }
  if (!fechaEgreso) fechaEgreso = today();

  if (!fechaEntrada || !fechaEgreso) {
    result.razon = 'sin fecha de entrada/egreso para calcular cab-días';
    return result;
  }

  fechaEntrada = String(fechaEntrada).slice(0, 10);
  fechaEgreso = String(fechaEgreso).slice(0, 10);

  var dInicio = new Date(fechaEntrada);
  var dFin = new Date(fechaEgreso);
  var diasLote = Math.max(1, Math.round((dFin - dInicio) / 86400000));

  // ── 2. Cabezas-días del lote ──
  // v1.8.42: el numerador (este lote) debe contar las cabezas con el MISMO criterio que el
  // denominador (cada lote del rebaño), o la fracción puede pasar de 100% (bug del 162%).
  // Criterio unificado: para un lote vendido, usar las cabezas de su compra de origen (lo que
  // realmente tuvo durante el ciclo), no animal_count=0. Para uno vivo, su animal_count actual.
  function _cabsRepresentativas(l, comprasDelLote) {
    var st = String(l.status || '').toLowerCase();
    if (st === 'vendido' || st === 'sold') {
      // cabezas de la compra de origen (lo que pobló el lote durante su ciclo)
      var cabsComp = 0;
      (comprasDelLote || []).forEach(function(c){ cabsComp += parseInt(c.animal_count || c.cabezas || 0) || 0; });
      if (cabsComp > 0) return cabsComp;
      // fallback: buscar compra por lot_code/lote_destinos
      var co = (db.compras_ganado || []).find(function(c){ return c.lot_code === l.code || (Array.isArray(c.lote_destinos) && c.lote_destinos.indexOf(l.code) >= 0); });
      if (co && co.animal_count) return parseInt(co.animal_count) || 50;
      return 50; // último recurso
    }
    return parseInt(l.animal_count || 0) || 0;
  }

  result.cabDiasLote = Math.round(_cabsRepresentativas(lot, compras) * diasLote);

  // ── 3. Cabezas-días totales del rebaño en el mismo período ──
  var cabDiasTotal = 0;
  (db.lots || []).forEach(function(l) {
    var lotEntry = l.entry_date ? new Date(l.entry_date) : dInicio;
    var lotExit = dFin;
    if (l.status === 'vendido' || l.status === 'sold') {
      var ultVenta = null;
      (db.sales || []).forEach(function(s) {
        var matchSingle = s.lot_code === l.code;
        var matchMulti = Array.isArray(s.lot_codes) && s.lot_codes.indexOf(l.code) >= 0;
        var matchItems = Array.isArray(s.items) && s.items.some(function(i) { return i.lot_code === l.code; });
        if (matchSingle || matchMulti || matchItems) {
          var f = s.date || s.fecha;
          if (f && (!ultVenta || f > ultVenta)) ultVenta = f;
        }
      });
      if (ultVenta) lotExit = new Date(String(ultVenta).slice(0, 10));
    }

    var solapInicio = lotEntry > dInicio ? lotEntry : dInicio;
    var solapFin = lotExit < dFin ? lotExit : dFin;
    if (solapFin < solapInicio) return;

    // v1.8.26: si el lote solapa el período (ya pasó el check solapFin<solapInicio arriba),
    // contar mínimo 1 día — igual que diasLote usa Math.max(1,...). Antes un lote que entraba
    // y salía el mismo día daba 0 días y se salteaba, dejando cabDiasTotal=0 y prorrateo en Bs 0.
    var diasSolap = Math.max(1, Math.round((solapFin - solapInicio) / 86400000));

    // v1.8.42: mismas cabezas representativas que el numerador (consistencia del prorrateo)
    var comprasL = (db.compras_ganado || []).filter(function(c){ return c.lot_code === l.code || (Array.isArray(c.lote_destinos) && c.lote_destinos.indexOf(l.code) >= 0); });
    var lAnim = _cabsRepresentativas(l, comprasL);

    cabDiasTotal += lAnim * diasSolap;
  });

  result.cabDiasTotal = cabDiasTotal;

  if (cabDiasTotal === 0) {
    result.razon = 'no hay otros lotes activos en el período para prorratear';
    return result;
  }

  var fraccion = result.cabDiasLote / cabDiasTotal;
  // v1.8.42: salvaguarda — la fracción de un lote no puede superar el 100% del rebaño.
  // (defensa ante cualquier inconsistencia de fechas/cabezas que infle el numerador).
  if (fraccion > 1) fraccion = 1;
  result.fraccionPct = fraccion * 100;

  // ── 4. Sumar costos indirectos del período ──
  function _estaEnPeriodo(fecha) {
    if (!fecha) return false;
    var f = String(fecha).slice(0, 10);
    return f >= fechaEntrada && f <= fechaEgreso;
  }

  // 4.1 Sueldos: historial_sueldos
  // v1.8.42: los registros usan los campos `pago_neto`/`salario` (no `monto`/`total`) y
  // la fecha es `fecha_pago` o el `mes` (YYYY-MM). Antes leía campos inexistentes → daba Bs 0.
  (db.historial_sueldos || []).forEach(function(s) {
    if (s.estado && String(s.estado).toLowerCase() !== 'pagado') return; // solo sueldos pagados
    var fechaSueldo = s.fecha_pago || s.fecha || s.date || '';
    // si no hay fecha_pago pero hay mes (YYYY-MM), usar el primer día del mes
    if (!fechaSueldo && s.mes) fechaSueldo = String(s.mes).slice(0,7) + '-01';
    if (_estaEnPeriodo(fechaSueldo)) {
      var montoSueldo = parseFloat(s.pago_neto != null ? s.pago_neto : (s.salario != null ? s.salario : (s.monto || s.total || 0))) || 0;
      result.sueldos_total += montoSueldo;
    }
  });

  // 4.2 Diesel: RECARGAS del período (las compras de combustible que tienen costo en Bs).
  // v1.8.43: antes leía los 'despacho' (consumo, sin costo) → daba Bs 0. El costo real del
  // combustible son las recargas (type:'recarga', con `total` y `precio`). La fecha puede venir
  // en `fecha` (Desktop) o `date` (WhatsApp).
  (db.diesel || []).forEach(function(d) {
    var tipo = String(d.type || d.tipo || '').toLowerCase();
    if (tipo !== 'recarga') return; // solo recargas (compras), no despachos/ajustes/traspasos
    if (!_estaEnPeriodo(d.date || d.fecha || d.created_at)) return;
    var litros = parseFloat(d.litros || d.qty || 0) || 0;
    var precio = parseFloat(d.precio || d.precio_unit || d.unit_cost || 0) || 0;
    var valor = parseFloat(d.total != null ? d.total : (litros * precio)) || 0;
    result.diesel_total += valor;
  });

  // 4.3 Mantenimiento general (sin lot_code)
  // v1.8.44: los registros de WhatsApp no traen `date`/`fecha`, solo `created_at`. Antes quedaban
  // "fuera del período" y su costo se perdía. Ahora se usa created_at como fecha de respaldo.
  (db.maintenance || []).forEach(function(m) {
    var enPeriodo = _estaEnPeriodo(m.date || m.fecha || m.created_at);
    var sinLote = !m.lot_code || m.lot_code === '';
    if (enPeriodo && sinLote) {
      var costoM = 0;
      if (Array.isArray(m.stock_items)) {
        m.stock_items.forEach(function(si) {
          var prod = (db.products || []).find(function(p) { return p.id === si.product_id || p.name === si.product_name; });
          var unitCost = prod ? parseFloat(prod.unit_cost || prod.cost || 0) : 0;
          var qty = parseFloat(si.quantity || si.count || 0) || 0;
          costoM += qty * unitCost;
        });
      }
      costoM += parseFloat(m.cost || m.costo_mano_obra || m.total || 0) || 0;
      result.mantGeneral_total += costoM;
    }
  });

  // 4.4 Compras de insumos sin lote (db.purchases)
  // v1.4.70: separar ALIMENTACIÓN como subcategoría propia (sal + alimento + suplementos
  // nutricionales). Paridad conceptual con CREA, donde subcuenta='Sal'/'Sal mineral'/'Alimento'
  // va a la categoría 'alimento'. Los registros de db.sal son operativos (descuento de stock),
  // no contables — el costo monetario vive en db.purchases.
  function _esAlimento(p) {
    var nombre = (p.product_name || p.name || p.descripcion || p.descripción || '').toLowerCase();
    var tipo = (p.product_type || p.type || p.tipo || '').toLowerCase();
    var cuenta = (p.subcuenta || p.cuenta || p.category || '').toLowerCase();
    var bag = nombre + ' ' + tipo + ' ' + cuenta;
    // Sal mineral, suplementos y alimentos del paquete nutricional
    return /\bsal\b|mineral|calcimin|calcio|fosfor|magnesi|suplement|premix|sodio|tabono|alimento|alimentaci|balanceado|concentrado|pellet|ensilaje|ensilado|silaje|heno|forraj|n[úu]cleo|raci[óo]n|melaza|afrechill?o|maiz molido|sorgo|expeller|harina de soja|harina soja/.test(bag);
  }
  (db.purchases || []).forEach(function(p) {
    var enPeriodo = _estaEnPeriodo(p.date || p.fecha || p.created_at);
    var sinLote = !p.lot_code || p.lot_code === '';
    if (enPeriodo && sinLote) {
      var monto = parseFloat(p.total || p.precio_total || p.cost || 0) || 0;
      if (_esAlimento(p)) {
        result.alimento_total += monto;
      } else {
        result.compras_total += monto;
      }
    }
  });

  // 4.5 Maquinaria (db.maquinaria — gastos asociados a equipos)
  (db.maquinaria || []).forEach(function(m) {
    var enPeriodo = _estaEnPeriodo(m.date || m.fecha || m.created_at);
    if (enPeriodo) {
      result.maquinaria_total += parseFloat(m.cost || m.costo || m.total || 0) || 0;
    }
  });

  // ── 5. Aplicar fracción a cada categoría ──
  result.sueldos     = result.sueldos_total     * fraccion;
  result.diesel      = result.diesel_total      * fraccion;
  result.alimento    = result.alimento_total    * fraccion;
  result.mantGeneral = result.mantGeneral_total * fraccion;
  result.compras     = result.compras_total     * fraccion;
  result.maquinaria  = result.maquinaria_total  * fraccion;
  result.total = result.sueldos + result.diesel + result.alimento + result.mantGeneral + result.compras;

  return result;
}

function _ahRenderObservaciones(lot, pesajes, treatments, compras, ventasDirectas, ventasCompartidas, bajas, partos, mantenimientos) {
  var el = document.getElementById('ah-observaciones');
  if (!el) return;

  var obs = [];

  // 1. Duración del lote
  var fechaEntrada = lot.entry_date || (compras[0] && compras[0].date) || null;
  var fechaVenta = _ahDetectarFechaVenta(lot);
  if (fechaEntrada && fechaVenta) {
    var dias = Math.max(1, Math.round((new Date(fechaVenta) - new Date(fechaEntrada)) / (1000 * 60 * 60 * 24)));
    if (dias <= 30) {
      obs.push('📅 Lote de muy corta duración (' + dias + ' días) — posible recría, paso o engorde acelerado.');
    } else if (dias <= 90) {
      obs.push('📅 Lote de duración corta (' + dias + ' días).');
    } else if (dias <= 365) {
      obs.push('📅 Lote estuvo ' + dias + ' días en el campo.');
    } else {
      obs.push('📅 Lote de larga duración (' + dias + ' días, ' + Math.round(dias/30) + ' meses).');
    }
  } else if (!fechaEntrada) {
    obs.push('📅 Sin fecha de entrada al campo registrada.');
  }

  // 2. Compra
  if (compras.length === 0) {
    obs.push('🏷️ Sin compra de origen registrada — los costos de adquisición no están disponibles, el ROI/margen neto no puede calcularse.');
  } else {
    var comprasDirectas = compras.filter(function(c) { return !c._via_traspaso; });
    var comprasViaTrasp = compras.filter(function(c) { return c._via_traspaso; });
    if (comprasViaTrasp.length === 0) {
      obs.push('🏷️ Origen: ' + compras.length + ' compra(s) directa(s) registrada(s).');
    } else if (comprasDirectas.length === 0) {
      var origenes = comprasViaTrasp.map(function(c) { return c._origen_lote; }).filter(function(o, i, arr) { return arr.indexOf(o) === i; });
      obs.push('🏷️ Origen: ' + comprasViaTrasp.length + ' compra(s) ingresaron vía traspaso desde cuarentena (' + origenes.join(', ') + '). El costo de adquisición se acredita a este lote.');
    } else {
      var origenes2 = comprasViaTrasp.map(function(c) { return c._origen_lote; }).filter(function(o, i, arr) { return arr.indexOf(o) === i; });
      obs.push('🏷️ Origen: ' + comprasDirectas.length + ' compra(s) directa(s) + ' + comprasViaTrasp.length + ' vía traspaso desde ' + origenes2.join(', ') + '.');
    }
  }

  // 2.5 Lote de concentración: vendió más cabezas de las que registran sus compras.
  // v1.8.53: esto ocurre cuando se juntan animales de otros lotes en este antes de vender
  // (ej. Tropa 1 + Tropa 2 → Tropa 3). Si los traspasos se hicieron por la vía formal quedan
  // registrados; si son datos antiguos, puede que no haya detalle del movimiento. Avisamos.
  var _comprasCabs = (compras || []).reduce(function(s, c) {
    var cc = parseInt(c.animal_count || c.cabezas || c.animals || 0) || 0;
    var dests = (Array.isArray(c.lote_destinos) && c.lote_destinos.length) ? c.lote_destinos.length : 1;
    // solo contar la parte de este lote
    var apunta = (c.lot_code === lot.code) || (Array.isArray(c.lote_destinos) && c.lote_destinos.indexOf(lot.code) >= 0);
    return apunta ? s + cc / dests : s;
  }, 0);
  var _vendidosPesaje = {};
  (db.pesajes || []).forEach(function(p) {
    if (p.tipo === 'venta' && String(p.lot_code || '').trim() === String(lot.code).trim() && p.animal_id) {
      _vendidosPesaje[String(p.animal_id)] = true;
    }
  });
  var _nVendidos = Object.keys(_vendidosPesaje).length;
  if (_nVendidos > Math.round(_comprasCabs) + 5) {  // margen de 5 para evitar falsos positivos
    var _porTraspaso = _nVendidos - Math.round(_comprasCabs);
    obs.push('🔀 Lote de concentración: se vendieron ' + _nVendidos + ' cabezas pero solo ' + Math.round(_comprasCabs) + ' ingresaron por compra. Las otras ~' + _porTraspaso + ' llegaron por traspaso desde otros lotes (ej. al juntar tropas para la venta). Las cifras económicas de este lote reflejan el total vendido. Para trazabilidad detallada de cada traspaso, usá la función "Mover animales" del módulo Lotes en futuras operaciones.');
  }

  // 3. Pesajes
  if (!pesajes || pesajes.length === 0) {
    obs.push('⚖️ Sin pesajes registrados — no se puede calcular GDP ni evolución de pesos.');
  } else if (pesajes.length === 1) {
    obs.push('⚖️ Solo 1 pesaje registrado — sin segundo punto no se puede calcular GDP del lote.');
  } else {
    obs.push('⚖️ ' + pesajes.length + ' pesajes a lo largo del ciclo.');
  }

  // 4. Sanidad
  if (treatments.length === 0) {
    obs.push('🩹 Sin tratamientos sanitarios registrados durante el ciclo.');
  } else if (treatments.length === 1) {
    obs.push('🩹 1 tratamiento sanitario aplicado durante el ciclo.');
  } else {
    obs.push('🩹 ' + treatments.length + ' tratamientos sanitarios aplicados.');
  }

  // 5. Mantenimientos
  if (mantenimientos.length > 0) {
    obs.push('🔧 ' + mantenimientos.length + ' mantenimiento(s) asignado(s) al lote.');
  }

  // 6. Mortalidad (solo si hay base de cálculo)
  if (compras.length > 0) {
    var cabsIniciales = compras.reduce(function(sum, c) { return sum + (parseInt(c.cabezas || c.qty || 0) || 0); }, 0);
    if (cabsIniciales > 0 && bajas.length > 0) {
      var mort = (bajas.length / cabsIniciales) * 100;
      obs.push('💀 ' + bajas.length + ' baja(s) sobre ' + cabsIniciales + ' cab iniciales (' + _ahFmtNum(mort, 1) + '%).');
    } else if (cabsIniciales > 0 && bajas.length === 0) {
      obs.push('💀 Sin bajas registradas durante el ciclo.');
    }
  } else if (bajas.length > 0) {
    obs.push('💀 ' + bajas.length + ' baja(s) registrada(s) — sin compra de origen para calcular % mortalidad.');
  }

  // 7. Partos
  if (partos.length > 0) {
    obs.push('🐮 ' + partos.length + ' parto(s) registrado(s) durante el ciclo.');
  }

  // 8. Ventas — fragmentación
  if (ventasDirectas.length === 1) {
    obs.push('💵 Venta directa única (lote completo en una sola operación individual).');
  } else if (ventasDirectas.length > 1) {
    obs.push('💵 Venta directa fragmentada: ' + ventasDirectas.length + ' ventas individuales del mismo lote.');
  } else if (ventasDirectas.length === 0 && ventasCompartidas.length > 0) {
    obs.push('💵 Este lote NO tiene ventas directas (individuales). Todo se vendió combinado con otros lotes.');
  }

  // 9. Ventas compartidas (multi-lote) — v1.4.66: ya no son "no asignables", se atribuyen exactamente
  if (ventasCompartidas && ventasCompartidas.length > 0) {
    obs.push('📋 ' + ventasCompartidas.length + ' venta(s) en conjunto con otros lotes — los animales de este lote se identifican por sus pesajes individuales y se atribuyen al análisis.');
  }

  // Construir HTML como lista de items
  var html = '<ul style="margin:0;padding-left:0;list-style:none">';
  obs.forEach(function(o) {
    html += '<li style="padding:6px 0;border-bottom:1px solid var(--bor)">' + o + '</li>';
  });
  html += '</ul>';
  el.innerHTML = html;
}

function _ahRenderVentas(ventasDirectas, ventasCompartidas, lotCode, compras) {
  var el = document.getElementById('ah-ventas-tabla');
  if (!el) return;

  var moneda = _ahMoneda();
  var html = '';

  // v1.4.66: Listado UNIFICADO de ventas. Muestra SOLO los números atribuidos a este lote.
  // No mostramos columnas con totales globales de la venta — confunde porque incluyen otros lotes.
  // Las ventas multi-lote se identifican con un badge pero los datos son SIEMPRE del lote analizado.
  var todasVentas = (ventasDirectas || []).concat(ventasCompartidas || []);

  if (todasVentas.length === 0) {
    html += '<div style="padding:14px;background:var(--bg);border:1px dashed var(--bor);border-radius:8px;text-align:center;color:var(--muted);font-size:12px">Sin ventas registradas para este lote.</div>';
    el.innerHTML = html;
    return;
  }

  // Calcular atribución por venta y ordenar por fecha (más reciente primero)
  var filasVentas = todasVentas.map(function(v) {
    var atr = _ahAtribuirVentaALote(v, lotCode);
    return { v: v, atr: atr };
  }).filter(function(r) {
    return r.atr && r.atr.cabs > 0;  // Solo ventas que realmente aportan al lote
  }).sort(function(a, b) {
    return String(b.v.date || '').localeCompare(String(a.v.date || ''));
  });

  // v1.8.50: aplicar el MISMO cap que el Resumen Ejecutivo para que ambos coincidan.
  // Si la suma de cabezas atribuidas supera las que el lote tuvo, escalar cada fila en proporción.
  var _sumCab = filasVentas.reduce(function(s, r){ return s + r.atr.cabs; }, 0);
  var _cabsLote = _ahCabezasDelLote(lotCode, compras);
  var _factorCap = 1;
  var _capado = false;
  if (_cabsLote > 0 && _sumCab > _cabsLote) {
    _factorCap = _cabsLote / _sumCab;
    _capado = true;
  }

  html += '<div style="font-size:11px;color:var(--muted);margin-bottom:8px">Cifras atribuidas a <strong style="color:var(--text)">' + escH(lotCode) + '</strong> (animales y kg específicos de este lote en cada venta)' + (_capado ? ' · <span style="color:#d4a017">⚠️ ajustadas al máximo del lote</span>' : '') + '</div>';
  html += '<div style="overflow-x:auto"><table style="width:100%;border-collapse:collapse;font-size:12px">';
  html += '<thead><tr style="border-bottom:1px solid var(--bor);color:var(--muted);text-transform:uppercase;font-size:10px;letter-spacing:.05em">';
  html += '<th style="text-align:left;padding:8px">Fecha</th>';
  html += '<th style="text-align:left;padding:8px">Comprador</th>';
  html += '<th style="text-align:left;padding:8px">Tipo</th>';
  html += '<th style="text-align:right;padding:8px">Cabezas</th>';
  html += '<th style="text-align:right;padding:8px">Kg</th>';
  html += '<th style="text-align:right;padding:8px">Precio/kg</th>';
  html += '<th style="text-align:right;padding:8px">Ingreso</th>';
  html += '</tr></thead><tbody>';

  var totCab = 0, totKg = 0, totImp = 0;
  filasVentas.forEach(function(r) {
    var v = r.v;
    // aplicar el factor de cap a las cifras de la fila
    var cabsFila = r.atr.cabs * _factorCap;
    var kgFila = r.atr.kg * _factorCap;
    var ingFila = r.atr.ingreso * _factorCap;
    var precio = parseFloat(v.price_per_kg || v.precio || 0) || 0;
    totCab += cabsFila; totKg += kgFila; totImp += ingFila;

    // Badge indicando tipo de venta
    var badge = '';
    var esMulti = (Array.isArray(v.lot_codes) && v.lot_codes.length > 1) ||
                  (typeof v.lot_code === 'string' && v.lot_code.indexOf(',') >= 0);
    if (esMulti) {
      var lotesV = Array.isArray(v.lot_codes) ? v.lot_codes :
                   (typeof v.lot_code === 'string' ? v.lot_code.split(',').map(function(x){return x.trim();}) : []);
      var otrosLotes = lotesV.filter(function(c) { return c !== lotCode; });
      var tooltipTxt = 'Venta multi-lote · ' + otrosLotes.length + ' otro(s) lote(s): ' + otrosLotes.join(', ');
      badge = ' <span title="' + escH(tooltipTxt) + '" style="font-size:9px;background:rgba(255,180,0,.15);color:var(--amber);padding:1px 6px;border-radius:8px;margin-left:4px;cursor:help">multi-lote</span>';
    }

    html += '<tr style="border-bottom:1px solid var(--bor)">';
    html += '<td style="padding:8px">' + _ahFmtFecha(v.date) + '</td>';
    html += '<td style="padding:8px">' + (v.comprador || v.buyer || '-') + badge + '</td>';
    html += '<td style="padding:8px">' + (v.tipo || v.type || '-') + '</td>';
    html += '<td style="padding:8px;text-align:right">' + _ahFmtNum(cabsFila) + '</td>';
    html += '<td style="padding:8px;text-align:right">' + _ahFmtNum(kgFila, 1) + '</td>';
    html += '<td style="padding:8px;text-align:right">' + (precio ? moneda + ' ' + _ahFmtNum(precio, 2) : '-') + '</td>';
    html += '<td style="padding:8px;text-align:right;font-weight:600;color:var(--green)">' + moneda + ' ' + _ahFmtNum(ingFila) + '</td>';
    html += '</tr>';
  });

  // Totales
  html += '<tr style="background:var(--bg);font-weight:600;border-top:2px solid var(--bor)">';
  html += '<td style="padding:8px" colspan="3">Total ' + escH(lotCode) + '</td>';
  html += '<td style="padding:8px;text-align:right">' + _ahFmtNum(totCab) + '</td>';
  html += '<td style="padding:8px;text-align:right">' + _ahFmtNum(totKg, 1) + '</td>';
  html += '<td style="padding:8px;text-align:right">-</td>';
  html += '<td style="padding:8px;text-align:right;color:var(--green)">' + moneda + ' ' + _ahFmtNum(totImp) + '</td>';
  html += '</tr>';
  html += '</tbody></table></div>';

  el.innerHTML = html;
}

