    html += '<div><label style="font-size:11px;color:var(--muted);display:block;margin-bottom:4px">Dias descanso</label><input class="form-input" type="number" id="edit-param-restdays" value="'+(item.rest_days||25)+'" style="width:100%"></div>';
    html += '</div>';
  }
  html += '<div style="display:flex;gap:8px;margin-top:16px"><button class="btn btn-ghost" id="edit-param-cancel" style="flex:1">Cancelar</button><button class="btn btn-primary" id="edit-param-save" style="flex:1">Guardar</button></div>';
  modal.innerHTML = html;
  overlay.appendChild(modal);
  document.body.appendChild(overlay);
  overlay.addEventListener('click', function(e){ if(e.target===overlay){document.body.removeChild(overlay);} });
  document.getElementById('edit-param-cancel').addEventListener('click', function(){ document.body.removeChild(overlay); });
  document.getElementById('edit-param-save').addEventListener('click', function(){
    var newName = (document.getElementById('edit-param-name').value||'').trim();
    if (!newName) { toast('El nombre no puede estar vacio','error'); return; }
    var oldName = item.name;
    item.name = newName;
    if (key === 'potreros') {
      item.capacity = parseInt(document.getElementById('edit-param-cap').value) || 0;
      item.hectares = parseFloat(document.getElementById('edit-param-ha').value) || 0;
      item.pasture_type = (document.getElementById('edit-param-pasture').value||'').trim();
      item.max_days = parseInt(document.getElementById('edit-param-maxdays').value) || 30;
      item.rest_days = parseInt(document.getElementById('edit-param-restdays').value) || 25;
      if (oldName !== newName) {
        (db.lots||[]).forEach(function(l){
          if ((l.paddock||'').toLowerCase() === oldName.toLowerCase()) l.paddock = newName;
        });
        // v1.8.68: rotation_history y evaluaciones de pasto también se vinculan por NOMBRE
        // de potrero → sin esto, renombrar rompía los cálculos de descanso/ocupación e historial.
        var _potMig = 0;
        (db.rotation_history||[]).forEach(function(r){ if((r.potrero||'').toLowerCase()===oldName.toLowerCase()){ r.potrero=newName; _potMig++; } });
        (db.pasture_evals||[]).forEach(function(e){ if((e.potrero||'').toLowerCase()===oldName.toLowerCase()){ e.potrero=newName; _potMig++; } });
        saveDB();
        try { replaceTableInRailway('lots', db.lots||[]); } catch(e){}
        if (_potMig) {
          try { replaceTableInRailway('rotation_history', db.rotation_history||[]); } catch(e){}
          try { replaceTableInRailway('pasture_evals', db.pasture_evals||[]); } catch(e){}
        }
      }
    }
    if (key === 'categorias' && oldName !== newName) {
      (db.lots||[]).forEach(function(l){
        if ((l.category||'').toLowerCase() === oldName.toLowerCase()) l.category = newName;
      });
      saveDB();
    }
    if (key === 'razas' && oldName !== newName) {
      (db.lots||[]).forEach(function(l){
        if ((l.breed||'').toLowerCase() === oldName.toLowerCase()) l.breed = newName;
      });
      // v1.8.75: cada animal guarda su propia raza/breed (y bajas también) → propagar ahí.
      var _animR = (typeof getAnimalesDB==='function') ? getAnimalesDB() : {};
      var _rMig = 0;
      Object.keys(_animR).forEach(function(lc){
        (_animR[lc]||[]).forEach(function(a){
          if ((a.raza||'').toLowerCase()===oldName.toLowerCase()){ a.raza=newName; _rMig++; }
          if ((a.breed||'').toLowerCase()===oldName.toLowerCase()){ a.breed=newName; }
        });
      });
      if (_rMig && typeof saveAnimalesDB==='function') saveAnimalesDB(_animR);
      (db.bajas||[]).forEach(function(b){ if ((b.raza||'').toLowerCase()===oldName.toLowerCase()) b.raza=newName; });
      saveDB();
    }
    // v1.8.75: renombrar un TIPO DE GASTO → cuentas/subcuentas/compras/kardex lo referencian por
    // nombre. Igual criterio que editCuenta (que sí cascada). Sin esto el catálogo quedaba inconsistente.
    if (key === 'tipos_gasto' && oldName !== newName) {
      (params.cuentas||[]).forEach(function(c){ if ((c.tipo_gasto||'')===oldName) c.tipo_gasto=newName; });
      (params.subcuentas||[]).forEach(function(s){ if ((s.cuenta_tipo||'')===oldName) s.cuenta_tipo=newName; });
      var _tgMig = 0;
      (db.purchases||[]).forEach(function(p){ if ((p.tipo_gasto||'')===oldName){ p.tipo_gasto=newName; _tgMig++; } });
      (db.kardex||[]).forEach(function(k){ if ((k.tipo_gasto||'')===oldName){ k.tipo_gasto=newName; _tgMig++; } });
      saveDB();
      if (_tgMig) { try { replaceTableInRailway('purchases', db.purchases||[]); } catch(e){} try { replaceTableInRailway('kardex', db.kardex||[]); } catch(e){} }
    }
    saveParams(params);
    renderParams();
    document.body.removeChild(overlay);
    toast((labels[key]||key)+' actualizado: '+newName, 'success');
  });
  document.getElementById('edit-param-name').focus();
}

