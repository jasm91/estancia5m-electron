function renderCompras() {
  var purTbody = document.getElementById('purchases-tbody');
  if (purTbody) {
    purTbody.innerHTML = '';
    db.purchases.slice().reverse().forEach(function(p) {
      var tr = document.createElement('tr');
      var srcLbl = (p.by||'').indexOf('WhatsApp')>-1||p.by==='Bot'?'🤖':'📱';
      if ((p.by||'')==='Desktop'||!p.by) srcLbl='🖥️';
      var _aiTag = p._ai_assigned ? ' <span style="font-size:8px;color:#A371F7">🤖</span>' : '';
      var _subBdg = p.subcuenta ? escH(p.subcuenta)+_aiTag : '<span style="color:var(--red)">Sin asignar</span>';
      tr.innerHTML = '<td>'+escH(p.desc)+'</td><td><span class="bdg bdg-blue" style="font-size:9px">'+(p.cuenta||'-')+'</span></td><td class="pur-sub-cell" data-pur-id="'+p.id+'" style="font-size:11px;cursor:pointer;text-decoration:underline dotted" title="Click para editar subcuenta">'+_subBdg+'</td><td style="font-size:11px">'+(p.tipo_gasto||'-')+'</td><td>'+p.qty+'</td><td>Bs '+p.unit_price+'</td><td style="color:var(--amber2)">Bs. '+p.total.toLocaleString()+'</td><td>'+escH(p.supplier||'-')+'</td><td>'+fmtDT(p.created_at||p.date)+'</td><td><span class="bdg '+(p.status==='paid'?'bdg-green':'bdg-amber')+'">'+(p.status==='paid'?'Pagado':'Pendiente')+'</span></td><td>'+srcLbl+'</td>';
      // Boton cambiar estado
      var statusCell = tr.lastElementChild;
      // Botón ver detalle (incluye items[] de multi-item)
      var detailBtn = document.createElement('button');
      detailBtn.className = 'btn btn-ghost btn-sm';
      detailBtn.style.cssText = 'color:var(--text);margin-right:4px;font-size:11px';
      detailBtn.textContent = '👁️';
      detailBtn.title = 'Ver detalle (incluye items multi-item)';
      detailBtn.onclick = (function(id){ return function(){ openActivityDetail(id, 'compra'); }; })(p.id);
      statusCell.appendChild(detailBtn);
      // Botón ver imagen
      var imgBtn = document.createElement('button');
      imgBtn.className = 'btn btn-ghost btn-sm';
      imgBtn.style.cssText = 'color:var(--blue);margin-right:4px;font-size:11px';
      imgBtn.textContent = '📷';
      imgBtn.title = 'Ver comprobante';
      imgBtn.onclick = (function(id){ return function(){ viewTransactionImage(id); }; })(p.id);
      statusCell.appendChild(imgBtn);
      if (p.status !== 'paid') {
        var payBtn = document.createElement('button');
        payBtn.className = 'btn btn-ghost btn-sm';
        payBtn.style.cssText = 'color:var(--green);margin-right:4px;font-size:10px';
        payBtn.textContent = 'Marcar pagado';
        payBtn.onclick = (function(id){ return function(){ togglePurchaseStatus(id); }; })(p.id);
        statusCell.appendChild(payBtn);
      }
      // Botón editar
      var editPurBtn = document.createElement('button');
      editPurBtn.className = 'btn btn-ghost btn-sm';
      editPurBtn.style.cssText = 'color:var(--amber2);margin-right:4px;font-size:11px';
      editPurBtn.textContent = '✏️';
      editPurBtn.title = 'Editar compra';
      editPurBtn.onclick = (function(id){ return function(){ editPurchase(id); }; })(p.id);
      statusCell.appendChild(editPurBtn);
      var delPurBtn = document.createElement('button');
      delPurBtn.className = 'btn btn-ghost btn-sm';
      delPurBtn.style.color = 'var(--red)';
      delPurBtn.textContent = 'x';
      delPurBtn.onclick = (function(id){ return function(){ deletePurchase(id); }; })(p.id);
      statusCell.appendChild(delPurBtn);
      purTbody.appendChild(tr);
    });
  }
}

function deletePurchase(id) {
  if (!confirm('Eliminar esta compra?')) return;
  
  // FIX v1.4.35: audit log para deletePurchase
  var _delRec_deletePurchase = (db.purchases || []).find(function(r){ return String(r.id) === String(id); });
  var _delSummary_deletePurchase = _delRec_deletePurchase ? _summarizeRecord('purchases', _delRec_deletePurchase) : 'Compra #' + id;
  try { auditLog('delete', 'purchases', id, _delSummary_deletePurchase); } catch(e){}
  trackDeletion(id, 'purchases');
  db.purchases = db.purchases.filter(function(p){ return p.id!==id; });
  saveDB(); renderCompras();
  replaceTableInRailway('purchases', db.purchases || []);
  // Pushear eliminacion a Railway inmediatamente
  if (navigator.onLine) {
    var apiUrl = getApiUrl();
    var token = localStorage.getItem('e5m_api_token') || '';
    var remaining = db.purchases;
    fetch(apiUrl+'/bulk-push', {
      method: 'POST',
      headers: {'Content-Type':'application/json','Authorization':'Bearer '+token},
      body: JSON.stringify({table:'purchases', records: remaining})
    }).catch(function(){});
  }
  toast('Compra eliminada', 'success');
}

function editPurchase(id) {
  var p = (db.purchases||[]).find(function(x){ return String(x.id) === String(id); });
  if (!p) { toast('Registro no encontrado','error'); return; }

  var o = document.createElement('div');
  o.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:500;display:flex;align-items:center;justify-content:center;padding:20px';
  var b = document.createElement('div');
  b.style.cssText = 'background:var(--sur);border-radius:12px;padding:22px;max-width:480px;width:100%';

  var srcLbl = (p.by||'').indexOf('WhatsApp')>-1||p.by==='Bot'?'🤖 Bot WhatsApp':(p.by||'')==='PWA'||p.by==='Campo'?'📱 PWA Campo':'🖥️ Desktop';
  var initialTotal = ((parseFloat(p.qty)||0) * (parseFloat(p.unit_price)||0));

  var h = '<div style="font-size:15px;font-weight:600;color:var(--text);margin-bottom:4px">✏️ Editar compra</div>';
  h += '<div style="font-size:11px;color:var(--muted);margin-bottom:16px">Origen: '+srcLbl+' · '+fmtDT(p.created_at||p.date)+'</div>';

  h += '<div style="font-size:11px;color:var(--muted);margin-bottom:6px">Descripción</div>';
  h += '<input type="text" id="_ep_desc" class="form-input" value="'+escH(p.desc||'')+'" style="margin-bottom:14px;width:100%">';

  h += '<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px">';
  h += '<div><div style="font-size:11px;color:var(--muted);margin-bottom:6px">Cantidad</div><input type="number" id="_ep_qty" class="form-input" value="'+(p.qty||0)+'" step="0.01" min="0" style="width:100%"></div>';
  h += '<div><div style="font-size:11px;color:var(--muted);margin-bottom:6px">Precio unit. (Bs)</div><input type="number" id="_ep_price" class="form-input" value="'+(p.unit_price||0)+'" step="0.01" min="0" style="width:100%"></div>';
  h += '</div>';

  h += '<div style="font-size:11px;color:var(--muted);margin-bottom:6px">Proveedor</div>';
  h += '<input type="text" id="_ep_supplier" class="form-input" value="'+escH(p.supplier||'')+'" style="margin-bottom:14px;width:100%">';

  h += '<div style="background:var(--sur2);padding:12px;border-radius:8px;margin-bottom:16px;display:flex;justify-content:space-between;align-items:center;border:1px solid var(--bor)">';
  h += '<span style="font-size:12px;color:var(--muted)">Total recalculado</span>';
  h += '<span id="_ep_total" style="font-size:18px;font-weight:700;color:var(--amber2)">Bs '+(Math.round(initialTotal*100)/100).toLocaleString()+'</span>';
  h += '</div>';

  h += '<div style="display:flex;gap:8px">';
  h += '<button id="_ep_save" class="btn btn-primary" style="flex:1">Guardar cambios</button>';
  h += '<button id="_ep_cancel" class="btn btn-ghost" style="flex:1">Cancelar</button>';
  h += '</div>';

  b.innerHTML = h;
  o.appendChild(b);
  document.body.appendChild(o);

  var dInp  = document.getElementById('_ep_desc');
  var qInp  = document.getElementById('_ep_qty');
  var prInp = document.getElementById('_ep_price');
  var sInp  = document.getElementById('_ep_supplier');
  var tEl   = document.getElementById('_ep_total');

  function updTot(){
    var t = (parseFloat(qInp.value)||0) * (parseFloat(prInp.value)||0);
    tEl.textContent = 'Bs ' + (Math.round(t*100)/100).toLocaleString();
  }
  qInp.addEventListener('input', updTot);
  prInp.addEventListener('input', updTot);
  dInp.focus(); dInp.select();

  function doSave(){
    var desc     = (dInp.value || '').trim();
    var qty      = parseFloat(qInp.value);
    var price    = parseFloat(prInp.value);
    var supplier = (sInp.value || '').trim();

    if (!desc) { toast('La descripción es obligatoria','error'); dInp.focus(); return; }
    if (isNaN(qty) || qty <= 0) { toast('Cantidad debe ser mayor a 0','error'); qInp.focus(); return; }
    if (isNaN(price) || price < 0) { toast('Precio inválido','error'); prInp.focus(); return; }

    var prev = { desc: p.desc, qty: p.qty, unit_price: p.unit_price, supplier: p.supplier, total: p.total };
    p.desc       = desc;
    p.qty        = qty;
    p.unit_price = Math.round(price * 100) / 100;
    p.total      = Math.round(qty * price * 100) / 100;
    p.supplier   = supplier;
    p.updated_at = new Date().toISOString();

    saveDB();
    o.remove();
    renderCompras();
    replaceTableInRailway('purchases', db.purchases || []);
    addActivity('Sistema','otro','','Compra editada: '+(prev.desc||'')+' → '+desc+' · Bs '+prev.total+' → Bs '+p.total);
    toast('Compra actualizada · Bs '+p.total.toLocaleString(),'success');
  }

  document.getElementById('_ep_save').onclick = doSave;
  document.getElementById('_ep_cancel').onclick = function(){ o.remove(); };
  o.addEventListener('click', function(e){ if(e.target===o) o.remove(); });
  // Enter en cualquier campo guarda; Esc cancela
  [dInp, qInp, prInp, sInp].forEach(function(inp){
    inp.addEventListener('keydown', function(e){
      if (e.key === 'Enter') { e.preventDefault(); doSave(); }
      if (e.key === 'Escape') { o.remove(); }
    });
  });
}

