var _rptCharts = [];
function destroyRptCharts(){ _rptCharts.forEach(function(c){try{c.destroy();}catch(e){}});_rptCharts=[]; }

function calcLotGmd(lot, animalesDB) {
  var animals=animalesDB[lot.code]||[];
  var gmds=[];
  animals.forEach(function(a){
    if(a.pesajes&&a.pesajes.length>=2){
      var p0=a.pesajes[0];var p1=a.pesajes[a.pesajes.length-1];
      var dias=Math.round((new Date(p1.fecha)-new Date(p0.fecha))/86400000);
      if(dias>0) gmds.push((p1.peso-p0.peso)/dias);
    }
  });
  return gmds.length?Math.round(gmds.reduce(function(s,g){return s+g;},0)/gmds.length*1000)/1000:(lot.gmd||0);
}

function onCREAPeriodoChange() {
  // Cuando cambia el preset, recalcular fechas y poblar inputs
  var sel = document.getElementById('crea-periodo');
  var inDesde = document.getElementById('crea-f-desde');
  var inHasta = document.getElementById('crea-f-hasta');
  var v = sel ? sel.value : 'year';
  if (v === 'custom') {
    // Modo personalizado: dejar las fechas tal cual y solo re-renderizar (siempre que ambas estén)
    if (inDesde && inHasta && inDesde.value && inHasta.value) renderReporteCREA();
    return;
  }
  var now = new Date(); var desde = new Date();
  if (v === 'ytd') {
    // Año en curso: del 1 de enero al día de hoy
    desde = new Date(now.getFullYear(), 0, 1);
  }
  else if (v === 'year') desde.setFullYear(desde.getFullYear() - 1);
  else if (v === 'semester') desde.setMonth(desde.getMonth() - 6);
  else if (v === 'month') desde.setMonth(desde.getMonth() - 1);
  else desde.setMonth(desde.getMonth() - 3);
  if (inDesde) inDesde.value = localDate(desde);
  if (inHasta) inHasta.value = localDate(now);
  renderReporteCREA();
}

function onCREADateChange() {
  // Si el usuario cambia manualmente las fechas, marcar como personalizado
  var sel = document.getElementById('crea-periodo');
  if (sel) sel.value = 'custom';
  var inDesde = document.getElementById('crea-f-desde');
  var inHasta = document.getElementById('crea-f-hasta');
  // Solo re-renderizar si ambas fechas están seteadas y son consistentes
  if (inDesde && inHasta && inDesde.value && inHasta.value && inDesde.value <= inHasta.value) {
    renderReporteCREA();
  }
}

function refreshReporteCREA() {
  var btn = document.getElementById('btn-crea-refresh');
  var originalLabel = btn ? btn.innerHTML : '';
  if (btn) { btn.innerHTML = '⏳ Sincronizando...'; btn.disabled = true; }

  function doneOk() {
    try { renderReporteCREA(); } catch(e){}
    if (btn) { btn.innerHTML = '✓ Actualizado'; setTimeout(function(){ btn.innerHTML = originalLabel || '🔄 Actualizar'; btn.disabled = false; }, 1200); }
  }
  function doneErr() {
    try { renderReporteCREA(); } catch(e){}
    if (btn) { btn.innerHTML = originalLabel || '🔄 Actualizar'; btn.disabled = false; }
    toast('Sin conexión — mostrando solo datos locales', 'warn');
  }

  if (!navigator.onLine) { doneErr(); return; }
  var apiUrl = (typeof getApiUrl === 'function') ? getApiUrl() : '';
  var token  = localStorage.getItem('e5m_api_token') || '';
  if (!token || !apiUrl) { doneErr(); return; }

  fetch(apiUrl + '/sync-pull?include_sold=true', {
    headers: { 'Content-Type':'application/json', 'Authorization':'Bearer '+token, 'X-App-Type':'desktop' },
    signal: (function(){ var c=new AbortController(); setTimeout(function(){c.abort();},10000); return c.signal; })()
  })
  .then(function(r){ return r.json(); })
  .then(function(remote){
    if (!remote || remote.error) { doneErr(); return; }
    function mergeById(localArr, remoteArr) {
      if (!Array.isArray(remoteArr)) return localArr || [];
      var out = (localArr || []).slice();
      var seen = {};
      out.forEach(function(r){ if (r && r.id != null) seen[String(r.id)] = true; });
      remoteArr.forEach(function(r){
        if (!r || r.id == null) return;
        var k = String(r.id);
        if (!seen[k]) { out.push(r); seen[k] = true; }
      });
      return out;
    }
    var tables = ['purchases','sales','advances','maintenance','diesel','cuentas','treatments','sal','alimento','aceite','bajas','compras_ganado','partos','lluvias','conteo','reproductive_services'];
    tables.forEach(function(t){
      if (Array.isArray(remote[t])) db[t] = mergeById(db[t], remote[t]);
    });
    if (typeof getDeletedIds === 'function') {
      tables.forEach(function(t){
        var del = getDeletedIds(t);
        if (del && Object.keys(del).length && Array.isArray(db[t])) {
          db[t] = db[t].filter(function(r){ return !del[String(r && r.id)]; });
        }
      });
    }
    localStorage.setItem(DB_KEY, JSON.stringify(db));
    doneOk();
  })
  .catch(function(){ doneErr(); });
}

function renderReporteCREA() {
  var el = document.getElementById('crea-content'); if (!el) return;
  var rp = getRp();
  var ha = rp.hectareas || 0;
  var pesoUA = rp.peso_ua || 400;
  var gastoAdmin = (rp.gasto_admin || 0) * 12;
  var gastoEstructura = (rp.gasto_estructura || 0) * 12;
  var precioRef = rp.precio_venta_ref || 25;

  if (!ha) {
    el.innerHTML = '<div style="text-align:center;padding:60px;color:var(--muted)"><div style="font-size:48px;margin-bottom:16px">🏆</div><div style="font-size:14px;font-weight:600;margin-bottom:8px">Configurá las hectáreas ganaderas</div><div style="font-size:12px">Andá a <strong>Params. Reporte → Parámetros Reporte CREA</strong> e ingresá las hectáreas y demás datos.</div></div>';
    return;
  }

  // Periodo: prioridad a inputs de fecha si están seteados, sino al preset
  var inDesde = (document.getElementById('crea-f-desde') || {}).value || '';
  var inHasta = (document.getElementById('crea-f-hasta') || {}).value || '';
  var periodo = (document.getElementById('crea-periodo') || {}).value || 'year';
  var now = new Date(); var desde = new Date();
  var hasta = new Date();
  if (inDesde && inHasta && inDesde <= inHasta) {
    // Modo personalizado: respetar las fechas del usuario
    desde = new Date(inDesde + 'T00:00:00');
    hasta = new Date(inHasta + 'T23:59:59');
    periodo = 'custom';
  } else {
    if (periodo === 'ytd') desde = new Date(now.getFullYear(), 0, 1);
    else if (periodo === 'year') desde.setFullYear(desde.getFullYear() - 1);
    else if (periodo === 'semester') desde.setMonth(desde.getMonth() - 6);
    else if (periodo === 'month') desde.setMonth(desde.getMonth() - 1);
    else desde.setMonth(desde.getMonth() - 3); // quarter por defecto
  }
  var desdeStr = localDate(desde);
  var hastaStr = localDate(hasta);
  var meses = Math.max(1, Math.round((hasta - desde) / (30.44 * 86400000)));

  // Sincronizar inputs con el rango calculado (si fue por preset)
  if (periodo !== 'custom') {
    var elDesde = document.getElementById('crea-f-desde');
    var elHasta = document.getElementById('crea-f-hasta');
    if (elDesde && !elDesde.value) elDesde.value = desdeStr;
    if (elHasta && !elHasta.value) elHasta.value = hastaStr;
  }

  // Datos base
  var activeLots = db.lots.filter(function(l) { return !l.status || l.status === 'activo' || l.status === 'active'; });
  var totalCab = activeLots.reduce(function(s, l) { return s + (l.animal_count || 0); }, 0);
  var animalesDB = (typeof getAnimalesDB === 'function') ? getAnimalesDB() : {};

  // v1.4.59: Lotes que existían al INICIO del período = activos hoy + vendidos DURANTE el período.
  // Sin esto, los lotes vendidos no contaban en stockInicialKg y la Producción CREA se inflaba.
  // Helper para detectar fecha de venta de un lote (reusa lógica de Análisis Histórico)
  function _creaFechaVenta(l) {
    if (l.sold_at) return String(l.sold_at).slice(0, 10);
    var ventas = (db.sales || []).filter(function(s) {
      if (s.lot_code === l.code) return true;
      if (Array.isArray(s.lot_codes) && s.lot_codes.indexOf(l.code) >= 0) return true;
      if (Array.isArray(s.items)) return s.items.some(function(i) { return i.lot_code === l.code; });
      return false;
    });
    if (ventas.length === 0) return l.updated_at ? String(l.updated_at).slice(0, 10) : null;
    ventas.sort(function(a, b) { return String(b.date || '').localeCompare(String(a.date || '')); });
    return ventas[0].date;
  }
  var lotsAtPeriodStart = db.lots.filter(function(l) {
    var st = (l.status || '').toLowerCase();
    if (st === 'sold' || st === 'vendido') {
      var fv = _creaFechaVenta(l);
      // Si fue vendido durante o después del inicio del período, estaba activo al inicio
      return fv && fv >= desdeStr;
    }
    // Activos y cuarentena: estaban al inicio (asumiendo que existían antes de desdeStr)
    return !st || st === 'activo' || st === 'active' || st === 'marcado_completo' || st === 'cuarentena';
  });

  // Existencia media (promedio simple)
  var existMedia = totalCab;

  // Kg vendidos en periodo
  var ventasPeriodo = (db.sales || []).filter(function(v) { return (v.date || '') >= desdeStr && (v.date || '') <= hastaStr; });
  var kgVendidos = ventasPeriodo.reduce(function(s, v) { return s + (v.kg || v.total_kg || 0); }, 0);
  var cabVendidas = ventasPeriodo.reduce(function(s, v) { return s + (v.animals || v.animal_count || 0); }, 0);
  var ingresoVentas = ventasPeriodo.reduce(function(s, v) { return s + (v.total || 0); }, 0);
  // Incluir ventas de carne de bajas
  var ventasCarne = ventasPeriodo.filter(function(v) { return v.type === 'carne_baja'; });
  var ingresoVentasCarne = ventasCarne.reduce(function(s, v) { return s + (v.total || 0); }, 0);
  var ventasGanado = ventasPeriodo.filter(function(v) { return v.type !== 'carne_baja'; });
  var ingresoVentasGanado = ventasGanado.reduce(function(s, v) { return s + (v.total || 0); }, 0);

  // Kg comprados en periodo (compras de ganado)
  var comprasGanadoPeriodo = (db.compras_ganado || []).filter(function(c) { return (c.fecha || '') >= desdeStr && (c.fecha || '') <= hastaStr; });
  var kgComprados = comprasGanadoPeriodo.reduce(function(s, c) { return s + (c.total_kg || 0); }, 0);
  var cabCompradas = comprasGanadoPeriodo.reduce(function(s, c) { return s + (c.animal_count || 0); }, 0);
  var inversionCompras = comprasGanadoPeriodo.reduce(function(s, c) { return s + (c.total || 0); }, 0);

  // Stock actual en kg (desde e5m_animals - último pesaje de cada animal)
  // v1.4.59: solo lotes ACTIVOS hoy (stock final = foto del momento)
  var stockFinalKg = 0;
  activeLots.forEach(function(lot) {
    var anims = animalesDB[lot.code] || [];
    anims.forEach(function(a) {
      if (a.pesajes && a.pesajes.length) stockFinalKg += a.pesajes[a.pesajes.length - 1].peso || 0;
      else stockFinalKg += lot.avg_weight || 350;
    });
  });

  // Stock inicial estimado: usar pesaje más cercano a desdeStr
  // v1.4.59: incluye lotes vendidos durante el período (lotsAtPeriodStart) — antes solo activos.
  // Para lotes vendidos, usamos el primer pesaje del lote como aproximación (peso al ingreso).
  var stockInicialKg = 0;
  lotsAtPeriodStart.forEach(function(lot) {
    var st = (lot.status || '').toLowerCase();
    var esVendido = (st === 'sold' || st === 'vendido');
    if (esVendido) {
      // Lote vendido: usar peso al ingreso desde db.compras_ganado del lote, o avg_weight
      var compras = (db.compras_ganado || []).filter(function(c) {
        if (c.lot_code === lot.code) return true;
        if (Array.isArray(c.lote_destinos) && c.lote_destinos.indexOf(lot.code) >= 0) return true;
        return false;
      });
      if (compras.length) {
        // Sumar kg comprados como aproximación de stock inicial del lote
        var kgComprasLot = compras.reduce(function(s, c) { return s + (parseFloat(c.total_kg) || 0); }, 0);
        stockInicialKg += kgComprasLot;
      } else {
        // Fallback: cabezas × avg_weight del lote (o 300 si no hay)
        stockInicialKg += (lot.animal_count || 0) * (parseFloat(lot.avg_weight) || 300);
      }
    } else {
      // Lote activo: usar pesaje más cercano a desdeStr para cada animal
      var anims = animalesDB[lot.code] || [];
      anims.forEach(function(a) {
        if (a.pesajes && a.pesajes.length) {
          var closest = a.pesajes[0];
          var closestDist = Math.abs(new Date(closest.fecha || closest.date || desdeStr).getTime() - new Date(desdeStr).getTime());
          a.pesajes.forEach(function(p) {
            var d = Math.abs(new Date(p.fecha || p.date || desdeStr).getTime() - new Date(desdeStr).getTime());
            if (d < closestDist) { closest = p; closestDist = d; }
          });
          stockInicialKg += closest.peso || 0;
        } else {
          stockInicialKg += 300;
        }
      });
    }
  });
  if (stockInicialKg === 0) stockInicialKg = stockFinalKg + kgVendidos - kgComprados;

  // PRODUCCIÓN CREA = kg vendidos + (stock final - stock inicial) - kg comprados
  var produccionCREA = kgVendidos + (stockFinalKg - stockInicialKg);
  // No restar comprados aquí porque ya se refleja en el stock final

  // Datos operativos adicionales del período
  var partosPeriodo = (db.partos || []).filter(function(p) { return (p.fecha || '') >= desdeStr && (p.fecha || '') <= hastaStr; }).length;
  var lluviaPeriodo = (db.lluvias || []).filter(function(l) { return (l.fecha || '') >= desdeStr && (l.fecha || '') <= hastaStr; }).reduce(function(s, l) { return s + (parseFloat(l.mm) || 0); }, 0);
  var dieselLitros = (db.diesel || []).filter(function(d) { return (d.fecha || '') >= desdeStr && (d.fecha || '') <= hastaStr; }).reduce(function(s, d) { return s + (parseFloat(d.litros) || 0); }, 0);
  var salKg = (db.sal || []).filter(function(r) { return (r.fecha || '') >= desdeStr && (r.fecha || '') <= hastaStr; }).reduce(function(s, r) { return s + (parseFloat(r.kg) || 0); }, 0);
  var tratamientosPeriodo = (db.treatments || []).filter(function(t) { return (t.applied_at || '') >= desdeStr && (t.applied_at || '') <= hastaStr; }).length;
  var conteosPeriodo = (db.conteo || []).filter(function(c) { return (c.fecha || '') >= desdeStr && (c.fecha || '') <= hastaStr; }).length;

  // Gastos directos en periodo
  // Mapping de subcuenta → categoría CREA (para clasificar coherentemente con Contabilidad)
  var sub2cat = {
    // sanidad
    'sanidad':'sanidad','sanidad veterinaria':'sanidad','medicamentos':'sanidad',
    // combustible
    'combustible':'combustible',
    // personal
    'personal':'personal','sueldos':'personal','adelantos personal':'personal',
    // mantenimiento
    'mantenimiento vehiculos':'mantenimiento','mantenimiento motor':'mantenimiento',
    'mantenimiento tractor':'mantenimiento','mantenimiento potreros':'mantenimiento',
    'mantenimiento camino':'mantenimiento','mantenimiento moto':'mantenimiento',
    'mantenimiento maquinaria':'mantenimiento','mantenimiento':'mantenimiento',
    // alimentación
    'sal':'alimento','sal mineral':'alimento','alimento':'alimento','alimentacion':'alimento',
    // admin/estructura
    'servicios':'admin','impuestos':'admin','seguro':'admin','institucion':'admin',
    'donacion':'admin','exportacion':'admin'
  };
  // Distribuir db.purchases del periodo por categoría según subcuenta
  var purchByCat = { sanidad:0, combustible:0, personal:0, mantenimiento:0, alimento:0, admin:0, otros:0 };
  (db.purchases || []).forEach(function(p) {
    if ((p.date || '') < desdeStr) return;
    var subKey = String(p.subcuenta || '').toLowerCase().trim();
    var cat = sub2cat[subKey] || 'otros';
    purchByCat[cat] += (parseFloat(p.total) || 0);
  });

  // Sanidad = costo de tratamientos + compras con subcuenta 'Sanidad'
  var gastSanidad = (db.treatments || []).filter(function(t) { return (t.applied_at || '') >= desdeStr && (t.applied_at || '') <= hastaStr; }).reduce(function(s, t) { return s + (t.cost || 0); }, 0)
                  + purchByCat.sanidad;

  // Personal = pagos REALMENTE realizados en el período:
  //   1) Sueldos pagados desde db.historial_sueldos (con fecha_pago en el período)
  //   2) Adelantos del período (db.advances con date en el período)
  //   3) Compras manuales con subcuenta='Personal' o 'Sueldos'
  // Ya NO se usa employees.salary × meses (esa estimación asumía pagos que no existieron).
  var gastPersonalSueldos = (db.historial_sueldos || []).filter(function(h) {
    var fp = h.fecha_pago || '';
    return fp >= desdeStr && fp <= hastaStr;
  }).reduce(function(s, h) { return s + (parseFloat(h.pago_neto) || 0); }, 0);
  var gastPersonal = gastPersonalSueldos + purchByCat.personal;
  var gastAdelantos = (db.advances || []).filter(function(a) { return (a.date || '') >= desdeStr && (a.date || '') <= hastaStr; }).reduce(function(s, a) { return s + (a.amount || 0); }, 0);

  // Diesel = recargas + compras con subcuenta 'Combustible'
  // v1.8.46: las recargas de WhatsApp usan `date` (no `fecha`); algunas solo `created_at`.
  // Antes el filtro miraba solo `d.fecha` y perdía esas recargas. Helper unificado:
  function _dieselFecha(d){ return String(d.date || d.fecha || d.created_at || '').slice(0,10); }
  function _esRecargaPeriodo(d){ var f=_dieselFecha(d); return d.type === 'recarga' && f >= desdeStr && f <= hastaStr; }
  function _esDespachoPeriodo(d){ var f=_dieselFecha(d); return d.type === 'despacho' && f >= desdeStr && f <= hastaStr; }
  var gastDiesel = (db.diesel || []).filter(_esRecargaPeriodo).reduce(function(s, d) { return s + (d.total || (parseFloat(d.litros)||0) * (parseFloat(d.precio)||0)); }, 0)
                + purchByCat.combustible;
  // Merma diesel como costo adicional
  var dieselRecargas = (db.diesel || []).filter(_esRecargaPeriodo).reduce(function(s,d){ return s + (parseFloat(d.litros)||0); }, 0);
  var dieselDespachos = (db.diesel || []).filter(_esDespachoPeriodo).reduce(function(s,d){ return s + (parseFloat(d.litros)||0); }, 0);
  var mermaDiesel = Math.max(0, dieselRecargas - dieselDespachos);
  var precioPromDiesel = dieselRecargas > 0 ? ((db.diesel || []).filter(_esRecargaPeriodo).reduce(function(s, d) { return s + (d.total || (parseFloat(d.litros)||0) * (parseFloat(d.precio)||0)); }, 0)) / dieselRecargas : 0;
  var costoMermaDiesel = Math.round(mermaDiesel * precioPromDiesel * 100) / 100;

  // Mantenimiento = registros de maintenance + compras con subcuenta 'Mantenimiento*'
  // v1.8.46: incluir mantenimientos de WhatsApp (sin date propio, solo created_at).
  var gastMaint = (db.maintenance || []).filter(function(m) { var f = String(m.date || m.fecha || m.created_at || '').slice(0,10); return f >= desdeStr && f <= hastaStr; }).reduce(function(s, m) { return s + (m.cost || 0); }, 0)
                + purchByCat.mantenimiento;

  // Compras insumos = SOLO las purchases que no caen en ninguna categoría productiva
  var gastCompras = purchByCat.otros;

  // Alimento = sal/alimento desde tablas + compras con subcuenta 'Sal' o 'Alimento'
  var gastAlimento = (db.sal || []).filter(function(r) { return (r.date || r.fecha || '') >= desdeStr && (r.date || r.fecha || '') <= hastaStr; }).reduce(function(s, r) {
    var cost = r.costo || 0;
    if (!cost && r.qty && r.product_id) {
      var prod = (db.products||[]).find(function(p){return p.id === r.product_id;});
      if (prod && prod.unit_price) cost = r.qty * prod.unit_price;
    }
    return s + cost;
  }, 0) + (db.alimento || []).filter(function(r) { return (r.date || r.fecha || '') >= desdeStr && (r.date || r.fecha || '') <= hastaStr; }).reduce(function(s, r) {
    var cost = r.costo || 0;
    if (!cost && r.qty && r.product_id) {
      var prod = (db.products||[]).find(function(p){return p.id === r.product_id;});
      if (prod && prod.unit_price) cost = r.qty * prod.unit_price;
    }
    return s + cost;
  }, 0) + purchByCat.alimento;

  var gastAceite = (db.aceite || []).filter(function(r) { return (r.fecha || '') >= desdeStr && (r.fecha || '') <= hastaStr; }).reduce(function(s, r) { return s + (r.total || r.costo || 0); }, 0);
  // Merma stock veterinario (productos vencidos o perdidos)
  var mermaVet = 0;
  (db.products || []).forEach(function(p) {
    if (p.stock_loss && p.stock_loss > 0) {
      mermaVet += (p.stock_loss || 0) * (p.unit_price || 0);
    }
  });
  // Gastos manuales registrados en Contabilidad (db.cuentas) que NO son derivados de otras tablas.
  // Los derivados tienen id con prefijo (compra-, trat-, cg-, diesel-, etc.) y se generan al renderizar.
  // Aquí solo sumamos los registros propios de db.cuentas (típicamente con id ct_ o numérico).
  // Filtro: solo cuentas COSTOS y GASTO ADMINISTRATIVO van a gasto operativo del reporte.
  // (INVERSIÓN se cuenta aparte en inversionCompras; INGRESOS van a ingresoVentas si los usás manualmente).
  var derivadoPrefixes = ['compra-','trat-','diesel-','sueldo-','maint-','adv-','aceite-','cg-','venta-','diesel-merma-'];
  var gastManuales = (db.cuentas || []).filter(function(r) {
    if (!r || !r.fecha || r.fecha < desdeStr) return false;
    var idStr = String(r.id || '');
    // Excluir derivados (no deberían estar en db.cuentas, pero por si acaso)
    if (derivadoPrefixes.some(function(pre){ return idStr.indexOf(pre) === 0; })) return false;
    var cu = String(r.cuenta || '').toUpperCase().trim();
    // Normalizar legacy
    if (cu === 'INVERSIONES') cu = 'INVERSIÓN';
    if (cu === 'GASTOS') cu = 'GASTO ADMINISTRATIVO';
    return cu === 'COSTOS' || cu === 'GASTO ADMINISTRATIVO';
  }).reduce(function(s, r) { return s + (parseFloat(r.monto) || 0); }, 0);

  var gastDirectos = gastSanidad + gastPersonal + gastAdelantos + gastDiesel + costoMermaDiesel + gastAceite + gastMaint + gastCompras + gastAlimento + mermaVet + gastManuales;
  var gastTotales = gastDirectos + gastoAdmin + gastoEstructura + inversionCompras;

  // INDICADORES PRODUCTIVOS
  var prodCarne = ha > 0 ? Math.round(produccionCREA / ha * 10) / 10 : 0;
  var cargaAnimal = (ha > 0 && pesoUA > 0) ? Math.round(stockFinalKg / pesoUA / ha * 100) / 100 : 0;

  // GDPV global
  var allGmds = [];
  activeLots.forEach(function(lot) {
    var anims = animalesDB[lot.code] || [];
    anims.forEach(function(a) {
      if (a.pesajes && a.pesajes.length >= 2) {
        var p0 = a.pesajes[0]; var p1 = a.pesajes[a.pesajes.length - 1];
        var dias = Math.round((new Date(p1.fecha) - new Date(p0.fecha)) / 86400000);
        if (dias > 0) allGmds.push((p1.peso - p0.peso) / dias);
      }
    });
  });
  var gdpv = allGmds.length ? Math.round(allGmds.reduce(function(s, g) { return s + g; }, 0) / allGmds.length * 1000) / 1000 : 0;
  // v1.4.63: Fix eficiencia de stock — usar stock medio en kg (no cabezas).
  // Antes: produccionCREA / cabezas × 100 daba números absurdos (38,616%).
  // Correcto AACREA: kg producidos / kg de stock medio × 100.
  var stockMedioKg = (stockInicialKg + stockFinalKg) / 2;
  var eficStock = stockMedioKg > 0 ? Math.round(produccionCREA / stockMedioKg * 1000) / 10 : 0;
  var prodCab = existMedia > 0 ? Math.round(produccionCREA / existMedia * 10) / 10 : 0;
  var tasaExtraccion = existMedia > 0 ? Math.round(cabVendidas / existMedia * 1000) / 10 : 0;
  var salPorCab = existMedia > 0 ? Math.round(salKg / existMedia * 10) / 10 : 0;

  // INDICADORES ECONÓMICOS
  // v1.4.63: Separar Costo Operativo (sin compra ganado) y Costo Total (con compra)
  // según criterio AACREA. PWA y Desktop ahora consistentes.
  var gastosOperativos = gastDirectos + gastoAdmin + gastoEstructura;  // sin inversionCompras
  var costoOperativoKg = produccionCREA > 0 ? Math.round(gastosOperativos / produccionCREA * 100) / 100 : 0;
  var costoKg = produccionCREA > 0 ? Math.round(gastTotales / produccionCREA * 100) / 100 : 0;  // total (con inversión)
  var margenBruto = ha > 0 ? Math.round((ingresoVentas - gastDirectos) / ha * 100) / 100 : 0;
  var resultOp = ha > 0 ? Math.round((ingresoVentas - gastTotales) / ha * 100) / 100 : 0;
  var gastoCabMes = existMedia > 0 && meses > 0 ? Math.round(gastDirectos / existMedia / meses * 100) / 100 : 0;
  var roi = gastTotales > 0 ? Math.round((ingresoVentas - gastTotales) / gastTotales * 1000) / 10 : 0;
  var ingresoHa = ha > 0 ? Math.round(ingresoVentas / ha * 100) / 100 : 0;
  var costoSanCab = existMedia > 0 ? Math.round(gastSanidad / existMedia * 100) / 100 : 0;

  // v1.4.91: Cachear KPIs para el resumen del topbar (Idea 11)
  // El topbar muestra Cabezas + Valor rodeo siempre, y Costo/kg desde acá.
  window._lastCREAKPIs = {
    costoOperativoKg: costoOperativoKg,
    prodCarne: prodCarne,
    cargaAnimal: cargaAnimal,
    resultOp: resultOp,
    roi: roi,
    computedAt: Date.now()
  };
  try { if (typeof renderTopbarSummary === 'function') renderTopbarSummary(); } catch(e) {}

  function kpi(label, value, unit, formula, color, trend) {
    return '<div class="card" style="padding:14px 16px;position:relative;border-left:3px solid ' + (color || 'var(--amber)') + '"><div style="font-size:10px;font-weight:700;color:var(--muted);letter-spacing:.5px;text-transform:uppercase;margin-bottom:4px">' + label + '</div><div style="font-size:22px;font-weight:800;font-family:DM Mono,monospace">' + value + '</div><div style="font-size:11px;color:var(--muted);margin-top:3px">' + unit + '</div><div style="font-size:9px;color:var(--muted);margin-top:4px;font-family:DM Mono,monospace;opacity:.6">' + formula + '</div>' + (trend ? '<div style="position:absolute;top:14px;right:14px;font-size:11px;font-weight:700;color:' + (trend > 0 ? 'var(--green)' : 'var(--red)') + '">' + (trend > 0 ? '▲' : '▼') + ' ' + Math.abs(trend) + '%</div>' : '') + '</div>';
  }

  var html = '<div style="margin-bottom:10px;font-size:11px;color:var(--muted)">Periodo: <strong>' + desdeStr + '</strong> al <strong>' + hastaStr + '</strong> · ' + ha + ' ha · ' + totalCab + ' cabezas · Stock: ' + Math.round(stockFinalKg/1000) + ' ton</div>';

  // Fórmula CREA visible
  html += '<div style="background:rgba(240,160,48,.06);border:1px solid rgba(240,160,48,.15);border-radius:8px;padding:10px 16px;font-size:11px;margin-bottom:16px;display:flex;gap:16px;flex-wrap:wrap;align-items:center">';
  html += '<span style="font-weight:700;color:var(--amber2)">Producción CREA:</span>';
  html += '<span>Kg vendidos: <strong>' + Math.round(kgVendidos).toLocaleString() + '</strong></span>';
  html += '<span>+ Diferencia stock: <strong>' + Math.round(stockFinalKg - stockInicialKg).toLocaleString() + '</strong> kg</span>';
  html += '<span>= <strong style="color:var(--green)">' + Math.round(produccionCREA).toLocaleString() + ' kg</strong></span>';
  if (cabCompradas) html += '<span style="color:var(--muted)">· Compras: ' + cabCompradas + ' cab (' + Math.round(kgComprados).toLocaleString() + ' kg)</span>';
  html += '</div>';

  // PRODUCTIVOS
  html += '<div style="font-size:14px;font-weight:700;color:var(--amber2);margin:16px 0 10px;border-bottom:1px solid var(--bor);padding-bottom:6px">🐄 Indicadores Productivos</div>';
  html += '<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:10px;margin-bottom:16px">';
  html += kpi('Producción de Carne', prodCarne, 'kg / ha / año', 'kg vendidos ÷ hectáreas', 'var(--green)');
  html += kpi('Carga Animal', cargaAnimal, 'UA / ha', 'existencia (UA) ÷ hectáreas', 'var(--amber)');
  html += kpi('GDPV', gdpv, 'kg / cab / día', 'ganancia peso ÷ días', 'var(--green)');
  html += kpi('Eficiencia de Stock', eficStock, '%', 'producción kg ÷ stock medio kg × 100', 'var(--blue)');
  html += kpi('Producción por Cabeza', prodCab, 'kg / cab / año', 'producción total ÷ exist. media', 'var(--amber)');
  html += kpi('Tasa de Extracción', tasaExtraccion, '%', 'cab vendidas ÷ exist. media × 100', 'var(--blue)');
  // Mortandad (placeholder - se puede calcular cuando se registren muertes)
  var bajasPeriodo = (db.bajas || []).filter(function(b) { return (b.fecha || '') >= desdeStr && (b.fecha || '') <= hastaStr; });
  var cabMuertas = bajasPeriodo.length;
  var mortandad = existMedia > 0 ? Math.round(cabMuertas / existMedia * 1000) / 10 : 0;
  html += kpi('Mortandad', mortandad + '% (' + cabMuertas + ' cab)', '%', cabMuertas + ' muertes ÷ ' + existMedia + ' exist. media × 100', mortandad > 3 ? 'var(--red)' : mortandad > 0 ? 'var(--amber)' : 'var(--green)');
  html += '</div>';

  // ECONÓMICOS
  html += '<div style="font-size:14px;font-weight:700;color:var(--amber2);margin:16px 0 10px;border-bottom:1px solid var(--bor);padding-bottom:6px">💰 Indicadores Económicos</div>';
  html += '<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:10px;margin-bottom:16px">';
  html += '<div class="card" style="padding:16px;grid-column:span 2;border-left:3px solid var(--amber);position:relative">' +
    '<div style="font-size:10px;font-weight:700;color:var(--muted);letter-spacing:.5px;text-transform:uppercase;margin-bottom:8px">Costo por Kg Vivo (AACREA)</div>' +
    '<div style="display:flex;gap:24px;align-items:flex-end;flex-wrap:wrap">' +
      '<div>' +
        '<div style="font-size:32px;font-weight:800;font-family:DM Mono,monospace;line-height:1">Bs. ' + costoOperativoKg + '</div>' +
        '<div style="font-size:11px;color:var(--amber2);margin-top:6px;font-weight:600">OPERATIVO · sin compra ganado</div>' +
        '<div style="font-size:10px;color:var(--muted);font-family:DM Mono,monospace;opacity:.7">eficiencia del campo</div>' +
      '</div>' +
      '<div style="opacity:.4;font-size:24px">|</div>' +
      '<div>' +
        '<div style="font-size:28px;font-weight:700;font-family:DM Mono,monospace;color:var(--muted);line-height:1">Bs. ' + costoKg + '</div>' +
        '<div style="font-size:11px;color:var(--muted);margin-top:6px">TOTAL · con compra ganado</div>' +
        '<div style="font-size:10px;color:var(--muted);font-family:DM Mono,monospace;opacity:.7">rentabilidad del negocio</div>' +
      '</div>' +
    '</div>' +
  '</div>';
  html += kpi('Margen Bruto', 'Bs. ' + margenBruto.toLocaleString(), 'Bs / ha / año', 'ingreso neto − gastos directos', 'var(--green)');
  html += kpi('Resultado Operativo', 'Bs. ' + resultOp.toLocaleString(), 'Bs / ha / año', 'margen bruto − admin − estructura', resultOp >= 0 ? 'var(--green)' : 'var(--red)');
  html += kpi('Gasto por Cab/Mes', 'Bs. ' + gastoCabMes, 'Bs / cab / mes', 'gastos directos ÷ exist. media ÷ meses', 'var(--amber)');
  html += kpi('ROI Ganadero', roi + '%', '', '(ingresos − gastos) ÷ gastos × 100', roi >= 0 ? 'var(--green)' : 'var(--red)');
  html += kpi('Ingreso por Ha', 'Bs. ' + ingresoHa.toLocaleString(), 'Bs / ha / año', 'ingresos ventas ÷ hectáreas', 'var(--blue)');
  html += kpi('Costo Sanidad / Cab', 'Bs. ' + costoSanCab, 'Bs / cab / año', 'gastos sanidad ÷ exist. media', 'var(--amber)');
  html += '</div>';

  // DETALLE POR LOTE
  // Desglose de costos
  html += '<div style="font-size:14px;font-weight:700;color:var(--amber2);margin:16px 0 10px;border-bottom:1px solid var(--bor);padding-bottom:6px">📝 Desglose de Costos e Ingresos</div>';
  html += '<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px">';

  // Costos
  html += '<div class="card" style="padding:14px"><div style="font-size:12px;font-weight:700;color:var(--red);margin-bottom:8px">EGRESOS — Bs. ' + Math.round(gastTotales).toLocaleString() + '</div>';
  var costos = [
    {n:'Personal (sueldos pagados)', v:gastPersonal},
    {n:'Diesel (recargas)', v:gastDiesel},
    {n:'Mantenimiento', v:gastMaint},
    {n:'Compras insumos', v:gastCompras},
    {n:'Sanidad', v:gastSanidad},
    {n:'Alimentacion (sal + alimento)', v:gastAlimento},
    {n:'Aceite', v:gastAceite},
    {n:'Adelantos personal', v:gastAdelantos},
    {n:'Compra ganado', v:inversionCompras},
    {n:'Admin + Estructura', v:gastoAdmin + gastoEstructura}
  ];
  if (costoMermaDiesel > 0) costos.push({n:'⚠️ Merma diesel (' + Math.round(mermaDiesel) + 'L)', v:costoMermaDiesel});
  if (mermaVet > 0) costos.push({n:'⚠️ Merma stock vet', v:mermaVet});
  if (gastManuales > 0) costos.push({n:'✏️ Otros (registros manuales)', v:gastManuales});
  costos.sort(function(a,b){return b.v - a.v;});
  costos.forEach(function(c) {
    if (c.v > 0) {
      var pct = gastTotales > 0 ? Math.round(c.v / gastTotales * 100) : 0;
      html += '<div style="display:flex;justify-content:space-between;font-size:11px;padding:3px 0;border-bottom:1px solid rgba(48,54,61,.15)"><span style="color:var(--muted)">' + c.n + '</span><span style="font-weight:600">Bs. ' + Math.round(c.v).toLocaleString() + ' <span style="font-size:9px;color:var(--muted)">(' + pct + '%)</span></span></div>';
    }
  });
  html += '</div>';

  // Ingresos
  html += '<div class="card" style="padding:14px"><div style="font-size:12px;font-weight:700;color:var(--green);margin-bottom:8px">INGRESOS — Bs. ' + Math.round(ingresoVentas).toLocaleString() + '</div>';
  if (ingresoVentasGanado > 0) html += '<div style="display:flex;justify-content:space-between;font-size:11px;padding:3px 0;border-bottom:1px solid rgba(48,54,61,.15)"><span style="color:var(--muted)">Venta ganado (' + ventasGanado.length + ' ops)</span><span style="font-weight:600;color:var(--green)">Bs. ' + Math.round(ingresoVentasGanado).toLocaleString() + '</span></div>';
  if (ingresoVentasCarne > 0) html += '<div style="display:flex;justify-content:space-between;font-size:11px;padding:3px 0;border-bottom:1px solid rgba(48,54,61,.15)"><span style="color:var(--muted)">Venta carne (bajas) (' + ventasCarne.length + ' ops)</span><span style="font-weight:600;color:var(--green)">Bs. ' + Math.round(ingresoVentasCarne).toLocaleString() + '</span></div>';
  var balance = ingresoVentas - gastTotales;
  html += '<div style="display:flex;justify-content:space-between;font-size:12px;padding:6px 0;margin-top:6px;border-top:2px solid var(--bor)"><span style="font-weight:700">BALANCE</span><span style="font-weight:800;color:' + (balance >= 0 ? 'var(--green)' : 'var(--red)') + '">Bs. ' + Math.round(balance).toLocaleString() + '</span></div>';
  html += '</div></div>';

  html += '<div style="font-size:14px;font-weight:700;color:var(--amber2);margin:16px 0 10px;border-bottom:1px solid var(--bor);padding-bottom:6px">📋 Detalle por Lote <span style="font-size:11px;font-weight:400;color:var(--muted)">(incluye lotes vendidos durante el período)</span></div>';
