      return '<button onclick="'+action+'()" style="display:inline-block;margin:4px 2px;padding:6px 14px;background:rgba(245,166,35,.15);border:1px solid rgba(245,166,35,.3);border-radius:6px;color:var(--amber2);font-size:11px;font-weight:600;cursor:pointer">'+label+'</button>';
    })
    .replace(/\[NAV:([^:]+):([^\]]+)\]/g, function(m, page, label) {
      return '<button onclick="aiNavigate(\''+page+'\')" style="display:inline-block;margin:4px 2px;padding:4px 10px;background:rgba(245,166,35,.15);border:1px solid rgba(245,166,35,.3);border-radius:6px;color:var(--amber2);font-size:11px;font-weight:600;cursor:pointer">→ '+label+'</button>';
    });
  div.innerHTML = html;
  container.appendChild(div);
  container.scrollTop = container.scrollHeight;
}

function aiNavigate(pageId) {
  var parts = pageId.split('/');
  var page = parts[0];
  var tab = parts[1] || '';
  var btn = document.querySelector('.nav-btn[onclick*="\''+page+'\'"]');
  if (typeof showPage === 'function') showPage(page, btn);
  if (tab && typeof showLotesTab === 'function') {
    setTimeout(function(){ showLotesTab('lotes-tab-'+tab, document.getElementById('lotes-tab-'+tab+'-btn')); }, 200);
  }
}

function buildAiDataContext() {
  var lines = [];
  try {
    var rp = (typeof getRp === 'function') ? getRp() : {};
    var ha = parseFloat(rp.hectareas) || 0;
    lines.push('ESTANCIA: ' + (rp.nombre_estancia||'') + ' | ' + (rp.propietario||'') + ' | ' + (rp.ubicacion||'') + ' | ' + ha + ' ha');
    var lots = (db.lots||[]).filter(function(l){var s=(l.status||'').toLowerCase();return s!=='sold'&&s!=='vendido';});
    var totalCab = lots.reduce(function(s,l){return s+(l.animal_count||0);},0);
    var avgW = lots.length ? Math.round(lots.reduce(function(s,l){return s+(l.avg_weight||0);},0)/lots.length) : 0;
    lines.push('GANADO: ' + totalCab + ' cab en ' + lots.length + ' lotes | Peso prom: ' + avgW + ' kg');
    lots.forEach(function(l){ lines.push('  ' + l.code + ': ' + (l.animal_count||0) + ' cab, ' + (l.avg_weight||0) + ' kg, GMD ' + (l.gmd||0) + ', ' + (l.category||'')); });
    // Animal-level weight distribution for AI analysis
    var animDB = (typeof getAnimalesDB === 'function') ? getAnimalesDB() : {};
    var weightRanges = {'500+':[],'450-499':[],'400-449':[],'350-399':[],'300-349':[],'<300':[]};
    var allAnimals = [];
    Object.keys(animDB).forEach(function(lc){
      (animDB[lc]||[]).forEach(function(a){
        var ps = a.pesajes||[];
        var w = ps.length ? ps[ps.length-1].peso : 0;
        allAnimals.push({id:a.id,lot:lc,peso:w});
        if(w>=500) weightRanges['500+'].push(a.id);
        else if(w>=450) weightRanges['450-499'].push(a.id);
        else if(w>=400) weightRanges['400-449'].push(a.id);
        else if(w>=350) weightRanges['350-399'].push(a.id);
        else if(w>=300) weightRanges['300-349'].push(a.id);
        else if(w>0) weightRanges['<300'].push(a.id);
      });
    });
    lines.push('DISTRIBUCION POR PESO:');
    Object.keys(weightRanges).forEach(function(r){
      if(weightRanges[r].length) lines.push('  ' + r + ' kg: ' + weightRanges[r].length + ' cab → IDs: ' + weightRanges[r].slice(0,20).join(', ') + (weightRanges[r].length>20?' ...(+' + (weightRanges[r].length-20) + ' mas)':''));
    });
    // Top 10 más pesados y más livianos
    allAnimals.sort(function(a,b){return b.peso-a.peso;});
    if(allAnimals.length>5) {
      lines.push('TOP 10 MAS PESADOS: ' + allAnimals.slice(0,10).map(function(a){return a.id+'('+a.lot+'):'+a.peso+'kg';}).join(', '));
      lines.push('10 MAS LIVIANOS: ' + allAnimals.filter(function(a){return a.peso>0;}).slice(-10).reverse().map(function(a){return a.id+'('+a.lot+'):'+a.peso+'kg';}).join(', '));
    }
    var bajas = db.bajas || [];
    var bajasYear = bajas.filter(function(b){return (b.fecha||'').startsWith(new Date().getFullYear()+'');});
    var mortPct = totalCab > 0 ? Math.round(bajasYear.length / (totalCab + bajasYear.length) * 1000) / 10 : 0;
    var causas = {};
    bajasYear.forEach(function(b){var c=b.causa||'?';causas[c]=(causas[c]||0)+1;});
    lines.push('MORTANDAD: ' + bajasYear.length + ' bajas (' + mortPct + '%) | ' + Object.keys(causas).map(function(c){return c+':'+causas[c];}).join(', '));
    var prods = db.products || [];
    var lowStock = prods.filter(function(p){return p.stock_qty<=p.stock_min;});
    if (lowStock.length) lines.push('STOCK CRITICO: ' + lowStock.map(function(p){return p.name+' ('+p.stock_qty+'/'+p.stock_min+')';}).join(', '));
    var tanks = (typeof getDieselTanks === 'function') ? getDieselTanks() : [];
    var diesel = db.diesel || [];
    var now = new Date();
    var mp = now.getFullYear() + '-' + String(now.getMonth()+1).padStart(2,'0');
    var mDesp = diesel.filter(function(r){return r.type==='despacho'&&(r.fecha||'').startsWith(mp);});
    var mRec = diesel.filter(function(r){return r.type==='recarga'&&(r.fecha||'').startsWith(mp);});
    var consumoMes = mDesp.reduce(function(s,r){return s+(parseFloat(r.litros)||0);},0);
    var gastoMes = mRec.reduce(function(s,r){return s+(parseFloat(r.total)||0);},0);
    lines.push('DIESEL: ' + tanks.map(function(t){return t.name+':'+t.current_level+'/'+t.capacity+'L';}).join(' ') + ' | Consumo:' + consumoMes.toFixed(0) + 'L | Bs.' + Math.round(gastoMes));
    var porV = {};
    mDesp.forEach(function(r){var v=r.vehiculo||'?';porV[v]=(porV[v]||0)+(parseFloat(r.litros)||0);});
    if (Object.keys(porV).length) lines.push('  Vehiculos: ' + Object.keys(porV).map(function(v){return v+':'+porV[v].toFixed(0)+'L';}).join(', '));
    var salRecs = (db.sal||[]).filter(function(r){return (r.date||'').startsWith(mp);});
    if (salRecs.length) {
      var totalSal = salRecs.reduce(function(s,r){return s+(r.qty||0);},0);
      var salPorLote = {};
      salRecs.forEach(function(r){salPorLote[r.lot_code]=(salPorLote[r.lot_code]||0)+(r.qty||0);});
      lines.push('SAL MES: ' + totalSal.toFixed(0) + 'kg | ' + Object.keys(salPorLote).map(function(l){return l+':'+salPorLote[l].toFixed(0)+'kg';}).join(', '));
    }
    var lluvias = (db.lluvias||[]).filter(function(r){return (r.fecha||'').startsWith(mp);});
    if (lluvias.length) {
      var pluvios = (typeof getPluvios === 'function') ? getPluvios() : [];
      lines.push('LLUVIA MES: ' + lluvias.length + ' dias | ' + pluvios.map(function(p){var t=lluvias.reduce(function(s,r){return s+(parseFloat(r[p.key])||0);},0);return p.label+':'+t.toFixed(0)+'mm';}).join(' '));
    }
    var ventas = (db.sales||[]).filter(function(v){return (v.date||'').startsWith(mp);});
    var ingreso = ventas.reduce(function(s,v){return s+(v.total||0);},0);
    lines.push('FINANZAS MES: Ingreso Bs.' + Math.round(ingreso) + ' | Egreso Bs.' + Math.round(gastoMes) + ' | Ventas: ' + ventas.length);
    var alertas = (db.alerts||[]).filter(function(a){return !a.resolved;});
    if (alertas.length) lines.push('ALERTAS ACTIVAS: ' + alertas.map(function(a){return a.title;}).join(' | '));

    // Empleados y adelantos
    var emps = db.employees || [];
    var advances = db.advances || [];
    var advMes = advances.filter(function(a){return (a.date||'').startsWith(mp);});
    if (emps.length) {
      var totalSalarios = emps.reduce(function(s,e){return s+(e.salary||0);},0);
      lines.push('PERSONAL: ' + emps.length + ' empleados | Nomina mensual: Bs.' + Math.round(totalSalarios));
      emps.forEach(function(e){
        var empAdv = advMes.filter(function(a){return a.employee===e.name||a.employee_id===e.id;});
        var empAdvTotal = empAdv.reduce(function(s,a){return s+(a.amount||0);},0);
        lines.push('  ' + e.name + ': Bs.' + (e.salary||0) + '/mes' + (empAdvTotal ? ' | Adelantos mes: Bs.' + empAdvTotal + ' (' + empAdv.length + ' veces)' : ''));
      });
    }
    if (advMes.length) {
      var totalAdv = advMes.reduce(function(s,a){return s+(a.amount||0);},0);
      lines.push('ADELANTOS MES: ' + advMes.length + ' adelantos por Bs.' + Math.round(totalAdv) + ' total');
      advMes.forEach(function(a){ lines.push('  ' + (a.date||'') + ': ' + (a.employee||'?') + ' Bs.' + (a.amount||0) + ' — ' + (a.reason||'')); });
    }
    // Total historico de adelantos
    if (advances.length > advMes.length) {
      var totalAdvHist = advances.reduce(function(s,a){return s+(a.amount||0);},0);
      lines.push('ADELANTOS HISTORICO: ' + advances.length + ' registros por Bs.' + Math.round(totalAdvHist) + ' total');
    }

    // Compras insumos
    var compras = (db.purchases||[]).filter(function(c){return (c.date||'').startsWith(mp);});
    if (compras.length) {
      var totalCompras = compras.reduce(function(s,c){return s+(c.total||0);},0);
      lines.push('COMPRAS MES: ' + compras.length + ' compras por Bs.' + Math.round(totalCompras));
      compras.forEach(function(c){ lines.push('  ' + (c.date||'') + ': ' + (c.desc||'?') + ' Bs.' + (c.total||0)); });
    }

    // Tratamientos / Sanidad
    var treats = (db.treatments||[]).filter(function(t){return (t.applied_at||'').startsWith(mp);});
    if (treats.length) {
      var treatCost = treats.reduce(function(s,t){return s+(t.cost||0);},0);
      lines.push('SANIDAD MES: ' + treats.length + ' tratamientos | Costo: Bs.' + Math.round(treatCost));
      var treatPorProd = {};
      treats.forEach(function(t){treatPorProd[t.product_name||'?']=(treatPorProd[t.product_name||'?']||0)+1;});
      lines.push('  Productos: ' + Object.keys(treatPorProd).map(function(p){return p+':'+treatPorProd[p];}).join(', '));
    }

    // Mantenimiento
    var maint = (db.maintenance||[]).filter(function(m){return (m.date||'').startsWith(mp);});
    if (maint.length) {
      var maintCost = maint.reduce(function(s,m){return s+(parseFloat(m.cost)||0);},0);
      lines.push('MANTENIMIENTO MES: ' + maint.length + ' registros | Bs.' + Math.round(maintCost));
    }

    // Ventas detalle
    if (ventas.length) {
      var totalKgVend = ventas.reduce(function(s,v){return s+(v.total_kg||0);},0);
      lines.push('VENTAS DETALLE: ' + ventas.length + ' ventas | ' + Math.round(totalKgVend) + ' kg | Bs.' + Math.round(ingreso));
      ventas.forEach(function(v){ lines.push('  ' + (v.date||'') + ': ' + (v.lot_code||'') + ' → ' + (v.buyer||'?') + ' ' + (v.animal_count||0) + ' cab ' + (v.total_kg||0) + 'kg Bs.' + (v.total||0)); });
    }

    // Partos
    var partos = (db.partos||[]).filter(function(p){return (p.date||'').startsWith(mp);});
    if (partos.length) {
      var sanos = partos.filter(function(p){return p.estado==='sano';}).length;
      var muertos = partos.filter(function(p){return p.estado==='muerto';}).length;
      lines.push('PARTOS MES: ' + partos.length + ' | Sanos: ' + sanos + ' | Mortinatos: ' + muertos);
    }

    // Stock vet completo
    if (prods.length) {
      lines.push('STOCK VET COMPLETO:');
      prods.forEach(function(p){ lines.push('  ' + p.name + ': ' + p.stock_qty + '/' + p.stock_min + ' ' + (p.unit||'') + (p.stock_qty<=p.stock_min?' ⚠️BAJO':'')); });
    }

    // Agua
    var aguaRecs = (db.agua||[]).filter(function(r){return (r.date||'').startsWith(mp);});
    if (aguaRecs.length) {
      var estadosAgua = {};
      aguaRecs.forEach(function(r){var e=r.estado||'?';estadosAgua[e]=(estadosAgua[e]||0)+1;});
      lines.push('AGUA MES: ' + aguaRecs.length + ' controles | ' + Object.keys(estadosAgua).map(function(e){return e+':'+estadosAgua[e];}).join(', '));
    }

    // Pesajes recientes
    var pesajes = (db.pesajes||[]).filter(function(p){return (p.date||'').startsWith(mp);});
    if (pesajes.length) {
      lines.push('PESAJES MES: ' + pesajes.length + ' sesiones');
    }
  } catch(e) { lines.push('Error: ' + e.message); }
  return lines.join('');
}

