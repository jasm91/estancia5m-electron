function addStock() {
  const product_id = parseInt(document.getElementById('stock-product-id').value);
  const qty = parseFloat(document.getElementById('stock-qty').value);
  if(!product_id||!qty||qty<=0){toast('Selecciona producto e ingresa cantidad','error');return;}
  const prod = db.products.find(p=>p.id===product_id);
  var prevStock = prod.stock_qty;
  var reason = (document.getElementById('stock-reason')||{}).value || 'ingreso';
  prod.stock_qty = Math.round((prod.stock_qty+qty)*100)/100;
  prod.stock_updated_at = new Date().toISOString();
  var expiryEl = document.getElementById('sa-expiry');
  var newExpiry = expiryEl ? expiryEl.value : '';
  if(newExpiry) prod.expiry_date = newExpiry;
  // Resolve stock alert
  db.alerts.forEach(a=>{if(!a.resolved&&a.type==='stock_low'&&a.title.includes(prod.name)&&prod.stock_qty>prod.stock_min) a.resolved=true;});
  // FIX: dejar registro del ingreso manual en el historial de stock (Movimientos),
  // visible en Desktop y PWA. Se guarda como inventory_counts tipo 'ingreso' (no es merma).
  if(!db.inventory_counts) db.inventory_counts = [];
  db.inventory_counts.push({
    id: 'ic_' + Date.now(), date: today(), by: 'Desktop', tipo: 'ingreso', ajustado: true,
    items: [{ product_id: prod.id, product_name: prod.name, unit: prod.unit || '',
      stock_teorico: prevStock, stock_fisico: prod.stock_qty,
      diferencia: qty, costo_merma: 0, motivo: reason }],
    total_merma_bs: 0, total_items: 1, items_con_diferencia: 1, created_at: new Date().toISOString()
  });
  addActivity(_desktopAuthor(),'alimentacion','','Ingreso de stock: '+qty+' '+prod.unit+' de '+prod.name+' ('+reason+')');
  saveDB(); closeModal('modal-stock-add'); renderStock(); renderDashboard();
  pushTableToRailway('inventory_counts', db.inventory_counts);
  toast(qty+' '+prod.unit+' de '+prod.name+' ingresados','success');
}


function deleteProduct(id) {
