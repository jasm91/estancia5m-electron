// Toggle de tema (Configuración → Apariencia). Default: oscuro.
function setTheme(t){
  t = (t === 'light') ? 'light' : 'dark';
  if (t === 'light') document.documentElement.setAttribute('data-theme','light');
  else document.documentElement.removeAttribute('data-theme');
  try { localStorage.setItem('e5m_theme', t); } catch(e){}
  var bd = document.getElementById('theme-btn-dark'), bl = document.getElementById('theme-btn-light');
  if (bd) { bd.style.background = (t==='dark') ? 'var(--sur2)' : 'transparent'; bd.style.color = (t==='dark') ? 'var(--text)' : 'var(--muted)'; }
  if (bl) { bl.style.background = (t==='light') ? 'var(--sur2)' : 'transparent'; bl.style.color = (t==='light') ? 'var(--text)' : 'var(--muted)'; }
}
document.addEventListener('DOMContentLoaded', function(){ try { setTheme(localStorage.getItem('e5m_theme')==='light' ? 'light':'dark'); } catch(e){} });
function showPage(name,btn){
  document.querySelectorAll('.page').forEach(function(p){p.classList.remove('active');});
  document.querySelectorAll('.nav-btn').forEach(function(b){b.classList.remove('active');});
  var pg=document.getElementById('page-'+name);if(pg)pg.classList.add('active');
  if(btn)btn.classList.add('active');
  var m=document.querySelector('.main');if(m)m.scrollTop=0;
  if(typeof renderPage==='function')renderPage(name);
  // Pull silencioso al cambiar de pagina para mostrar datos frescos del campo
  if(navigator.onLine) {
    clearTimeout(window._pageChangePull);
    window._pageChangePull = setTimeout(function(){ if(typeof pullFromRailwayDesktop==='function') pullFromRailwayDesktop(false); }, 500);
  }
}
