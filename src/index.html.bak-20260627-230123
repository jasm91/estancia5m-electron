function evaluatePasto() {
  if (!_evpPhoto) { toast('Falta la foto','error'); return; }
  var sel = document.getElementById('evp-lot');
  var val = sel ? sel.value : '';
  if (!val) { toast('Seleccioná un potrero o lote','error'); return; }

  var lotCode = '', potrero = '';
  if (val.indexOf('LOT:') === 0) {
    lotCode = val.substring(4);
    var lot = (db.lots||[]).find(function(l){ return l.code === lotCode; });
    if (lot) potrero = lot.paddock || '';
  } else if (val.indexOf('POT:') === 0) {
    potrero = val.substring(4);
  }

  var btn = document.getElementById('evp-eval-btn');
  if (btn) { btn.disabled = true; btn.textContent = '⏳ Evaluando...'; }
  var res = document.getElementById('evp-result');
  if (res) res.innerHTML = '<div style="padding:10px;color:var(--muted);font-size:12px">🤖 Analizando con IA Gemini...</div>';

  // v1.4.27: ya no se valida geminiKey local; el server maneja la disponibilidad

  var b64 = _evpPhoto.replace(/^data:image\/\w+;base64,/, '');
  var context = potrero ? 'Potrero: '+potrero+'. ' : '';
  if (lotCode) context += 'Lote: '+lotCode+'. ';
  var prompt = 'Eres un agronomo experto en pasturas tropicales del oriente boliviano. Analiza esta foto y responde EXACTAMENTE en este formato (sin texto adicional antes ni despues):\n**ESPECIE**: [nombre cientifico y comun]\n**ALTURA**: [numero] cm\n**COBERTURA**: [numero] %\n**ESTADO**: [Excelente|Bueno|Regular|Degradado|Critico]\n**NDVI_EST**: [0.0-1.0]\n**RECOMENDACION**: [una linea breve]\n\n' + context + 'Sé conciso, en español.';

  aiGenerate({
    contents: [{parts: [
      {inline_data: {mime_type: 'image/jpeg', data: b64}},
      {text: prompt}
    ]}],
    generationConfig: {
      maxOutputTokens: 2048,
      temperature: 0.2,
      thinkingConfig: { thinkingBudget: 0 }  // Gemini 2.5: deshabilitar reasoning para no consumir tokens
    }
  }).then(function(d){
    console.log('[EvalPasto Desktop] Respuesta Gemini:', d);
    var txt = '';
    var finishReason = '';
    try {
      var cand = d.candidates && d.candidates[0];
      if (cand) {
        finishReason = cand.finishReason || '';
        if (cand.content && cand.content.parts) {
          txt = cand.content.parts.map(function(p){return p.text||'';}).join('');
        }
      }
    } catch(e) { console.warn('[EvalPasto] Parse error:', e); }

    if (!txt) {
      var errMsg = 'Sin respuesta de IA';
      if (finishReason === 'MAX_TOKENS') errMsg = 'Respuesta cortada por límite de tokens — intentá de nuevo';
      else if (finishReason === 'SAFETY') errMsg = 'Imagen bloqueada por filtros de seguridad';
      else if (d && d.error && d.error.message) errMsg = 'Error API: ' + d.error.message;
      if (res) res.innerHTML = '<div style="padding:10px;color:var(--red);font-size:12px">'+escH(errMsg)+'</div>';
      if (btn) { btn.disabled = false; btn.textContent = '🤖 Evaluar con IA'; }
      return;
    }
    // Detectar respuesta truncada (no contiene RECOMENDACION) → reintentar automáticamente UNA vez
    var looksTruncated = (finishReason === 'MAX_TOKENS') || (txt.length < 80) || !/RECOMENDACION/i.test(txt);
    if (looksTruncated && !window._evpRetried) {
      window._evpRetried = true;
      console.warn('[EvalPasto] Respuesta truncada, reintentando con más tokens...');
      if (res) res.innerHTML = '<div style="padding:10px;color:var(--amber);font-size:12px">⚠ Respuesta incompleta, reintentando...</div>';
      setTimeout(function(){ evaluatePasto(); }, 500);
      return;
    }
    window._evpRetried = false;

    _evpResultText = txt;
    if (res) {
      res.innerHTML = '<div style="background:var(--sur2);border:1px solid var(--bor);border-radius:8px;padding:12px"><div style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px">🤖 Análisis IA</div><div style="font-size:12px;line-height:1.6;color:var(--text);white-space:pre-wrap">'+escH(txt).replace(/\n/g,'<br>').replace(/\*\*([^*]+)\*\*/g,'<b>$1</b>')+'</div><div style="margin-top:10px;display:flex;gap:8px"><button class="btn btn-primary btn-sm" onclick="saveEvalPasto()">💾 Guardar</button><button class="btn btn-ghost btn-sm" onclick="evaluatePasto()">🔄 Re-evaluar</button></div></div>';
    }
    if (btn) { btn.disabled = false; btn.textContent = '🤖 Evaluar con IA'; btn.style.display = 'none'; }
  }).catch(function(e){
    console.error('[EvalPasto] Error:', e);
    if (res) res.innerHTML = '<div style="padding:10px;color:var(--red);font-size:12px">Error: '+escH(e.message)+'</div>';
    if (btn) { btn.disabled = false; btn.textContent = '🤖 Evaluar con IA'; }
  });
}

function saveEvalPasto() {
