  calcSaleTotal();
}

function selectAllSaleAnimals() {
  var lotCode=(document.getElementById('sale-lot')||{}).value||'';
  var animalesDB=getAnimalesDB();
  // Construir lista de animales según el modo seleccionado
  var animals = [];
  // Set de códigos de lotes existentes y NO vendidos para filtrar el modo "__all__"
  var validLotCodes = {};
  (db.lots||[]).forEach(function(l){
    if (l.status !== 'vendido' && l.status !== 'sold') validLotCodes[l.code] = true;
  });
  if (lotCode === '__all__' || !lotCode) {
    // Modo "todos los lotes (mix)" — agregar TODOS los animales de lotes activos
    Object.keys(animalesDB).forEach(function(lc){
      if (!validLotCodes[lc]) return;  // skip lotes vendidos o huérfanos
      (animalesDB[lc]||[]).forEach(function(a){
        animals.push(Object.assign({}, a, {_lotCode: lc}));
      });
    });
  } else {
    // Modo lote específico — solo de ese lote, si está activo
    if (!validLotCodes[lotCode]) {
      toast('El lote seleccionado no está activo','warning');
      return;
    }
    animals = (animalesDB[lotCode]||[]).map(function(a){ return Object.assign({}, a, {_lotCode: lotCode}); });
  }
  if (!animals.length) {
    toast('No hay animales para seleccionar','warning');
    return;
  }
  _salePesoMap={};
  _saleAnimalLotMap = {};
  _saleSelectedAnimals=animals.map(function(a){
    var aid=(a.animal_id||a.id||'').toString();
    var lp=a.pesajes&&a.pesajes.length?a.pesajes[a.pesajes.length-1].peso:0;
    if(lp) _salePesoMap[aid]=lp;
    if(a._lotCode) _saleAnimalLotMap[aid] = a._lotCode;
    return aid;
  });
  filterSaleAnimals();
}

function clearSaleAnimals() {
  _saleSelectedAnimals=[];
  _salePesoMap={};
  _saleAnimalLotMap = {};
  filterSaleAnimals();
}

function updateSaleAnimalSummary() {
  var countEl=document.getElementById('sai-count');
  var kgEl=document.getElementById('sai-kg');
  var avgEl=document.getElementById('sai-avg');
  var summEl=document.getElementById('sale-individual-summary');
  var selCountEl=document.getElementById('sale-selected-count');
  var n=_saleSelectedAnimals.length;
  if(selCountEl) selCountEl.textContent=n?'('+n+' selec.)':'';
  if(!n){if(summEl)summEl.style.display='none';return;}
  if(summEl) summEl.style.display='block';
  var animalesDB=getAnimalesDB();
  var lotCode=(document.getElementById('sale-lot')||{}).value||'';
  var animals=lotCode?(animalesDB[lotCode]||[]):Object.values(animalesDB).reduce(function(a,b){return a.concat(b);},[]);
  var totalKg=0;
  _saleSelectedAnimals.forEach(function(id){
    var a=animals.find(function(x){return (x.animal_id||x.id||'').toString()===id;});
    if(a&&a.pesajes&&a.pesajes.length) totalKg+=a.pesajes[a.pesajes.length-1].peso;
  });
  var avg=n?Math.round(totalKg/n*10)/10:0;
  if(countEl) countEl.textContent=n;
  if(kgEl) kgEl.textContent=Math.round(totalKg)+' kg';
  if(avgEl) avgEl.textContent=avg+' kg';
  // Recalcular total monetario cada vez que cambia la seleccion
  calcSaleTotal();
}

function calcSaleTotal() {
  var scope=(document.getElementById('sale-scope')||{}).value||'lot';
  var price=parseFloat((document.getElementById('sale-price')||{}).value)||0;
  var totalEl=document.getElementById('sale-total');
  // Descuento de peso (opcional). Ej: 5 = 5% menos kg facturados
  var discountPct=parseFloat((document.getElementById('sale-discount-pct')||{}).value)||0;
  if (discountPct < 0) discountPct = 0;
  if (discountPct > 50) discountPct = 50;  // límite de seguridad
  var discountInfoEl = document.getElementById('sale-discount-info');
  var totalKg = 0;
  if(scope==='individual') {
    // Obtener animales de la DB para buscar pesos (fuente de verdad)
    var animalesDB=getAnimalesDB();
    var lotCode=(document.getElementById('sale-lot')||{}).value||'';
    var allAnimals=lotCode?(animalesDB[lotCode]||[]):Object.values(animalesDB).reduce(function(a,b){return a.concat(b);},[]);
    _saleSelectedAnimals.forEach(function(id){
      // Buscar en mapa primero (mas rapido), luego en DB
      var peso=_salePesoMap[id]||0;
      if(!peso) {
        var a=allAnimals.find(function(x){return (x.animal_id||x.id||'').toString()===id;});
        if(a&&a.pesajes&&a.pesajes.length) peso=a.pesajes[a.pesajes.length-1].peso;
      }
      totalKg+=peso||0;
    });
  } else {
    totalKg = parseFloat((document.getElementById('sale-kg')||{}).value)||0;
  }
  // Aplicar descuento
  var kgFacturados = discountPct > 0 ? Math.round(totalKg * (1 - discountPct/100) * 10) / 10 : totalKg;
  var tot = Math.round(kgFacturados * price * 100) / 100;
  if (discountInfoEl) {
    if (discountPct > 0 && totalKg > 0) {
      var diferencia = Math.round((totalKg - kgFacturados) * 10) / 10;
      discountInfoEl.style.display = 'block';
      discountInfoEl.innerHTML = totalKg.toFixed(1) + ' kg − ' + discountPct + '% = <strong>' + kgFacturados.toFixed(1) + ' kg</strong> facturados <span style="color:var(--red)">(−' + diferencia.toFixed(1) + ' kg)</span>';
    } else {
      discountInfoEl.style.display = 'none';
    }
  }
  if(totalEl) {
    if (scope==='individual') {
      totalEl.value = _saleSelectedAnimals.length && price ? 'Bs. '+tot.toLocaleString() : '';
    } else {
      totalEl.value = 'Bs. '+tot.toLocaleString();
    }
  }
}

