function populateTrAnimalList(lotCode, filter) {
  var sel=document.getElementById('tr-animal');
  if(!sel) return;
  var animalesDB=getAnimalesDB();
  var animals=[];
  if(lotCode) {
    animals=animalesDB[lotCode]||[];
  } else {
    Object.values(animalesDB).forEach(function(arr){ animals=animals.concat(arr); });
  }
  var f=(filter||'').toLowerCase();
  var filtered=animals.filter(function(a){ return !f||a.animal_id.toLowerCase().indexOf(f)>=0; });
  sel.innerHTML=filtered.map(function(a){
    var lastP=a.pesajes&&a.pesajes.length?a.pesajes[a.pesajes.length-1].peso:null;
    var label=a.animal_id+(lastP?' - '+lastP+' kg':'')+(a.breed?' ('+a.breed+')':'');
    return '<option value="'+a.animal_id+'">'+label+'</option>';
  }).join('');
  if(!filtered.length) sel.innerHTML='<option value="">Sin animales encontrados</option>';
}

function filterTrAnimals(text) {
  var lotCode=(document.getElementById('tr-lot')||{}).value||'';
  populateTrAnimalList(lotCode, text);
}

function onTrAnimalChange(animalId) {
  var infoEl=document.getElementById('tr-animal-info');
  if(!animalId){if(infoEl)infoEl.style.display='none';return;}
  var animalesDB=getAnimalesDB();
  var animal=null;
  Object.values(animalesDB).forEach(function(arr){
    var found=arr.find(function(a){return a.animal_id===animalId;});
    if(found) animal=found;
  });
  if(!animal){if(infoEl)infoEl.style.display='none';return;}
  var lastP=animal.pesajes&&animal.pesajes.length?animal.pesajes[animal.pesajes.length-1].peso:null;
  var razaEl=document.getElementById('tr-ani-raza');
  var pesoEl=document.getElementById('tr-ani-peso');
  if(razaEl) razaEl.textContent=animal.breed||'-';
  if(pesoEl) pesoEl.textContent=lastP?lastP+' kg':'-';
  if(infoEl) infoEl.style.display='block';
  // Poner count en 1 automaticamente
  var countEl=document.getElementById('tr-count');
  if(countEl) countEl.value=1;
  calcTotalProduct();
}

function updateDoseHint() {
  const id=parseInt(document.getElementById('tr-product').value);
  const prod=db.products.find(p=>p.id===id);
  const hint=document.getElementById('tr-dose-hint');
  if(prod){
    if(prod.dose_per_50kg) hint.textContent='Dosis estandar: '+prod.dose_per_50kg+' '+prod.unit+'/50kg';
    document.getElementById('tr-dose').value=prod.dose_per_50kg||'';
    calcTotalProduct();
  } else hint.textContent='';
}

function calcTotalProduct() {
  const dose=parseFloat(document.getElementById('tr-dose').value)||0;
  const count=parseInt(document.getElementById('tr-count').value)||0;
  const total=Math.round(dose*count*100)/100;
  const totEl=document.getElementById('tr-total');
  totEl.value=total||'';
  const prodId=parseInt(document.getElementById('tr-product').value);
  const prod=db.products.find(p=>p.id===prodId);
  const hint=document.getElementById('tr-stock-hint');
  if(prod&&total){
    const sufficient=prod.stock_qty>=total;
    hint.textContent='Stock disponible: '+prod.stock_qty+' '+prod.unit+' '+(sufficient?'OK':'INSUFICIENTE');
    hint.style.color=sufficient?'var(--green)':'var(--red)';
  }
}

