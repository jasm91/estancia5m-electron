function _reproHistPopulateDataLists() {
  // Datalist con crías (de partos)
  var crias = document.getElementById('repro-hist-crias-list');
  var madres = document.getElementById('repro-hist-madres-list');
  if (!crias || !madres) return;

  var partos = _reproGetPartos();
  var criaIds = {};
  var madreIds = {};
  partos.forEach(function(p) {
    if (p.cria_id && p.cria_id !== 'N/A') criaIds[p.cria_id] = true;
    if (p.madre_id) madreIds[p.madre_id] = true;
  });
  // También animales de e5m_animals como crías potenciales
  try {
    var animDB = (typeof getAnimalesDB === 'function') ? getAnimalesDB() : {};
    Object.keys(animDB || {}).forEach(function(lot) {
      (animDB[lot] || []).forEach(function(a) {
        if (a && a.id && a.id !== 'N/A') criaIds[a.id] = true;
      });
    });
  } catch(e) {}
  // Madres también desde servicios (vacas que tuvieron servicio)
  _reproGetServicios().forEach(function(s) {
    if (s.animal_id) madreIds[s.animal_id] = true;
  });

  crias.innerHTML = Object.keys(criaIds).sort().map(function(id) {
    return '<option value="' + String(id).replace(/"/g, '&quot;') + '">';
  }).join('');
  madres.innerHTML = Object.keys(madreIds).sort().map(function(id) {
    return '<option value="' + String(id).replace(/"/g, '&quot;') + '">';
  }).join('');
}

function _reproHistFindAnimalLote(animalId) {
  // Buscar en e5m_animals en qué lote está
  try {
    var animDB = (typeof getAnimalesDB === 'function') ? getAnimalesDB() : {};
    var found = null;
    Object.keys(animDB || {}).forEach(function(lot) {
      (animDB[lot] || []).forEach(function(a) {
        if (a && (a.id === animalId || a.caravana === animalId || a.animal_id === animalId)) {
          found = { lot: lot, animal: a };
        }
      });
    });
    return found;
  } catch(e) { return null; }
}

function _reproHistFindPesajes(animalId) {
  try {
    var animDB = (typeof getAnimalesDB === 'function') ? getAnimalesDB() : {};
    var pesajes = [];
    Object.keys(animDB || {}).forEach(function(lot) {
      (animDB[lot] || []).forEach(function(a) {
        if (a && (a.id === animalId || a.caravana === animalId || a.animal_id === animalId)) {
          (a.pesajes || []).forEach(function(p) {
            pesajes.push({ fecha: p.fecha || p.date, peso: p.peso || p.weight, lot: lot });
          });
        }
      });
    });
    return pesajes.sort(function(a, b) { return (a.fecha || '').localeCompare(b.fecha || ''); });
  } catch(e) { return []; }
}

function renderReproHistorial() {
  _reproHistPopulateDataLists();
  var criaQ = (document.getElementById('repro-hist-search-cria').value || '').trim();
  var madreQ = (document.getElementById('repro-hist-search-madre').value || '').trim();
  var resultEl = document.getElementById('repro-hist-result');
  if (!resultEl) return;

  if (!criaQ && !madreQ) {
    resultEl.innerHTML = '<div class="card"><div class="card-body" style="padding:40px;text-align:center;color:var(--muted)"><div style="font-size:48px;margin-bottom:12px">📜</div><div style="font-size:13px">Ingresá una cría o una madre para ver su historial reproductivo</div></div></div>';
    return;
  }

  if (criaQ) {
    resultEl.innerHTML = _reproHistRenderCria(criaQ);
  } else {
    resultEl.innerHTML = _reproHistRenderMadre(madreQ);
  }
}

function _reproHistRenderCria(criaId) {
  var partos = _reproGetPartos();
  // Buscar parto donde cria_id matchea
  var parto = partos.find(function(p) { return p.cria_id === criaId; });
  if (!parto) {
    return '<div class="card"><div class="card-body" style="padding:30px;text-align:center;color:var(--muted);font-size:13px">No se encontró ningún parto con cría <b>' + escH(criaId) + '</b>. ¿Es un animal sin registro de nacimiento?<br><br>Si la cría existe en el sistema pero no tiene parto vinculado, su origen no fue registrado vía Reproducción.</div></div>';
  }

  // Buscar servicio origen
  var servicio = parto.servicio_id ?
    _reproGetServicios().find(function(s) { return s.id === parto.servicio_id; }) : null;

  // Buscar animal actual (lote actual + raza)
  var animLoc = _reproHistFindAnimalLote(criaId);

  // Buscar pesajes
  var pesajes = _reproHistFindPesajes(criaId);

  // Construir timeline events ordenados cronológicamente
  var events = [];

  if (servicio) {
    var srvTitle = servicio.tipo_servicio === 'IA' ?
      '💉 Inseminación artificial' : '🐂 Servicio por monta';
    var srvDetail = [];
    if (servicio.tipo_servicio === 'IA') {
      if (servicio.semen_lote) srvDetail.push('Pajuela: <b>' + escH(servicio.semen_lote) + '</b>');
      if (servicio.technician) srvDetail.push('Técnico: <b>' + escH(servicio.technician) + '</b>');
    } else {
      if (servicio.toro_id) srvDetail.push('Toro: <b>' + escH(servicio.toro_id) + '</b>');
      else srvDetail.push('<span style="color:var(--muted)">Toro suelto (sin identificar)</span>');
    }
    srvDetail.push('Madre: <b>' + escH(servicio.animal_id) + '</b>');
    if (servicio.lot_code) srvDetail.push('Lote al servicio: ' + escH(servicio.lot_code));
    if (servicio.paddock) srvDetail.push('Potrero: ' + escH(servicio.paddock));
    events.push({
      date: servicio.date, type: 'servicio', icon: '🐂',
      title: srvTitle, color: 'var(--purple)',
      detail: srvDetail.join(' · '),
      notes: servicio.notes || ''
    });
    if (servicio.diagnosis_date) {
      var diagLabel = _reproDiagLabel(servicio.diagnosis_method);
      events.push({
        date: servicio.diagnosis_date, type: 'diagnostico', icon: '🔬',
        title: '🔬 Diagnóstico — ' + diagLabel,
        color: servicio.result === 'preñada' ? 'var(--green)' : 'var(--red)',
        detail: 'Resultado: <b>' + (servicio.result === 'preñada' ? '✓ Preñada' : '✗ Vacía') + '</b>',
        notes: ''
      });
    }
  } else {
    events.push({
      date: '', type: 'sin_servicio', icon: '⚠',
      title: '⚠ Sin servicio vinculado',
      color: 'var(--amber)',
      detail: 'El parto no fue creado desde Reproducción o se hizo manualmente sin servicio previo',
      notes: ''
    });
  }

  // Evento parto
  var sexoLbl = parto.sexo === 'macho' ? '🐂 Macho (Torillo)' : (parto.sexo === 'hembra' ? '🐄 Hembra (Ternera)' : '—');
  var estadoLbl = parto.estado === 'sano' ? '✅ Sano' :
    (parto.estado === 'debil' ? '⚠ Débil al nacer' : (parto.estado === 'muerto' ? '❌ Mortinato' : '—'));
  var partoDetail = [
    'Sexo: <b>' + sexoLbl + '</b>',
    'Peso al nacer: <b>' + (parto.peso ? parto.peso + ' kg' : '—') + '</b>',
    'Estado: <b>' + estadoLbl + '</b>'
  ];
  if (parto.lot_code) partoDetail.push('Nacido en lote: ' + escH(parto.lot_code));
  if (parto.paddock) partoDetail.push('Potrero: ' + escH(parto.paddock));
  events.push({
    date: parto.date, type: 'parto', icon: '🐣',
    title: '🐣 Nacimiento de cría ' + escH(criaId),
    color: 'var(--green)',
    detail: partoDetail.join(' · '),
    notes: parto.obs || ''
  });

  // Pesajes adicionales (omitir el de nacimiento que ya está implícito)
  pesajes.forEach(function(p, idx) {
    if (idx === 0 && parto.date && p.fecha && String(p.fecha).slice(0,10) === String(parto.date).slice(0,10)) return; // skip nacimiento
    events.push({
      date: p.fecha, type: 'pesaje', icon: '⚖',
      title: '⚖ Pesaje',
      color: 'var(--blue)',
      detail: 'Peso: <b>' + p.peso + ' kg</b> · Lote: ' + escH(p.lot || '—'),
      notes: ''
    });
  });

  // Sort
  events.sort(function(a, b) { return (a.date || '').localeCompare(b.date || ''); });

  // Card resumen + timeline
  var summary = '<div class="card" style="margin-bottom:14px">' +
    '<div class="card-body" style="padding:16px">' +
      '<div style="display:flex;gap:14px;flex-wrap:wrap;align-items:flex-start">' +
        '<div style="flex:1;min-width:180px">' +
          '<div style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px;font-family:DM Mono,monospace">Cría / ID</div>' +
          '<div style="font-size:20px;font-weight:600">' + escH(criaId) + '</div>' +
          '<div style="font-size:11px;color:var(--muted);margin-top:2px">' + sexoLbl + '</div>' +
        '</div>' +
        '<div style="flex:1;min-width:180px">' +
          '<div style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px;font-family:DM Mono,monospace">Madre</div>' +
          '<div style="font-size:14px;font-weight:500">' + escH(parto.madre_id || '—') + '</div>' +
        '</div>' +
        '<div style="flex:1;min-width:180px">' +
          '<div style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px;font-family:DM Mono,monospace">Padre</div>' +
          '<div style="font-size:14px;font-weight:500">' + escH(parto.padre_id || '—') + '</div>' +
        '</div>' +
        '<div style="flex:1;min-width:140px">' +
          '<div style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px;font-family:DM Mono,monospace">Lote actual</div>' +
          '<div style="font-size:14px;font-weight:500">' + escH(animLoc ? animLoc.lot : (parto.lot_code || '—')) + '</div>' +
        '</div>' +
        '<div style="flex:1;min-width:140px">' +
          '<div style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px;font-family:DM Mono,monospace">Fecha nacimiento</div>' +
          '<div style="font-size:14px;font-weight:500">' + _reproFmtDate(parto.date) + '</div>' +
        '</div>' +
        '<div style="flex:1;min-width:140px">' +
          '<div style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px;font-family:DM Mono,monospace">Edad</div>' +
          '<div style="font-size:14px;font-weight:500">' + _reproHistEdad(parto.date) + '</div>' +
        '</div>' +
      '</div>' +
    '</div>' +
  '</div>';

  return summary + _reproHistRenderTimeline(events, '<button class="btn btn-ghost" style="float:right;font-size:11px;padding:4px 10px" onclick="exportReproHistorialCria(\'' + escH(criaId).replace(/'/g, "\\'") + '\')">⬇ Excel</button>📜 Línea de tiempo');
}

function _reproHistRenderMadre(madreId) {
  var partos = _reproGetPartos().filter(function(p) { return p.madre_id === madreId; });
  var servicios = _reproGetServicios().filter(function(s) { return s.animal_id === madreId; });

  if (!partos.length && !servicios.length) {
    return '<div class="card"><div class="card-body" style="padding:30px;text-align:center;color:var(--muted);font-size:13px">No se encontraron registros reproductivos para la vaca <b>' + escH(madreId) + '</b>.</div></div>';
  }

  // Resumen
  var prenadas = servicios.filter(function(s) { return s.result === 'preñada'; }).length;
  var vacias = servicios.filter(function(s) { return s.result === 'vacia'; }).length;
  var crias_vivas = partos.filter(function(p) { return p.estado !== 'muerto'; }).length;
  var crias_muertas = partos.filter(function(p) { return p.estado === 'muerto'; }).length;

  var summary = '<div class="card" style="margin-bottom:14px">' +
    '<div class="card-body" style="padding:16px">' +
      '<div style="display:flex;gap:14px;flex-wrap:wrap">' +
        '<div style="flex:1;min-width:140px"><div style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px;font-family:DM Mono,monospace">Vaca</div><div style="font-size:20px;font-weight:600">' + escH(madreId) + '</div></div>' +
        '<div style="flex:1;min-width:120px"><div style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px;font-family:DM Mono,monospace">Servicios</div><div style="font-size:18px;font-weight:600">' + servicios.length + '</div><div style="font-size:11px;color:var(--muted)">' + prenadas + ' preñ · ' + vacias + ' vac</div></div>' +
        '<div style="flex:1;min-width:120px"><div style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px;font-family:DM Mono,monospace">Partos</div><div style="font-size:18px;font-weight:600">' + partos.length + '</div><div style="font-size:11px;color:var(--muted)">' + crias_vivas + ' vivas · ' + crias_muertas + ' muertas</div></div>' +
      '</div>' +
    '</div>' +
  '</div>';

  // Eventos: cada servicio + cada parto
  var events = [];
  servicios.forEach(function(s) {
    var det = [];
    if (s.tipo_servicio === 'IA') {
      if (s.semen_lote) det.push('Pajuela: <b>' + escH(s.semen_lote) + '</b>');
      if (s.technician) det.push('Téc: ' + escH(s.technician));
    } else {
      det.push('Toro: <b>' + escH(s.toro_id || 'suelto') + '</b>');
    }
    if (s.lot_code) det.push('Lote: ' + escH(s.lot_code));
    var resColor = s.result === 'preñada' ? 'var(--green)' : (s.result === 'vacia' ? 'var(--red)' : 'var(--amber)');
    var resTxt = s.result === 'preñada' ? '✓ Preñada' : (s.result === 'vacia' ? '✗ Vacía' : '⌛ Pendiente');
    det.push('Resultado: <span style="color:' + resColor + ';font-weight:500">' + resTxt + '</span>');
    if (s.diagnosis_date) det.push('Diag: ' + _reproDiagLabel(s.diagnosis_method) + ' ' + _reproFmtDate(s.diagnosis_date));
    events.push({
      date: s.date, type: 'servicio', icon: s.tipo_servicio === 'IA' ? '💉' : '🐂',
      title: s.tipo_servicio === 'IA' ? '💉 Inseminación artificial' : '🐂 Servicio por monta',
      color: 'var(--purple)',
      detail: det.join(' · '),
      notes: s.notes || ''
    });
  });
  partos.forEach(function(p) {
    var sexoLbl = p.sexo === 'macho' ? '🐂 Macho' : (p.sexo === 'hembra' ? '🐄 Hembra' : '—');
    var estadoLbl = p.estado === 'sano' ? '✅ Sano' : (p.estado === 'debil' ? '⚠ Débil' : (p.estado === 'muerto' ? '❌ Mortinato' : '—'));
    var det = [sexoLbl, 'Peso: ' + (p.peso ? p.peso + ' kg' : '—'), estadoLbl];
    if (p.cria_id && p.cria_id !== 'N/A') det.push('Cría: <b>' + escH(p.cria_id) + '</b>');
    if (p.padre_id) det.push('Padre: ' + escH(p.padre_id));
    events.push({
      date: p.date, type: 'parto', icon: '🐣',
      title: '🐣 Parto',
      color: p.estado === 'muerto' ? 'var(--red)' : 'var(--green)',
      detail: det.join(' · '),
      notes: p.obs || ''
    });
  });
  events.sort(function(a, b) { return (a.date || '').localeCompare(b.date || ''); });

  return summary + _reproHistRenderTimeline(events, '<button class="btn btn-ghost" style="float:right;font-size:11px;padding:4px 10px" onclick="exportReproHistorialMadre(\'' + escH(madreId).replace(/'/g, "\\'") + '\')">⬇ Excel</button>📜 Línea de tiempo de la vaca');
}

function _reproHistEdad(birthDate) {
  if (!birthDate) return '—';
  try {
    var b = new Date(birthDate);
    var now = new Date();
    var diffMs = now - b;
    var days = Math.floor(diffMs / 86400000);
    if (days < 30) return days + ' días';
    var months = Math.floor(days / 30);
    if (months < 24) return months + ' meses';
    var years = Math.floor(months / 12);
    var mods = months % 12;
    return years + ' año' + (years !== 1 ? 's' : '') + (mods > 0 ? ' ' + mods + ' m' : '');
  } catch(e) { return '—'; }
}

function _reproHistRenderTimeline(events, titleHtml) {
  if (!events.length) {
    return '<div class="card"><div class="card-body" style="padding:30px;text-align:center;color:var(--muted)">Sin eventos para mostrar</div></div>';
  }
  var html = '<div class="card"><div class="card-hd"><div class="card-title">' + titleHtml + '</div></div>' +
    '<div class="card-body" style="padding:18px 20px 22px">' +
      '<div style="position:relative;padding-left:32px">';
  // línea vertical
  html += '<div style="position:absolute;left:11px;top:8px;bottom:8px;width:2px;background:rgba(255,255,255,0.1)"></div>';

  events.forEach(function(e, idx) {
    html += '<div style="position:relative;padding-bottom:' + (idx === events.length - 1 ? '0' : '20px') + '">';
    // bullet
    html += '<div style="position:absolute;left:-32px;top:0;width:24px;height:24px;border-radius:50%;background:' + e.color + ';color:#fff;display:flex;align-items:center;justify-content:center;font-size:13px;box-shadow:0 0 0 3px var(--bg)">' + e.icon + '</div>';
    // contenido
    html += '<div style="background:rgba(255,255,255,0.03);border:1px solid var(--border);border-radius:8px;padding:10px 14px">';
    html += '<div style="display:flex;justify-content:space-between;align-items:baseline;gap:10px;flex-wrap:wrap">';
    html += '<div style="font-size:13px;font-weight:600;color:' + e.color + '">' + e.title + '</div>';
    html += '<div style="font-size:11px;color:var(--muted);font-family:DM Mono,monospace">' + _reproFmtDate(e.date) + '</div>';
    html += '</div>';
    if (e.detail) html += '<div style="font-size:12px;color:var(--text);line-height:1.6;margin-top:4px">' + e.detail + '</div>';
    if (e.notes) html += '<div style="font-size:11px;color:var(--muted);font-style:italic;margin-top:4px;padding-top:4px;border-top:1px dashed var(--border)">📝 ' + escH(e.notes) + '</div>';
    html += '</div>';
    html += '</div>';
  });

  html += '</div></div></div>';
  return html;
}

