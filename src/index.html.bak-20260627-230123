// FIX v1.4.37: helper para abrir el modal de mover lote desde botones de rotación
function abrirMoverLote(lotCode) {
  if (!lotCode) { toast('No hay lote asignado a este potrero', 'warning'); return; }
  // Buscar el lote por code → id, y reusar openMoveLot existente
  var lot = (db.lots || []).find(function(l){ return l.code === lotCode; });
  if (!lot) { toast('Lote "' + lotCode + '" no encontrado', 'error'); return; }
  if (typeof openMoveLot === 'function') {
    openMoveLot(lot.id);
  } else {
    toast('Funcionalidad de mover lote no disponible', 'error');
  }
}

function checkRotationAlerts() {
  var params = typeof getParams==='function' ? getParams() : {potreros:[]};
  var potreros = params.potreros || [];
  var history = db.rotation_history || [];
  var today = new Date();
  var alerts = [];

  potreros.forEach(function(p) {
    var activeEntry = history.find(function(r) { return r.potrero === p.name && !r.exit_date; });
    if (activeEntry) {
      var days = Math.max(1, Math.round((today - new Date(activeEntry.entry_date)) / 86400000));
      var maxOcc = p.max_occupation_days || 30;
      if (days > maxOcc) {
        alerts.push({type:'rotation_overdue', potrero:p.name, lot:activeEntry.lot_code, days:days, max:maxOcc,
          msg:'🔴 '+p.name+': Lote '+activeEntry.lot_code+' lleva '+days+' días (máx: '+maxOcc+'). Rotar para evitar degradación.'});
      } else if (days >= maxOcc - 3) {
        alerts.push({type:'rotation_soon', potrero:p.name, lot:activeEntry.lot_code, days:days, max:maxOcc,
          msg:'🟡 '+p.name+': Lote '+activeEntry.lot_code+' debe rotar en '+(maxOcc-days)+' días.'});
      }
    }
  });

  // Show in dashboard if there are alerts
  var rotAlertEl = document.getElementById('rotation-alerts');
  if (rotAlertEl && alerts.length) {
    rotAlertEl.innerHTML = alerts.map(function(a) {
      var bg = a.type==='rotation_overdue' ? 'rgba(239,68,68,.1)' : 'rgba(245,166,35,.1)';
      var bor = a.type==='rotation_overdue' ? 'rgba(239,68,68,.3)' : 'rgba(245,166,35,.3)';
      return '<div style="padding:6px 10px;border-radius:6px;background:'+bg+';border:1px solid '+bor+';font-size:11px;margin-bottom:4px">'+a.msg+'</div>';
    }).join('');
  } else if (rotAlertEl) { rotAlertEl.innerHTML = ''; }
  return alerts;
}
setTimeout(checkRotationAlerts, 3000);

