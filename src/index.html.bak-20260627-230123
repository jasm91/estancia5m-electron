function suggestSubcuentasAI() {
  var need = (db.purchases||[]).filter(function(p){ return !p.subcuenta && p.desc; });
  if (!need.length) return;
  // v1.4.27: ya no se valida geminiKey local; el server maneja la disponibilidad
  var params = getParams();
  var subcuentas = params.subcuentas || [];
  var subList = subcuentas.map(function(s){ return s.name+' ('+s.cuenta+')'; }).join(', ');
  var batch = need.slice(0, 10);
  var descs = batch.map(function(p,i){ return (i+1)+'. '+p.desc+' (Bs '+p.total+', proveedor: '+(p.supplier||'-')+')'; }).join('\n');
  var subNames = subcuentas.map(function(s){ return s.name; });
  var prompt = 'Asigna UNA subcuenta a cada compra. Responde SOLO un JSON array de strings.\nSubcuentas validas: '+subNames.join(', ')+'\n\nCompras:\n'+descs+'\n\nEjemplo respuesta: ["Herramientas","Sanidad","Combustible"]\nSOLO el array JSON, nada mas.';
  aiGenerate({
    contents:[{parts:[{text:prompt}]}],
    generationConfig:{temperature:0.1,maxOutputTokens:1000}
  }).then(function(d){
    var text = (d.candidates&&d.candidates[0]&&d.candidates[0].content&&d.candidates[0].content.parts&&d.candidates[0].content.parts[0]&&d.candidates[0].content.parts[0].text)||'';
    text = text.replace(/```json|```/g,'').trim();
    // Clean: remove "(COSTOS)" etc from names
    text = text.replace(/\s*\([^)]*\)/g, '');
    try {
      var sug = JSON.parse(text);
      if (Array.isArray(sug)) {
        var assigned = 0;
        batch.forEach(function(p,i){
          if (!sug[i]) return;
          var subObj = subcuentas.find(function(s){ return s.name === sug[i]; });
          if (subObj) {
            p.subcuenta = subObj.name;
            p.cuenta = subObj.cuenta;
            p.tipo_gasto = resolveCuentaTipoGasto(params, subObj, 'VARIABLE');
            p._ai_assigned = true;
            assigned++;
            console.log('[AI] Assigned: "'+p.desc+'" → '+p.subcuenta+' / '+p.cuenta+' / '+p.tipo_gasto);
          } else {
            console.warn('[AI] Subcuenta not found: "'+sug[i]+'" for "'+p.desc+'"');
          }
        });
        if (assigned) { saveDB(); renderCompras(); toast('🤖 IA asignó subcuentas a '+assigned+' compras','success'); }
      }
    } catch(e){ console.warn('[AI] Parse error:', text); }
  }).catch(function(e){ console.warn('[AI] Error:', e.message); });
}

