}

function calcVentaCarne() {
  var kg = parseFloat((document.getElementById('vc-kg')||{}).value) || 0;
  var precio = parseFloat((document.getElementById('vc-precio')||{}).value) || 0;
  var total = document.getElementById('vc-total');
  if (total) total.value = kg && precio ? 'Bs. ' + (kg * precio).toFixed(2) : '';
}

function saveVentaCarne() {
  var bajaId = ((document.getElementById('vc-baja-id')||{}).value||'').trim();
  var fecha = (document.getElementById('vc-fecha')||{}).value || '';
  // FIX v1.4.34: no permitir fechas futuras
  if(!validateNotFuture(fecha, 'fecha de venta')) return;
  var comprador = ((document.getElementById('vc-comprador')||{}).value || '').trim();
  var kg = parseFloat((document.getElementById('vc-kg')||{}).value) || 0;
  var precio = parseFloat((document.getElementById('vc-precio')||{}).value) || 0;
  var obs = ((document.getElementById('vc-obs')||{}).value || '').trim();
  if (!fecha || !kg || !precio) { toast('Completa fecha, kg y precio','error'); return; }
  var baja = (db.bajas||[]).find(function(b){ return String(b.id) === String(bajaId); });
  if (!baja) { toast('Baja no encontrada (ID: '+bajaId+')','error'); return; }
  var total = Math.round(kg * precio * 100) / 100;
  // Register as sale
  if (!db.sales) db.sales = [];
  if (!db.next_ids.sale) db.next_ids.sale = db.sales.length + 1;
  var ventaCarneRec = {
    id: db.next_ids.sale++,
    date: fecha,
    lot_code: baja.lot_code,
    buyer: comprador || 'Venta carne',
    animal_count: 1,
    total_kg: kg,
    price_per_kg: precio,
    total: total,
    type: 'carne_baja',
    notes: '🪦 Venta carne post-baja Animal #' + baja.animal_id + (obs ? ' - ' + obs : ''),
    by: 'Desktop',
    created_at: new Date().toISOString()
  };
  db.sales.push(ventaCarneRec);
  // Mark baja as sale registered
  baja.venta_registrada = true;
  baja.venta_kg = kg;
  baja.venta_total = total;
  saveDB();
  replaceTableInRailway('sales', db.sales || []);
  replaceTableInRailway('bajas', db.bajas || []);
  closeModal('modal-venta-carne');
  renderBajasDesktop();
  renderDashboard();
  toast('💰 Venta registrada: ' + kg + ' kg × Bs.' + precio + ' = Bs.' + total.toLocaleString(), 'success');
  // FIX v1.4.35: audit log para venta de carne (operación con dinero)
  try { auditLog('create', 'sales', ventaCarneRec.id, 'Venta carne post-baja: Animal #' + baja.animal_id + ' · ' + kg + 'kg · Bs ' + total); } catch(e){}
}

function viewBajaPhoto(txId) {
  // Check local photos first (try multiple ID formats)
  var tryIds = [txId, 'baja_'+txId];
  try {
    var localPhotos = JSON.parse(localStorage.getItem('e5m_local_photos')||'{}');
    for (var i=0; i<tryIds.length; i++) {
      if (localPhotos[tryIds[i]]) {
        var lb = document.getElementById('photo-lightbox');
        var img = document.getElementById('photo-lightbox-img');
        if (lb && img) { img.src = localPhotos[tryIds[i]]; lb.style.display = 'flex'; }
        return;
      }
    }
  } catch(e) {}
  // Fallback to server — try txId first, then baja_txId
  var apiUrl = getApiUrl();
  var token = localStorage.getItem('e5m_api_token') || '';
  fetch(apiUrl + '/transaction-image/' + txId, { headers: { 'Authorization': 'Bearer ' + token } })
    .then(function(r){ return r.json(); })
    .then(function(d){
      var imgSrc = d.image || (d.base64 ? 'data:' + (d.mime_type||'image/jpeg') + ';base64,' + d.base64 : null);
      if (imgSrc) {
        var lb = document.getElementById('photo-lightbox');
        var img = document.getElementById('photo-lightbox-img');
        if (lb && img) { img.src = imgSrc; lb.style.display = 'flex'; }
        // Cache locally
        try { var lp = JSON.parse(localStorage.getItem('e5m_local_photos')||'{}'); lp[txId] = imgSrc; localStorage.setItem('e5m_local_photos', JSON.stringify(lp)); } catch(e){}
      } else { toast('Foto no disponible','error'); }
    })
    .catch(function(){ 
      // Try with baja_ prefix
      fetch(apiUrl + '/transaction-image/baja_' + txId, { headers: { 'Authorization': 'Bearer ' + token } })
      .then(function(r2){ return r2.json(); })
      .then(function(d2){
        var imgSrc2 = d2.image || (d2.base64 ? 'data:' + (d2.mime_type||'image/jpeg') + ';base64,' + d2.base64 : null);
        if (imgSrc2) {
          var lb2 = document.getElementById('photo-lightbox');
          var img2 = document.getElementById('photo-lightbox-img');
          if (lb2 && img2) { img2.src = imgSrc2; lb2.style.display = 'flex'; }
        } else { toast('Foto no disponible','error'); }
      })
      .catch(function(){ toast('Error al cargar foto','error'); });
    });
}

function deleteBaja(id) {
  // FIX v1.4.35 BUG-LOT-1: al eliminar una baja, restaurar el animal en el lote, incrementar
  // animal_count, y crear contra-asiento en kardex. Antes solo se borraba el registro de baja
  // dejando los datos inconsistentes: el animal seguía descontado del lote pero la baja no
  // existía → animal "perdido" en limbo. Especialmente grave si el bot/sync ya había
  // pusheado el animal_count al server.
  var baja = (db.bajas || []).find(function(b){ return String(b.id) === String(id); });
  if (!baja) { toast('Baja no encontrada', 'error'); return; }

  var puedeRestaurar = !!baja.animal_snapshot;
  var msg = '¿Eliminar este registro de baja?';
  if (puedeRestaurar) {
    msg = '⚠ Esto eliminará la baja Y restaurará al animal #' + baja.animal_id +
          ' en el lote "' + baja.lot_code + '"' +
          '. También se anulará el asiento de kardex relacionado.\n\n¿Continuar?';
  } else {
    msg = '⚠ Atención: esta baja es de versión vieja (sin snapshot del animal).\n\n' +
          'Eliminarla SOLO borrará el registro pero NO restaurará al animal en el lote ' +
          '(el animal seguirá descontado).\n\n¿Continuar de todas formas?';
  }
  if (!confirm(msg)) return;

  // 1. Si tiene snapshot, restaurar el animal en e5m_animals
  if (puedeRestaurar) {
    try {
      var adb = getAnimalesDB();
      if (!adb[baja.lot_code]) adb[baja.lot_code] = [];
      // Verificar que no exista ya (idempotencia)
      var yaExiste = adb[baja.lot_code].some(function(a){
        return String(a.id || a.animal_id || '') === String(baja.animal_id);
      });
      if (!yaExiste) {
        adb[baja.lot_code].push(baja.animal_snapshot);
        saveAnimalesDB(adb);
      }
    } catch(e) { console.error('[deleteBaja] Error restaurando animal:', e.message); }

    // 2. Incrementar animal_count del lote
    var lot = (db.lots || []).find(function(l){ return l.code === baja.lot_code; });
    if (lot) {
      lot.animal_count = (lot.animal_count || 0) + 1;
      // Si el lote estaba marcado como vendido por animal_count=0, reactivarlo
      if (lot.status === 'vendido' && lot.animal_count > 0) {
        lot.status = 'active';
        console.warn('[deleteBaja] Lote ' + lot.code + ' reactivado (estaba vendido)');
      }
      lot.updated_at = new Date().toISOString();
    }
  }

  // 3. Crear contra-asiento en kardex (reversa) y marcar el original como anulado
  if (baja.kardex_ref_id && db.kardex) {
    var originalK = db.kardex.find(function(k){ return k.id === baja.kardex_ref_id; });
    if (originalK) {
      originalK.anulado = true;
      originalK.anulado_at = new Date().toISOString();
    }
    db.kardex.push({
      id: Date.now() + 7,
      lote: baja.lot_code || '',
      tipo: 'reversa_baja',
      fecha: localDate(),
      cabezas: 1,
      precio: 0,
      total: 0,
      desc: 'REVERSA de baja Animal #' + baja.animal_id + ' (' + (baja.causa||'?') + ')',
      by: 'Desktop',
      created_at: new Date().toISOString(),
      auto: true,
      reverses_id: baja.kardex_ref_id
    });
  }

  // 4. Borrar el registro de baja
  trackDeletion(id, 'bajas');
  db.bajas = (db.bajas || []).filter(function(b){ return String(b.id) !== String(id); });

  // 5. Persistir todo
  saveDB(true);
  replaceTableInRailway('bajas', db.bajas || []);
  if (puedeRestaurar) {
    replaceTableInRailway('lots', db.lots || []);
    replaceTableInRailway('kardex', db.kardex || []);
  }
  renderBajasDesktop();
  renderLotes();
  try { auditLog('delete', 'bajas', id, 'Baja eliminada (Animal #' + baja.animal_id + ', lote ' + baja.lot_code + ')' + (puedeRestaurar ? ' — animal restaurado' : ' — sin restore (snapshot ausente)')); } catch(e){}
  toast(puedeRestaurar ? 'Baja eliminada y animal restaurado al lote' : 'Baja eliminada (animal NO restaurado)', 'success');
}

