function saveMaint() {
  var desc = (document.getElementById('mnt-desc')||{}).value||'';
  if (!desc.trim()) { toast('Ingresa una descripcion', 'error'); return; }
  if (!db.maintenance) db.maintenance = [];

  var editId = (document.getElementById('mnt-edit-id')||{}).value;

  // Validar y consolidar items SOLO si es creación nueva (en edit los items son readonly)
  var stockItems = [];
  if (!editId) {
    for (var i = 0; i < _mntStockRows.length; i++) {
      var row = _mntStockRows[i];
      var pid = parseInt(row.product_id) || 0;
      var qty = parseFloat(row.qty) || 0;
      if (!pid && !qty) continue; // fila vacía: ignorar
      if (!pid) { toast('Fila ' + (i+1) + ': selecciona un producto o quitá la fila', 'error'); return; }
      if (qty <= 0) { toast('Fila ' + (i+1) + ': ingresá una cantidad mayor a 0', 'error'); return; }
      var prod = (db.products||[]).find(function(p){ return p.id == pid; });
      if (!prod) { toast('Fila ' + (i+1) + ': producto no encontrado', 'error'); return; }
      if (qty > (prod.stock_qty || 0)) {
        toast('⚠ Stock insuficiente de ' + prod.name + ': disponible ' + prod.stock_qty + ' ' + (prod.unit||''), 'error');
        return;
      }
      stockItems.push({ product_id: prod.id, product_name: prod.name, qty: qty, unit: prod.unit || '' });
    }
    // Validación duplicados (defensiva — la UI ya evita pero confirmamos)
    var seen = {};
    for (var j = 0; j < stockItems.length; j++) {
      if (seen[stockItems[j].product_id]) {
        toast('Producto duplicado: ' + stockItems[j].product_name + '. Consolidá en una sola fila.', 'error');
        return;
      }
      seen[stockItems[j].product_id] = true;
    }
  }

  // FIX v1.4.34: no permitir fechas futuras
  var mntDateVal = (document.getElementById('mnt-date')||{}).value||localDate();
  if(!validateNotFuture(mntDateVal, 'fecha del trabajo')) return;
  var recData = {
    category: (document.getElementById('mnt-cat')||{}).value||'otro',
    equipo: ((document.getElementById('mnt-equipo')||{}).value||'').trim(),
    status: (document.getElementById('mnt-status')||{}).value||'completado',
    desc: desc.trim(),
    who: (document.getElementById('mnt-who')||{}).value.trim(),
    cost: parseFloat((document.getElementById('mnt-cost')||{}).value)||0,
    date: mntDateVal,
    location: (document.getElementById('mnt-location')||{}).value.trim(),
    notes: (document.getElementById('mnt-notes')||{}).value.trim(),
    by: 'Desktop',
    updated_at: new Date().toISOString(),
  };

  if (editId) {
    var existing = db.maintenance.find(function(m){return String(m.id)===String(editId);});
    if (existing) {
      var oldSnap = JSON.parse(JSON.stringify(existing));
      // En edit: NO modificar stock_items / stock_product_id / etc. del registro
      Object.keys(recData).forEach(function(k){ existing[k] = recData[k]; });
      if (_mntPhotos.length) existing.photos = (existing.photos||[]).concat(_mntPhotos);
      toast('Trabajo actualizado','success');
      try { auditLog('update', 'maintenance', existing.id, _summarizeRecord('maintenance', existing), _computeDiff(oldSnap, existing)); } catch(e){}
    }
  } else {
    recData.id = db.next_ids.maint++;
    recData.photos = _mntPhotos.slice();
    recData.created_at = new Date().toISOString();
    // Adjuntar items consumidos
    if (stockItems.length) {
      recData.stock_items = stockItems;
      // Legacy: si hay un solo item, también poblar campos legacy para compat con renders viejos
      if (stockItems.length === 1) {
        recData.stock_product_id = stockItems[0].product_id;
        recData.stock_product = stockItems[0].product_name;
        recData.stock_descontado = stockItems[0].qty;
        recData.stock_unit = stockItems[0].unit;
      }
    }
    db.maintenance.push(recData);
    // Descontar stock por cada item
    var anyStockChange = false;
    stockItems.forEach(function(item) {
      var p = db.products.find(function(x){ return x.id == item.product_id; });
      if (p) {
        p.stock_qty = Math.round((p.stock_qty - item.qty) * 100) / 100;
        p.stock_updated_at = new Date().toISOString();
        anyStockChange = true;
      }
    });
    if (anyStockChange) replaceTableInRailway('vet_products', db.products || []);
    // Registrar actividad
    var activityDesc = '🔧 '+recData.desc+(recData.equipo?' — '+recData.equipo:'')+(recData.cost?' — Bs.'+recData.cost:'');
    if (stockItems.length === 1) {
      activityDesc += ' (usó '+stockItems[0].qty+' '+stockItems[0].unit+' de '+stockItems[0].product_name+')';
    } else if (stockItems.length > 1) {
      activityDesc += ' (usó '+stockItems.length+' insumos del stock)';
    }
    addActivity(recData.who||'Desktop', 'mantenimiento', recData.location||'', activityDesc, recData.date);
    toast(stockItems.length ? 'Trabajo registrado y stock descontado' : 'Trabajo registrado','success');
    try { auditLog('create', 'maintenance', recData.id, _summarizeRecord('maintenance', recData)); } catch(e){}
  }
  saveDB();
  replaceTableInRailway('maintenance', db.maintenance || []);
  closeModal('modal-maint');
  _mntPhotos = [];
  document.getElementById('mnt-photos-preview').innerHTML = '';
  renderMantenimiento();
  if (typeof renderStock === 'function' && stockItems.length) renderStock();
}

