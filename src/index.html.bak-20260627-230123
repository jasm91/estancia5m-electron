var _onboardingParsed = null;

function handleOnboardingFile(event) {
  var file = event.target.files[0];
  if (!file) return;
  var resultEl = document.getElementById('onboarding-result');
  if (resultEl) { resultEl.style.display = 'block'; resultEl.innerHTML = 'Leyendo archivo...'; resultEl.style.color = 'var(--muted)'; }
  var reader = new FileReader();
  reader.onload = function(e) {
    try {
      if (!window.estancia || !window.estancia.xlsx) {
        if (resultEl) { resultEl.innerHTML = 'XLSX no disponible — actualiza la app'; resultEl.style.color = 'var(--red)'; }
        return;
      }
      var raw = window.estancia.xlsx.readBuffer(e.target.result);
      var parsed = parseOnboardingWorkbook(raw);
      _onboardingParsed = parsed;
      showOnboardingPreview(parsed);
      event.target.value = '';
    } catch(err) {
      console.error('[Onboarding] Error:', err);
      if (resultEl) { resultEl.innerHTML = 'Error leyendo archivo: ' + err.message; resultEl.style.color = 'var(--red)'; }
    }
  };
  reader.onerror = function() {
    if (resultEl) { resultEl.innerHTML = 'No se pudo leer el archivo'; resultEl.style.color = 'var(--red)'; }
  };
  reader.readAsArrayBuffer(file);
}

function _isExampleOrEmptyRow(row) {
  var values = Object.values(row || {});
  var allEmpty = values.every(function(v){ return v === null || v === undefined || String(v).trim() === ''; });
  if (allEmpty) return true;
  return values.some(function(v){
    var s = String(v||'').toLowerCase();
    return s.indexOf('ejemplo - borrar') >= 0 || s.indexOf('ejemplo-borrar') >= 0;
  });
}

function _getCol(row, names) {
  for (var i = 0; i < names.length; i++) {
    var keys = Object.keys(row || {});
    for (var j = 0; j < keys.length; j++) {
      if (keys[j].toUpperCase().replace(/[*\s]/g,'').indexOf(names[i].toUpperCase().replace(/[*\s]/g,'')) >= 0) {
        return row[keys[j]];
      }
    }
  }
  return null;
}

function _getColNum(row, names) {
  var v = _getCol(row, names);
  if (v === null || v === undefined || v === '') return null;
  var n = parseFloat(String(v).replace(',','.'));
  return isNaN(n) ? null : n;
}

function _getColStr(row, names) {
  var v = _getCol(row, names);
  return (v === null || v === undefined) ? '' : String(v).trim();
}

function parseOnboardingWorkbook(raw) {
  var sheets = raw.sheets || {};
  function findSheet(keyword) {
    for (var name in sheets) {
      if (name.toUpperCase().indexOf(keyword.toUpperCase()) >= 0) return sheets[name];
    }
    return [];
  }
  var result = { parametros:[], potreros:[], pluviometros:[], subcuentas:[], lotes:[], animales:[], stockVet:[], maquinaria:[], tanques:[], personal:[] };

  findSheet('Parametros').forEach(function(r){
    if (_isExampleOrEmptyRow(r)) return;
    var key = _getColStr(r, ['PARAMETRO']);
    var val = _getCol(r, ['VALOR']);
    if (key) result.parametros.push({ key: key, value: val });
  });

  findSheet('Potrero').forEach(function(r){
    if (_isExampleOrEmptyRow(r)) return;
    var name = _getColStr(r, ['NOMBRE']);
    var ha = _getColNum(r, ['HECTAREAS']);
    if (!name || ha == null) return;
    result.potreros.push({ name: name, hectareas: ha, capacidad: _getColNum(r, ['CAPACIDAD']), pluviometro: _getColStr(r, ['PLUVIOMETRO']), obs: _getColStr(r, ['OBSERVACIONES']) });
  });

  findSheet('Pluviometro').forEach(function(r){
    if (_isExampleOrEmptyRow(r)) return;
    var name = _getColStr(r, ['NOMBRE']);
    if (!name) return;
    result.pluviometros.push({ name: name, ubicacion: _getColStr(r, ['UBICACION']), obs: _getColStr(r, ['OBSERVACIONES']) });
  });

  findSheet('Subcuenta').forEach(function(r){
    if (_isExampleOrEmptyRow(r)) return;
    var cuenta = _getColStr(r, ['CUENTA']);
    var name = _getColStr(r, ['SUBCUENTA']);
    if (!cuenta || !name) return;
    result.subcuentas.push({ cuenta: cuenta, name: name, desc: _getColStr(r, ['DESCRIPCION']) });
  });

  // v1.8.76: hoja unica "Animales" - cada fila = un animal con los datos de su lote.
  // Los lotes se DERIVAN agrupando por lot_code (metadata de la 1a fila no vacia). Elimina el mismatch
  // CABEZAS-vs-IDs que generaba lotes fantasma. Compatibilidad: si existe hoja "Lotes" (plantilla vieja), su metadata pisa.
  var _lotMeta = {};
  function _ensureLotMeta(code){ if(!_lotMeta[code]) _lotMeta[code] = { code: code, category:'', breed:'', paddock:'', supplier:'', animal_count:null, avg_weight:null }; return _lotMeta[code]; }

  findSheet('Animales').forEach(function(r){
    if (_isExampleOrEmptyRow(r)) return;
    var lc = _getColStr(r, ['LOTECODE','LOTE']);
    var aid = _getColStr(r, ['ANIMALID','ID']);
    if (!lc || !aid) return;
    var animBreed = _getColStr(r, ['RAZA']);
    result.animales.push({ lot_code: lc, animal_id: aid, breed: animBreed, peso: _getColNum(r, ['PESO']), fecha: _getColStr(r, ['FECHAPESAJE','FECHA']), sexo: _getColStr(r, ['SEXO']), obs: _getColStr(r, ['OBSERVACIONES']) });
    var meta = _ensureLotMeta(lc);
    if (!meta.category) meta.category = _getColStr(r, ['CATEGORIA']);
    if (!meta.breed) meta.breed = animBreed;
    if (!meta.paddock) meta.paddock = _getColStr(r, ['POTRERO']);
    if (!meta.supplier) meta.supplier = _getColStr(r, ['PROVEEDOR']);
  });

  // Legacy/opcional: hoja "Lotes" separada (plantillas viejas). Su metadata pisa la derivada.
  findSheet('Lotes').forEach(function(r){
    if (_isExampleOrEmptyRow(r)) return;
    var code = _getColStr(r, ['CODIGO']);
    var category = _getColStr(r, ['CATEGORIA']);
    if (!code || !category) return;
    var meta = _ensureLotMeta(code);
    meta.category = category;
    meta.breed = _getColStr(r, ['RAZA']) || meta.breed;
    meta.paddock = _getColStr(r, ['POTRERO']) || meta.paddock;
    meta.supplier = _getColStr(r, ['PROVEEDOR']) || meta.supplier;
    var cab = _getColNum(r, ['CABEZAS']); if (cab != null) meta.animal_count = cab;
    var pp = _getColNum(r, ['PESOPROM']); if (pp != null) meta.avg_weight = pp;
  });

  Object.keys(_lotMeta).forEach(function(code){
    var m = _lotMeta[code];
    result.lotes.push({ code: m.code, category: m.category || '', breed: m.breed || '', paddock: m.paddock || '', animal_count: m.animal_count, avg_weight: m.avg_weight, supplier: m.supplier || '', obs: '' });
  });

  findSheet('Stock').forEach(function(r){
    if (_isExampleOrEmptyRow(r)) return;
    var name = _getColStr(r, ['NOMBREPRODUCTO','NOMBRE']);
    var stock = _getColNum(r, ['STOCK']);
    var unit = _getColStr(r, ['UNIDAD']);
    if (!name || stock == null || !unit) return;
    result.stockVet.push({ name: name, type: _getColStr(r, ['TIPO']), stock: stock, unit: unit, dose: _getColStr(r, ['DOSIS']), cost: _getColNum(r, ['COSTO']), obs: _getColStr(r, ['OBSERVACIONES']) });
  });

  findSheet('Maquinaria').forEach(function(r){
    if (_isExampleOrEmptyRow(r)) return;
    var name = _getColStr(r, ['IDENTIFICADOR','NOMBRE']);
    var tipo = _getColStr(r, ['TIPO']);
    if (!name || !tipo) return;
    result.maquinaria.push({ name: name, type: tipo, brand: _getColStr(r, ['MARCA']), year: _getColNum(r, ['ANIO']), horometro: _getColNum(r, ['HOROMETRO']), km: _getColNum(r, ['KM']), obs: _getColStr(r, ['OBSERVACIONES']) });
  });

  findSheet('Tanques').forEach(function(r){
    if (_isExampleOrEmptyRow(r)) return;
    var name = _getColStr(r, ['NOMBRE']);
    var fuel = _getColStr(r, ['TIPOCOMBUSTIBLE','TIPO']);
    var cap = _getColNum(r, ['CAPACIDAD']);
    if (!name || !fuel || cap == null) return;
    result.tanques.push({ name: name, fuel: fuel, capacity: cap, level: _getColNum(r, ['NIVEL']), location: _getColStr(r, ['UBICACION']), obs: _getColStr(r, ['OBSERVACIONES']) });
  });

  findSheet('Personal').forEach(function(r){
    if (_isExampleOrEmptyRow(r)) return;
    var name = _getColStr(r, ['NOMBRECOMPLETO','NOMBRE']);
    var role = _getColStr(r, ['ROL']);
    if (!name || !role) return;
    result.personal.push({ name: name, role: role, salary: _getColNum(r, ['SUELDO']), hire_date: _getColStr(r, ['FECHAINGRESO','FECHA']), phone: _getColStr(r, ['TELEFONO']), pin: _getColStr(r, ['PIN']), obs: _getColStr(r, ['OBSERVACIONES']) });   // v1.8.70: +pin
  });

  return result;
}

function validateOnboardingImport(parsed) {
  var errors = [], warnings = [];
  var lotCodes = {};
  parsed.lotes.forEach(function(l){
    if (lotCodes[l.code]) errors.push('Lote duplicado en Excel: ' + l.code);
    lotCodes[l.code] = true;
  });
  var allLotCodes = {};
  (db.lots || []).forEach(function(l){ allLotCodes[l.code] = true; });
  parsed.lotes.forEach(function(l){ allLotCodes[l.code] = true; });
  parsed.animales.forEach(function(a){
    if (!allLotCodes[a.lot_code]) errors.push('Animal ' + a.animal_id + ': el lote "' + a.lot_code + '" no existe (ni en sistema ni en Excel)');
  });
  var animKey = {};
  parsed.animales.forEach(function(a){
    var k = a.lot_code + ':' + a.animal_id;
    if (animKey[k]) errors.push('Animal duplicado en Excel: ' + a.animal_id + ' en lote ' + a.lot_code);
    animKey[k] = true;
  });
  var pluvNames = {};
  parsed.pluviometros.forEach(function(p){ pluvNames[p.name] = true; });
  parsed.potreros.forEach(function(p){
    if (p.pluviometro && !pluvNames[p.pluviometro]) warnings.push('Potrero "' + p.name + '": pluviómetro "' + p.pluviometro + '" no está en hoja Pluviometros');
  });
  // v1.8.73: ESTRICTO — cada lote NUEVO debe individualizarse (tener sus animales con ID en la hoja
  // Animales). El conteo de cabezas sale SIEMPRE de Animales; la columna CABEZAS de Lotes es referencial.
  var _animCountByLot = {};
  parsed.animales.forEach(function(a){ _animCountByLot[a.lot_code] = (_animCountByLot[a.lot_code]||0) + 1; });
  var _existingLotCodes = {};
  (db.lots || []).forEach(function(l){ _existingLotCodes[l.code] = true; });
  parsed.lotes.forEach(function(l){
    if (_existingLotCodes[l.code]) return; // ya existe en el sistema → no se re-importa
    var n = _animCountByLot[l.code] || 0;
    if (n === 0) {
      errors.push('Lote "' + l.code + '" no tiene animales con ID en la hoja Animales. Cada lote debe individualizarse (una fila por animal en la hoja Animales).');
    } else if (l.animal_count != null && Number(l.animal_count) !== n) {
      warnings.push('Lote "' + l.code + '": en Lotes pusiste ' + l.animal_count + ' cabezas, pero hay ' + n + ' animales con ID → se usará ' + n + ' (manda la hoja Animales).');
    }
  });
  return { errors: errors, warnings: warnings, ok: errors.length === 0 };
}

