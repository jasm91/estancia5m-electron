function saveAceite() {
  var fecha=(document.getElementById('aceite-fecha')||{}).value||'';
  // FIX v1.4.34: no permitir fechas futuras
  if(!validateNotFuture(fecha, 'fecha del cambio')) return;
  var vehiculo=((document.getElementById('aceite-vehiculo')||{}).value||'').trim();
  var kmhr=((document.getElementById('aceite-kmhr')||{}).value||'').trim();
  var tipo=((document.getElementById('aceite-tipo')||{}).value||'').trim();
  var costo=parseFloat((document.getElementById('aceite-costo')||{}).value)||0;
  var obs=((document.getElementById('aceite-obs')||{}).value||'').trim();
  if(!fecha||!vehiculo){toast('Completa fecha y vehiculo','error');return;}

  // Insumo del stock (opcional)
  var stockPid = parseInt((document.getElementById('aceite-stock-product')||{}).value)||0;
  var stockQty = parseFloat((document.getElementById('aceite-stock-qty')||{}).value)||0;
  var stockInfo = null;
  if (stockPid && stockQty > 0) {
    var prod = (db.products||[]).find(function(p){ return p.id == stockPid; });
    if (!prod) { toast('Producto no encontrado','error'); return; }
    if (stockQty > prod.stock_qty) {
      toast('⚠ Stock insuficiente de ' + prod.name + ': disponible ' + prod.stock_qty + ' ' + prod.unit, 'error');
      return;
    }
    stockInfo = { product_id: prod.id, product_name: prod.name, qty: stockQty, unit: prod.unit };
  } else if (stockPid && stockQty <= 0) {
    toast('Ingresa una cantidad o quitá el producto', 'error');
    return;
  }

  if(!db.aceite) db.aceite=[];
  if(!db.inventory_counts) db.inventory_counts=[];
  var rec = {id:Date.now(),fecha:fecha,vehiculo:vehiculo,kmhr:kmhr,tipo:tipo,costo:costo,obs:obs,by:'Desktop',created_at:new Date().toISOString()};
  if (stockInfo) {
    rec.stock_product_id = stockInfo.product_id;
    rec.stock_product = stockInfo.product_name;
    rec.stock_descontado = stockInfo.qty;
    rec.stock_unit = stockInfo.unit;
    var p = db.products.find(function(x){return x.id == stockInfo.product_id;});
    if (p) {
      p.stock_qty = Math.round((p.stock_qty - stockInfo.qty) * 100) / 100;
      replaceTableInRailway('vet_products', db.products || []);
    }
  }
  db.aceite.push(rec);
  saveDB();
  replaceTableInRailway('aceite', db.aceite || []);
  closeModal('modal-aceite');
  renderDieselDesktop();
  if (typeof renderStock === 'function' && stockInfo) renderStock();
  toast(stockInfo ? 'Cambio de aceite registrado y stock descontado' : 'Cambio de aceite registrado','success');
  try { auditLog('create', 'aceite', rec.id, _summarizeRecord('aceite', rec)); } catch(e){}
}
