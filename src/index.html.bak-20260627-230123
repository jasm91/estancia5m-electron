function saveAnimal(){
  var modal=document.getElementById("modal-animal");
  var lotCode=(modal&&modal._lotCode)?modal._lotCode:((document.getElementById("animales-lot-filter")||{}).value||"");
  var id=((document.getElementById("animal-id")||{}).value||"").trim();
  var peso=parseFloat((document.getElementById("animal-peso")||{}).value||"0");
  var fecha=((document.getElementById("animal-pesaje-date")||{}).value||"");
  if(!id){toast("Selecciona un animal","error");return;}
  if(!peso||!fecha){toast("Completa peso y fecha","error");return;}
  var all=getAnimalesDB();
  var animals=all[lotCode]||[];
  var animal=animals.find(function(a){return a.id===id;});
  if(!animal){toast("Animal no encontrado","error");return;}
  // Agregar pesaje al animal existente
  animal.pesajes=animal.pesajes||[];
  var exists=animal.pesajes.find(function(p){return p.fecha===fecha;});
  if(exists){exists.peso=peso;}else{animal.pesajes.push({fecha:fecha,peso:peso});}
  animal.pesajes.sort(function(a,b){return a.fecha.localeCompare(b.fecha);});
  // Actualizar avg_weight del lote
  var lot=(db.lots||[]).find(function(l){return l.code===lotCode;});
  if(lot&&animals.length){
    var ws=animals.map(function(a){return a.pesajes&&a.pesajes.length?a.pesajes[a.pesajes.length-1].peso:0;});
    lot.avg_weight=Math.round(ws.reduce(function(s,w){return s+w;},0)/ws.length*10)/10;
