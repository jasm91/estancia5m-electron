function updateContCuentaFilter() {
  var params = getParams();
  var tipoSel = (document.getElementById('cont-f-tipo-gasto')||{}).value || '';
  var cSel = document.getElementById('cont-f-cuenta');
  if (!cSel) return;
  var cur = cSel.value;
  cSel.innerHTML = '<option value="">Todas las cuentas</option>';
  var seen = {};
  (params.cuentas||[]).filter(function(c){ return !tipoSel || c.tipo_gasto === tipoSel; }).forEach(function(c){
    if (seen[c.name]) return;
    seen[c.name] = true;
    var o = document.createElement('option'); o.value = c.name; o.textContent = c.name;
    cSel.appendChild(o);
  });
