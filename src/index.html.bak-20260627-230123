function getParams() {
  var defaults = (typeof PARAM_DEFAULTS !== 'undefined') ? PARAM_DEFAULTS : {potreros:[],categorias:[],razas:[],actividades:[],cuentas:[],subcuentas:[],tipos_gasto:[]};
  var saved = lsGetParamsJSON('e5m_params');
  if (!saved) {
    lsSetParamsJSON('e5m_params', defaults);
    return defaults;
  }
  var changed = false;
  Object.keys(defaults).forEach(function(k){ 
    if(!saved[k] || (Array.isArray(saved[k]) && !saved[k].length)) {
      saved[k]=defaults[k];
      changed = true;
    }
  });
  // Migración: asegurar que existe la subcuenta "Venta de Carne (Baja)" para diferenciar
  // ventas normales de ventas de carne post-baja.
  if (Array.isArray(saved.subcuentas)) {
    var hasCarneBaja = saved.subcuentas.some(function(s){
      return s && (s.name === 'Venta de Carne (Baja)' || (s.name||'').toLowerCase() === 'venta carne (baja)');
    });
    if (!hasCarneBaja) {
      saved.subcuentas.push({ name: 'Venta de Carne (Baja)', cuenta: 'INGRESOS', cuenta_tipo: 'VARIABLE' });
      changed = true;
      console.log('[Params] Migration: added subcuenta "Venta de Carne (Baja)"');
    }
    // Migración: asegurar que existe la subcuenta "Merma" para mermas de inventario y combustible
    var hasMerma = saved.subcuentas.some(function(s){
      return s && (s.name === 'Merma' || (s.name||'').toLowerCase() === 'merma');
    });
    if (!hasMerma) {
      saved.subcuentas.push({ name: 'Merma', cuenta: 'COSTOS' });
      changed = true;
      console.log('[Params] Migration: added subcuenta "Merma"');
    }
  }
  if (changed) {
    lsSetParamsJSON('e5m_params', saved);
    console.log('[Params] New keys added from defaults:', Object.keys(defaults).filter(function(k){ return !lsGetParamsJSON('e5m_params') || true; }).join(', '));
  }
  return saved;
}
function lsGetParamsJSON(k){ try{var v=localStorage.getItem(k);return v?JSON.parse(v):null;}catch(e){return null;} }
function lsSetParamsJSON(k,v){ try{localStorage.setItem(k,JSON.stringify(v));}catch(e){} }

// Resuelve el tipo_gasto correcto para una subcuenta, manejando el caso de cuentas con
// el mismo nombre pero distinto tipo_gasto. Las subcuentas nuevas guardan cuenta_tipo
// directamente; las legacy caen al find() y toman la primera coincidencia.
function resolveCuentaTipoGasto(params, subObj, fallback) {
  if (!subObj) return fallback || 'VARIABLE';
  if (subObj.cuenta_tipo) return subObj.cuenta_tipo;
  var cu = (params.cuentas || []).find(function(c){ return c.name === subObj.cuenta; });
  return cu ? cu.tipo_gasto : (fallback || 'VARIABLE');
}
function saveParams(params){
  // FIX v1.4.33: setear updated_at para que el merge en pull use last-write-wins.
  // Antes el merge usaba "local source of truth", lo que permitía que defaults autogenerados
  // pisaran los reales del server. Ahora server gana si su timestamp es más nuevo.
  params.updated_at = new Date().toISOString();
  lsSetParamsJSON('e5m_params', params);
  // Push to Railway immediately so PWA/Bot get the update
  replaceTableInRailway('estancia_params', params);
  console.log('[Params] Saved locally + pushed to Railway (updated_at=' + params.updated_at + ')');
  // Re-renderizar reportes que dependen del catálogo de cuentas/subcuentas (resolución dinámica)
  if (typeof renderContabilidad === 'function') { try { renderContabilidad(); } catch(e){} }
  if (typeof renderReporteCREA === 'function') { try { renderReporteCREA(); } catch(e){} }
}

function getPotreroCapacity(paddockName) {
  if (!paddockName) return 0;
  var params = getParams();
  var potrero = (params.potreros||[]).find(function(p){ return (p.name||'').toLowerCase() === (paddockName||'').toLowerCase(); });
  return potrero ? (potrero.capacity || 0) : 0;
}

function checkPotreroCapacity(lotCode, addCount) {
  addCount = addCount || 1;
  var lot = (db.lots||[]).find(function(l){ return l.code === lotCode; });
  if (!lot || !lot.paddock) return { ok: true };
  var cap = getPotreroCapacity(lot.paddock);
  if (!cap) return { ok: true };
  var current = lot.animal_count || 0;
  if ((current + addCount) > cap) {
    return { ok: false, msg: 'Potrero "' + lot.paddock + '" lleno: ' + current + '/' + cap + ' cab. No caben ' + addCount + ' más.' };
  }
  return { ok: true };
}

function renderParams() {
  var params = getParams();
  var keys = {potreros:'potreros', categorias:'categorias', razas:'razas', actividades:'actividades', tipos_gasto:'tipos_gasto'};
  Object.keys(keys).forEach(function(key) {
    var el = document.getElementById('params-'+key+'-list');
    if (!el) return;
    el.innerHTML = '';
    if (!params[key] || !params[key].length) {
      el.innerHTML = '<div style="padding:12px;color:var(--muted);font-size:12px">Sin elementos. Agrega uno.</div>';
      return;
    }
    params[key].forEach(function(item, idx) {
      var row = document.createElement('div');
      row.style.cssText = 'display:flex;align-items:center;justify-content:space-between;padding:9px 14px;border-bottom:1px solid rgba(48,54,61,.3);font-size:13px';
      var left = document.createElement('div');
      left.style.flex='1';
      left.textContent = item.name;
      if (key==='potreros') {
        var extraInfo = [];
        if (item.capacity) extraInfo.push(item.capacity + ' cab');
        if (item.hectares) extraInfo.push(item.hectares + ' ha');
        if (item.grass_type) extraInfo.push(item.grass_type);
        if (item.max_occupation_days) extraInfo.push('Ocup: ' + item.max_occupation_days + 'd');
        if (item.rest_days) extraInfo.push('Desc: ' + item.rest_days + 'd');
        if (extraInfo.length) {
        var cap = document.createElement('span');
        cap.style.cssText='font-size:10px;color:var(--muted);margin-left:8px';
        var curInP = (db.lots||[]).filter(function(l){return (l.paddock||'').toLowerCase()===(item.name||'').toLowerCase();}).reduce(function(s,l){return s+(l.animal_count||0);},0);
        cap.textContent = (item.capacity ? curInP+'/'+item.capacity+' cab' : '') + (extraInfo.length > 1 ? ' · '+extraInfo.slice(1).join(' · ') : '');
        if (item.capacity && curInP >= item.capacity) cap.style.color = 'var(--red)';
        left.appendChild(cap);
      }
      }
      var btns = document.createElement('div');
      btns.style.cssText='display:flex;gap:4px';
      var edit = document.createElement('button');
      edit.className='btn btn-ghost btn-sm'; edit.style.cssText='color:var(--blue);font-size:11px'; edit.textContent='✎';
      edit.onclick=(function(k2,i){ return function(){ editParam(k2,i); }; })(key,idx);
      var del = document.createElement('button');
      del.className='btn btn-ghost btn-sm'; del.style.color='var(--red)'; del.textContent='✕';
      del.onclick=(function(k2,i){ return function(){ deleteParam(k2,i); }; })(key,idx);
      btns.appendChild(edit); btns.appendChild(del);
      row.appendChild(left); row.appendChild(btns);
      el.appendChild(row);
    });
  });
  // Update selects in modals
  updateParamSelects();
  // Render cuentas grouped by tipo_gasto
  renderCuentas();
  // Render subcuentas grouped by cuenta
  renderSubcuentas();
  // Populate cuenta dropdown in subcuenta add form
  // Como puede haber cuentas con el mismo nombre pero distinto tipo_gasto (ej. COSTOS-FIJO y COSTOS-VARIABLE),
  // mostramos "NOMBRE (TIPO)" y usamos value compuesto JSON para no perder la asociación.
  var cuentaSel = document.getElementById('param-sub-cuenta');
  if (cuentaSel) {
    cuentaSel.innerHTML = '<option value="">Cuenta padre...</option>';
    var _seenSubKey = {};
    (params.cuentas||[]).forEach(function(c){
      if (!c.name) return;
      var tipo = c.tipo_gasto || '';
      var key = c.name + '|' + tipo;
      if (_seenSubKey[key]) return;
      _seenSubKey[key] = true;
      var o = document.createElement('option');
      o.value = JSON.stringify({n:c.name, t:tipo});
      o.textContent = c.name + (tipo ? ' (' + tipo + ')' : '');
      cuentaSel.appendChild(o);
    });
  }
  // Update SUBCUENTAS_DEFAULT when params change
  SUBCUENTAS_DEFAULT = getSubcuentasMap();
}

