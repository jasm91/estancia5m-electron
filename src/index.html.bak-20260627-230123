// v1.8.55: cálculo de días trabajados en un mes para prorrateo de sueldo.
// mes = 'YYYY-MM'. Considera ingreso y baja del empleado contra los días reales del mes.
function diasTrabajadosEnMes(emp, mes){
  if(!mes || !/^\d{4}-\d{2}$/.test(mes)) return null;
  var y = parseInt(mes.slice(0,4),10), m = parseInt(mes.slice(5,7),10);
  var inicioMes = new Date(y, m-1, 1);
  var finMes = new Date(y, m, 0);                 // último día del mes (28/29/30/31)
  var diasMes = finMes.getDate();
  // Parsear fechas del empleado (YYYY-MM-DD) como fecha local
  function pd(s){ if(!s) return null; var p=String(s).slice(0,10).split('-'); if(p.length<3) return null; return new Date(+p[0],+p[1]-1,+p[2]); }
  var ingreso = pd(emp.hire_date);
  var baja = pd(emp.term_date);
  // Rango efectivo trabajado dentro del mes
  var desde = inicioMes, hasta = finMes;
  if(ingreso && ingreso > desde) desde = ingreso;
  if(baja && baja < hasta) hasta = baja;
  // Si el empleado no estuvo activo ningún día de este mes
  if((ingreso && ingreso > finMes) || (baja && baja < inicioMes) || desde > hasta){
    return { dias:0, diasMes:diasMes, completo:false, parcial:true };
  }
  var dias = Math.round((hasta - desde)/86400000) + 1; // inclusivo ambos extremos
  if(dias < 0) dias = 0;
  if(dias > diasMes) dias = diasMes;
  var completo = (dias === diasMes);
  return { dias:dias, diasMes:diasMes, completo:completo, parcial:!completo };
}

function renderPsEmpleados() {
  var tbody=document.getElementById('ps-empleados-tbody');
  if(!tbody)return;
  var mes=(document.getElementById('ps-mes')||{}).value||'';
  // v1.8.55: incluir activos + empleados dados de baja DENTRO del mes que se paga
  // (para poder pagarles el último mes prorrateado)
  var emps=(db.employees||[]).filter(function(e){
    if(e.active!==false) return true;
    // inactivo: incluir solo si su baja cae en este mes (tiene días que pagar)
    if(e.term_date && mes && String(e.term_date).slice(0,7)===mes) return true;
    return false;
  });
  if(!emps.length){
    tbody.innerHTML='<tr><td colspan="7" style="text-align:center;padding:20px;color:var(--muted)">No hay empleados activos</td></tr>';
    return;
  }
  tbody.innerHTML='';
  emps.forEach(function(emp){
    // ¿Ya tiene pago registrado para este mes?
    var existing=(db.historial_sueldos||[]).find(function(r){return r.empleado===emp.name&&r.mes===mes;});
    var yaPagado=!!existing&&existing.estado==='pagado';
    // Calcular adelantos del mes
    var totalAdv=(db.advances||[]).filter(function(a){return a.employee===emp.name&&(a.date||'').startsWith(mes)&&a.status==='descontado';}).reduce(function(s,a){return s+(a.amount||0);},0);
    var salario=emp.salary||0;
    // v1.8.55: prorrateo por días reales del mes (ingreso / baja a mitad de mes)
    var prr=diasTrabajadosEnMes(emp, mes);
    var dias = prr ? prr.dias : 30;
    var diasMes = prr ? prr.diasMes : 30;
    var parcial = prr ? prr.parcial : false;
    var salarioBase = salario; // salario mensual completo (referencia)
    var salarioProrr = diasMes>0 ? Math.round((salario/diasMes)*dias) : salario;
    // v1.8.57: deuda arrastrada de meses anteriores (saldo en contra del trabajador)
    var deudaPrevia = parseFloat(emp.deuda_arrastrada) || 0;
    // balance = salario prorrateado − deuda previa − adelantos del mes
    var balance = salarioProrr - deudaPrevia - totalAdv;
    var neto = Math.max(0, balance);
    var deudaResultante = balance < 0 ? Math.abs(balance) : 0;  // lo que sigue debiendo → se arrastra
    var rowId='ps-row-'+emp.name.replace(/[^a-zA-Z0-9]/g,'_');
    var tr=document.createElement('tr');
    tr.id=rowId;
    tr.style.cssText='border-bottom:1px solid rgba(48,54,61,.3)' + (yaPagado?';opacity:.55':'');
    tr.dataset.empName=emp.name;
    tr.dataset.salarioBase=salarioBase;
    tr.dataset.diasMes=diasMes;
    tr.dataset.dias=dias;
    tr.dataset.salario=salarioProrr;
    tr.dataset.adelantos=totalAdv;
    tr.dataset.neto=neto;
    tr.dataset.deudaPrevia=deudaPrevia;
    tr.dataset.deudaResultante=deudaResultante;
    tr.dataset.yaPagado=yaPagado?'1':'0';
    var checkHtml=yaPagado
      ? '<input type="checkbox" disabled title="Ya pagado">'
      : '<input type="checkbox" class="ps-emp-check" onchange="updatePsTotal()">';
    var estadoBadge=yaPagado
      ? '<span style="background:rgba(57,211,83,.12);color:var(--green);padding:3px 8px;border-radius:6px;font-size:10px;font-weight:600">Pagado</span>'
      : '<span style="background:rgba(212,160,23,.12);color:var(--amber2);padding:3px 8px;border-radius:6px;font-size:10px;font-weight:600">Pendiente</span>';
    // Campo días editable + badge "parcial" cuando no es mes completo
    var diasInput = yaPagado
      ? ('<span style="font-family:DM Mono,monospace">'+dias+'</span>')
      : ('<input type="number" min="0" max="'+diasMes+'" value="'+dias+'" class="ps-dias-input" oninput="recalcPsRow(this)" style="width:48px;padding:4px 6px;text-align:center;background:var(--sur2);border:1px solid var(--bor);border-radius:6px;color:var(--text);font-family:DM Mono,monospace">');
    var parcialBadge = parcial
      ? '<span title="Pago prorrateado (ingreso o baja a mitad de mes)" style="margin-left:6px;background:rgba(99,102,241,.15);color:#a5b4fc;padding:2px 6px;border-radius:5px;font-size:9px;font-weight:700">PRORRATEO</span>'
      : '';
    // v1.8.57: badge de deuda arrastrada de meses anteriores
    var deudaBadge = deudaPrevia>0
      ? '<span title="Deuda arrastrada de meses anteriores, se descuenta de este pago" style="margin-left:6px;background:rgba(248,81,73,.15);color:var(--red);padding:2px 6px;border-radius:5px;font-size:9px;font-weight:700">DEUDA Bs. '+deudaPrevia.toLocaleString()+'</span>'
      : '';
    tr.innerHTML='<td style="padding:8px;text-align:center">'+checkHtml+'</td>'+
      '<td style="padding:8px"><div style="font-weight:600">'+escH(emp.name)+parcialBadge+deudaBadge+'</div><div style="font-size:10px;color:var(--muted)">'+escH(roleLabel(emp.role||''))+'</div></td>'+
      '<td style="padding:8px;text-align:center">'+diasInput+'<div style="font-size:9px;color:var(--muted);margin-top:2px">de '+diasMes+'</div></td>'+
      '<td style="padding:8px;text-align:right;font-family:DM Mono,monospace" class="ps-salario-cell">Bs. '+salarioProrr.toLocaleString()+'<div style="font-size:9px;color:var(--muted)">base '+salarioBase.toLocaleString()+'</div></td>'+
      '<td style="padding:8px;text-align:right;font-family:DM Mono,monospace;color:'+(totalAdv>0?'var(--amber2)':'var(--muted)')+'">Bs. '+totalAdv.toLocaleString()+'</td>'+
      '<td style="padding:8px;text-align:right;font-family:DM Mono,monospace;color:var(--green);font-weight:700" class="ps-neto-cell">Bs. '+neto.toLocaleString()+'</td>'+
      '<td style="padding:8px;text-align:center">'+estadoBadge+'</td>';
    tbody.appendChild(tr);
  });
  updatePsTotal();
}

