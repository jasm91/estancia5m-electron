      detalle:'Diesel recarga — '+(d.proveedor||'')+(d.litros?' '+d.litros+' L':''),
      monto:d.total||0, origen:'auto', by:d.by||''
    });
  });

  // COSTOS: de sueldos pagados
  (db.historial_sueldos||[]).forEach(function(s) {
    if (!s.fecha_pago) return;
    derivados.push({
      id:'sueldo-'+s.id, cuenta:'COSTOS', subcuenta:'Personal', tipo_gasto:'FIJO',
      tipo:'FIJO', fecha:s.fecha_pago,
      detalle:'Sueldo '+s.empleado+' - '+s.mes,
      monto:s.pago_neto||0, origen:'auto', by:'Desktop'
    });
  });
  // v1.8.79: COSTOS de bonos/aguinaldos
  (db.bonos||[]).forEach(function(b) {
    if (!b.date) return;
    derivados.push({ id:'bono-'+b.id, cuenta:'COSTOS', subcuenta:'Personal', tipo_gasto:'FIJO', tipo:'VARIABLE', fecha:b.date, detalle:(b.tipo==='aguinaldo'?'Aguinaldo':b.tipo==='doble_aguinaldo'?'Doble aguinaldo':b.tipo==='beneficio'?'Beneficio social':'Bono')+' '+b.employee, monto:b.amount||0, origen:'auto', by:b.by||'Desktop' });
  });
  // v1.8.79: COSTOS de liquidaciones (bajas de personal)
  (db.bajas_personal||[]).forEach(function(bp) {
    if (!bp.term_date || !bp.monto_liquidacion) return;
    derivados.push({ id:'bajap-'+bp.id, cuenta:'COSTOS', subcuenta:'Personal', tipo_gasto:'FIJO', tipo:'VARIABLE', fecha:bp.term_date, detalle:'Liquidación '+bp.employee+' ('+bp.motivo+')', monto:bp.monto_liquidacion||0, origen:'auto', by:bp.by||'Desktop' });
  });

  // COSTOS: de mantenimiento (con costo)
  (db.maintenance||[]).forEach(function(m) {
    if (!m.date || !m.cost) return;
    derivados.push({
      id:'maint-'+m.id, cuenta:'COSTOS', subcuenta:m.category==='vehiculos'?'Mantenimiento Vehiculos':m.category==='tractor'?'Mantenimiento Tractor':'Mantenimiento Motor', tipo_gasto:'VARIABLE',
      tipo:'VARIABLE', fecha:m.date,
      detalle:'🔧 '+(m.desc||'Mantenimiento')+(m.equipo?' — '+m.equipo:'')+(m.location?' — '+m.location:'')+(m.who?' ('+m.who+')':''),
      monto:m.cost||0, origen:'auto', by:m.by||m.who||''
    });
  });

  // COSTOS: de adelantos al personal
  (db.advances||[]).forEach(function(a) {
    if (!a.date) return;
    derivados.push({
      id:'adv-'+a.id, cuenta:'COSTOS', subcuenta:'Personal', tipo_gasto:'FIJO',
      tipo:'VARIABLE', fecha:a.date,
      detalle:'Adelanto '+escH(a.employee||'')+(a.reason?' - '+a.reason:''),
      monto:a.amount||0, origen:'auto', by:a.by||''
    });
  });

  // COSTOS: de aceite/lubricantes
  (db.aceite||[]).forEach(function(a) {
    if (!a.fecha) return;
    derivados.push({
      id:'aceite-'+a.id, cuenta:'COSTOS', subcuenta:'Combustible', tipo_gasto:'FIJO',
      tipo:'VARIABLE', fecha:a.fecha,
      detalle:'Aceite/Lubricante - '+(a.tipo||'')+(a.equipo?' - '+a.equipo:''),
      monto:a.total||0, origen:'auto'
    });
  });

  // INVERSIONES: de compras de ganado (resolver tipo_gasto desde el catálogo de cuentas)
  var _paramsCG_R = (typeof getParams === 'function') ? getParams() : {};
  var _cuObjInv = (_paramsCG_R.cuentas || []).find(function(c){ return c.name === 'INVERSIÓN'; });
  var _tipoGastoInv = _cuObjInv ? _cuObjInv.tipo_gasto : 'VARIABLE';
  (db.compras_ganado||[]).forEach(function(c) {
    if (!c.fecha) return;
    derivados.push({
      id:'cg-'+c.id, cuenta:'INVERSIÓN', subcuenta:'Compra de Animales', tipo_gasto:_tipoGastoInv,
      tipo:_tipoGastoInv, fecha:c.fecha,
      detalle:(c.animal_count||0)+' animales de '+(c.proveedor||'')+ ' -> Lote '+(c.lot_code||''),
      monto:c.total||0, origen:'auto'
    });
  });

  // COSTOS: merma de diesel (ajustes de inventario con diferencia negativa)
  (db.diesel||[]).filter(function(d){ return d.type==='ajuste' && d.ajuste_direccion==='merma'; }).forEach(function(d) {
    if (!d.fecha) return;
    // Calcular costo: litros perdidos × precio promedio de recargas
    var recargas = (db.diesel||[]).filter(function(r){ return r.type==='recarga' && r.precio; });
    var precioPromL = recargas.length ? recargas.reduce(function(s,r){return s+(r.precio||0);},0) / recargas.length : 0;
    var costoMerma = Math.round((d.litros||0) * precioPromL * 100) / 100;
    derivados.push({
      id:'diesel-merma-'+d.id, cuenta:'COSTOS', subcuenta:'Merma', tipo_gasto:'VARIABLE',
      tipo:'VARIABLE', fecha:d.fecha,
      detalle:'🔻 Merma diesel: '+(d.litros||0)+' L ('+( d.merma_pct||0)+'%) — '+(d.motivo||''),
      monto:costoMerma, origen:'auto', by:d.by||''
    });
  });

  // COSTOS: merma de inventario (conteos físicos con faltantes en cualquier producto: sal, alimento, vet, etc.)
  (db.inventory_counts||[]).forEach(function(ic) {
    if (!ic.date || !ic.total_merma_bs) return;
    // Construir detalle con los productos afectados (top 5 por costo)
    var itemsConMerma = (ic.items || []).filter(function(it) { return (it.diferencia || 0) < 0; });
    itemsConMerma.sort(function(a, b) { return (b.costo_merma||0) - (a.costo_merma||0); });
    var top = itemsConMerma.slice(0, 5).map(function(it) {
      return it.product_name + ' (' + Math.abs(it.diferencia) + ' ' + (it.unit||'') + ')';
    }).join(', ');
    if (itemsConMerma.length > 5) top += ', +' + (itemsConMerma.length - 5) + ' más';
    derivados.push({
      id:'merma-inv-'+ic.id, cuenta:'COSTOS', subcuenta:'Merma', tipo_gasto:'VARIABLE',
      tipo:'VARIABLE', fecha:ic.date,
      detalle:'🔻 Merma inventario: ' + (top || ic.items_con_diferencia + ' productos') + ' — Bs. ' + Math.round(ic.total_merma_bs),
      monto:ic.total_merma_bs, origen:'auto', by:ic.by||''
    });
  });

  // Combinar derivados + manuales (db.cuentas), evitando duplicados por id
  var idsDerivados = {};
  derivados.forEach(function(r){ idsDerivados[r.id]=true; });
  var todos = derivados.concat((db.cuentas||[]).filter(function(r){
    if (idsDerivados[r.id]) return false;
    // Excluir registros redundantes de compras de animales en db.cuentas:
    // estos se derivan automáticamente desde db.compras_ganado (ver bloque de arriba).
    // Los registros aquí son legacy (versiones anteriores los duplicaban) o espejos accidentales.
    var sub = String(r.subcuenta || '').trim();
    if (sub === 'Compra de Animales' || sub === 'Compra de ganado') return false;
    return true;
  }));

  // Normalizar nombres legacy
  var cuentaNorm = {'INVERSIONES':'INVERSIÓN','GASTOS':'GASTO ADMINISTRATIVO'};
  var subNorm = {'Compra de ganado':'Compra de Animales','Sueldos':'Personal','Adelantos personal':'Personal','Sanidad veterinaria':'Sanidad','Mantenimiento maquinaria':'Mantenimiento Vehiculos','Merma combustible':'Merma','Merma stock veterinario':'Merma','Venta ganado':'Venta de Ganado','Venta carne (baja)':'Venta de Carne (Baja)','Sal mineral':'Sal'};
  var validTipos = {'FIJO':1,'VARIABLE':1,'CAPITAL':1,'OPERATIVO':1,'EXTRAORDINARIA':1,'ACTIVO NO CORRIENTE':1};
  var _paramsContab = getParams();

  // Helper: normalizar string (lowercase, sin acentos, sin espacios extras)
  function _normN(s) {
    return String(s||'').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'').replace(/\s+/g,' ').trim();
  }

  // Index de cuentas: name normalizado → array de objetos cuenta (puede haber duplicados con tipo distinto)
  // También cuentaByNameType: clave compuesta name|tipo para lookup exacto
  var _cuentasByName = {};
  var _cuentasByNameType = {};
  (_paramsContab.cuentas || []).forEach(function(c){
    if (!c || !c.name) return;
    var nk = _normN(c.name);
    if (!_cuentasByName[nk]) _cuentasByName[nk] = [];
    _cuentasByName[nk].push(c);
    if (c.tipo_gasto) _cuentasByNameType[nk + '|' + _normN(c.tipo_gasto)] = c;
  });

  var _subIndex = {};
  (_paramsContab.subcuentas || []).forEach(function(s){
    if (!s || !s.name) return;
    var k = _normN(s.name);
    if (!_subIndex[k]) _subIndex[k] = [];
    _subIndex[k].push(s);
  });

  // Diagnóstico: detectar registros que no se pueden resolver con el catálogo actual
  var _diag = { resolved: 0, subOrphan: [], cuentaOrphan: [] };

  todos.forEach(function(r) {
    // 1) Normalizar nombres legacy (renombres de versiones viejas)
    if (cuentaNorm[r.cuenta]) r.cuenta = cuentaNorm[r.cuenta];
    if (subNorm[r.subcuenta]) r.subcuenta = subNorm[r.subcuenta];

    var subKey = _normN(r.subcuenta);
    var subMatches = subKey ? (_subIndex[subKey] || []) : [];

    if (subMatches.length) {
      // Desambiguar si hay varios matches por subcuenta name
      var pickedSub = null;
      if (subMatches.length === 1) {
        pickedSub = subMatches[0];
      } else {
        var rTipo = _normN(r.tipo_gasto || r.tipo || '');
        var rCuenta = _normN(r.cuenta || '');
        pickedSub = subMatches.find(function(s){ return _normN(s.cuenta) === rCuenta && _normN(s.cuenta_tipo||'') === rTipo; });
        if (!pickedSub) pickedSub = subMatches.find(function(s){ return _normN(s.cuenta) === rCuenta; });
        if (!pickedSub) pickedSub = subMatches[0];
      }
      if (pickedSub.cuenta) r.cuenta = pickedSub.cuenta;

      // Resolver tipo_gasto desde el catálogo de cuentas (DINÁMICO).
      // Si la subcuenta tiene cuenta_tipo definido, buscar cuenta específica por (name, tipo).
      // Sino, tomar la única cuenta con ese nombre, o la primera si hay duplicados.
      var cuKey = _normN(r.cuenta);
      var cuList = _cuentasByName[cuKey] || [];
      var cuObj = null;
      if (pickedSub.cuenta_tipo) {
        cuObj = _cuentasByNameType[cuKey + '|' + _normN(pickedSub.cuenta_tipo)];
      }
      if (!cuObj && cuList.length === 1) cuObj = cuList[0];
      if (!cuObj && cuList.length > 1) {
        // Múltiples cuentas con ese nombre y subcuenta sin cuenta_tipo: preferir la que matchea el tipo guardado en el registro
        var rTipo2 = _normN(r.tipo_gasto || r.tipo || '');
        cuObj = cuList.find(function(c){ return _normN(c.tipo_gasto) === rTipo2; }) || cuList[0];
      }
      if (cuObj && validTipos[cuObj.tipo_gasto]) {
        r.tipo_gasto = cuObj.tipo_gasto;
        _diag.resolved++;
      } else if (pickedSub.cuenta_tipo && validTipos[pickedSub.cuenta_tipo]) {
        r.tipo_gasto = pickedSub.cuenta_tipo;
        _diag.resolved++;
      } else {
        if (_diag.cuentaOrphan.indexOf(r.cuenta) < 0) _diag.cuentaOrphan.push(r.cuenta);
      }
    } else {
      // Subcuenta no está en el catálogo
      if (r.subcuenta && _diag.subOrphan.indexOf(r.subcuenta) < 0) _diag.subOrphan.push(r.subcuenta);
      var cuKey2 = _normN(r.cuenta);
      var cuList2 = _cuentasByName[cuKey2] || [];
      var cuObj2 = cuList2.length === 1 ? cuList2[0] : (cuList2.length > 1 ? (cuList2.find(function(c){ return _normN(c.tipo_gasto) === _normN(r.tipo_gasto || r.tipo || ''); }) || cuList2[0]) : null);
      if (cuObj2 && validTipos[cuObj2.tipo_gasto]) {
        r.tipo_gasto = cuObj2.tipo_gasto;
      } else {
        var current = String(r.tipo_gasto || r.tipo || '').toUpperCase().trim();
        r.tipo_gasto = validTipos[current] ? current : 'VARIABLE';
        if (r.cuenta && _diag.cuentaOrphan.indexOf(r.cuenta) < 0) _diag.cuentaOrphan.push(r.cuenta);
      }
    }
  });

  // Diagnóstico en consola (útil cuando el reporte no refleja cambios esperados)
  console.log('[Contabilidad] Resolución dinámica:', {
    totalRegistros: todos.length,
    resueltosViaSubcuenta: _diag.resolved,
    subcuentasHuerfanas: _diag.subOrphan,
    cuentasHuerfanas: _diag.cuentaOrphan,
    catalogoCuentas: (_paramsContab.cuentas||[]).length,
    catalogoSubcuentas: (_paramsContab.subcuentas||[]).length
  });
  // Guardar para inspección desde la consola
  window._contabDiag = _diag;

  var registros = todos.filter(function(r) {
    var fecha = r.fecha || '';
    if (selDesde && fecha < selDesde) return false;
    if (selHasta && fecha > selHasta) return false;
    if (selTipoGasto && (r.tipo_gasto||r.tipo||'') !== selTipoGasto) return false;
    if (selCuenta && r.cuenta !== selCuenta) return false;
    if (selSubcuenta && r.subcuenta !== selSubcuenta) return false;
    return true;
  });

  // Totales por cuenta
  var totales = {};
  ['COSTOS','INGRESOS','INVERSIÓN','GASTO ADMINISTRATIVO'].forEach(function(c){ totales[c]=0; });
  registros.forEach(function(r){ 
    var c = r.cuenta || '';
    if (totales[c]===undefined) totales[c]=0;
    totales[c]+=(parseFloat(r.monto)||0);
  });

  var totalEgresos = (totales['COSTOS']||0) + (totales['GASTO ADMINISTRATIVO']||0) + (totales['INVERSIÓN']||0);
  var totalIngresos = totales['INGRESOS']||0;
  var resultado = totalIngresos - totalEgresos;

  var periodoLabel = selDesde && selHasta ? selDesde + ' al ' + selHasta : selDesde ? 'Desde ' + selDesde : selHasta ? 'Hasta ' + selHasta : 'Todos';
  var subEl = document.getElementById('cont-sub');
  if (subEl) subEl.textContent = periodoLabel+' · '+registros.length+' movimientos';

  // Cards resumen
  var resEl = document.getElementById('cont-resumen');
  if (resEl) {
    var cuentaColors = {COSTOS:'var(--amber2)',INGRESOS:'var(--green)',GASTOS:'var(--red)',INVERSIONES:'var(--blue)'};
    var cardsData = [
      {label:'INGRESOS',val:totales['INGRESOS']||0,color:'var(--green)'},
      {label:'COSTOS',val:totales['COSTOS']||0,color:'var(--amber2)'},
      {label:'INVERSIÓN',val:totales['INVERSIÓN']||0,color:'var(--blue)'},
      {label:'GASTO ADM.',val:totales['GASTO ADMINISTRATIVO']||0,color:'var(--red)'},
      {label:'RESULTADO',val:resultado,color:resultado>=0?'var(--green)':'var(--red)'},
    ];
    resEl.innerHTML = cardsData.map(function(c){
      return '<div style="background:var(--sur);border:1px solid var(--bor);border-radius:10px;padding:12px 16px">'+
        '<div style="font-size:10px;color:var(--muted);font-weight:700;margin-bottom:4px">'+c.label+'</div>'+
        '<div style="font-size:20px;font-weight:700;color:'+c.color+'">'+(c.val<0?'-':'')+' Bs. '+Math.abs(c.val).toLocaleString()+'</div>'+
      '</div>';
    }).join('');
  }

  // Desglose por subcuenta — DOS COLUMNAS: Ingresos | Egresos
  var desEl = document.getElementById('cont-desglose');
  if (desEl) {
    var tipoColors = {'FIJO':'var(--blue)','VARIABLE':'var(--green)','CAPITAL':'var(--amber2)','OPERATIVO':'#A371F7','EXTRAORDINARIA':'var(--red)','ACTIVO NO CORRIENTE':'#8B949E'};
    var cuentaColors2 = {'COSTOS':'var(--amber2)','INGRESOS':'var(--green)','INVERSIÓN':'var(--blue)','GASTO ADMINISTRATIVO':'var(--red)'};

    // Construir dos árboles: ingresos y egresos
    function buildTree(filterFn) {
      var tree = {};
      registros.filter(filterFn).forEach(function(r) {
        var tg = r.tipo_gasto || r.tipo || 'SIN TIPO';
        var cu = r.cuenta || 'SIN CUENTA';
        var su = r.subcuenta || 'Sin subcuenta';
        if (!tree[tg]) tree[tg] = {};
        if (!tree[tg][cu]) tree[tg][cu] = {};
        if (!tree[tg][cu][su]) tree[tg][cu][su] = 0;
        tree[tg][cu][su] += (parseFloat(r.monto)||0);
      });
      return tree;
    }
    var ingresosTree = buildTree(function(r){ return (r.cuenta||'') === 'INGRESOS'; });
    var egresosTree  = buildTree(function(r){ return (r.cuenta||'') !== 'INGRESOS'; });

    function totalOfTree(tree) {
      var sum = 0;
      Object.keys(tree).forEach(function(t){
        Object.keys(tree[t]).forEach(function(cu){
          Object.values(tree[t][cu]).forEach(function(v){ sum += v; });
        });
      });
      return sum;
    }
    var totalIngresos = totalOfTree(ingresosTree);
    var totalEgresos = totalOfTree(egresosTree);
    var balance = totalIngresos - totalEgresos;

    function renderTree(tree, treeTotal) {
      if (!Object.keys(tree).length) {
        return '<div style="padding:24px 12px;color:var(--muted);font-size:12px;text-align:center">Sin movimientos</div>';
      }
      var rows = '';
      Object.keys(tree).sort().forEach(function(tipo) {
        var tipoTotal = 0;
        Object.keys(tree[tipo]).forEach(function(cu){ Object.values(tree[tipo][cu]).forEach(function(v){tipoTotal+=v;}); });
        var tipoPct = treeTotal ? Math.round(tipoTotal/treeTotal*100) : 0;
        rows += '<tr style="background:var(--sur2)"><td colspan="3" style="font-weight:700;padding:7px 10px;font-size:12px;color:'+(tipoColors[tipo]||'var(--muted)')+'">🏷️ '+escH(tipo)+'</td><td style="font-weight:700;text-align:right;font-family:DM Mono,monospace;padding:7px 10px;font-size:12px;white-space:nowrap">Bs. '+tipoTotal.toLocaleString()+' <span style="font-size:9px;color:var(--muted)">('+tipoPct+'%)</span></td></tr>';
        Object.keys(tree[tipo]).sort().forEach(function(cuenta) {
          var cuentaTotal = Object.values(tree[tipo][cuenta]).reduce(function(s,v){return s+v;},0);
          rows += '<tr><td colspan="3" style="padding-left:14px;font-weight:600;padding-top:5px;padding-bottom:2px;font-size:11px;color:'+(cuentaColors2[cuenta]||'var(--muted)')+'">📒 '+escH(cuenta)+'</td><td style="text-align:right;font-family:DM Mono,monospace;font-weight:600;font-size:11px;color:'+(cuentaColors2[cuenta]||'var(--muted)')+';white-space:nowrap">Bs. '+cuentaTotal.toLocaleString()+'</td></tr>';
          Object.keys(tree[tipo][cuenta]).sort().forEach(function(sub) {
            var subVal = tree[tipo][cuenta][sub];
            var subPct = cuentaTotal ? Math.round(subVal/cuentaTotal*100) : 0;
            rows += '<tr><td style="padding-left:30px;color:var(--muted);font-size:11px">'+escH(sub)+'</td>'+
              '<td style="font-family:DM Mono,monospace;font-size:11px;white-space:nowrap">Bs. '+subVal.toLocaleString()+'</td>'+
              '<td style="min-width:50px"><div style="background:var(--sur2);border-radius:4px;height:5px;width:100%;overflow:hidden"><div style="background:'+(tipoColors[tipo]||'var(--blue)')+';height:100%;width:'+subPct+'%"></div></div></td>'+
              '<td style="text-align:right;font-size:10px;color:var(--muted)">'+subPct+'%</td></tr>';
          });
        });
      });
      return '<table style="width:100%;border-collapse:collapse">'+rows+'</table>';
    }

    var balanceColor = balance >= 0 ? 'var(--green)' : 'var(--red)';
    var balanceLabel = balance >= 0 ? 'Resultado positivo' : 'Resultado negativo';

    var html = '<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(360px,1fr));gap:16px;margin-bottom:14px">';

    // Columna INGRESOS
    html += '<div style="background:var(--sur);border:1px solid var(--bor);border-radius:10px;overflow:hidden">';
    html += '<div style="padding:10px 14px;background:rgba(63,185,80,.08);border-bottom:1px solid var(--bor);display:flex;justify-content:space-between;align-items:center">';
    html += '<div style="font-size:13px;font-weight:700;color:var(--green);text-transform:uppercase;letter-spacing:.5px">📥 INGRESOS</div>';
    html += '<div style="font-family:DM Mono,monospace;font-weight:700;color:var(--green);font-size:14px">Bs. '+Math.round(totalIngresos).toLocaleString()+'</div>';
    html += '</div>';
    html += '<div style="overflow-x:auto">'+renderTree(ingresosTree, totalIngresos)+'</div>';
    html += '</div>';

    // Columna EGRESOS
    html += '<div style="background:var(--sur);border:1px solid var(--bor);border-radius:10px;overflow:hidden">';
    html += '<div style="padding:10px 14px;background:rgba(248,81,73,.08);border-bottom:1px solid var(--bor);display:flex;justify-content:space-between;align-items:center">';
    html += '<div style="font-size:13px;font-weight:700;color:var(--red);text-transform:uppercase;letter-spacing:.5px">📤 EGRESOS</div>';
    html += '<div style="font-family:DM Mono,monospace;font-weight:700;color:var(--red);font-size:14px">Bs. '+Math.round(totalEgresos).toLocaleString()+'</div>';
    html += '</div>';
    html += '<div style="overflow-x:auto">'+renderTree(egresosTree, totalEgresos)+'</div>';
    html += '</div>';

    html += '</div>';

    // Resumen / balance
    html += '<div style="display:flex;justify-content:space-between;align-items:center;padding:12px 16px;background:var(--sur2);border:1px solid var(--bor);border-radius:8px">';
    html += '<div style="font-size:12px;color:var(--muted);font-weight:600;text-transform:uppercase;letter-spacing:.5px">⚖️ '+balanceLabel+'</div>';
    html += '<div style="font-family:DM Mono,monospace;font-weight:700;font-size:16px;color:'+balanceColor+'">Bs. '+Math.round(balance).toLocaleString()+'</div>';
    html += '</div>';

    desEl.innerHTML = html;
  }

  // Exponer registros para que exportContabilidadPDF acceda
  window._contabRegistros = registros;

  // === RESUMEN JERÁRQUICO (A) + TARJETAS POR SUBCUENTA (B) ===
  var jerar = document.getElementById('cont-jerarquia');
  var tarj  = document.getElementById('cont-tarjetas');
  var badge = document.getElementById('cont-total-badge');
  var totalGeneral = registros.reduce(function(s,r){return s+(parseFloat(r.monto)||0);},0);
  if (badge) badge.textContent = 'Total: Bs. '+ totalGeneral.toLocaleString();

  // Hidden tbody (legacy compat) — sin uso visual
  var tbody = document.getElementById('cont-tbody');
  if (tbody) tbody.innerHTML = '';

  if (!jerar || !tarj) return;

  if (!registros.length) {
    jerar.innerHTML = '<div style="padding:24px;text-align:center;color:var(--muted);font-size:12px">Sin movimientos en este periodo.</div>';
    tarj.innerHTML  = '<div style="padding:24px;text-align:center;color:var(--muted);font-size:12px">Las ventas, compras, diesel y sueldos se importan automáticamente.</div>';
    return;
  }

  // Construir árbol: tipo_gasto → cuenta → subcuenta → registros[]
  var tree = {};
  registros.forEach(function(r){
    var tg = r.tipo_gasto || r.tipo || 'SIN TIPO';
    var cu = r.cuenta || 'SIN CUENTA';
    var su = r.subcuenta || 'Sin subcuenta';
    if (!tree[tg]) tree[tg] = {};
    if (!tree[tg][cu]) tree[tg][cu] = {};
    if (!tree[tg][cu][su]) tree[tg][cu][su] = [];
    tree[tg][cu][su].push(r);
  });

  var tipoColors = {'FIJO':'var(--blue)','VARIABLE':'var(--green)','CAPITAL':'var(--amber2)','OPERATIVO':'#A371F7','EXTRAORDINARIA':'var(--red)','ACTIVO NO CORRIENTE':'#8B949E'};
  // v1.8.39: RGB de cada tipo para generar fondos/bordes con transparencia (mejora estética del árbol)
  var tipoRGB = {'FIJO':'88,166,255','VARIABLE':'63,185,80','CAPITAL':'240,192,64','OPERATIVO':'163,113,247','EXTRAORDINARIA':'248,81,73','ACTIVO NO CORRIENTE':'139,148,150'};
  var cuentaColors = {'COSTOS':'var(--amber2)','INGRESOS':'var(--green)','INVERSIÓN':'var(--blue)','GASTO ADMINISTRATIVO':'var(--red)'};
  var subIcons = {'Sanidad':'💊','Sal':'🧂','Personal':'👷','Combustible':'⛽','Implementos de Caballeria':'🐎','Viveres':'🍽️','Servicios':'🔧','Compra de Animales':'🐄','Venta de Ganado':'🐮','Venta de Carne (Baja)':'🥩','Mantenimiento Motor':'🔩','Aceite':'🛢️','Adelantos personal':'💵','Alimento':'🌾'};

  // helper: ID seguro para anchors (sin espacios/caracteres especiales)
  function _slug(s){ return String(s||'').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'').replace(/[^a-z0-9]+/g,'-').replace(/^-|-$/g,''); }

  // === BLOQUE A: JERARQUÍA PLEGABLE ===
  var jHtml = '';
  Object.keys(tree).sort().forEach(function(tipo){
    var tipoTotal = 0;
    Object.keys(tree[tipo]).forEach(function(cu){
      Object.keys(tree[tipo][cu]).forEach(function(su){
        tree[tipo][cu][su].forEach(function(r){ tipoTotal += parseFloat(r.monto)||0; });
      });
    });
    var tipoPct = totalGeneral ? Math.round(tipoTotal/totalGeneral*100) : 0;
    var tipoId = _slug('tipo-'+tipo);
    var tColor = tipoColors[tipo]||'var(--muted)';
    var tRGB = tipoRGB[tipo]||'125,133,144';

    // v1.8.39: cada tipo es una tarjeta con borde y acento de su color
    jHtml += '<div style="border:1px solid rgba('+tRGB+',.22);border-radius:8px;overflow:hidden;margin-bottom:6px">';
    jHtml += '<div onclick="contJerarToggle(\''+tipoId+'\')" style="cursor:pointer;padding:12px 16px;display:flex;justify-content:space-between;align-items:center;background:rgba('+tRGB+',.10);border-left:3px solid '+tColor+';user-select:none">';
    jHtml += '<div style="display:flex;align-items:center;gap:10px">';
    jHtml += '<span class="cont-jerar-arrow" data-target="'+tipoId+'" style="display:inline-block;transition:transform .15s;transform:rotate(90deg);font-size:10px;color:var(--muted)">▶</span>';
    jHtml += '<span style="font-weight:700;color:'+tColor+';font-size:14px;letter-spacing:.02em">'+escH(tipo)+'</span>';
    jHtml += '<span style="background:rgba('+tRGB+',.18);color:'+tColor+';font-size:10px;padding:2px 8px;border-radius:10px;font-weight:600">'+tipoPct+'%</span>';
    jHtml += '</div>';
    jHtml += '<span style="font-family:DM Mono,monospace;font-weight:700;font-size:15px;color:var(--text)">Bs. '+tipoTotal.toLocaleString()+'</span>';
    jHtml += '</div>';
    jHtml += '<div id="'+tipoId+'" class="cont-jerar-body" style="display:block">';

    Object.keys(tree[tipo]).sort().forEach(function(cuenta){
      var cuentaTotal = 0;
      Object.keys(tree[tipo][cuenta]).forEach(function(su){
        tree[tipo][cuenta][su].forEach(function(r){ cuentaTotal += parseFloat(r.monto)||0; });
      });
      var cuentaId = _slug('cu-'+tipo+'-'+cuenta);
      var cColor = cuentaColors[cuenta]||'var(--muted)';

      jHtml += '<div onclick="contJerarToggle(\''+cuentaId+'\')" style="cursor:pointer;padding:9px 16px 9px 34px;display:flex;justify-content:space-between;align-items:center;font-size:12px;user-select:none;border-bottom:1px solid rgba(48,54,61,.25)">';
      jHtml += '<div style="display:flex;align-items:center;gap:8px">';
      jHtml += '<span class="cont-jerar-arrow" data-target="'+cuentaId+'" style="display:inline-block;transition:transform .15s;transform:rotate(90deg);font-size:9px;color:var(--muted)">▶</span>';
      jHtml += '<span style="font-weight:600;color:'+cColor+';display:flex;align-items:center;gap:6px"><span style="width:7px;height:7px;border-radius:2px;background:'+cColor+';display:inline-block"></span>'+escH(cuenta)+'</span>';
      jHtml += '</div>';
      jHtml += '<span style="font-family:DM Mono,monospace;font-weight:600;color:'+cColor+'">Bs. '+cuentaTotal.toLocaleString()+'</span>';
      jHtml += '</div>';
      jHtml += '<div id="'+cuentaId+'" class="cont-jerar-body" style="display:block">';

      Object.keys(tree[tipo][cuenta]).sort().forEach(function(sub){
        var regs = tree[tipo][cuenta][sub];
        var subTotal = regs.reduce(function(s,r){return s+(parseFloat(r.monto)||0);},0);
        var subPct = cuentaTotal ? Math.round(subTotal/cuentaTotal*100) : 0;
        var icon = subIcons[sub] || '•';
        var cardId = 'card-'+_slug(tipo+'-'+cuenta+'-'+sub);

        jHtml += '<div onclick="contScrollToCard(\''+cardId+'\')" style="cursor:pointer;padding:8px 16px 8px 52px;display:flex;justify-content:space-between;align-items:center;font-size:11px;color:#9aa3ad;user-select:none;border-bottom:1px solid rgba(48,54,61,.12)" onmouseover="this.style.background=\'rgba(212,160,23,.06)\'" onmouseout="this.style.background=\'\'">';
        jHtml += '<span><span style="margin-right:7px">'+icon+'</span>'+escH(sub)+' <span style="opacity:.5">· '+regs.length+'</span></span>';
        jHtml += '<span style="display:flex;align-items:center;gap:10px"><div style="background:var(--sur2);border-radius:4px;height:6px;width:70px;overflow:hidden"><div style="background:'+tColor+';height:100%;width:'+subPct+'%;border-radius:4px"></div></div>';
        jHtml += '<span style="font-family:DM Mono,monospace;min-width:90px;text-align:right;color:var(--text)">Bs. '+subTotal.toLocaleString()+'</span></span>';
        jHtml += '</div>';
      });

      jHtml += '</div>';
    });

    jHtml += '</div></div>';
  });
  jerar.innerHTML = jHtml;

  // === BLOQUE B: TARJETAS POR SUBCUENTA ===
  // Aplanar tree → array de tarjetas, ordenado por monto descendente
  var cards = [];
  Object.keys(tree).forEach(function(tipo){
    Object.keys(tree[tipo]).forEach(function(cuenta){
      Object.keys(tree[tipo][cuenta]).forEach(function(sub){
        var regs = tree[tipo][cuenta][sub];
        var total = regs.reduce(function(s,r){return s+(parseFloat(r.monto)||0);},0);
        cards.push({ tipo:tipo, cuenta:cuenta, sub:sub, regs:regs, total:total });
      });
    });
  });
  cards.sort(function(a,b){ return b.total - a.total; });

  var tHtml = '<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:12px">';
  cards.forEach(function(c){
    var icon = subIcons[c.sub] || '📌';
    var cuentaColor = cuentaColors[c.cuenta] || 'var(--muted)';
    var cardId = 'card-'+_slug(c.tipo+'-'+c.cuenta+'-'+c.sub);
    tHtml += '<div id="'+cardId+'" style="background:var(--sur);border:1px solid var(--bor);border-radius:10px;overflow:hidden;display:flex;flex-direction:column">';
    // Header
    tHtml += '<div style="padding:10px 14px;background:var(--sur2);border-bottom:1px solid var(--bor)">';
    tHtml += '<div style="display:flex;justify-content:space-between;align-items:center;gap:8px">';
    tHtml += '<div style="font-size:13px;font-weight:600;color:var(--text);display:flex;align-items:center;gap:6px;min-width:0">';
    tHtml += '<span>'+icon+'</span><span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap">'+escH(c.sub)+'</span>';
    tHtml += '<span style="color:var(--muted);font-size:11px;font-weight:400">('+c.regs.length+')</span>';
    tHtml += '</div></div>';
    tHtml += '<div style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-top:3px">';
    tHtml += '<span style="color:'+cuentaColor+';font-weight:600">'+escH(c.cuenta)+'</span> · '+escH(c.tipo);
    tHtml += '</div></div>';
    // Body: lista de registros
    tHtml += '<div style="padding:6px 0;flex:1;max-height:320px;overflow-y:auto">';
    c.regs.slice().sort(function(a,b){return (b.fecha||'').localeCompare(a.fecha||'');}).forEach(function(r){
      var fecha = (r.fecha || r.created_at || '').slice(0,10);
      var byLabel = r.by || (r.origen==='auto'?'Auto':'');
      var detalle = (r.detalle || '').slice(0, 60);
      var canDelete = r.origen !== 'auto';
      tHtml += '<div style="display:flex;justify-content:space-between;align-items:flex-start;padding:6px 14px;border-bottom:1px solid rgba(48,54,61,.15);font-size:11px;gap:10px">';
      tHtml += '<div style="flex:1;min-width:0">';
      tHtml += '<div style="color:var(--text);overflow:hidden;text-overflow:ellipsis;white-space:nowrap">'+escH(detalle||'-')+'</div>';
      tHtml += '<div style="color:var(--muted);font-size:10px;margin-top:2px;font-family:DM Mono,monospace">'+escH(fecha);
      if (byLabel) tHtml += ' · '+escH(byLabel);
      tHtml += '</div></div>';
      tHtml += '<div style="display:flex;align-items:center;gap:6px;flex-shrink:0">';
      tHtml += '<span style="font-family:DM Mono,monospace;font-weight:600;color:'+cuentaColor+';white-space:nowrap">Bs. '+((parseFloat(r.monto)||0).toLocaleString())+'</span>';
      if (canDelete) {
        tHtml += '<button onclick="deleteCuenta(\''+escH(String(r.id))+'\')" style="background:transparent;border:none;color:var(--red);cursor:pointer;font-size:14px;padding:0 4px" title="Eliminar">×</button>';
      }
      tHtml += '</div></div>';
    });
    tHtml += '</div>';
    // Footer: total
    tHtml += '<div style="padding:8px 14px;background:var(--sur2);border-top:1px solid var(--bor);display:flex;justify-content:space-between;align-items:center;font-size:11px">';
    tHtml += '<span style="color:var(--muted);text-transform:uppercase;letter-spacing:.5px;font-weight:600">Total</span>';
    tHtml += '<span style="font-family:DM Mono,monospace;font-weight:700;color:'+cuentaColor+';font-size:13px">Bs. '+c.total.toLocaleString()+'</span>';
    tHtml += '</div>';
    tHtml += '</div>';
  });
  tHtml += '</div>';
  tarj.innerHTML = tHtml;
}

