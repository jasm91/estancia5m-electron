function calcPesajeTotals() {
  var avg = parseFloat((document.getElementById('pesaje-avg')||{}).value)||0;
  var count = parseInt((document.getElementById('pesaje-count')||{}).value)||0;
  var total = Math.round(avg * count);
  var totalEl = document.getElementById('pesaje-total');
  if (totalEl) totalEl.value = total ? total.toLocaleString() + ' kg' : '';
}

function renderPesajes() {
  if (!db.pesajes) db.pesajes = [];
  if (!db.agua) db.agua = [];
  if (!db.sal) db.sal = [];
  if (!db.conteo) db.conteo = [];
  if (!db.partos) db.partos = [];
  if (!db.alimento) db.alimento = [];

  // Populate lot filter
  var lotFilter = document.getElementById('pesaje-filter-lot');
  if (lotFilter) {
    var cur = lotFilter.value;
    lotFilter.innerHTML = '<option value="">Todos los lotes</option>';
    db.lots.forEach(function(l){
      var o = document.createElement('option'); o.value=l.code; o.textContent=l.code;
      if(l.code===cur) o.selected=true;
      lotFilter.appendChild(o);
    });
    lotFilter.onchange = function() { renderPesajes(); updateHistogramForFilter(); };
  }
  updateHistogramForFilter();

  var filterLot = (document.getElementById('pesaje-filter-lot')||{}).value||'';
  var filtered = filterLot
    ? db.pesajes.filter(function(p){ return p.lot_code===filterLot; })
    : db.pesajes;

  // Summary cards by lot
  var cardsEl = document.getElementById('pesaje-summary-cards');
  if (cardsEl) {
    cardsEl.innerHTML = '';
    var lots = filterLot ? db.lots.filter(function(l){return l.code===filterLot;}) : db.lots.filter(function(l){return !l.status||l.status==='activo'||l.status==='active';});
    lots.forEach(function(lot) {
      var lotPesajes = db.pesajes.filter(function(p){return p.lot_code===lot.code;});
      if (!lotPesajes.length) return;
      var last = lotPesajes.slice(-1)[0];
      var card = document.createElement('div');
      card.style.cssText = 'background:var(--sur);border:1px solid var(--bor);border-radius:12px;padding:14px';
      card.innerHTML = '<div style="font-size:14px;font-weight:700;color:var(--amber2);margin-bottom:8px">'+lot.code+'</div>' +
        '<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px;text-align:center">' +
        '<div><div style="font-size:10px;color:var(--muted)">PROMEDIO</div><div style="font-size:16px;font-weight:700;color:var(--text)">'+(last.avg_weight||'-')+' kg</div></div>' +
        '<div><div style="font-size:10px;color:var(--green)">MÍNIMO</div><div style="font-size:16px;font-weight:700;color:var(--green)">'+(last.min_weight||'-')+' kg</div></div>' +
        '<div><div style="font-size:10px;color:var(--amber2)">MÁXIMO</div><div style="font-size:16px;font-weight:700;color:var(--amber2)">'+(last.max_weight||'-')+' kg</div></div>' +
        '</div>' +
        '<div style="font-size:10px;color:var(--muted);margin-top:8px;text-align:center">Último pesaje: '+last.date+' · '+lotPesajes.length+' registros</div>';
      cardsEl.appendChild(card);
    });
  }

  // Table
  var tbody = document.getElementById('pesajes-tbody');
  if (!tbody) return;
  tbody.innerHTML = '';
  if (!filtered.length) {
    tbody.innerHTML = '<tr><td colspan="9" style="text-align:center;padding:24px;color:var(--muted);font-size:12px">Sin pesajes registrados. Hace clic en "+ Registrar pesaje" para empezar.</td></tr>';
    return;
  }
  filtered.slice().reverse().forEach(function(p) {
    var tr = document.createElement('tr');
    var delBtn = document.createElement('button');
    delBtn.className='btn btn-ghost btn-sm'; delBtn.style.color='var(--red)'; delBtn.textContent='✕';
    delBtn.onclick=(function(id){return function(){deletePesaje(id);};})(p.id);
    tr.innerHTML = '<td style="color:var(--amber2);font-weight:600">'+p.lot_code+'</td>' +
      '<td>'+fmtDT(p.created_at||p.date)+'</td>' +
      '<td>'+p.animal_count+'</td>' +
      '<td style="font-weight:600">'+p.avg_weight+' kg</td>' +
      '<td style="color:var(--green)">'+( p.min_weight||'-')+' kg</td>' +
      '<td style="color:var(--amber2)">'+(p.max_weight||'-')+' kg</td>' +
      '<td>'+(p.total_kg?p.total_kg.toLocaleString()+' kg':'-')+'</td>' +
      '<td style="font-size:11px;color:var(--muted)">'+(p.by||'-')+'</td>' +
      '<td></td>';
    tr.lastElementChild.appendChild(delBtn);
    tbody.appendChild(tr);
  });
}

function savePesaje() {
  var lotCode = (document.getElementById('pesaje-lot')||{}).value;
  var date    = (document.getElementById('pesaje-date')||{}).value||today();
  // FIX v1.4.34: no permitir fechas futuras
  if(!validateNotFuture(date, 'fecha del pesaje')) return;
  var count   = parseInt((document.getElementById('pesaje-count')||{}).value)||0;
  var avg     = parseFloat((document.getElementById('pesaje-avg')||{}).value)||0;
  var min     = parseFloat((document.getElementById('pesaje-min')||{}).value)||0;
  var max     = parseFloat((document.getElementById('pesaje-max')||{}).value)||0;
  var by      = (document.getElementById('pesaje-by')||{}).value||'Cesar Moreno';
  var notes   = (document.getElementById('pesaje-notes')||{}).value||'';

  if (!lotCode || !avg) { toast('Selecciona lote e ingresa peso promedio', 'error'); return; }
  if (min && max && min > max) { toast('El peso minimo no puede ser mayor al maximo', 'error'); return; }
  var pesajeLot = db.lots.find(function(l){ return l.code===lotCode; });
  if (pesajeLot && count && count > pesajeLot.animal_count) {
    toast('⚠ Pesaje registra '+count+' animales pero el lote tiene '+pesajeLot.animal_count+'. Verifica el dato.', 'error');
    // Warn but allow - pesaje is measurement only, doesn't modify lot count
  }

  if (!db.pesajes) db.pesajes = [];
  if (!db.agua) db.agua = [];
  if (!db.sal) db.sal = [];
  if (!db.conteo) db.conteo = [];
  if (!db.partos) db.partos = [];
  if (!db.alimento) db.alimento = [];
  db.pesajes.push({
    id: db.next_ids.pesaje++,
    lot_code: lotCode,
    date: date,
    animal_count: count,
    avg_weight: avg,
    min_weight: min || null,
    max_weight: max || null,
    total_kg: count && avg ? Math.round(count * avg) : null,
    by: by,
    notes: notes,
    created_at: new Date().toISOString(),
  });

  // Update lot's avg_weight with latest pesaje
  var lot = db.lots.find(function(l){ return l.code===lotCode; });
  if (lot) lot.avg_weight = avg;

  saveDB();
  closeModal('modal-pesaje');
  renderPesajes();
  renderLotes();
  renderDashboard();
  toast('Pesaje registrado para lote '+lotCode, 'success');
}

function deletePesaje(id) {
  if (!confirm('00bfEliminar este pesaje?')) return;
  trackDeletion(id, 'pesajes');
  db.pesajes = db.pesajes.filter(function(p){ return p.id!==id; });
  saveDB(); renderPesajes();
  pushTableToRailway('pesajes', db.pesajes);
  toast('Pesaje eliminado', 'success');
}

