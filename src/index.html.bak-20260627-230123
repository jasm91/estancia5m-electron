      (r.total ? '<div style="font-family:DM Mono,monospace;font-size:14px;color:var(--amber2);margin-top:2px">Bs. ' + parseFloat(r.total).toLocaleString() + '</div>' : '') +
    '</div>' +
  '</div>';

  // Sección: detalles principales
  html += '<div style="background:var(--sur2);border-radius:8px;padding:0 14px;margin-bottom:14px">';
  html += row('Fecha', dieselFechaDisplay(r), { mono: true }); // v1.8.66: fecha elegida ("Timestamp creación" abajo muestra el registro)
  if (r._tank_name) html += row('Tanque', r._tank_name, { bold: true });
  if (type === 'despacho' || type === 'recarga') {
    if (r.vehiculo) html += row('Vehículo / Equipo', r.vehiculo, { bold: true });
    if (r.proveedor) html += row('Proveedor', r.proveedor);
    if (r.precio) html += row('Precio por L', 'Bs. ' + r.precio, { mono: true });
  } else if (type === 'ajuste') {
    html += row('Nivel teórico', r.nivel_teorico + ' L', { mono: true });
    html += row('Nivel físico', r.nivel_fisico + ' L', { mono: true });
    if (typeof r.merma_pct !== 'undefined') html += row('Merma %', r.merma_pct + '%', { mono: true, color: r.ajuste_direccion === 'merma' ? 'var(--red)' : 'var(--green)' });
    if (r.costo_merma) html += row('Costo merma estimado', 'Bs. ' + r.costo_merma, { mono: true, color: 'var(--red)' });
    if (r.motivo) html += row('Motivo', r.motivo);
  } else if (type === 'traspaso') {
    if (r.from_tank_name) html += row('Origen', r.from_tank_name);
    if (r.to_tank_name) html += row('Destino', r.to_tank_name);
  }
  if (typeof r._balance !== 'undefined') html += row('Balance post-mov.', r._balance + ' L', { mono: true });
  if (r.obs) html += row('Observaciones', r.obs);
  html += '</div>';

  // Sección: trazabilidad (origen)
  html += '<div style="background:var(--sur2);border-radius:8px;padding:0 14px;margin-bottom:14px">';
  var srcBadgeBig = '<span style="font-size:11px;padding:3px 10px;border-radius:4px;background:' + srcColor + ';color:#fff;font-weight:600">' + escH(src) + '</span>';
  html += row('Origen del registro', srcBadgeBig, { html: true });
  if (r.created_at) html += row('Timestamp creación', r.created_at, { mono: true });
  if (r.tank_id) html += row('Tank ID', r.tank_id, { mono: true });
  html += '</div>';

  // Footer: acciones
  html += '<div style="display:flex;gap:8px;justify-content:flex-end;margin-top:18px">' +
    '<button class="btn btn-ghost" onclick="closeModal(\'modal-diesel-detail\')">Cerrar</button>' +
    '<button class="btn btn-ghost" style="color:var(--red)" onclick="if(confirm(\'¿Eliminar este registro?\')){closeModal(\'modal-diesel-detail\');deleteDiesel(\'' + r.id + '\');}">🗑 Eliminar</button>' +
  '</div>';

  html += '</div>';

  // Crear o reutilizar modal
  // v1.4.109 FIX: usar modal-overlay como wrapper (no .modal), porque .modal solo es la caja
  // interior sin posicionamiento. Sin overlay, el modal aparecía flotando en el body donde
  // estuviera scrolleado. .modal-content tampoco existe en el CSS del proyecto.
  var modal = document.getElementById('modal-diesel-detail');
  if (!modal) {
    modal = document.createElement('div');
    modal.id = 'modal-diesel-detail';
    modal.className = 'modal-overlay';
    modal.innerHTML = '<div class="modal" style="max-width:600px"><div id="diesel-detail-body"></div></div>';
    document.body.appendChild(modal);
    // Click fuera = cerrar
    modal.addEventListener('click', function(ev){
      if (ev.target === modal) closeModal('modal-diesel-detail');
    });
  }
  document.getElementById('diesel-detail-body').innerHTML = html;
  openModal('modal-diesel-detail');
}

