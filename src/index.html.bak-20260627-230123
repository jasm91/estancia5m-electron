// v1.8.70: normaliza el TIPO de producto del Excel a la clave canónica que usa Curación.
function _normOnbProdType(t){
  var s = String(t||'').toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g,'').replace(/\s+/g,' ').trim();
  var map = {
    'antiparasitario':'antiparasitario','antiparasitarios':'antiparasitario',
    'vacuna':'vacuna','vacunas':'vacuna',
    'antibiotico':'antibiotico','antibioticos':'antibiotico',
    'antiinflamatorio':'antiinflamatorio','antinflamatorio':'antiinflamatorio',
    'vitamina':'vitamina_mineral','vitaminas':'vitamina_mineral','mineral':'vitamina_mineral','vitamina mineral':'vitamina_mineral','vitamina/mineral':'vitamina_mineral',
    'hormona':'hormona','hormona reproductiva':'hormona','hormonal':'hormona',
    'sal mineral':'sal_mineral','sal':'sal_mineral',
    'alimento':'alimento_balanceado','alimento balanceado':'alimento_balanceado','balanceado':'alimento_balanceado','concentrado':'alimento_balanceado',
    'combustible':'combustible','diesel':'combustible','gasolina':'combustible',
    'lubricante':'lubricante','aceite':'lubricante','grasa':'lubricante'
  };
  if (map[s]) return map[s];
  return s ? s.replace(/[^a-z0-9]+/g,'_') : '';
}
// v1.8.70: normaliza sexo a 'macho'/'hembra' (acepta m/h/f y variantes).
function _normOnbSexo(s){
  var v = String(s||'').toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g,'').trim();
  if (v === 'm' || v.indexOf('macho')>=0 || v.indexOf('torillo')>=0 || v.indexOf('toro')>=0) return 'macho';
  if (v === 'h' || v === 'f' || v.indexOf('hembra')>=0 || v.indexOf('vaca')>=0 || v.indexOf('vaquill')>=0 || v.indexOf('ternera')>=0) return 'hembra';
  return '';
}

async function confirmOnboardingImport() {
  if (!_onboardingParsed) return;
  if (!confirm('¿Importar los registros nuevos al sistema? Los existentes no se modifican.')) return;
  var progressEl = document.getElementById('onboarding-progress');
  var importBtn = document.getElementById('onboarding-import-btn');
  if (importBtn) importBtn.disabled = true;
  if (progressEl) { progressEl.style.display = 'block'; progressEl.textContent = 'Aplicando datos al sistema local...'; }

  var p = _onboardingParsed;
  var rp = (typeof getRp === 'function') ? getRp() : {};
  if (!rp.potreros) rp.potreros = [];
  if (!rp.subcuentas) rp.subcuentas = [];
  if (!db.products) db.products = [];
  if (!db.maquinaria) db.maquinaria = [];
  if (!db.employees) db.employees = [];
  if (!db.lots) db.lots = [];

  try {
    // v1.8.70: los parámetros PRODUCTIVOS (precios, GMD) viven en report_params, no en estancia_params.
    var reportParams = {}; try { reportParams = JSON.parse(localStorage.getItem('e5m_report_params')||'{}'); } catch(e){}
    var _rpTouched = false;
    p.parametros.forEach(function(par){
      var k = String(par.key||'').toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g,'');
      var numv = parseFloat(String(par.value==null?'':par.value).replace(',','.'))||0;
      if (k.indexOf('nombre') >= 0 && k.indexOf('estancia') >= 0) rp.nombre_estancia = String(par.value||'');
      else if (k.indexOf('propietario') >= 0) rp.propietario = String(par.value||'');
      else if (k.indexOf('ubicaci') >= 0) rp.ubicacion = String(par.value||'');
      else if (k.indexOf('hect') >= 0) rp.superficie_total = parseFloat(par.value)||0;
      else if (k.indexOf('moneda') >= 0) rp.moneda = String(par.value||'Bs');
      else if (k.indexOf('precio')>=0 && k.indexOf('carne')>=0) { reportParams.precio_kg_carne = numv; _rpTouched=true; }
      else if (k.indexOf('precio')>=0 && k.indexOf('objetivo')>=0) { reportParams.precio_objetivo = numv; _rpTouched=true; }
      else if (k.indexOf('precio')>=0 && k.indexOf('feria')>=0) { reportParams.precio_feria = numv; _rpTouched=true; }
      else if (k.indexOf('precio')>=0 && k.indexOf('frigorif')>=0) { reportParams.precio_frigorifico = numv; _rpTouched=true; }
      else if (k.indexOf('gmd')>=0) { reportParams.gmd_default = numv; _rpTouched=true; }
    });
    if (_rpTouched) { try { reportParams.updated_at = new Date().toISOString(); localStorage.setItem('e5m_report_params', JSON.stringify(reportParams)); } catch(e){} }

    var existingPot = {};
    (rp.potreros||[]).forEach(function(po){ existingPot[String(po.name||po).toLowerCase()] = true; });
    p.potreros.forEach(function(po){
      if (!existingPot[String(po.name).toLowerCase()]) rp.potreros.push({ name: po.name, hectareas: po.hectareas, capacidad: po.capacidad || null });
    });

    var pluvios = [];
    try { pluvios = JSON.parse(localStorage.getItem('e5m_pluvios')||'[]'); } catch(e){}
    var pluvSet = {};
    pluvios.forEach(function(pl){ pluvSet[String(pl.name||'').toLowerCase()] = true; });
    p.pluviometros.forEach(function(pl){
      if (!pluvSet[String(pl.name).toLowerCase()]) pluvios.push({ name: pl.name, ubicacion: pl.ubicacion || '' });
    });
    localStorage.setItem('e5m_pluvios', JSON.stringify(pluvios));

    var existingSubs = {};
    (rp.subcuentas||[]).forEach(function(s){ existingSubs[String(s.name||'').toLowerCase()] = true; });
    p.subcuentas.forEach(function(s){
      if (!existingSubs[String(s.name).toLowerCase()]) rp.subcuentas.push({ name: s.name, cuenta: s.cuenta });
    });

    var existingL = {};
    db.lots.forEach(function(l){ existingL[l.code] = true; });
    var _newLotCodes = {};   // v1.8.73: lotes creados en este import (para reconciliar conteo desde Animales)
    var nextLotId = (db.next_ids && db.next_ids.lot) || 100;
    p.lotes.forEach(function(l){
      if (existingL[l.code]) return;
      _newLotCodes[l.code] = true;
      var newLot = {
        id: nextLotId++, code: l.code, category: l.category, breed: l.breed || '',
        paddock: l.paddock || '', animal_count: l.animal_count || 0, avg_weight: l.avg_weight || 0,
        supplier: l.supplier || '', status: 'active',
        entry_date: (typeof localDate==='function'?localDate():new Date().toISOString().slice(0,10)),
        notes: l.obs || ''
      };
      db.lots.push(newLot);
      // v1.4.105: garantizar entry en rotation_history para lotes nuevos con paddock
      if (typeof _ensureRotationEntry === 'function') {
        _ensureRotationEntry(newLot, { reason: 'Onboarding inicial' });
      }
    });
    if (db.next_ids) db.next_ids.lot = nextLotId;

    var animDB = {};
    try { animDB = JSON.parse(localStorage.getItem('e5m_animals')||'{}'); } catch(e){}
    p.animales.forEach(function(a){
      if (!animDB[a.lot_code]) animDB[a.lot_code] = [];
      var existsId = animDB[a.lot_code].find(function(x){ return String(x.animal_id||x.id||'') === String(a.animal_id); });
      if (existsId) return;
      var pesajes = [];
      if (a.peso) pesajes.push({ fecha: a.fecha || (typeof localDate==='function'?localDate():new Date().toISOString().slice(0,10)), peso: a.peso });
      animDB[a.lot_code].push({ animal_id: String(a.animal_id), id: String(a.animal_id), breed: a.breed || '', raza: a.breed || '', sexo: _normOnbSexo(a.sexo), pesajes: pesajes });   // v1.8.70: +sexo
    });
    localStorage.setItem('e5m_animals', JSON.stringify(animDB));

    // v1.8.73: el conteo del lote SIEMPRE sale de los animales individuales (la hoja Animales manda).
    // Solo para los lotes creados en este import, para no tocar lotes existentes parcialmente trackeados.
    db.lots.forEach(function(lot){
      if (!_newLotCodes[lot.code]) return;
      var anims = animDB[lot.code] || [];
      lot.animal_count = anims.length;
      var ws = anims.map(function(a){ return (a.pesajes && a.pesajes.length) ? a.pesajes[a.pesajes.length-1].peso : 0; }).filter(function(w){ return w > 0; });
      if (ws.length) lot.avg_weight = Math.round(ws.reduce(function(s,w){return s+w;},0)/ws.length*10)/10;
    });

    var existingP = {};
    (db.products||[]).forEach(function(prd){ existingP[String(prd.name||'').toLowerCase()] = true; });
    var nextProdId = (db.next_ids && db.next_ids.product) || 100;
    p.stockVet.forEach(function(prd){
      if (existingP[String(prd.name).toLowerCase()]) return;
      // v1.8.70: la app lee stock_qty y unit_cost (no stock/cost) → escribir ambos; y normalizar el tipo a la clave canónica (si no, no aparece en Curación).
      db.products.push({ id: nextProdId++, name: prd.name, type: _normOnbProdType(prd.type), stock: prd.stock || 0, stock_qty: prd.stock || 0, unit: prd.unit || 'unidad', dose_per_50kg: prd.dose || '', cost: prd.cost || 0, unit_cost: prd.cost || 0, notes: prd.obs || '' });
    });
    if (db.next_ids) db.next_ids.product = nextProdId;

    var existingM = {};
    (db.maquinaria||[]).forEach(function(m){ existingM[String(m.name||'').toLowerCase()] = true; });
    p.maquinaria.forEach(function(m){
      if (existingM[String(m.name).toLowerCase()]) return;
      db.maquinaria.push({ id: Date.now() + Math.random()*100, name: m.name, type: m.type, brand: m.brand || '', year: m.year || null, horometro: m.horometro || 0, km: m.km || 0, notes: m.obs || '' });
    });

    var tanks = [];
    try { tanks = JSON.parse(localStorage.getItem('e5m_diesel_tank')||'[]'); } catch(e){}
    if (!Array.isArray(tanks)) tanks = [];
    var existingT = {};
    tanks.forEach(function(t){ existingT[String(t.name||'').toLowerCase()] = true; });
    p.tanques.forEach(function(tk){
      if (existingT[String(tk.name).toLowerCase()]) return;
      tanks.push({ id: Date.now() + Math.random()*100, name: tk.name, fuel: tk.fuel, capacity: tk.capacity, level: tk.level != null ? tk.level : tk.capacity, location: tk.location || '' });
    });
    localStorage.setItem('e5m_diesel_tank', JSON.stringify(tanks));

    var existingE = {};
    (db.employees||[]).forEach(function(e){ existingE[String(e.name||'').toLowerCase()] = true; });
    var nextEmpId = (db.next_ids && db.next_ids.employee) || 100;
    p.personal.forEach(function(e){
      if (existingE[String(e.name).toLowerCase()]) return;
      db.employees.push({ id: nextEmpId++, name: e.name, role: e.role, salary: e.salary || 0, hire_date: e.hire_date || '', phone: e.phone || '', pin: e.pin || '', notes: e.obs || '' });   // v1.8.70: +pin (login PWA)
    });
    if (db.next_ids) db.next_ids.employee = nextEmpId;

    if (typeof saveRp === 'function') saveRp(rp);
    saveDB();

    if (progressEl) progressEl.textContent = 'Sincronizando con el server (esto puede tardar 10-20s)...';

    var pushTables = [
      { name: 'lots', data: db.lots },
      { name: 'vet_products', data: db.products },
      { name: 'employees', data: db.employees },
      { name: 'maquinaria', data: db.maquinaria },
      { name: 'animals', data: animDB },
      { name: 'estancia_params', data: rp },
      // v1.8.70: faltaban → pluviómetros y tanques quedaban solo en el equipo que importó.
      { name: 'pluvios_config', data: pluvios },
      { name: 'diesel_tank', data: tanks }
    ];
    if (_rpTouched) pushTables.push({ name: 'report_params', data: reportParams });
    var ok = 0, fail = 0;
    for (var i = 0; i < pushTables.length; i++) {
      var t = pushTables[i];
      if (progressEl) progressEl.textContent = 'Sincronizando ' + t.name + ' (' + (i+1) + '/' + pushTables.length + ')...';
      try {
        var r = await replaceTableInRailway(t.name, t.data);
        if (r) ok++; else fail++;
      } catch(e) { fail++; console.error('[Onboarding] push ' + t.name + ':', e); }
      await new Promise(function(r){ setTimeout(r, 200); });
    }

    closeOnboardingPreview();
    var resultEl = document.getElementById('onboarding-result');
    if (resultEl) {
      resultEl.style.display = 'block';
      resultEl.innerHTML = 'Importacion completa. ' + ok + '/' + pushTables.length + ' tablas sincronizadas. Recargando...';
      resultEl.style.color = 'var(--green)';
    }
    toast('Onboarding completo — recargando','success');
    setTimeout(function(){ location.reload(); }, 2000);
  } catch(err) {
    console.error('[Onboarding] Error en import:', err);
    if (progressEl) progressEl.textContent = 'Error: ' + err.message;
    toast('Error al importar: ' + err.message, 'error');
    if (importBtn) importBtn.disabled = false;
  }
}

