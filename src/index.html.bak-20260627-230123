function renderAnimalesLote(){
  var lotSel=document.getElementById("animales-lot-filter");
  // v1.4.82: construir set de códigos por categoría de status
  // Filtro estricto en "Todos los lotes": solo activos.
  // Solo aparecen lotes no-activos en el dropdown si tienen toggle dedicado (vendidos).
  var existingLotCodes = {};
  var soldLotCodes = {};
  var inactiveLotCodes = {};  // cuarentena, marcado, inactivo (cualquier no-activo que no sea vendido)
  (db.lots||[]).forEach(function(l){
    existingLotCodes[l.code] = true;
    if (l.status === 'vendido' || l.status === 'sold') {
      soldLotCodes[l.code] = true;
    } else if (l.status && l.status !== 'activo' && l.status !== 'active') {
      inactiveLotCodes[l.code] = true;
    }
  });
  // Detectar si el toggle de "incluir vendidos" está activado
  var includeSold = false;
  var inclSoldEl = document.getElementById('animales-show-sold');
  if (inclSoldEl) includeSold = inclSoldEl.checked;
  if(lotSel){
    var curVal=lotSel.value;
    // v1.4.87: pedir seleccionar lote por defecto (no cargar todos los animales de entrada)
    // El usuario raramente necesita ver los 200+ animales juntos. Esto acelera el render.
    lotSel.innerHTML='<option value="">← Seleccionar lote...</option>';
    (db.lots||[]).forEach(function(l){
      // Excluir vendidos (a menos que toggle esté activo)
      if (soldLotCodes[l.code] && !includeSold) return;
      // Excluir SIEMPRE lotes no-activos no-vendidos (cuarentena, marcado, etc.)
      if (inactiveLotCodes[l.code]) return;
      var o=document.createElement("option");
      o.value=l.code;
      o.textContent=l.code+" - "+(l.paddock||"")+" ("+(l.animal_count||0)+" cab)";
      if(l.code===curVal) o.selected=true;
      lotSel.appendChild(o);
    });
    // Opción especial al final para los que la quieran
    var optAll=document.createElement("option");
    optAll.value="__ALL__";
    optAll.textContent="── Ver todos los lotes (lento) ──";
    if(curVal==="__ALL__") optAll.selected=true;
    lotSel.appendChild(optAll);
  }
  var lotCode=(lotSel||{}).value||"";
  var showAll=(lotCode==="__ALL__");
  // El valor "__ALL__" significa "todos", pero lo tratamos como "" para el resto del render
  if(showAll) lotCode="";
  var search=((document.getElementById("animales-search")||{}).value||"").toLowerCase();
  var animalsAll=getAnimalesDB();
  var animals = [];

  // v1.4.87: si no hay lote seleccionado y no se pidió "ver todos", mostrar empty state.
  if (!lotCode && !showAll) {
    var subEmpty=document.getElementById("animales-subtitle");
    if(subEmpty) subEmpty.textContent="Seleccioná un lote para ver sus animales";
    var statsElEmpty=document.getElementById("animales-stats");
    if(statsElEmpty) statsElEmpty.style.display="none";
    var histoCardEmpty=document.getElementById("animales-histograma-card");
    if(histoCardEmpty) histoCardEmpty.style.display="none";
    var elEmpty=document.getElementById("animales-list");
    if(elEmpty){
      var totalActivos=(db.lots||[]).filter(function(l){
        return !l.status || l.status==='activo' || l.status==='active';
      }).length;
      elEmpty.innerHTML='<div style="text-align:center;padding:48px 20px;color:var(--muted)">' +
        '<div style="font-size:42px;margin-bottom:14px">🐄</div>' +
        '<div style="font-size:14px;color:var(--text);margin-bottom:6px">Seleccioná un lote para empezar</div>' +
        '<div style="font-size:11px">Hay ' + totalActivos + ' lote' + (totalActivos===1?'':'s') + ' activo' + (totalActivos===1?'':'s') + ' · usá el desplegable de arriba</div>' +
      '</div>';
    }
    // Limpiar selección bulk para que no quede colgada de una sesión previa
    if (typeof window._bulkSelected !== 'undefined') {
      window._bulkSelected = {};
      if (typeof bulkRefreshBar === 'function') bulkRefreshBar();
    }
    return;
  }

  if (lotCode) {
    // Si el lote está vendido y el toggle está apagado, no mostrar nada
    if (soldLotCodes[lotCode] && !includeSold) {
      animals = [];
    } else if (!existingLotCodes[lotCode]) {
      // Lote huérfano (no existe en db.lots) → no mostrar
      animals = [];
    } else {
      (animalsAll[lotCode]||[]).forEach(function(a){ animals.push({id:a.id,raza:a.raza,pesajes:a.pesajes||[],_lot:lotCode}); });
    }
  } else {
    Object.keys(animalsAll).forEach(function(lc){
      // Excluir lotes que NO existen en db.lots (huérfanos del cache)
      if (!existingLotCodes[lc]) return;
      // Excluir lotes vendidos a menos que el toggle esté activado
      if (soldLotCodes[lc] && !includeSold) return;
      // v1.4.82: excluir SIEMPRE lotes no-activos (cuarentena, marcado, etc.)
      if (inactiveLotCodes[lc]) return;
      (animalsAll[lc]||[]).forEach(function(a){ animals.push({id:a.id,raza:a.raza,pesajes:a.pesajes||[],_lot:lc}); });
    });
  }
  var sub=document.getElementById("animales-subtitle");
  if(sub){
    if(lotCode){
      var lot=(db.lots||[]).find(function(l){return l.code===lotCode;});
      sub.textContent=(lot?lot.category+" - "+lot.paddock:"")+": "+animals.length+" animales";
    } else {
      sub.textContent="Todos los lotes: "+animals.length+" animales";
    }
  }
  var statsEl=document.getElementById("animales-stats");
  if(statsEl&&animals.length){
    var ws=animals.map(function(a){return a.pesajes&&a.pesajes.length?a.pesajes[a.pesajes.length-1].peso:0;}).filter(function(w){return w>0;});
    var avg=ws.length?Math.round(ws.reduce(function(s,w){return s+w;},0)/ws.length*10)/10:0;
    var mn=ws.length?Math.min.apply(null,ws):0;
    var mx=ws.length?Math.max.apply(null,ws):0;
    var totalKg=Math.round(avg*animals.length);
    statsEl.style.display="flex";
    statsEl.innerHTML=
      '<div style="background:var(--sur2);border:1px solid var(--bor);border-radius:8px;padding:10px 16px;font-size:12px;min-width:100px">'+
        '<div style="color:var(--muted);font-size:10px">ANIMALES</div>'+
        '<div style="font-size:20px;font-weight:700;color:var(--amber2)">'+animals.length+'</div>'+
      '</div>'+
      '<div style="background:var(--sur2);border:1px solid var(--bor);border-radius:8px;padding:10px 16px;font-size:12px;min-width:100px">'+
        '<div style="color:var(--muted);font-size:10px">PESO PROM.</div>'+
        '<div style="font-size:20px;font-weight:700;color:var(--text)">'+avg+' kg</div>'+
      '</div>'+
      '<div style="background:var(--sur2);border:1px solid var(--bor);border-radius:8px;padding:10px 16px;font-size:12px;min-width:100px">'+
        '<div style="color:var(--muted);font-size:10px">MIN / MAX</div>'+
        '<div style="font-size:14px;font-weight:700">'+mn+' / '+mx+' kg</div>'+
      '</div>'+
      '<div style="background:var(--sur2);border:1px solid var(--bor);border-radius:8px;padding:10px 16px;font-size:12px;min-width:100px">'+
        '<div style="color:var(--muted);font-size:10px">TOTAL KG</div>'+
        '<div style="font-size:20px;font-weight:700;color:var(--green)">'+totalKg.toLocaleString()+'</div>'+
      '</div>';
  } else if(statsEl){statsEl.style.display="none";}
  var el=document.getElementById("animales-list");
  if(!el) return;
  var pesoMin = parseFloat((document.getElementById('animales-peso-min')||{}).value) || 0;
  var pesoMax = parseFloat((document.getElementById('animales-peso-max')||{}).value) || 0;
  var filtered=animals;
  if(search) filtered=filtered.filter(function(a){var aid=(a.id||'').toString();return aid.toLowerCase().includes(search)||(a.raza||"").toLowerCase().includes(search)||a._lot.toLowerCase().includes(search);});
  if(pesoMin || pesoMax) {
    filtered=filtered.filter(function(a){
      var ps=a.pesajes||[];
      var lastW=ps.length?ps[ps.length-1].peso:0;
      if(pesoMin && lastW<pesoMin) return false;
      if(pesoMax && lastW>pesoMax) return false;
      return true;
    });
  }
  var filterCountEl = document.getElementById('animales-filter-count');
  if(filterCountEl) {
    if(search || pesoMin || pesoMax) {
      filterCountEl.textContent = filtered.length + ' de ' + animals.length + ' animales';
    } else {
      filterCountEl.textContent = '';
