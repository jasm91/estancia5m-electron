// Poblar dropdown de meses (12 meses hacia atrás desde el mes actual)
function populateAdvMonthSelect() {
  var sel = document.getElementById('adv-month-sel');
  if (!sel) return;
  var now = new Date();
  var nombres = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
  var html = '';
  // 12 meses hacia atrás incluyendo el actual
  for (var i = 0; i < 12; i++) {
    var d = new Date(now.getFullYear(), now.getMonth() - i, 1);
    var ym = d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0');
    var label = nombres[d.getMonth()] + ' ' + d.getFullYear();
    if (i === 0) label += ' (actual)';
    html += '<option value="'+ym+'"'+(i===0?' selected':'')+'>'+label+'</option>';
  }
  sel.innerHTML = html;
}

function setAdvPeriod(period, btn) {
  _advPeriod = period;
  document.querySelectorAll('.adv-period-btn').forEach(function(b){ b.classList.remove('active'); });
  if (btn) btn.classList.add('active');
  var rangeInputs = document.getElementById('adv-range-inputs');
  var now = new Date();
  if (period === 'mes' || period === 'month-pick') {
    // Si es month-pick, leer el valor del dropdown; si es 'mes' (default), usar mes actual
    var ym;
    if (period === 'month-pick') {
      var sel = document.getElementById('adv-month-sel');
      ym = sel ? sel.value : '';
    }
    if (!ym) ym = now.getFullYear() + '-' + String(now.getMonth()+1).padStart(2,'0');
    var parts = ym.split('-');
    var year = parseInt(parts[0]);
    var month = parseInt(parts[1]) - 1;
    _advFrom = localDate(new Date(year, month, 1));
    _advTo   = localDate(new Date(year, month+1, 0));
    if(rangeInputs) rangeInputs.style.display='none';
  } else if (period === 'semana') {
    _advFrom = localDate(new Date(Date.now()-7*86400000));
    _advTo   = today();
    if(rangeInputs) rangeInputs.style.display='none';
  } else if (period === 'todo') {
    _advFrom = null; _advTo = null;
    if(rangeInputs) rangeInputs.style.display='none';
  } else if (period === 'custom') {
    if(rangeInputs) { rangeInputs.style.display='flex'; }
    _advFrom = (document.getElementById('adv-range-from')||{}).value || null;
    _advTo   = (document.getElementById('adv-range-to')||{}).value || null;
  }
