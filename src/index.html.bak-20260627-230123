  html += '</tbody></table></div>';

  // NOTA METODOLÓGICA
  html += '<div style="background:rgba(88,166,255,.06);border:1px solid rgba(88,166,255,.15);border-radius:8px;padding:12px 16px;font-size:11px;color:var(--blue);margin-top:16px;line-height:1.5"><strong>ℹ️ Nota:</strong> Indicadores calculados según metodología AACREA. UA = ' + pesoUA + ' kg. Existencia media = ' + existMedia + ' cabezas. Gastos admin+estructura anualizados.</div>';

  el.innerHTML = html;

  // v1.4.67: renderizar los donuts de Composición de Gastos
  _creaRenderGastosDonuts();
