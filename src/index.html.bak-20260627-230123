    editBtn.onclick = (function(id){ return function(){ openTaskModal(id); }; })(task.id);
    actions.appendChild(editBtn);

    var delBtn = document.createElement('button');
    delBtn.className = 'btn btn-ghost btn-sm';
    delBtn.textContent = '✕';
    delBtn.title = 'Eliminar';
    delBtn.style.color = 'var(--muted)';
    delBtn.onclick = (function(id){ return function(){
      if (!confirm('Eliminar esta tarea?')) return;
      trackDeletion(id, 'tasks');
      var remaining = getTaskDB().filter(function(t){ return t.id !== id; });
      setTaskDB(remaining);
      renderTaskList();
      toast('Tarea eliminada', 'success');
      if (navigator.onLine) {
        var apiUrl2 = getApiUrl();
        var token2  = localStorage.getItem('e5m_api_token') || '';
        fetch(apiUrl2+'/tasks/bulk', {
          method:'POST',
          headers:{'Content-Type':'application/json','Authorization':'Bearer '+token2},
          body: JSON.stringify({tasks: remaining, replace_all: true})
        }).catch(function(){});
      }
    }; })(task.id);
    actions.appendChild(delBtn);

    row.appendChild(actions);
    container.appendChild(row);
  });
}

function openTaskModal(taskId) {
  var hidden = document.getElementById('task-id');
  if (hidden) hidden.value = taskId || '';
  var ti = document.getElementById('task-modal-title');
  if (ti) ti.textContent = taskId ? '✏️ Editar Tarea' : '📋 Nueva Tarea';

  // Populate assignee
  var ae = document.getElementById('task-assignee');
  if (ae) {
    ae.innerHTML = '<option value="">Seleccionar responsable...</option>';
    db.employees.filter(function(e){return e.active;}).forEach(function(e){
      var o = document.createElement('option'); o.value=e.name; o.textContent=e.name; ae.appendChild(o);
    });
  }
  // Populate lot
  var le = document.getElementById('task-lot');
  if (le) {
    le.innerHTML = '<option value="">Sin lote</option>';
    (db.lots||[]).filter(function(l){return !l.status||l.status==='activo'||l.status==='active';}).forEach(function(l){
      var o = document.createElement('option'); o.value=l.code; o.textContent=l.code+' ('+l.animal_count+' cab.)'; le.appendChild(o);
    });
  }

  if (taskId) {
    var task = getTaskDB().find(function(t){ return t.id === taskId; });
    if (task) {
      document.getElementById('task-title').value = task.title || '';
      document.getElementById('task-desc').value = task.desc || '';
      if (ae) ae.value = task.assignee || '';
      document.getElementById('task-priority').value = task.priority || 'media';
      document.getElementById('task-due').value = task.due || '';
      if (le) le.value = task.lot || '';
    }
  } else {
    document.getElementById('task-title').value = '';
    document.getElementById('task-desc').value = '';
    document.getElementById('task-priority').value = 'media';
    document.getElementById('task-due').value = today();
  }

