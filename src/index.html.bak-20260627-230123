function renderContabilidad() {
  populateCuentaSelects();
  if (!db.cuentas) db.cuentas = [];
  var now = new Date();
  var curYear = now.getFullYear();

  // Date range defaults: últimos 30 días (más útil que "mes actual" cuando es día 1).
  // Si el usuario eligió un filtro rápido (botón Hoy/Semana/Mes/Año/Todo), respetar su elección
  // (incluso si vacío para "Todo").
  var desdeEl = document.getElementById('cont-f-desde');
  var hastaEl = document.getElementById('cont-f-hasta');
  var userChose = window._contDateUserChoice === true;
  if (!userChose) {
    if (desdeEl && !desdeEl.value) {
      var d30 = new Date(now.getTime() - 30 * 24 * 60 * 60 * 1000);
      desdeEl.value = d30.getFullYear() + '-' + String(d30.getMonth()+1).padStart(2,'0') + '-' + String(d30.getDate()).padStart(2,'0');
    }
    if (hastaEl && !hastaEl.value) hastaEl.value = localDate();
  }
  // Reset flag para próximas llamadas (si el usuario edita manualmente las fechas, queremos que esos
  // cambios se respeten también — el onchange del input dispara renderContabilidad sin tocar la flag)

  var selDesde = (desdeEl||{}).value || '';
  var selHasta = (hastaEl||{}).value || '';
  populateContFilters();
  var selTipoGasto = (document.getElementById('cont-f-tipo-gasto')||{}).value || '';
  var selCuenta = (document.getElementById('cont-f-cuenta')||{}).value || '';
  var selSubcuenta = (document.getElementById('cont-f-subcuenta')||{}).value || '';

  // Construir registros derivados de tablas existentes
  var derivados = [];

  // INGRESOS: de ventas (separar venta normal vs venta de carne post-baja)
  (db.sales||[]).forEach(function(v) {
