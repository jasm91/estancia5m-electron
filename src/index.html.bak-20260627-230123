var _evpPhoto = null;
var _evpResultText = '';
var _evpDetailId = null;

function renderEvalPasto() {
  if (!db.pasture_evals) db.pasture_evals = [];
  var grid = document.getElementById('evalpasto-grid');
  var sumEl = document.getElementById('evalpasto-summary');
  var fPot = document.getElementById('evalpasto-filter-potrero');
  var fLote = document.getElementById('evalpasto-filter-lote');
  var fEst = document.getElementById('evalpasto-filter-estado');
  if (!grid) return;

  var evals = db.pasture_evals.slice();

  // Poblar filtros
  if (fPot && fLote) {
    var prevPot = fPot.value, prevLote = fLote.value;
    var pots = {}, lotes = {};
    evals.forEach(function(e){
      if (e.potrero) pots[e.potrero] = true;
      if (e.lot_code || e.lot) lotes[e.lot_code || e.lot] = true;
    });
    fPot.innerHTML = '<option value="">Todos</option>' + Object.keys(pots).sort().map(function(p){return '<option value="'+escAttr(p)+'">'+escH(p)+'</option>';}).join('');
    fLote.innerHTML = '<option value="">Todos</option>' + Object.keys(lotes).sort().map(function(l){return '<option value="'+escAttr(l)+'">'+escH(l)+'</option>';}).join('');
    fPot.value = prevPot || '';
    fLote.value = prevLote || '';
  }

  var filtPot = fPot ? fPot.value : '';
  var filtLote = fLote ? fLote.value : '';
  var filtEst = fEst ? (fEst.value || '').toLowerCase() : '';
  var filtered = evals.filter(function(e){
    var lc = e.lot_code || e.lot || '';
    if (filtPot && e.potrero !== filtPot) return false;
    if (filtLote && lc !== filtLote) return false;
    if (filtEst) {
      var rUp = String(e.result || e.estado || '').toUpperCase();
      var match = false;
      if (filtEst === 'excelente') match = /EXCELENTE/.test(rUp);
      else if (filtEst === 'bueno') match = /BUENO/.test(rUp) && !/MUY BUENO/.test(rUp);
      else if (filtEst === 'regular') match = /REGULAR/.test(rUp);
      else if (filtEst === 'degradado') match = /DEGRADADO/.test(rUp);
      else if (filtEst === 'critico') match = /CRITICO|CRÍTICO/.test(rUp);
      if (!match) return false;
    }
    return true;
  });

  // Sort por fecha desc
  filtered.sort(function(a,b){
    var ta = new Date(a.evaluated_at || a.date || a.created_at || 0).getTime();
    var tb = new Date(b.evaluated_at || b.date || b.created_at || 0).getTime();
    return tb - ta;
  });

  // Resumen
  if (sumEl) {
    var done = evals.filter(function(e){return e.type==='completed' || e.result;}).length;
    sumEl.textContent = filtered.length + ' / ' + evals.length + ' · ✓ ' + done + ' completadas';
  }

  if (!filtered.length) {
    grid.innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:40px 20px;color:var(--muted)">' +
      '<div style="font-size:48px;margin-bottom:8px">🌿</div>' +
      '<div style="font-size:14px">Sin evaluaciones registradas</div>' +
      '<div style="font-size:11px;margin-top:6px">Tocá "+ Nueva evaluación" para empezar</div></div>';
    return;
  }

  function pasturaColor(result) {
    var r = String(result||'').toUpperCase();
    if (/EXCELENTE/.test(r)) return '#56D364';
    if (/BUENO/.test(r) && !/MUY BUENO/.test(r)) return 'var(--green)';
    if (/REGULAR/.test(r)) return 'var(--amber2)';
    if (/DEGRADADO/.test(r)) return '#F0883E';
    if (/CRITICO|CRÍTICO/.test(r)) return 'var(--red)';
    return 'var(--muted)';
  }

  grid.innerHTML = filtered.map(function(ev){
    var lotc = ev.lot_code || ev.lot || '';
    var dt = new Date(ev.evaluated_at || ev.date || ev.created_at || 0);
    var dtFmt = isNaN(dt.getTime()) ? '' : dt.toLocaleDateString('es-BO',{day:'2-digit',month:'short',year:'numeric'}) + ' ' + dt.toLocaleTimeString('es-BO',{hour:'2-digit',minute:'2-digit'});
    var pColor = pasturaColor(ev.result);
    var summary = '';
    if (ev.result) {
      var r = String(ev.result).trim();
      var m = r.match(/\*?\*?(?:ESTADO|RESUMEN|RECOMENDACI[OÓ]N)\*?\*?\s*:\s*([^\n]{1,90})/i);
      summary = m ? m[1].trim() : r.replace(/\*\*[^*]+\*\*/g,'').replace(/\n+/g,' ').slice(0,90);
      if (r.length > 90) summary += '…';
    }
    var hasPhoto = !!(ev.photo_base64 || ev.photo || ev.has_photo);
    return '<div onclick="openEvalPastoDetailDesktop(\''+String(ev.id).replace(/\'/g,"\\'")+'\')" style="background:var(--sur);border:1px solid var(--bor);border-radius:10px;padding:14px;cursor:pointer;transition:border-color .15s,background .15s" onmouseover="this.style.borderColor=\'var(--green)\';this.style.background=\'var(--sur2)\'" onmouseout="this.style.borderColor=\'var(--bor)\';this.style.background=\'var(--sur)\'">' +
      '<div style="display:flex;justify-content:space-between;align-items:flex-start;gap:8px;margin-bottom:8px">' +
        '<div style="flex:1;min-width:0">' +
          '<div style="font-size:14px;font-weight:600;color:var(--text);overflow:hidden;text-overflow:ellipsis">🌿 '+escH(ev.potrero||'-')+'</div>' +
          (lotc ? '<div style="font-size:10px;color:var(--muted);font-family:DM Mono,monospace;margin-top:2px">Lote '+escH(lotc)+'</div>' : '') +
        '</div>' +
        (hasPhoto ? '<span style="font-size:10px;color:var(--muted)">📷</span>' : '') +
      '</div>' +
      '<div style="font-size:10px;color:var(--muted);font-family:DM Mono,monospace;margin-bottom:8px">'+escH(dtFmt)+(ev.by?' · '+escH(ev.by):'')+'</div>' +
      (summary ? '<div style="font-size:11px;color:'+pColor+';line-height:1.5;border-left:2px solid '+pColor+';padding-left:8px">'+escH(summary)+'</div>' : '<div style="font-size:11px;color:var(--muted);font-style:italic">Sin análisis disponible</div>') +
    '</div>';
  }).join('');
}

function openEvalPastoDetailDesktop(evalId) {
  var ev = (db.pasture_evals||[]).find(function(e){ return e.id == evalId; });
  if (!ev) return;
  _evpDetailId = evalId;
  var titleEl = document.getElementById('evp-det-title');
  if (titleEl) titleEl.textContent = '🌿 ' + (ev.potrero || 'Evaluación') + (ev.lot_code ? ' · Lote ' + ev.lot_code : '');

  var dt = new Date(ev.evaluated_at || ev.date || ev.created_at || 0);
  var dtFmt = isNaN(dt.getTime()) ? '' : dt.toLocaleString('es-BO',{day:'2-digit',month:'long',year:'numeric',hour:'2-digit',minute:'2-digit'});

  var content = document.getElementById('evp-det-content');
  if (!content) return;

  var html = '';
  html += '<div style="display:flex;gap:12px;margin-bottom:12px">';
  if (ev.potrero) html += '<div style="flex:1;background:var(--sur2);border:1px solid var(--bor);border-radius:8px;padding:10px"><div style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px">Potrero</div><div style="font-size:14px;font-weight:600;margin-top:3px">'+escH(ev.potrero)+'</div></div>';
  if (ev.lot_code || ev.lot) html += '<div style="flex:1;background:var(--sur2);border:1px solid var(--bor);border-radius:8px;padding:10px"><div style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px">Lote</div><div style="font-size:14px;font-weight:600;margin-top:3px">'+escH(ev.lot_code||ev.lot)+'</div></div>';
  html += '</div>';
  html += '<div style="font-size:11px;color:var(--muted);font-family:DM Mono,monospace;margin-bottom:12px">'+escH(dtFmt)+(ev.by?' · '+escH(ev.by):'')+'</div>';

  // Foto si está disponible
  // FIX v1.4.38: validar que el base64 sea real (mínimo 100 chars y caracteres válidos)
  // Bug observado: a veces photo_base64 contiene el id de la evaluación (data corrupto)
  var photoSrc = ev.photo_base64 || ev.photo || '';
  var isValidBase64 = photoSrc && photoSrc.length > 100 && /^[A-Za-z0-9+/=,:;A-Za-z]+$/.test(photoSrc.substring(0, 200));
  if (isValidBase64) {
    if (photoSrc.indexOf('data:') !== 0) photoSrc = 'data:image/jpeg;base64,' + photoSrc;
    html += '<div style="margin-bottom:12px;text-align:center"><img src="'+photoSrc+'" style="max-width:100%;max-height:300px;border-radius:8px;border:1px solid var(--bor)"></div>';
  } else if (ev.has_photo) {
    html += '<div style="background:var(--sur2);border:1px dashed var(--bor);border-radius:8px;padding:14px;text-align:center;color:var(--muted);font-size:11px;margin-bottom:12px">📷 Foto no disponible (no descargada o data corrupta)</div>';
  }

  // Resultado IA
  if (ev.result) {
    html += '<div style="background:var(--sur2);border:1px solid var(--bor);border-radius:8px;padding:14px;margin-bottom:8px">';
    html += '<div style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px">🤖 Análisis IA</div>';
    html += '<div style="font-size:13px;line-height:1.7;color:var(--text);white-space:pre-wrap">' +
      escH(ev.result).replace(/\n/g,'<br>').replace(/\*\*([^*]+)\*\*/g,'<b>$1</b>') +
      '</div></div>';
  }

  content.innerHTML = html;
  openModal('modal-evalpasto-detail');
}

function deleteEvalPastoDesktop() {
  if (!_evpDetailId) return;
  if (!confirm('¿Eliminar esta evaluación?')) return;

  // FIX v1.4.63: usar endpoint dedicado /api/pasture-eval/:id que maneja
  // _deleted_ids de forma atómica server-side. Antes usaba replaceTableInRailway
  // que tenía race conditions con la PWA Campo (la PWA podía re-pushear la eval
  // antes de que el _deleted_ids llegara al server).
  var idToDelete = _evpDetailId;
  var _delRec = (db.pasture_evals || []).find(function(r){ return String(r.id) === String(idToDelete); });
  var _delSummary = _delRec ? _summarizeRecord('pasture_evals', _delRec) : 'Evaluación pasto #' + idToDelete;
  try { auditLog('delete', 'pasture_evals', idToDelete, _delSummary); } catch(e){}

  // 1. Trackear local primero (atomic, sin red)
  trackDeletion(idToDelete, 'pasture_evals');
  db.pasture_evals = (db.pasture_evals||[]).filter(function(e){ return String(e.id) !== String(idToDelete); });
  saveDB();
  closeModal('modal-evalpasto-detail');
  _evpDetailId = null;
  renderEvalPasto();

  // 2. Llamar al endpoint dedicado del server (que también actualiza _deleted_ids)
  try {
    var apiUrl = (typeof getApiUrl === 'function') ? getApiUrl() : (localStorage.getItem('e5m_api_url') || 'https://estancia5m-api-production.up.railway.app/api');
    var token = localStorage.getItem('e5m_api_token') || '';
    if (apiUrl && token && navigator.onLine) {
      fetch(apiUrl + '/pasture-eval/' + encodeURIComponent(idToDelete), {
        method: 'DELETE',
        headers: { 'Authorization': 'Bearer ' + token }
      }).then(function(r){ return r.json(); }).then(function(d){
        if (d && d.ok) {
          console.log('[Pasto] DELETE server OK:', idToDelete, '(before:', d.before, '→ after:', d.after, ')');
        } else {
          console.warn('[Pasto] DELETE server respondió sin ok:', d);
        }
      }).catch(function(e){
        console.warn('[Pasto] DELETE server falló (queda local):', e.message);
      });
    }
  } catch(e) {
    console.warn('[Pasto] DELETE server exception:', e.message);
  }

  toast('Evaluación eliminada', 'success');
}

