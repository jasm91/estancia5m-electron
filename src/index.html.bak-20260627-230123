function fetchNDVI() {
  var apiKey = localStorage.getItem('e5m_agro_key') || AGRO_API_KEY || '';
  if (!apiKey) return;
  var coords = getWeatherCoords();
  var polyId = localStorage.getItem('e5m_agro_poly_id') || '';

  if (!polyId) {
    // Check if polygon already exists
    fetch('https://api.agromonitoring.com/agro/1.0/polygons?appid=' + apiKey)
    .then(function(r){return r.json();})
    .then(function(polys){
      if (Array.isArray(polys) && polys.length > 0) {
        var poly = polys[0];
        localStorage.setItem('e5m_agro_poly_id', poly.id);
        fetchNDVIData(apiKey, poly.id);
        return;
      }
      createNDVIPolygon(apiKey, coords);
    }).catch(function(e){
      document.getElementById('ndvi-content').innerHTML = '<div style="color:var(--red);font-size:12px">Error conectando con Agromonitoring: '+e.message+'</div>';
    });
    return;
  }
  fetchNDVIData(apiKey, polyId);
}

function createNDVIPolygon(apiKey, coords) {
  // Create polygon first
    var size = 0.02; // ~2km around center
    var polygon = {
      name: 'EstanciaPro',
      geo_json: {
        type: 'Feature',
        properties: {},
        geometry: {
          type: 'Polygon',
          coordinates: [[
            [coords.lon - size, coords.lat - size],
            [coords.lon + size, coords.lat - size],
            [coords.lon + size, coords.lat + size],
            [coords.lon - size, coords.lat + size],
            [coords.lon - size, coords.lat - size]
          ]]
        }
      }
    };
    fetch('https://api.agromonitoring.com/agro/1.0/polygons?appid=' + apiKey, {
      method: 'POST', headers: {'Content-Type':'application/json'},
      body: JSON.stringify(polygon)
    }).then(function(r){return r.json();}).then(function(d){
      if (d.id) {
        localStorage.setItem('e5m_agro_poly_id', d.id);
        _ndviPolyId = d.id;
        fetchNDVIData(apiKey, d.id);
      } else {
        document.getElementById('ndvi-content').innerHTML = '<div style="color:var(--red);font-size:12px">Error creando poligono: '+(d.message||JSON.stringify(d))+'</div>';
      }
    }).catch(function(e){
      document.getElementById('ndvi-content').innerHTML = '<div style="color:var(--red);font-size:12px">Error: '+e.message+'</div>';
    });
}

function fetchNDVIData(apiKey, polyId) {
  var end = Math.floor(Date.now() / 1000);
  var start = end - (30 * 86400); // Last 30 days
  fetch('https://api.agromonitoring.com/agro/1.0/image/search?start='+start+'&end='+end+'&polyid='+polyId+'&appid='+apiKey)
  .then(function(r){return r.json();})
  .then(function(images){
    if (!images.length) {
      document.getElementById('ndvi-content').innerHTML = '<div style="color:var(--muted);font-size:12px">No hay imagenes satelitales disponibles para los ultimos 30 dias.</div>';
      return;
    }
    // Get latest image with NDVI
    var latest = images[images.length - 1];
    var toHttps = function(u) { return u ? u.replace('http://','https://') : null; };
    var ndviUrl = latest.image ? toHttps(latest.image.ndvi) : null;
    var trueColorUrl = latest.image ? toHttps(latest.image.truecolor) : null;
    var statsUrl = latest.stats ? toHttps(latest.stats.ndvi) : null;
    var dt = new Date(latest.dt * 1000);

    var html = '<div style="font-size:12px;color:var(--muted);margin-bottom:8px">Ultima imagen: '+dt.toLocaleDateString()+' ('+latest.type+')</div>';

    if (statsUrl) {
      fetch(statsUrl).then(function(r){return r.json();}).then(function(stats){
        var mean = (stats.mean || 0).toFixed(3);
        var min = (stats.min || 0).toFixed(3);
        var max = (stats.max || 0).toFixed(3);
        var color = mean >= 0.6 ? 'var(--green)' : mean >= 0.3 ? 'var(--amber2)' : 'var(--red)';
        var label = mean >= 0.6 ? 'EXCELENTE' : mean >= 0.4 ? 'BUENO' : mean >= 0.3 ? 'MODERADO' : mean >= 0.2 ? 'DEGRADADO' : 'CRITICO';
        html += '<div style="display:flex;gap:16px;align-items:center">';
        html += '<div style="text-align:center"><div style="font-size:36px;font-weight:700;color:'+color+'">'+mean+'</div><div style="font-size:11px;color:var(--muted)">NDVI Promedio</div><div style="font-size:10px;font-weight:700;color:'+color+'">'+label+'</div></div>';
        html += '<div style="flex:1"><div style="font-size:11px;margin-bottom:4px">Min: '+min+' | Max: '+max+'</div>';
        html += '<div style="height:12px;background:linear-gradient(to right,#8B0000,#FF4500,#FFD700,#90EE90,#006400);border-radius:6px;position:relative">';
        html += '<div style="position:absolute;left:'+(mean*100)+'%;top:-2px;width:3px;height:16px;background:#fff;border:1px solid #000;border-radius:1px"></div>';
        html += '</div><div style="display:flex;justify-content:space-between;font-size:9px;color:var(--muted)"><span>0 Suelo</span><span>0.5</span><span>1.0 Verde</span></div></div>';
        html += '</div>';

        // Recommendations
        if (parseFloat(mean) < 0.3) {
          html += '<div style="margin-top:10px;padding:8px 12px;background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.3);border-radius:8px;font-size:12px">🔴 <b>Pasto degradado.</b> Considerar rotacion de lotes o suplementacion con alimento.</div>';
        } else if (parseFloat(mean) < 0.5) {
          html += '<div style="margin-top:10px;padding:8px 12px;background:rgba(245,166,35,.1);border:1px solid rgba(245,166,35,.3);border-radius:8px;font-size:12px">🟡 <b>Pasto moderado.</b> Monitorear y planificar rotacion si la tendencia baja.</div>';
        } else {
          html += '<div style="margin-top:10px;padding:8px 12px;background:rgba(34,197,94,.1);border:1px solid rgba(34,197,94,.3);border-radius:8px;font-size:12px">🟢 <b>Pasto en buen estado.</b> Condiciones optimas para pastoreo.</div>';
        }

        document.getElementById('ndvi-content').innerHTML = html;
      });
    }

    // Show NDVI image
    var mapEl = document.getElementById('ndvi-images');
    if (mapEl && ndviUrl) {
      mapEl.innerHTML = '<div style="display:flex;gap:8px;height:100%">' +
        (trueColorUrl ? '<div style="flex:1;position:relative"><img src="'+trueColorUrl+'" style="width:100%;height:100%;object-fit:cover;border-radius:6px"><div style="position:absolute;bottom:4px;left:4px;font-size:9px;color:#fff;background:rgba(0,0,0,.6);padding:2px 6px;border-radius:3px">Color real</div></div>' : '') +
        '<div style="flex:1;position:relative"><img src="'+ndviUrl+'" style="width:100%;height:100%;object-fit:cover;border-radius:6px"><div style="position:absolute;bottom:4px;left:4px;font-size:9px;color:#fff;background:rgba(0,0,0,.6);padding:2px 6px;border-radius:3px">NDVI</div></div>' +
        '</div>';
    }

    // NDVI history chart
    fetchNDVIHistory(apiKey, polyId);
  })
  .catch(function(e){
    document.getElementById('ndvi-content').innerHTML = '<div style="color:var(--red);font-size:12px">Error: '+e.message+'</div>';
  });
}

function fetchNDVIHistory(apiKey, polyId) {
  var end = Math.floor(Date.now() / 1000);
  var start = end - (180 * 86400); // 6 months
  fetch('https://api.agromonitoring.com/agro/1.0/ndvi/history?start='+start+'&end='+end+'&polyid='+polyId+'&appid='+apiKey)
  .then(function(r){return r.json();})
  .then(function(history){
    if (!history.length) return;
    var histEl = document.getElementById('ndvi-history');
    if (!histEl) return;
    var maxH = 120;
    var w = Math.max(400, history.length * 8);
    var vals = history.map(function(h){return h.data ? h.data.mean : 0;});
    var maxV = Math.max.apply(null, vals) || 1;
    var svg = '<svg viewBox="0 0 '+w+' '+(maxH+30)+'" style="width:100%;height:150px">';
    svg += '<text x="4" y="12" fill="var(--muted)" font-size="10">NDVI ultimos 6 meses</text>';
    var path = '';
    vals.forEach(function(v, i) {
      var x = i * (w / vals.length) + 10;
      var y = maxH - (v / maxV * (maxH - 20)) + 15;
      path += (i === 0 ? 'M' : 'L') + x + ',' + y;
    });
    svg += '<path d="'+path+'" fill="none" stroke="var(--green)" stroke-width="2"/>';
    // Add month labels
    history.forEach(function(h, i) {
      if (i % Math.ceil(history.length / 6) === 0) {
        var dt = new Date(h.dt * 1000);
        var x = i * (w / vals.length) + 10;
        svg += '<text x="'+x+'" y="'+(maxH+28)+'" fill="var(--muted)" font-size="9">'+dt.toLocaleDateString('es',{month:'short'})+'</text>';
      }
    });
    svg += '</svg>';
    histEl.innerHTML = '<div class="card" style="padding:12px">'+svg+'</div>';
  }).catch(function(){});
}

