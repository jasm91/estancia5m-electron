  });
  try { auditLog('update', 'compras_ganado', compra ? compra.id : _mcLoteCuarentena.code, 'Marcaje: ' + n + ' animales en ' + loteDest + (costoProporcional > 0 ? ' (costo Bs. ' + costoProporcional + ')' : '')); } catch(e){}
  // FIX v1.4.31: log explícito de movimientos en los lotes involucrados (origen y destino).
  try {
    var origenMsg = 'Marcaje saliente: ' + _mcLoteCuarentena.code + ' · ' + n + ' animales → ' + loteDest +
      (esCompleto ? ' (lote cerrado: cuarentena → marcado_completo)' : ' (parcial, quedan ' + _mcLoteCuarentena.animal_count + ' en cuarentena)');
    auditLog('update', 'lots', _mcLoteCuarentena.id, origenMsg, {
      animal_count: [_origenSnap.animal_count, _mcLoteCuarentena.animal_count],
      status: [_origenSnap.status, _mcLoteCuarentena.status || 'cuarentena']
    });
  } catch(e){}
  // Para el lote destino: si era recién creado, ya hay un audit 'create lots' del paso anterior.
  // Si era preexistente, registrar el ingreso de animales.
  if (!creandoNuevo) {
    try {
      var destinoMsg = 'Marcaje entrante: ' + loteDestObj.code + ' · +' + n + ' animales desde ' + _mcLoteCuarentena.code;
      auditLog('update', 'lots', loteDestObj.id, destinoMsg, {
        animal_count: [_destinoSnap.animal_count, loteDestObj.animal_count]
      });
    } catch(e){}
  }

  // Reset state
  _mcAnimals = [];
  _mcLoteCuarentena = null;
}

function renderComprasGanado() {
  var compras = db.compras_ganado || [];
  var tbody = document.getElementById('cg-tbody');
  if (!tbody) return;

  // KPIs
  var totalAnimales = compras.reduce(function(s,c) { return s + (c.animal_count||0); }, 0);
  var totalBs = compras.reduce(function(s,c) { return s + (c.total||0); }, 0);
  var totalKg = compras.reduce(function(s,c) { return s + (c.total_kg||0); }, 0);
  var pesoProm = totalAnimales > 0 ? Math.round(totalKg / totalAnimales * 10) / 10 : 0;
  var precioKgProm = totalKg > 0 ? Math.round(totalBs / totalKg * 100) / 100 : 0;

  var el;
  el = document.getElementById('cg-total-animales'); if(el) el.textContent = totalAnimales;
  el = document.getElementById('cg-total-bs'); if(el) el.textContent = 'Bs. ' + totalBs.toLocaleString();
  el = document.getElementById('cg-peso-prom'); if(el) el.textContent = pesoProm + ' kg';
  el = document.getElementById('cg-stat-precio-kg'); if(el) el.textContent = 'Bs. ' + precioKgProm;

  if (!compras.length) {
    tbody.innerHTML = '<tr><td colspan="9" style="text-align:center;padding:30px;color:var(--muted)">Sin compras de ganado registradas</td></tr>';
    return;
  }

  tbody.innerHTML = compras.sort(function(a,b) { return (b.fecha||'').localeCompare(a.fecha||''); }).map(function(c) {
    var detalle = (c.animales || []).map(function(a) { return a.id + ' (' + a.peso + 'kg)'; }).join(', ');
    return '<tr>' +
      '<td>' + fmtDT(c.created_at || c.fecha || '') + '</td>' +
      '<td>' + (c.proveedor||'') + '</td>' +
      '<td style="font-weight:700;color:var(--amber2)">' + (c.animal_count||0) + '</td>' +
      '<td>' + (c.total_kg||0).toLocaleString() + ' kg</td>' +
      '<td>Bs. ' + (c.price_per_kg||0) + '</td>' +
      '<td style="font-weight:700;color:var(--green)">Bs. ' + (c.total||0).toLocaleString() + '</td>' +
      '<td>' + (c.lot_code||'') + '</td>' +
      '<td style="font-size:10px;color:var(--muted);max-width:200px;overflow:hidden;text-overflow:ellipsis">' + detalle + '</td>' +
      '<td><button class="btn btn-ghost btn-sm" onclick="deleteCompraGanado(\'' + c.id + '\')" style="color:var(--red)">🗑</button></td>' +
      '</tr>';
  }).join('');
}

function deleteCompraGanado(id) {
  var compra = (db.compras_ganado || []).find(function(c){ return c.id === id; });
  if (!compra) return;
  var loteCuar = (compra.cuarentena && compra.lot_code) ? compra.lot_code : null;
  var msg = '¿Eliminar esta compra de ganado?';
  if (loteCuar) msg += '\n\nTambién se eliminará el lote ' + loteCuar + ' (' + (compra.animal_count||0) + ' animales en cuarentena).';
  if (!confirm(msg)) return;
  
  // FIX v1.4.35: audit log para deleteCompraGanado
  var _delRec_deleteCompraGanado = (db.compras_ganado || []).find(function(r){ return String(r.id) === String(id); });
  var _delSummary_deleteCompraGanado = _delRec_deleteCompraGanado ? _summarizeRecord('compras_ganado', _delRec_deleteCompraGanado) : 'Compra ganado #' + id;
  try { auditLog('delete', 'compras_ganado', id, _delSummary_deleteCompraGanado); } catch(e){}
  trackDeletion(id, 'compras_ganado');
  db.compras_ganado = (db.compras_ganado || []).filter(function(c) { return c.id !== id; });
  // Si tenía lote de cuarentena asociado, borrarlo también
  if (loteCuar) {
    var lote = (db.lots || []).find(function(l){ return l.code === loteCuar; });
    if (lote) {
      trackDeletion(lote.id, 'lots');
      db.lots = db.lots.filter(function(l){ return l.id !== lote.id; });
    }
    // Borrar cache de animales si los tuviera
    try {
      var rawAnim = JSON.parse(localStorage.getItem('e5m_animals') || '{}');
      if (rawAnim[loteCuar]) {
        delete rawAnim[loteCuar];
        localStorage.setItem('e5m_animals', JSON.stringify(rawAnim));
      }
    } catch(e){}
  }
  saveDB(true);
  // Push secuencial: animals → lots → compras_ganado
  if (loteCuar) {
    var animsAfter = {};
    try { animsAfter = JSON.parse(localStorage.getItem('e5m_animals') || '{}'); } catch(e){}
    replaceTableInRailway('animals', animsAfter).then(function(){
      return replaceTableInRailway('lots', db.lots || []);
    }).then(function(){
      replaceTableInRailway('compras_ganado', db.compras_ganado || []);
    });
  } else {
    replaceTableInRailway('compras_ganado', db.compras_ganado || []);
  }
  renderComprasGanado();
  if (typeof renderLotes === 'function') renderLotes();
  if (typeof renderDashboard === 'function') renderDashboard();
  toast(loteCuar ? ('Compra y lote ' + loteCuar + ' eliminados') : 'Compra eliminada', 'success');
}

function exportComprasGanado() {
  var compras = db.compras_ganado || [];
  if (!compras.length) { toast('Sin compras para exportar', 'error'); return; }
  exportCSV('compras_ganado_estanciapro',
    ['Fecha','Proveedor','Animales','Kg Totales','Bs/kg','Total Bs','Lote','Notas'],
    compras.map(function(c) { return [c.fecha,c.proveedor,c.animal_count,c.total_kg,c.price_per_kg,c.total,c.lot_code,c.notes]; })
  );
}

