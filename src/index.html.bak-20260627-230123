function triggerMinVersionUpdate() {
  var statusEl = document.getElementById('mvb-status');
  var btn = document.getElementById('mvb-update-btn');
  if (btn) btn.disabled = true;
  if (statusEl) statusEl.textContent = '⏳ Buscando y descargando actualización...';

  // Si electron-updater está disponible, usarlo
  if (window.estancia && window.estancia.app) {
    // Listeners de progreso (si existen)
    if (typeof window.estancia.app.onUpdateProgress === 'function') {
      try {
        window.estancia.app.onUpdateProgress(function(data){
          if (statusEl && data && typeof data.percent === 'number') {
            statusEl.textContent = '⬇️ Descargando... ' + Math.round(data.percent) + '%';
          }
        });
      } catch(e){}
    }
    if (typeof window.estancia.app.onUpdateDownloaded === 'function') {
      try {
        window.estancia.app.onUpdateDownloaded(function(){
          if (statusEl) statusEl.textContent = '✅ Descarga completa. Instalando en 2 segundos...';
          setTimeout(function(){
            if (typeof window.estancia.app.quitAndInstall === 'function') {
              window.estancia.app.quitAndInstall();
            }
          }, 2000);
        });
      } catch(e){}
    }
    if (typeof window.estancia.app.onUpdateError === 'function') {
      try {
        window.estancia.app.onUpdateError(function(msg){
          if (statusEl) statusEl.innerHTML = '❌ Error: ' + (msg || 'no se pudo descargar') + '. <a href="#" onclick="window.estancia.app.openExternal(\'https://github.com/jasm91/estancia5m-electron/releases/latest\');return false;" style="color:var(--green)">Descargar manual</a>';
          if (btn) btn.disabled = false;
        });
      } catch(e){}
    }

    // Usar forceUpdate que dispara el flow completo
    if (typeof window.estancia.app.forceUpdate === 'function') {
      window.estancia.app.forceUpdate().catch(function(e){
        console.error('[MinVersion] Update error:', e);
        if (statusEl) statusEl.innerHTML = '❌ Error al iniciar descarga. <a href="#" onclick="window.estancia.app.openExternal(\'https://github.com/jasm91/estancia5m-electron/releases/latest\');return false;" style="color:var(--green)">Descargar manual</a>';
        if (btn) btn.disabled = false;
      });
    } else if (typeof window.estancia.app.checkUpdate === 'function') {
      // Fallback: solo checkUpdate, después usuario tendrá que cerrar y reabrir
      window.estancia.app.checkUpdate().catch(function(e){
        console.error('[MinVersion] checkUpdate error:', e);
      });
      if (statusEl) statusEl.textContent = '⏳ Verificando... cerrá y reabrí la app cuando termine la descarga';
    } else {
      // Fallback final: abrir página
      if (statusEl) statusEl.innerHTML = '↗ Abriendo página de descarga...';
      if (window.estancia.app.openExternal) {
        window.estancia.app.openExternal('https://github.com/jasm91/estancia5m-electron/releases/latest');
      }
      if (btn) btn.disabled = false;
    }
  } else {
    // Sin electron API: abrir página
    if (statusEl) statusEl.innerHTML = '↗ Abriendo página de descarga...';
    window.open('https://github.com/jasm91/estancia5m-electron/releases/latest', '_blank');
    if (btn) btn.disabled = false;
  }
}

function showUpdateBadge(version, downloaded) {
  var badge = document.getElementById('header-update-badge');
  if (!badge) return;
  badge.style.display = 'inline-block';
  badge.title = downloaded
    ? 'v' + version + ' descargada y lista para instalar. Click para ir a actualizar.'
    : 'Nueva versión v' + version + ' disponible. Click para descargar.';
  badge.innerHTML = downloaded ? ('✅ v' + version + ' lista') : ('⬇️ Nueva v' + version);
}

function hideUpdateBadge() {
  var badge = document.getElementById('header-update-badge');
  if (badge) badge.style.display = 'none';
}

function showUpdateNotification(version, downloaded) {
  // Notificación nativa del sistema operativo
  if (!('Notification' in window)) return;
  var send = function(){
    try {
      new Notification('EstanciaPro — Nueva Versión Disponible', {
        body: downloaded
          ? 'La versión ' + version + ' ya está descargada. Reiniciá la app para instalarla.'
          : 'La versión ' + version + ' ya está disponible. Click en "Nueva versión" del header para actualizar.',
        icon: 'assets/icon.png',
        tag: 'estanciapro-update-' + version,
        requireInteraction: false
      });
    } catch(e) { console.warn('[UpdateNotify]', e.message); }
  };
  if (Notification.permission === 'granted') {
    send();
  } else if (Notification.permission !== 'denied') {
    Notification.requestPermission().then(function(p){ if (p === 'granted') send(); });
  }
}

