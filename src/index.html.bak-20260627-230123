function calcCGTotal() {
  // Si estamos en modo cuarentena, delegar
  var marcar = !!(document.getElementById('cg-marcar-ahora') || {}).checked;
  if (!marcar) { calcCGCuarentenaTotal(); return; }
  var precioKg = parseFloat(document.getElementById('cg-precio-kg').value) || 0;
  var pesoTotal = _cgAnimals.reduce(function(s,a) { return s + (a.peso||0); }, 0);
  var count = _cgAnimals.length;
  var pesoProm = count > 0 ? Math.round(pesoTotal / count * 10) / 10 : 0;
  var total = Math.round(pesoTotal * precioKg * 100) / 100;

  document.getElementById('cg-count-display').textContent = count;
  document.getElementById('cg-peso-total').textContent = pesoTotal.toLocaleString() + ' kg';
  document.getElementById('cg-peso-prom-display').textContent = pesoProm + ' kg';
  document.getElementById('cg-total').value = 'Bs. ' + total.toLocaleString();
}

var _saveCompraGanadoInProgress = false;
function saveCompraGanado() {
  // Guard contra doble-click / submits múltiples (mismo bug que saveAdvance)
  if (_saveCompraGanadoInProgress) { console.warn('[saveCompraGanado] Ya está en progreso, ignorando'); return; }
  _saveCompraGanadoInProgress = true;
  // Desactivar el botón visualmente
  var _btnCG = document.querySelector('#modal-compra-ganado .btn-primary');
  if (_btnCG) { _btnCG.disabled = true; _btnCG.textContent = 'Guardando...'; }

  function _releaseCG() {
    _saveCompraGanadoInProgress = false;
    if (_btnCG) { _btnCG.disabled = false; _btnCG.textContent = 'Guardar'; }
  }

  try {
  var proveedor = document.getElementById('cg-proveedor').value.trim();
  var fecha = document.getElementById('cg-fecha').value;
  var lote = document.getElementById('cg-lote').value;
  var categoria = document.getElementById('cg-categoria').value;
  var raza = document.getElementById('cg-raza').value;
  var precioKg = parseFloat(document.getElementById('cg-precio-kg').value) || 0;
  var notas = document.getElementById('cg-notas').value.trim();
  var marcarAhora = !!(document.getElementById('cg-marcar-ahora') || {}).checked;

  if (!proveedor) { toast('Ingresa el proveedor', 'error'); _releaseCG(); return; }
  if (!fecha) { toast('Ingresa la fecha', 'error'); _releaseCG(); return; }
  // FIX v1.4.34: no permitir fechas futuras
  if (!validateNotFuture(fecha, 'fecha de compra')) { _releaseCG(); return; }
  if (!precioKg) { toast('Ingresa el precio por kg', 'error'); _releaseCG(); return; }

  // ────── MODO CUARENTENA (animales sin ID, lote temporal) ──────
  if (!marcarAhora) {
    var cantCuar = parseInt((document.getElementById('cg-cuarentena-count')||{}).value) || 0;
    var pesoPromCuar = parseFloat((document.getElementById('cg-cuarentena-peso-prom')||{}).value) || 0;
    if (!cantCuar) { toast('Ingresa la cantidad de cabezas', 'error'); _releaseCG(); return; }
    if (!pesoPromCuar) { toast('Ingresa el peso promedio estimado', 'error'); _releaseCG(); return; }

    // Detectar duplicado reciente: misma compra (proveedor+fecha+cant+precio) en últimos 60s
    var nowMsCG = Date.now();
    var dupRecent = (db.compras_ganado || []).find(function(c){
      if (c.proveedor !== proveedor || c.fecha !== fecha) return false;
      if (c.animal_count !== cantCuar || c.price_per_kg !== precioKg) return false;
      var cTime = c.created_at ? new Date(c.created_at).getTime() : 0;
      return cTime && (nowMsCG - cTime) < 60000;
    });
    if (dupRecent) {
      if (!confirm('Ya hay una compra idéntica de ' + proveedor + ' (' + cantCuar + ' cab.) registrada hace menos de 1 minuto.\n\n¿Estás seguro de registrar otra?')) { _releaseCG(); return; }
    }

    var pesoTotalCuar = Math.round(cantCuar * pesoPromCuar * 10) / 10;
    var totalCuar = Math.round(pesoTotalCuar * precioKg * 100) / 100;

    // Generar código único de cuarentena: CUAR-001, CUAR-002, ...
    var existingCuar = (db.lots || []).filter(function(l){ return /^CUAR-\d+$/.test(l.code); });
    var maxN = 0;
    existingCuar.forEach(function(l){ var n = parseInt(l.code.replace('CUAR-','')) || 0; if (n > maxN) maxN = n; });
    var nuevoCode = 'CUAR-' + String(maxN + 1).padStart(3, '0');

    // Crear lote temporal de cuarentena
    if (!db.next_ids) db.next_ids = {};
    if (!db.next_ids.lot) db.next_ids.lot = (db.lots||[]).reduce(function(m,l){return Math.max(m, l.id||0);},0) + 1;
    var nuevoLote = {
      id: db.next_ids.lot++,
      code: nuevoCode,
      breed: raza,
      status: 'cuarentena',
      paddock: 'Cuarentena',
      category: categoria,
      avg_weight: pesoPromCuar,
      entry_date: fecha,
      animal_count: cantCuar,
      notes: 'Cuarentena de compra de ' + proveedor + (notas ? ' — ' + notas : ''),
      cuarentena_origen: proveedor,
      cuarentena_fecha_compra: fecha,
      created_at: new Date().toISOString()
    };
    db.lots.push(nuevoLote);
    // v1.4.104: garantizar entry en rotation_history para el lote de cuarentena
    _ensureRotationEntry(nuevoLote, { reason: 'Compra: cuarentena de ' + proveedor });

    // Registrar la compra (sin animales individuales)
    if (!db.compras_ganado) db.compras_ganado = [];
    db.compras_ganado.push({
      id: 'cg_' + Date.now(),
      proveedor: proveedor,
      fecha: fecha,
      lot_code: nuevoCode,
      categoria: categoria,
      raza: raza,
      animal_count: cantCuar,
      total_kg: pesoTotalCuar,
      price_per_kg: precioKg,
      total: totalCuar,
      animales: [],   // sin IDs todavía
      cuarentena: true,
      marcaje_progreso: 0,
      notes: notas,
      created_at: new Date().toISOString()
    });
    // Auto-Kardex
    if (!db.kardex) db.kardex = [];
    db.kardex.push({
      id: Date.now()+1, lote: nuevoCode, tipo: 'compra', fecha: fecha,
      cabezas: cantCuar, precio: precioKg, total: totalCuar,
      desc: 'Compra de ' + proveedor + ' — ' + cantCuar + ' cab. (cuarentena)',
      by: 'Desktop', created_at: new Date().toISOString(), auto: true
    });

    localStorage.setItem(DB_KEY, JSON.stringify(db));
    closeModal('modal-compra-ganado');
    renderComprasGanado();
    renderLotes();
    renderDashboard();
    toast('Compra registrada en cuarentena: ' + nuevoCode + ' (' + cantCuar + ' animales)', 'success');

    replaceTableInRailway('lots', db.lots);
    replaceTableInRailway('compras_ganado', db.compras_ganado);
    replaceTableInRailway('kardex', db.kardex);
    try { auditLog('create', 'compras_ganado', 'cg_'+Date.now(), 'Compra cuarentena: ' + cantCuar + ' cab. de ' + proveedor); } catch(e){}
    _releaseCG();
    return;
  }

  // ────── MODO MARCAJE INMEDIATO (animales con ID y peso individuales) ──────
  if (!lote) { toast('Selecciona el lote destino', 'error'); _releaseCG(); return; }
  if (!_cgAnimals.length) { toast('Agrega al menos un animal', 'error'); _releaseCG(); return; }

  var pesoTotal = _cgAnimals.reduce(function(s,a) { return s + (a.peso||0); }, 0);
  var total = Math.round(pesoTotal * precioKg * 100) / 100;

  // Obtener DB de animales
  var animals = getAnimalesDB();

  // Validar IDs duplicados
  var allExistingIds = {};
  Object.values(animals).forEach(function(list) {
    list.forEach(function(a) { allExistingIds[String(a.id)] = true; });
  });

  // Asignar IDs vacíos y validar duplicados
  var maxId = 0;
  Object.values(animals).forEach(function(list) {
    list.forEach(function(a) {
      var num = parseInt(String(a.id).replace(/[^0-9]/g, '')) || 0;
      if (num > maxId) maxId = num;
    });
  });

  var duplicados = [];
  _cgAnimals.forEach(function(a, i) {
    if (!a.id) {
      a.id = String(maxId + 1 + i);
    } else if (allExistingIds[String(a.id)]) {
      duplicados.push(a.id);
    }
  });

  if (duplicados.length) {
    toast('IDs duplicados: ' + duplicados.join(', ') + '. Cambia los IDs antes de guardar.', 'error');
    return;
  }

  // Agregar animales al lote
  if (!animals[lote]) animals[lote] = [];
  _cgAnimals.forEach(function(a) {
    animals[lote].push({
      id: String(a.id),
      raza: a.raza || '',
      pesajes: [{ fecha: fecha, peso: a.peso }]
    });
  });
  saveAnimalesDB(animals);

  // Actualizar conteo del lote: INCREMENTAR (no reemplazar)
  var lotObj = db.lots.find(function(l) { return l.code === lote; });
  if (lotObj) {
    lotObj.animal_count = (lotObj.animal_count || 0) + _cgAnimals.length;
    var allPesos = animals[lote].map(function(a) {
      var ps = a.pesajes || [];
      return ps.length ? ps[ps.length-1].peso : 0;
    }).filter(function(p) { return p > 0; });
    if (allPesos.length) lotObj.avg_weight = Math.round(allPesos.reduce(function(s,p){return s+p;},0) / allPesos.length * 10) / 10;
  }

  // Registrar la compra de ganado
  if (!db.compras_ganado) db.compras_ganado = [];
  db.compras_ganado.push({
    id: 'cg_' + Date.now(),
    proveedor: proveedor,
    fecha: fecha,
    lot_code: lote,
    categoria: categoria,
    animal_count: _cgAnimals.length,
    total_kg: pesoTotal,
    price_per_kg: precioKg,
    total: total,
    animales: _cgAnimals.map(function(a) { return { id: a.id, peso: a.peso, raza: a.raza }; }),
    notes: notas,
    created_at: new Date().toISOString()
  });
  // Auto-Kardex
  if (!db.kardex) db.kardex = [];
  db.kardex.push({id:Date.now()+1,lote:lote,tipo:'compra',fecha:fecha,cabezas:_cgAnimals.length,precio:parseFloat(precioKg)||0,total:total,desc:'Compra de '+(proveedor||'')+' — '+_cgAnimals.length+' cab',by:'Desktop',created_at:new Date().toISOString(),auto:true});

  // NOTA: NO insertar en db.cuentas. El reporte de Contabilidad ya genera el registro
  // automáticamente como derivado de db.compras_ganado (ver renderContabilidad).
  // Insertarlo aquí causaba duplicación (un registro derivado + uno espejo en distintas categorías).

  // Guardar SIN trigger de pull-push (evita que Railway sobreescriba el conteo)
  localStorage.setItem(DB_KEY, JSON.stringify(db));
  closeModal('modal-compra-ganado');

  renderComprasGanado();
  renderLotes();
  renderDashboard();
  toast('Compra registrada: ' + _cgAnimals.length + ' animales ingresados al lote ' + lote, 'success');
  _cgAnimals = [];

  // Push después de renderizar (sin pull que sobreescriba)
  clearTimeout(window._syncTimer);
  window._syncTimer = setTimeout(function() { pushDesktopRecords(); }, 2000);
  } catch(e) {
    console.error('[saveCompraGanado] error:', e);
    toast('Error al guardar compra: ' + e.message, 'error');
  } finally {
    _releaseCG();
  }
}

// ══════════════════════════════════════════════════
// MARCAJE de cuarentena (asignar IDs a animales)
// ══════════════════════════════════════════════════

var _mcAnimals = [];        // animales que se están marcando
var _mcLoteCuarentena = null;

function openMarcarCuarentena(lotIdOrCode) {
  // v1.8.23: buscar por code primero (único y estable), luego por id (compatibilidad).
  // Antes buscaba solo por id, y con IDs duplicados .find() agarraba el lote equivocado.
  var lot = (db.lots || []).find(function(l) { return l.code === lotIdOrCode; });
  if (!lot) lot = (db.lots || []).find(function(l) { return String(l.id) === String(lotIdOrCode); });
  if (!lot) { toast('Lote no encontrado', 'error'); return; }
  if (lot.status !== 'cuarentena') { toast('Este lote no está en cuarentena', 'error'); return; }
  _mcLoteCuarentena = lot;
  _mcAnimals = [];

  // Pre-cargar animales ya marcados (si los hay) — viven en e5m_animals[lot.code]
  var animDB = (typeof getAnimalesDB === 'function') ? getAnimalesDB() : {};
  var existing = animDB[lot.code] || [];
  existing.forEach(function(a) {
    _mcAnimals.push({
      id: a.id || a.animal_id || '',
      peso: (a.pesajes && a.pesajes.length) ? a.pesajes[a.pesajes.length-1].peso : 0,
      categoria: a.categoria || lot.category || '',
      raza: a.raza || a.breed || lot.breed || ''
    });
  });

  // UI labels
  document.getElementById('mc-lote-code').textContent = lot.code;
  var info = '<strong>' + lot.animal_count + ' cabezas</strong> de cuarentena · ';
  info += 'Origen: <strong>' + (lot.cuarentena_origen || '—') + '</strong> · ';
  info += 'Compra: ' + (lot.cuarentena_fecha_compra || lot.entry_date || '—') + ' · ';
  info += 'Peso prom estimado: <strong>' + (lot.avg_weight || 0) + ' kg</strong>';
  document.getElementById('mc-info').innerHTML = info;
  document.getElementById('mc-fecha').value = (typeof localDate === 'function') ? localDate() : new Date().toISOString().slice(0,10);

  // Poblar dropdown lotes destino (activos solamente)
  var sel = document.getElementById('mc-lote-destino');
  sel.innerHTML = '<option value="">Seleccionar lote activo...</option>' +
                  '<option value="__NEW__" style="color:#A855F7;font-weight:600">➕ Crear lote nuevo...</option>';
  (db.lots || []).forEach(function(l) {
    if (l.id === lot.id) return; // no incluir el mismo lote de cuarentena
    if (l.status === 'activo' || l.status === 'active' || !l.status) {
      sel.innerHTML += '<option value="' + l.code + '">' + l.code + ' - ' + l.category + ' (' + (l.animal_count||0) + ' cab.)</option>';
    }
  });
  sel.onchange = function() { onMcLoteDestinoChange(this.value); };
  // Reset campos de creación si están abiertos
  var newBox = document.getElementById('mc-new-lot-box');
  if (newBox) newBox.style.display = 'none';

  renderMCAnimals();
  openModal('modal-marcar-cuarentena');
}

// Toggle del sub-form de creación de lote nuevo cuando elige "➕ Crear lote nuevo"
function onMcLoteDestinoChange(value) {
  var box = document.getElementById('mc-new-lot-box');
  if (!box) return;
  if (value === '__NEW__') {
    box.style.display = 'block';
    // Defaults heredados del lote de cuarentena
    var codeInput = document.getElementById('mc-new-code');
    var catSel = document.getElementById('mc-new-category');
    var breedInput = document.getElementById('mc-new-breed');
    var paddockSel = document.getElementById('mc-new-paddock');
    if (codeInput) codeInput.value = '';
    if (catSel && _mcLoteCuarentena && _mcLoteCuarentena.category) {
      // Buscar opción que matchee, si no existe dejar primera
      for (var i=0; i<catSel.options.length; i++) {
        if (catSel.options[i].value === _mcLoteCuarentena.category) { catSel.selectedIndex = i; break; }
      }
    }
    if (breedInput && _mcLoteCuarentena) breedInput.value = _mcLoteCuarentena.breed || '';
    // Poblar potreros desde estancia_params (si existen)
    if (paddockSel) {
      paddockSel.innerHTML = '<option value="">Sin asignar</option>';
      try {
        var params = JSON.parse(localStorage.getItem('e5m_params') || '{}');
        var potreros = params.potreros || [];
        potreros.forEach(function(p){
          var nombre = (typeof p === 'string') ? p : (p.name || p.nombre || '');
          if (nombre) paddockSel.innerHTML += '<option value="' + nombre + '">' + nombre + '</option>';
        });
      } catch(e){}
    }
    if (codeInput) setTimeout(function(){ codeInput.focus(); }, 100);
  } else {
    box.style.display = 'none';
  }
}

function addMCAnimal() {
  if (_mcAnimals.length >= (_mcLoteCuarentena ? _mcLoteCuarentena.animal_count : 9999)) {
    toast('Ya alcanzaste la cantidad de la compra', 'warning');
    return;
  }
  _mcAnimals.push({
    id: '',
    peso: _mcLoteCuarentena ? _mcLoteCuarentena.avg_weight || 0 : 0,
    categoria: _mcLoteCuarentena ? _mcLoteCuarentena.category : '',
    raza: _mcLoteCuarentena ? _mcLoteCuarentena.breed : ''
  });
  renderMCAnimals();
}

function addMCAnimalsBatch() {
  if (!_mcLoteCuarentena) return;
  var faltan = (_mcLoteCuarentena.animal_count || 0) - _mcAnimals.length;
  if (faltan <= 0) { toast('Ya están todos agregados', 'info'); return; }
  for (var i = 0; i < faltan; i++) {
    _mcAnimals.push({
      id: '',
      peso: _mcLoteCuarentena.avg_weight || 0,
      categoria: _mcLoteCuarentena.category || '',
      raza: _mcLoteCuarentena.breed || ''
    });
  }
  renderMCAnimals();
}

function removeMCAnimal(idx) {
  _mcAnimals.splice(idx, 1);
  renderMCAnimals();
}

function renderMCAnimals() {
  var tbody = document.getElementById('mc-animals-tbody');
  if (!tbody) return;
  var params = (typeof getParams === 'function') ? getParams() : { categorias: [], razas: [] };
  var catOptions = (params.categorias || []).map(function(c) { return c.name; });
  var razOptions = (params.razas || []).map(function(r) { return r.name; });
  tbody.innerHTML = _mcAnimals.map(function(a, i) {
    var catSel = '<select class="form-select" style="width:90px;padding:4px 6px;font-size:11px" oninput="_mcAnimals['+i+'].categoria=this.value">' +
      catOptions.map(function(c){ return '<option value="'+c+'"'+(a.categoria===c?' selected':'')+'>'+c+'</option>'; }).join('') + '</select>';
    var razSel = '<select class="form-select" style="width:80px;padding:4px 6px;font-size:11px" oninput="_mcAnimals['+i+'].raza=this.value">' +
      razOptions.map(function(r){ return '<option value="'+r+'"'+(a.raza===r?' selected':'')+'>'+r+'</option>'; }).join('') + '</select>';
    return '<tr>' +
      '<td style="color:var(--muted);font-size:10px">'+(i+1)+'</td>' +
      '<td><input class="form-input" style="width:110px;padding:4px 8px;font-size:11px" value="' + escH(String(a.id||'')) + '" placeholder="ej: '+(_mcLoteCuarentena?_mcLoteCuarentena.code:'C')+'-'+String(i+1).padStart(4,'0')+'" oninput="_mcAnimals['+i+'].id=this.value"></td>' +
      '<td><input class="form-input" type="number" step="0.1" style="width:80px;padding:4px 8px;font-size:11px" value="' + (a.peso||'') + '" placeholder="kg" oninput="_mcAnimals['+i+'].peso=parseFloat(this.value)||0;updateMCStats()"></td>' +
      '<td>' + catSel + '</td>' +
      '<td>' + razSel + '</td>' +
      '<td><button class="btn btn-ghost btn-sm" onclick="removeMCAnimal('+i+')" style="padding:2px 6px;color:var(--red)">✕</button></td>' +
      '</tr>';
  }).join('');
  updateMCStats();
}

function updateMCStats() {
  var n = _mcAnimals.length;
  var pesoTotal = _mcAnimals.reduce(function(s, a) { return s + (a.peso || 0); }, 0);
  var pesoProm = n > 0 ? Math.round(pesoTotal / n * 10) / 10 : 0;
  var totalCuar = _mcLoteCuarentena ? (_mcLoteCuarentena.animal_count || 0) : 0;
  var elCount = document.getElementById('mc-count');
  var elTotal = document.getElementById('mc-peso-total');
  var elProm = document.getElementById('mc-peso-prom');
  var elProgreso = document.getElementById('mc-progreso');
  if (elCount) elCount.textContent = n;
  if (elTotal) elTotal.textContent = Math.round(pesoTotal) + ' kg';
  if (elProm) elProm.textContent = pesoProm + ' kg';
  if (elProgreso) elProgreso.textContent = '(' + n + ' / ' + totalCuar + ')';
}

function saveMarcaje() {
  if (!_mcLoteCuarentena) { toast('Sin lote de cuarentena', 'error'); return; }
  var loteDest = document.getElementById('mc-lote-destino').value;
  var fecha = document.getElementById('mc-fecha').value;
  if (!loteDest) { toast('Seleccioná el lote destino', 'error'); return; }
  if (!fecha) { toast('Ingresá fecha de marcaje', 'error'); return; }
  // FIX v1.4.34: no permitir fechas futuras
  if (!validateNotFuture(fecha, 'fecha de marcaje')) return;

  // Validar: todos deben tener ID y peso
  var sinId = _mcAnimals.filter(function(a) { return !String(a.id || '').trim(); });
  var sinPeso = _mcAnimals.filter(function(a) { return !a.peso || a.peso <= 0; });
  if (sinId.length) { toast(sinId.length + ' animales sin ID', 'error'); return; }
  if (sinPeso.length) { toast(sinPeso.length + ' animales sin peso', 'error'); return; }
  if (!_mcAnimals.length) { toast('Marcá al menos 1 animal', 'error'); return; }

  // Validar IDs únicos dentro del marcaje
  var idsSet = {};
  var dup = '';
  _mcAnimals.some(function(a) {
    var id = String(a.id).trim();
    if (idsSet[id]) { dup = id; return true; }
    idsSet[id] = true;
    return false;
  });
  if (dup) { toast('ID duplicado: ' + dup, 'error'); return; }

  // ── Crear lote nuevo en caliente, si corresponde
  var creandoNuevo = false;
  if (loteDest === '__NEW__') {
    var newCode = (document.getElementById('mc-new-code').value || '').trim().toUpperCase();
    if (!newCode) { toast('Ingresá el código del lote nuevo', 'error'); return; }
    if (db.lots.find(function(l){ return (l.code||'').toUpperCase() === newCode; })) {
      var _uniqMc = _uniqueLotCode(newCode, fecha || localDate());
      if(!confirm('Ya existe un lote "'+newCode+'".\n\nPara no mezclarlo, se creará como:\n\n    '+_uniqMc+'\n\n¿Continuar?')){ return; }
      newCode = _uniqMc;
    }
    var newCat = (document.getElementById('mc-new-category').value) || _mcLoteCuarentena.category || 'novillo';
    var newBreed = (document.getElementById('mc-new-breed').value || '').trim() || _mcLoteCuarentena.breed || '';
    var newPaddock = (document.getElementById('mc-new-paddock').value || '').trim();
    // Validar capacidad del potrero si se asignó
    if (newPaddock && typeof getPotreroCapacity === 'function') {
      var cap = getPotreroCapacity(newPaddock);
      if (cap && _mcAnimals.length > cap) {
        toast('Potrero "' + newPaddock + '" tiene capacidad para ' + cap + ' animales. Querés cargar ' + _mcAnimals.length, 'error');
        return;
      }
    }
    if (!db.next_ids) db.next_ids = {};
    if (!db.next_ids.lot) db.next_ids.lot = ((db.lots||[]).reduce(function(m,l){return Math.max(m,l.id||0);},0)) + 1;
    var nuevoLote = {
      id: db.next_ids.lot++,
      code: newCode,
      category: newCat,
      breed: newBreed,
      paddock: newPaddock,
      animal_count: 0,    // se incrementa abajo
      avg_weight: null,
      entry_date: fecha,
      status: 'active',
      notes: 'Creado desde marcaje de cuarentena ' + _mcLoteCuarentena.code,
      created_at: new Date().toISOString()
    };
    db.lots.push(nuevoLote);
    loteDest = newCode;
    creandoNuevo = true;
    try { auditLog('create', 'lots', nuevoLote.id, _summarizeRecord('lots', nuevoLote)); } catch(e){}
  }

  var totalCuar = _mcLoteCuarentena.animal_count || 0;
  var n = _mcAnimals.length;
  var esCompleto = n >= totalCuar;

  // Cargar animales al lote destino
  var rawAnim = JSON.parse(localStorage.getItem('e5m_animals') || '{}');
  if (!rawAnim[loteDest]) rawAnim[loteDest] = [];

  _mcAnimals.forEach(function(a) {
    rawAnim[loteDest].push({
      id: String(a.id),
      raza: a.raza || _mcLoteCuarentena.breed || '',
      categoria: a.categoria || _mcLoteCuarentena.category || '',
      pesajes: [{ fecha: fecha, peso: a.peso, tipo: 'marcaje', nota: 'Marcaje desde ' + _mcLoteCuarentena.code }]
    });
  });
  localStorage.setItem('e5m_animals', JSON.stringify(rawAnim));

  // ── Actualizar lote destino: animal_count + avg_weight
  var loteDestObj = db.lots.find(function(l) { return l.code === loteDest; });
  if (!loteDestObj) {
    // Defensivo: no debería pasar nunca, pero si pasa, error claro (no silencioso)
    toast('Error interno: lote destino "' + loteDest + '" no encontrado en db.lots. Revertí los cambios.', 'error');
    rawAnim[loteDest] = (rawAnim[loteDest] || []).slice(0, -n);
    if (!rawAnim[loteDest].length) delete rawAnim[loteDest];
    localStorage.setItem('e5m_animals', JSON.stringify(rawAnim));
    return;
  }
  // FIX v1.4.31: snapshots para audit log de movimientos de lote (origen y destino).
  // Antes el marcaje solo logueaba update en compras_ganado, dejando los cambios reales
  // de status/animal_count del lote sin trazabilidad en el tablero de auditoría.
  var _origenSnap = {
    code: _mcLoteCuarentena.code,
    animal_count: _mcLoteCuarentena.animal_count,
    status: _mcLoteCuarentena.status || 'cuarentena'
  };
  var _destinoSnap = {
    code: loteDestObj.code,
    animal_count: loteDestObj.animal_count || 0,
    avg_weight: loteDestObj.avg_weight || 0
  };
  loteDestObj.animal_count = (loteDestObj.animal_count || 0) + n;
  var pesos = rawAnim[loteDest].map(function(a) {
    return (a.pesajes && a.pesajes.length) ? a.pesajes[a.pesajes.length-1].peso : 0;
  }).filter(function(p) { return p > 0; });
  if (pesos.length) loteDestObj.avg_weight = Math.round(pesos.reduce(function(s,p){return s+p;},0) / pesos.length * 10) / 10;

  // v1.8.22: registrar el ORIGEN del lote destino para que la trazabilidad (Análisis Lote /
  // Análisis Histórico) pueda rastrear hacia atrás hasta el lote de cuarentena y, desde ahí,
  // la compra inicial del ganado. Sin esto, el linaje se cortaba en el lote destino.
  // Solo se setea si el lote destino NO tenía ya un cost_origin (no pisar separaciones previas).
  if (!loteDestObj.cost_origin || !loteDestObj.cost_origin.from_lot) {
    var _compraOrigen = (db.compras_ganado || []).find(function(c) { return c.lot_code === _mcLoteCuarentena.code; });
    loteDestObj.cost_origin = {
      from_lot: _mcLoteCuarentena.code,
      date: fecha,
      animal_count: n,
      total_kg: pesos.length ? Math.round(pesos.reduce(function(s,p){return s+p;},0) * 10) / 10 : 0,
      via: 'marcaje',
      compra_id: _compraOrigen ? (_compraOrigen.id || null) : null
    };
  }

  // v1.4.104: garantizar entry en rotation_history si es lote nuevo con paddock
  // (creandoNuevo=true) o si se agregaron animales a un lote que no tenía entry abierta
  if (loteDestObj.paddock) {
    _ensureRotationEntry(loteDestObj, { reason: 'Marcaje desde ' + _mcLoteCuarentena.code });
  }

  // Actualizar lote de cuarentena: descontar animales marcados
  _mcLoteCuarentena.animal_count = Math.max(0, totalCuar - n);

  if (esCompleto || _mcLoteCuarentena.animal_count === 0) {
    // Marcaje completo → cerrar la cuarentena
    _mcLoteCuarentena.status = 'marcado_completo';
    _mcLoteCuarentena.animal_count = 0;
    _mcLoteCuarentena.marcaje_completo_at = new Date().toISOString();
    _mcLoteCuarentena.marcaje_lot_destino = loteDest;
  } else {
    // Marcaje parcial — actualizar progreso pero sigue en cuarentena
    _mcLoteCuarentena.marcaje_progreso = (_mcLoteCuarentena.marcaje_progreso || 0) + n;
  }

  // Actualizar la compra correspondiente
  var compra = (db.compras_ganado || []).find(function(c) { return c.lot_code === _mcLoteCuarentena.code; });
  if (compra) {
    compra.marcaje_progreso = (compra.marcaje_progreso || 0) + n;
    if (esCompleto) compra.marcaje_completo_at = new Date().toISOString();
    if (!compra.lote_destinos) compra.lote_destinos = [];
    if (compra.lote_destinos.indexOf(loteDest) < 0) compra.lote_destinos.push(loteDest);
  }

  // ── ASIENTO DUAL EN KARDEX: traspaso de costo cuarentena → lote destino ──
  // Calcula el costo proporcional según animales marcados sobre el total comprado
  var costoProporcional = 0;
  var pesoProporcional = 0;
  if (compra && compra.total && compra.animal_count) {
    costoProporcional = Math.round((compra.total * n / compra.animal_count) * 100) / 100;
    pesoProporcional = Math.round((compra.total_kg || 0) * n / compra.animal_count * 10) / 10;
  }
  if (costoProporcional > 0) {
    if (!db.kardex) db.kardex = [];
    var precioPorCab = Math.round(costoProporcional / n * 100) / 100;
    var nowIso = new Date().toISOString();
    // 1. HABER en lote cuarentena (sale costo proporcional)
    db.kardex.push({
      id: Date.now() + 100,
      lote: _mcLoteCuarentena.code,
      tipo: 'venta', // En kardex el lado HABER es 'venta' (egreso del lote)
      fecha: fecha,
      cabezas: n,
      precio: precioPorCab,
      total: costoProporcional,
      desc: 'Traspaso por marcaje → ' + loteDest + ' (' + n + ' cab.)',
      by: 'Desktop',
      created_at: nowIso,
      auto: true,
      traspaso: true,
      traspaso_destino: loteDest
    });
    // 2. DEBE en lote destino (entra costo proporcional)
    db.kardex.push({
      id: Date.now() + 101,
      lote: loteDest,
      tipo: 'compra', // El lado DEBE es 'compra' (ingreso al lote)
      fecha: fecha,
      cabezas: n,
      precio: precioPorCab,
      total: costoProporcional,
      desc: 'Traspaso desde cuarentena ' + _mcLoteCuarentena.code + ' (' + n + ' cab. × Bs. ' + precioPorCab + ')',
      by: 'Desktop',
      created_at: nowIso,
      auto: true,
      traspaso: true,
      traspaso_origen: _mcLoteCuarentena.code
    });
  }

  // Persistir + sync
  // ── Rotation history: registrar movimientos derivados del marcaje ──
  if (!db.rotation_history) db.rotation_history = [];
  var nowIso2 = new Date().toISOString();

  // 1) Si se creó un lote nuevo CON paddock asignado, abrir rotación inicial
  if (creandoNuevo) {
    var loteCreado = db.lots.find(function(l){ return l.code === loteDest; });
    if (loteCreado && loteCreado.paddock) {
      // Defensivo: cerrar cualquier rotación abierta previa de este lote (no debería haber, es nuevo)
      (db.rotation_history || []).forEach(function(r){
        if (r.lot_code === loteCreado.code && !r.exit_date) {
          r.exit_date = fecha;
          r.exit_at = nowIso2;
          var d1c = new Date(r.entry_date); var d2c = new Date(fecha);
          r.days_occupied = Math.max(1, Math.round((d2c-d1c)/86400000));
        }
      });
      db.rotation_history.push({
        id: Date.now() + Math.random()*1000,
        lot_code: loteCreado.code,
        potrero: loteCreado.paddock,
        from_potrero: 'Cuarentena',
        entry_date: fecha,
        entry_at: nowIso2,
        exit_date: null, exit_at: null, days_occupied: 0,
        cabezas: n,
        reason: 'Marcaje desde cuarentena ' + _mcLoteCuarentena.code,
        by: 'Desktop'
      });
    }
  }

  // 2) Si la cuarentena se vació por marcaje completo, cerrar su rotación
  if (esCompleto) {
    (db.rotation_history || []).forEach(function(r){
      if (r.lot_code === _mcLoteCuarentena.code && !r.exit_date) {
        r.exit_date = fecha;
        r.exit_at = nowIso2;
        var d1q = new Date(r.entry_date); var d2q = new Date(fecha);
        r.days_occupied = Math.max(1, Math.round((d2q-d1q)/86400000));
      }
    });
  }

  saveDB(true); // lotChanged=true para trigger sync de lotes
  closeModal('modal-marcar-cuarentena');
  renderLotes();
  renderDashboard();
  if (typeof renderComprasGanado === 'function') renderComprasGanado();
  if (typeof renderAnimalesLote === 'function') renderAnimalesLote();
  if (typeof renderRotacion === 'function') renderRotacion();

  var msg = creandoNuevo
    ? 'Lote ' + loteDest + ' creado con ' + n + ' animales'
    : (esCompleto
        ? 'Marcaje completo: ' + n + ' animales movidos a ' + loteDest
        : n + ' animales marcados (faltan ' + _mcLoteCuarentena.animal_count + ' en cuarentena)');
  toast(msg, 'success');

  // CRÍTICO: orden secuencial. Animals antes que lots para que el server reconcilie correctamente.
  replaceTableInRailway('animals', rawAnim).then(function(){
    return replaceTableInRailway('lots', db.lots);
  }).then(function(){
    if (db.compras_ganado) replaceTableInRailway('compras_ganado', db.compras_ganado);
