// ── LIMPIEZA DE LOTES HUÉRFANOS ────────────────────────────
// Detecta y limpia inconsistencias entre db.lots y e5m_animals
async function cleanupOrphanLots() {
  var resultEl = document.getElementById('cleanup-result');
  if (resultEl) { resultEl.style.display = 'none'; resultEl.textContent = ''; }

  var rawAnim = JSON.parse(localStorage.getItem('e5m_animals') || '{}');
  var lots = db.lots || [];
  var lotCodes = {};
  lots.forEach(function(l) { lotCodes[l.code] = l; });

  // Plan de limpieza
  var soldWithGhosts = [];      // lotes vendidos con animales en cache
  var lotsZeroAnimals = [];     // lotes con animal_count > 0 pero cache vacío Y status 'vendido'
  var orphanCacheKeys = [];     // claves de e5m_animals sin lote padre en db.lots
  var inconsistentCount = [];   // animal_count distinto de cache.length (en lotes activos)

  lots.forEach(function(l) {
    var cacheCount = (rawAnim[l.code] || []).length;
    var isVendido = l.status === 'vendido' || l.status === 'sold';
    if (isVendido && cacheCount > 0) {
      soldWithGhosts.push({ code: l.code, ghosts: cacheCount });
    }
    if (isVendido && (l.animal_count || 0) > 0) {
      lotsZeroAnimals.push({ code: l.code, claimedCount: l.animal_count, willBe: 0 });
    }
    if (!isVendido && (l.animal_count || 0) !== cacheCount && cacheCount > 0) {
      // Solo reportamos si la diferencia es real (no por anims pendientes de pull)
      if (Math.abs((l.animal_count || 0) - cacheCount) >= 1) {
        inconsistentCount.push({ code: l.code, claimedCount: l.animal_count || 0, realCount: cacheCount });
      }
    }
  });

  Object.keys(rawAnim).forEach(function(code) {
    if (!lotCodes[code] && (rawAnim[code] || []).length > 0) {
      orphanCacheKeys.push({ code: code, count: rawAnim[code].length });
    }
  });

  var totalProblems = soldWithGhosts.length + lotsZeroAnimals.length + orphanCacheKeys.length + inconsistentCount.length;

  if (totalProblems === 0) {
    toast('✓ No hay lotes huérfanos. Todo está consistente.', 'success');
    if (resultEl) {
      resultEl.style.display = 'block';
      resultEl.textContent = '✓ Sin inconsistencias. Lotes: ' + lots.length + ' · Cache: ' + Object.keys(rawAnim).length + ' claves.';
    }
    return;
  }

  // Construir mensaje de confirmación
  var msg = 'Se detectaron ' + totalProblems + ' inconsistencia(s):\n\n';
  if (soldWithGhosts.length) {
    msg += '🪦 ' + soldWithGhosts.length + ' lote(s) vendidos con animales fantasma:\n';
    soldWithGhosts.forEach(function(x) { msg += '   • ' + x.code + ' → eliminar ' + x.ghosts + ' animal(es) del cache\n'; });
    msg += '\n';
  }
  if (lotsZeroAnimals.length) {
    msg += '📊 ' + lotsZeroAnimals.length + ' lote(s) vendidos con animal_count > 0:\n';
    lotsZeroAnimals.forEach(function(x) { msg += '   • ' + x.code + ' → animal_count: ' + x.claimedCount + ' → 0\n'; });
    msg += '\n';
  }
  if (orphanCacheKeys.length) {
    msg += '🗑️ ' + orphanCacheKeys.length + ' clave(s) en cache sin lote padre:\n';
    orphanCacheKeys.forEach(function(x) { msg += '   • "' + x.code + '" → eliminar ' + x.count + ' animal(es)\n'; });
    msg += '\n';
  }
  if (inconsistentCount.length) {
    msg += '⚠️ ' + inconsistentCount.length + ' lote(s) con conteo desincronizado:\n';
    inconsistentCount.forEach(function(x) { msg += '   • ' + x.code + ' → animal_count: ' + x.claimedCount + ' → ' + x.realCount + '\n'; });
    msg += '\n';
  }
  msg += '¿Aplicar limpieza? Esta acción NO se puede deshacer.';

  if (!confirm(msg)) {
    toast('Limpieza cancelada', 'success');
    return;
  }

  // Aplicar limpieza
  var changes = 0;
  soldWithGhosts.forEach(function(x) {
    rawAnim[x.code] = [];
    changes++;
  });
  lotsZeroAnimals.forEach(function(x) {
    var l = lotCodes[x.code];
    if (l) {
      l.animal_count = 0;
      changes++;
    }
  });
  orphanCacheKeys.forEach(function(x) {
    delete rawAnim[x.code];
    changes++;
  });
  inconsistentCount.forEach(function(x) {
    var l = lotCodes[x.code];
    if (l) {
      l.animal_count = x.realCount;
      changes++;
    }
  });

  // Persistir
  localStorage.setItem('e5m_animals', JSON.stringify(rawAnim));
  saveDB(true);

  // Push al server — animals primero, después lots (orden crítico para reconciliación)
  try {
    replaceTableInRailway('animals', rawAnim).then(function(){
      return replaceTableInRailway('lots', db.lots);
    });
  } catch(e){}

  // Re-render
  if (typeof renderLotes === 'function') renderLotes();
  if (typeof renderDashboard === 'function') renderDashboard();
  if (typeof renderAnimalesLote === 'function') renderAnimalesLote();

  toast('✓ Limpieza aplicada: ' + changes + ' cambio(s)', 'success');
  if (resultEl) {
    resultEl.style.display = 'block';
    resultEl.textContent = '✓ Limpieza aplicada — ' + changes + ' cambio(s).\nServidor sincronizado.\nÚltima ejecución: ' + new Date().toLocaleString('es-BO');
  }
  try { auditLog('cleanup', 'lots', null, 'Limpieza de lotes huérfanos: ' + changes + ' cambios'); } catch(e){}
}

