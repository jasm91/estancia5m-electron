function recalcTotalMerma() {
  var totalMerma = 0;
  document.querySelectorAll('.ic-fisico-dyn').forEach(function(inp) {
    var pid = parseInt(inp.getAttribute('data-pid'));
    var prod = db.products.find(function(p) { return p.id === pid; });
    if (!prod) return;
    var diff = (parseFloat(inp.value) || 0) - prod.stock_qty;
    if (diff < 0) totalMerma += Math.abs(diff) * (prod.unit_cost || 0);
  });
  var el = document.getElementById('ic-total-merma-dyn');
  if (el) el.textContent = 'Bs. ' + Math.round(totalMerma).toLocaleString();
}

