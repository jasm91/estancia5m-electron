  html += '<div style="overflow-x:auto"><table class="tbl"><thead><tr><th>Indicador</th><th>Tu Estancia</th><th>Promedio Bolivia</th><th>Top 25% CREA</th><th>Estado</th></tr></thead><tbody>';
  function benchRow(ind, val, promMin, promMax, topMin, topMax, unit, lower) {
    var numVal = parseFloat(val) || 0;
    var estado, color;
    if (lower) {
      estado = numVal <= topMax ? '✓ Top 25%' : numVal <= promMax ? '→ Promedio' : '⚠ Revisar';
      color = numVal <= topMax ? 'var(--green)' : numVal <= promMax ? 'var(--amber)' : 'var(--red)';
    } else {
      estado = numVal >= topMin ? '✓ Top 25%' : numVal >= promMin ? '→ Promedio' : '⚠ Revisar';
      color = numVal >= topMin ? 'var(--green)' : numVal >= promMin ? 'var(--amber)' : 'var(--red)';
    }
    return '<tr><td>' + ind + '</td><td style="font-family:DM Mono;font-weight:700">' + val + ' ' + unit + '</td><td style="font-family:DM Mono;color:var(--muted)">' + promMin + '-' + promMax + '</td><td style="font-family:DM Mono;color:var(--blue)">' + topMin + '-' + topMax + '</td><td style="color:' + color + ';font-weight:600">' + estado + '</td></tr>';
  }
