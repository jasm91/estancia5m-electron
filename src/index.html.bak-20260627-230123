function renderVentas() {
  const total=db.sales.reduce((s,v)=>s+(v.total||0),0);
  const animals=db.sales.reduce((s,v)=>s+(v.animals||v.animal_count||0),0);
  const totalKg=db.sales.reduce((s,v)=>s+(v.kg||v.total_kg||0),0);
  document.getElementById('v-total').textContent='Bs. '+total.toLocaleString();
  document.getElementById('v-animals').textContent=animals;
  document.getElementById('v-kgprice').textContent=totalKg?'Bs. '+(total/totalKg).toFixed(2):'-';
  var carneBajaKg = db.sales.filter(function(v){return v.type==='carne_baja';}).reduce(function(s,v){return s+(v.kg||v.total_kg||0);},0);
  var carneBajaEl = document.getElementById('v-carne-baja');
  if(carneBajaEl) carneBajaEl.textContent = carneBajaKg ? carneBajaKg + ' kg' : '0 kg';
  var saleTbody = document.getElementById('sales-tbody');
  if (saleTbody) {
    saleTbody.innerHTML = '';
    db.sales.slice().reverse().forEach(function(s) {
      var tr = document.createElement('tr');
      var isCarne = s.type === 'carne_baja';
      var traceBdg = s.trace_req ? '<span class="bdg bdg-purple">Si</span>' : '<span class="bdg bdg-amber">No</span>';
      var typeBdg = isCarne
        ? '<span class="bdg bdg-red">Carne baja</span>'
        : '<span class="bdg bdg-'+(s.type==='frigorifico'?'blue':'green')+'">'+capFirst(s.type||'venta')+'</span>';
      var animalCount = s.animals || s.animal_count || 0;
      var kgTotal = s.kg || s.total_kg || 0;
      var kgFacturados = s.kg_facturados || kgTotal;
      var hasDiscount = s.discount_pct && s.discount_pct > 0 && kgFacturados !== kgTotal;
      var kgDisplay = hasDiscount
        ? '<span title="Bruto: '+kgTotal+' kg, descuento '+s.discount_pct+'%">'+kgFacturados+' kg <span style="color:var(--red);font-size:10px">(−'+s.discount_pct+'%)</span></span>'
        : kgTotal+' kg';
      var priceKg = s.price_per_kg || (kgTotal ? Math.round(s.total / kgTotal * 100) / 100 : 0);
      var hasIds = s.animal_ids && s.animal_ids.length > 0;
      var idsPreview = hasIds
        ? s.animal_ids.slice(0,3).join(', ')+(s.animal_ids.length>3?' +('+(s.animal_ids.length-3)+' más)':'')
        : isCarne ? (s.notes||'').replace(/🪦 Venta carne post-baja /,'') : (s.scope==='lot'?'Lote completo':'—');
      // Mostrar lot_code: si es multi-lote, badge especial
      var lotCodeDisplay = '';
      var isMultiLot = (s.lot_codes && s.lot_codes.length > 1) || (String(s.lot_code||'').indexOf(',') >= 0);
      if (isMultiLot) {
        var lots = s.lot_codes || String(s.lot_code).split(',').map(function(x){return x.trim();});
        lotCodeDisplay = '<span class="bdg bdg-purple" style="font-size:10px" title="'+escH(lots.join(', '))+'">🌐 ' + lots.length + ' lotes</span>';
      } else {
        lotCodeDisplay = '<span style="color:var(--amber2)">' + escH(s.lot_code||'') + '</span>';
      }
      tr.innerHTML = '<td>'+lotCodeDisplay+'</td>'+
        '<td>'+escH(s.buyer||'')+'</td>'+
        '<td>'+typeBdg+'</td>'+
        '<td>'+animalCount+'</td>'+
        '<td>'+kgDisplay+'</td>'+
        '<td style="font-family:DM Mono,monospace">Bs. '+priceKg+'</td>'+
        '<td style="color:var(--amber2);font-weight:600">Bs. '+(s.total||0).toLocaleString()+'</td>'+
        '<td style="font-size:12px">'+fmtDT(s.created_at||s.date)+'</td>'+
        '<td>'+traceBdg+'</td>'+
        '<td style="font-size:11px;color:var(--muted);max-width:180px">' +
          (hasIds
            ? '<button class="btn btn-ghost btn-sm" style="font-size:10px" onclick="toggleSaleIds(\''+s.id+'\')">🐄 Ver IDs</button>'
            : '<span style="color:var(--muted)">'+escH(idsPreview)+'</span>'
          )+'</td>'+
        '<td></td>';
      var delBtn = document.createElement('button');
      delBtn.className = 'btn btn-ghost btn-sm';
      delBtn.style.color = 'var(--red)';
      delBtn.textContent = '✕';
      delBtn.onclick = (function(id){ return function(){ deleteSale(id); }; })(s.id);
      tr.lastElementChild.appendChild(delBtn);
      saleTbody.appendChild(tr);

      // Fila expandible de detalle
      if(hasIds) {
        var trIds = document.createElement('tr');
        trIds.id = 'sale-ids-row-'+s.id;
        trIds.style.display = 'none';
        trIds.style.background = 'var(--sur2)';
        var tdIds = document.createElement('td');
        tdIds.colSpan = 11;
        tdIds.style.cssText = 'padding:12px 16px;border-top:none';

        // Detectar multi-lote para columnas dinámicas
        var saleLotsForFilter = isMultiLot
          ? (s.lot_codes || String(s.lot_code).split(',').map(function(x){return x.trim();}))
          : [s.lot_code];

        // Cruzar animal_ids con db.pesajes tipo venta — incluir TODOS los lotes de la venta
        var pesajesVenta = (db.pesajes||[]).filter(function(p){
          return p.tipo === 'venta' && saleLotsForFilter.indexOf(p.lot_code) >= 0 && p.date === s.date;
        });
        var pesoMap = {};
        var lotMap = {};   // animal_id -> lot_code (para columna Lote en multi-lote)
        pesajesVenta.forEach(function(p){
          pesoMap[String(p.animal_id)] = p.peso;
          lotMap[String(p.animal_id)] = p.lot_code;
        });
        var totalKgDetalle = 0;
        var rowsHtml = s.animal_ids.map(function(aid, idx){
          var peso = pesoMap[String(aid)] || 0;
          totalKgDetalle += peso;
          var total = peso ? (peso * s.price_per_kg).toLocaleString('es-BO', {minimumFractionDigits:2, maximumFractionDigits:2}) : '—';
          var loteCol = isMultiLot
            ? '<td style="padding:5px 10px;font-family:DM Mono,monospace;font-size:11px"><span class="bdg" style="background:rgba(168,85,247,.12);color:#a855f7;padding:2px 6px;border-radius:4px;font-size:10px">'+escH(lotMap[String(aid)] || '?')+'</span></td>'
            : '';
          return '<tr style="border-bottom:1px solid var(--bor)">'+
            '<td style="padding:5px 10px;font-family:DM Mono,monospace;font-size:12px;color:var(--amber2)">#'+(idx+1)+'</td>'+
            '<td style="padding:5px 10px;font-family:DM Mono,monospace;font-size:12px">'+escH(String(aid))+'</td>'+
            loteCol +
            '<td style="padding:5px 10px;font-size:12px">'+(peso ? peso+' kg' : '—')+'</td>'+
            '<td style="padding:5px 10px;font-size:12px;color:var(--green)">Bs. '+total+'</td>'+
            '</tr>';
        }).join('');
        var avgKg = s.animal_ids.length ? Math.round(totalKgDetalle / s.animal_ids.length * 10) / 10 : 0;

        var headerExtras = isMultiLot ? '<th style="padding:6px 10px;text-align:left">Lote origen</th>' : '';
        var colSpanFooter = isMultiLot ? 3 : 2;

        var idsHtml =
          '<div style="margin-bottom:8px;display:flex;align-items:center;gap:12px">'+
            '<span style="font-size:11px;font-weight:700;color:var(--muted)">DETALLE DE ANIMALES VENDIDOS' + (isMultiLot ? ' — VENTA MIXTA' : '') + '</span>'+
            '<span style="font-size:11px;color:var(--muted)">'+s.animal_ids.length+' animales · '+
              (totalKgDetalle ? totalKgDetalle.toFixed(0)+' kg total · '+avgKg+' kg prom.' : '')+
            '</span>'+
          '</div>'+
          '<div style="max-height:280px;overflow-y:auto;border:1px solid var(--bor);border-radius:8px">'+
          '<table style="width:100%;border-collapse:collapse">'+
            '<thead><tr style="background:var(--sur);font-size:11px;color:var(--muted)">'+
              '<th style="padding:6px 10px;text-align:left">#</th>'+
              '<th style="padding:6px 10px;text-align:left">ID Animal</th>'+
              headerExtras +
              '<th style="padding:6px 10px;text-align:left">Peso venta</th>'+
              '<th style="padding:6px 10px;text-align:left">Total Bs.</th>'+
            '</tr></thead>'+
            '<tbody>'+rowsHtml+'</tbody>'+
            '<tfoot><tr style="background:var(--sur);font-weight:700;font-size:12px">'+
              '<td colspan="'+colSpanFooter+'" style="padding:6px 10px;color:var(--muted)">TOTAL</td>'+
              '<td style="padding:6px 10px;color:var(--amber2)">'+totalKgDetalle.toFixed(0)+' kg</td>'+
              '<td style="padding:6px 10px;color:var(--green)">Bs. '+(totalKgDetalle*s.price_per_kg).toLocaleString('es-BO',{minimumFractionDigits:2,maximumFractionDigits:2})+'</td>'+
            '</tr></tfoot>'+
          '</table></div>';
        tdIds.innerHTML = idsHtml;
        trIds.appendChild(tdIds);
        saleTbody.appendChild(trIds);
      }
    });
  }
}

function toggleSaleIds(id) {
  var row = document.getElementById('sale-ids-row-'+id);
  if(row) row.style.display = row.style.display === 'none' ? 'table-row' : 'none';
}

function deleteSale(id) {
  if (!confirm('00bfEliminar esta venta?')) return;
  
  // FIX v1.4.35: audit log para deleteSale
  var _delRec_deleteSale = (db.sales || []).find(function(r){ return String(r.id) === String(id); });
  var _delSummary_deleteSale = _delRec_deleteSale ? _summarizeRecord('sales', _delRec_deleteSale) : 'Venta #' + id;
  try { auditLog('delete', 'sales', id, _delSummary_deleteSale); } catch(e){}
  trackDeletion(id, 'sales');
  db.sales = db.sales.filter(function(s){ return String(s.id)!==String(id); });
  saveDB(); renderVentas(); renderDashboard();
  replaceTableInRailway('sales', db.sales || []);
  toast('Venta eliminada', 'success');
}


function validateSaleCount() {
  var lotCode = (document.getElementById('sale-lot')||{}).value;
  var count = parseInt((document.getElementById('sale-count')||{}).value)||0;
  var warn = document.getElementById('sale-count-warn');
  var lot = db.lots.find(function(l){return l.code===lotCode;});
  if (warn && lot && count > lot.animal_count) {
    warn.style.display = 'block';
  } else if (warn) {
    warn.style.display = 'none';
  }
}

// Variables globales para venta individual
var _saleSelectedAnimals = [];
// Mapa global: animal_id -> lot_code (preserva info del lote aunque el DOM se re-renderice)
var _saleAnimalLotMap = {};
var _saleAnimalLotMapForKardex = []; // Para distribuir venta multi-lote en kardex después del save

function openModalSale() {
  // Reset state global
  _saleSelectedAnimals = [];
  _salePesoMap = {};
  _saleAnimalLotMap = {};
  _saleAnimalLotMapForKardex = [];

  // Reset campos del form (con guardas porque algunos pueden no existir)
  function _setVal(id, val) {
    var el = document.getElementById(id);
    if (el) {
      if (el.type === 'checkbox') el.checked = !!val;
      else el.value = val;
    }
  }
  function _setText(id, val) {
    var el = document.getElementById(id);
    if (el) el.textContent = val;
  }
  function _hide(id) {
    var el = document.getElementById(id);
    if (el) el.style.display = 'none';
  }

  _setVal('sale-lot', '');
  _setVal('sale-scope', 'lot'); // Modo "Lote completo" por default
  _setVal('sale-count', '');
  _setVal('sale-kg', '');
  _setVal('sale-peso-momento', '');
  _setVal('sale-kg-calc', '');
  _setVal('sale-animal-search', '');
  _setVal('sale-peso-min', '');
  _setVal('sale-peso-max', '');
  _setVal('sale-buyer', '');
  _setVal('sale-type', 'frigorifico');
  _setVal('sale-price', '');
  _setVal('sale-discount-pct', '');
  _setVal('sale-total', '');
  _setVal('sale-date', localDate());
  _setVal('sale-invoice', '');
  _setVal('sale-trace', false);

  // Reset textos auxiliares
  _setText('sale-count-max', '');
  _setText('sale-selected-count', '');

  // Ocultar warns/info bloques
  _hide('sale-count-warn');
  _hide('sale-discount-info');
  _hide('sale-individual-summary');

  // Reset modos visibles
  var lotMode = document.getElementById('sale-lot-mode');
  var indMode = document.getElementById('sale-individual-mode');
  if (lotMode) lotMode.style.display = 'block';
  if (indMode) indMode.style.display = 'none';

  // Limpiar lista de animales individual
  var animList = document.getElementById('sale-animals-list');
  if (animList) animList.innerHTML = '';

  // Repopular dropdown de lotes con conteo real (e5m_animals.length)
  var saleLotEl = document.getElementById('sale-lot');
  if (saleLotEl) {
    var _saleAnimDB = (typeof getAnimalesDB === 'function') ? getAnimalesDB() : {};
    var lotOpts = (db.lots || [])
      .filter(function(l) { return !l.status || l.status === 'activo' || l.status === 'active'; })
      .map(function(l) {
        var realCount = (_saleAnimDB[l.code] || []).length || (l.animal_count || 0);
        return '<option value="' + l.code + '">' + escH(l.code) + ' - ' + escH(l.category || '') + ' (' + realCount + ' cab.)</option>';
      }).join('');
    saleLotEl.innerHTML = '<option value="">Seleccionar...</option><option value="__all__">🌐 Todos los lotes (mix)</option>' + lotOpts;
  }

  openModal('modal-sale');
}

function onSaleScopeChange(val) {
  // No permitir modo "Lote completo" si está seleccionado "Todos los lotes"
  var lotVal = (document.getElementById('sale-lot')||{}).value || '';
  if (val === 'lot' && lotVal === '__all__') {
    toast('"Todos los lotes" solo funciona en modo individual','warning');
    var scopeEl = document.getElementById('sale-scope');
    if (scopeEl) scopeEl.value = 'individual';
    val = 'individual';
  }
  document.getElementById('sale-lot-mode').style.display = val==='lot'?'block':'none';
  document.getElementById('sale-individual-mode').style.display = val==='individual'?'block':'none';
  if(val==='individual') {
    _saleSelectedAnimals=[];
    _saleAnimalLotMap = {};
    var lotCode = lotVal === '__all__' ? '' : lotVal;
    renderSaleAnimalList(lotCode,'','','');
  } else if (val === 'lot' && lotVal && lotVal !== '__all__') {
    // Al volver a "Lote completo" con un lote ya elegido, prellenar campos
    onSaleLotChange(lotVal);
  }
}

function onSaleLotChange(code) {
  // Si elige "Todos los lotes", forzar modo individual
  if (code === '__all__') {
    var scopeEl = document.getElementById('sale-scope');
    if (scopeEl && scopeEl.value !== 'individual') {
      scopeEl.value = 'individual';
      onSaleScopeChange('individual');
      toast('Para venta de animales mezclados de varios lotes se usa modo individual','info');
    } else {
      _saleSelectedAnimals = [];
      _saleAnimalLotMap = {};
      renderSaleAnimalList('', '', '', '');  // pasar '' para que use todos los lotes
    }
    var maxEl=document.getElementById('sale-count-max');
    if(maxEl) maxEl.textContent='(varios lotes)';
    return;
  }
  var lot=db.lots.find(function(l){return l.code===code;});
  var maxEl=document.getElementById('sale-count-max');
  if(lot&&maxEl) maxEl.textContent='(max. '+lot.animal_count+')';
  else if(maxEl) maxEl.textContent='';
  var scope=(document.getElementById('sale-scope')||{}).value||'lot';
  if(scope==='individual') {
    _saleSelectedAnimals=[];
    _saleAnimalLotMap = {};
    renderSaleAnimalList(code,'','','');
  } else if (scope === 'lot' && lot) {
    // Modo "Lote completo": prellenar automáticamente cantidad, peso/animal y kg totales
    var countInput = document.getElementById('sale-count');
    var pesoInput = document.getElementById('sale-peso-momento');
    var kgInput = document.getElementById('sale-kg');
    var kgCalcEl = document.getElementById('sale-kg-calc');
    if (countInput && !countInput.value) countInput.value = lot.animal_count || 0;
    if (pesoInput && !pesoInput.value && lot.avg_weight) pesoInput.value = lot.avg_weight;
    // Calcular peso total = cantidad × peso/animal
    var cnt = parseInt(countInput.value) || 0;
    var avgW = parseFloat(pesoInput.value) || 0;
    if (cnt && avgW) {
      var totalKg = Math.round(cnt * avgW * 10) / 10;
      if (kgInput) kgInput.value = totalKg;
      if (kgCalcEl) kgCalcEl.value = 'Bs./kg x ' + totalKg + ' kg total';
    }
    calcSaleTotal();
  }
}

function renderSaleAnimalList(lotCode, filter, pesoMin, pesoMax) {
  var container=document.getElementById('sale-animals-list');
  if(!container) return;
  var animalesDB=getAnimalesDB();
  var animals=[];
  // Si lotCode es vacío o '__all__', concatenar TODOS los lotes
  if(lotCode && lotCode !== '__all__') {
    animals = (animalesDB[lotCode]||[]).map(function(a){ return Object.assign({}, a, {_lotCode: lotCode}); });
  } else {
    Object.keys(animalesDB).forEach(function(lc){
      (animalesDB[lc]||[]).forEach(function(a){ animals.push(Object.assign({}, a, {_lotCode: lc})); });
    });
  }

  var f=(filter||'').toLowerCase();
  var pMin=parseFloat(pesoMin)||0;
  var pMax=parseFloat(pesoMax)||0;

  var filtered=animals.filter(function(a){
    var aid=(a.animal_id||a.id||'').toString();
    if(f && aid.toLowerCase().indexOf(f)<0) return false;
    var lastP=a.pesajes&&a.pesajes.length?a.pesajes[a.pesajes.length-1].peso:0;
    if(pMin && lastP<pMin) return false;
    if(pMax && lastP>pMax) return false;
    return true;
  });

  if(!filtered.length) {
    container.innerHTML='<div style="padding:20px;text-align:center;color:var(--muted);font-size:12px">Sin animales que coincidan con el filtro</div>';
    return;
  }

  var showLotCol = !lotCode || lotCode === '__all__';

  container.innerHTML=filtered.map(function(a){
    var aid=(a.animal_id||a.id||'').toString();
    var lastP=a.pesajes&&a.pesajes.length?a.pesajes[a.pesajes.length-1].peso:null;
    if(lastP) _salePesoMap[aid]=lastP;
    var sel=_saleSelectedAnimals.indexOf(aid)>=0;
    var raza=a.breed||a.raza||'';
    var pesoActual=_salePesoMap[aid]||lastP||0;
    var bgSel=sel?'background:rgba(201,168,76,.08)':'';
    var lotBadge = showLotCol ? '<span style="font-family:DM Mono,monospace;font-size:10px;background:rgba(88,166,255,.1);color:var(--blue);padding:2px 6px;border-radius:4px;margin-right:4px;flex-shrink:0">'+escH(a._lotCode||'-')+'</span>' : '';
    return '<div id="sale-row-'+aid+'" style="display:flex;align-items:center;gap:6px;padding:6px 10px;border-bottom:1px solid rgba(48,54,61,.35);'+bgSel+'">' +
      '<input type="checkbox" id="chk-'+aid+'" '+(sel?'checked':'')+' style="accent-color:var(--amber);flex-shrink:0" onchange="toggleSaleAnimalChk(this)" data-aid="'+aid+'" data-peso="'+pesoActual+'" data-lot="'+escH(a._lotCode||'')+'">' +
      lotBadge +
      '<span style="font-family:DM Mono,monospace;font-size:12px;font-weight:600;color:var(--amber2);min-width:70px;cursor:pointer" onclick="document.getElementById(\'chk-'+aid+'\').click()">'+aid+'</span>' +
      '<span style="font-size:11px;color:var(--muted);cursor:pointer" onclick="document.getElementById(\'chk-'+aid+'\').click()">'+raza+'</span>' +
      '<span style="font-size:11px;color:var(--muted);margin-left:4px">'+(lastP?'('+lastP+' kg)':'')+'</span>' +
      '<div style="display:flex;align-items:center;gap:4px;flex-shrink:0;margin-left:auto">' +
        '<span style="font-size:10px;color:var(--muted)">kg venta:</span>' +
        '<input type="number" id="peso-'+aid+'" placeholder="'+(lastP||'')+'" value="'+(pesoActual||'')+'" step="0.5" min="0" style="width:72px;padding:3px 6px;font-size:11px;background:var(--sur);border:1px solid var(--bor);border-radius:6px;color:var(--text)" oninput="onPesoInputChange(\''+aid+'\',this.value)">' +
      '</div>' +
    '</div>';
  }).join('');

  updateSaleAnimalSummary();
}

function filterSaleAnimals(text) {
  var lotCode=(document.getElementById('sale-lot')||{}).value||'';
  if (lotCode === '__all__') lotCode = '';
  var search=text!==undefined?text:(document.getElementById('sale-animal-search')||{}).value||'';
  var pMin=(document.getElementById('sale-peso-min')||{}).value||'';
  var pMax=(document.getElementById('sale-peso-max')||{}).value||'';
  renderSaleAnimalList(lotCode, search, pMin, pMax);
}

var _salePesoMap = {}; // mapa id -> peso del ultimo pesaje

function onPesoRealChange(animalId, val) {
  var p = parseFloat(val)||0;
  if (p > 0) _salePesoMap[animalId] = p;
  updateSaleAnimalSummary();
  calcSaleTotal();
}

function onPesoInputChange(animalId, val) {
  var p = parseFloat(val)||0;
  if (p > 0) _salePesoMap[animalId] = p;
  updateSaleAnimalSummary();
  calcSaleTotal();
}

function toggleSaleAnimalChk(chk) {
  var aid = chk.getAttribute('data-aid');
  var lotFromChk = chk.getAttribute('data-lot') || '';
  var pesoEl = document.getElementById('peso-'+aid);
  var peso = pesoEl ? (parseFloat(pesoEl.value)||parseFloat(chk.getAttribute('data-peso'))||0) : 0;
  var idx = _saleSelectedAnimals.indexOf(aid);
  if (chk.checked && idx < 0) {
    _saleSelectedAnimals.push(aid);
    if (peso) _salePesoMap[aid] = peso;
    if (lotFromChk) _saleAnimalLotMap[aid] = lotFromChk;
  } else if (!chk.checked && idx >= 0) {
    _saleSelectedAnimals.splice(idx, 1);
    delete _salePesoMap[aid];
    delete _saleAnimalLotMap[aid];
  }
  var row = document.getElementById('sale-row-'+aid);
  if (row) row.style.background = chk.checked ? 'rgba(201,168,76,.08)' : '';
  updateSaleAnimalSummary();
  calcSaleTotal();
}

function onSalePesoMomento() {
  var pesoProm = parseFloat((document.getElementById('sale-peso-momento')||{}).value)||0;
  var count = parseInt((document.getElementById('sale-count')||{}).value)||0;
  var kgCalcEl = document.getElementById('sale-kg-calc');
  var kgEl = document.getElementById('sale-kg');
  if (pesoProm && count) {
    var total = Math.round(pesoProm * count * 10) / 10;
    if (kgCalcEl) kgCalcEl.value = 'Bs./kg x ' + total + ' kg total';
    if (kgEl) { kgEl.value = total; calcSaleTotal(); }
  } else {
    if (kgCalcEl) kgCalcEl.value = '';
  }
}

function toggleSaleAnimal(animalId, checked, peso) {
  var idx=_saleSelectedAnimals.indexOf(animalId);
  if(checked && idx<0) {
    _saleSelectedAnimals.push(animalId);
    if(peso) _salePesoMap[animalId] = peso;
  }
  if(!checked && idx>=0) {
    _saleSelectedAnimals.splice(idx,1);
