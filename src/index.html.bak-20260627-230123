  var saveBtn = document.getElementById('btn-save-task');
  if (saveBtn) saveBtn.onclick = saveTask;
  var cancelBtn = document.getElementById('btn-cancel-task');
  if (cancelBtn) cancelBtn.onclick = function(){ closeModal('modal-task'); };
}

function renderTaskList() {
  var container = document.getElementById('task-list-container');
  if (!container) return;

  var tasks = getTaskDB();
  var fs = (document.getElementById('filter-status')||{}).value || '';
  var fa = (document.getElementById('filter-assignee')||{}).value || '';
  var fp = (document.getElementById('filter-priority')||{}).value || '';
  if (fs) tasks = tasks.filter(function(t){ return t.status === fs; });
  if (fa) tasks = tasks.filter(function(t){ return t.assignee === fa; });
  if (fp) tasks = tasks.filter(function(t){ return t.priority === fp; });

  if (!tasks.length) {
    container.innerHTML = '<div style="text-align:center;padding:40px;color:var(--muted);font-size:13px">Sin tareas para mostrar</div>';
    return;
  }

  var todayVal = today();
  container.innerHTML = '';

  tasks.forEach(function(task) {
    var isOv = task.due && task.due < todayVal && task.status !== 'completada';
