  <!-- Apariencia / Tema (v1.8.72) -->
  <div class="card" style="margin-bottom:20px;border-left:3px solid var(--amber2)">
    <div class="card-hd"><div class="card-title">🎨 Apariencia</div></div>
    <div class="card-body">
      <div style="display:flex;align-items:center;gap:14px;flex-wrap:wrap">
        <span style="font-size:13px;color:var(--muted)">Tema de la aplicación</span>
        <div style="display:inline-flex;border:1px solid var(--bor);border-radius:9px;overflow:hidden">
          <button id="theme-btn-dark" onclick="setTheme('dark')" style="border:none;background:transparent;color:var(--muted);padding:8px 16px;font-size:13px;cursor:pointer;display:flex;align-items:center;gap:6px">🌙 Oscuro</button>
          <button id="theme-btn-light" onclick="setTheme('light')" style="border:none;background:transparent;color:var(--muted);padding:8px 16px;font-size:13px;cursor:pointer;display:flex;align-items:center;gap:6px">☀️ Claro</button>
        </div>
        <span style="font-size:11px;color:var(--muted)">Se recuerda en este equipo</span>
      </div>
    </div>
  </div>

  <!-- Identidad de la estancia -->
  <div class="card" style="margin-bottom:20px;border-left:3px solid var(--amber2)">
    <div class="card-hd"><div class="card-title">🏠 Identidad de la Estancia</div></div>
    <div class="card-body">
      <div class="form-row">
        <div class="form-group"><label class="form-label">Nombre de la estancia</label>
          <input class="form-input" id="cfg-nombre-estancia" placeholder="Ej: Estancia Jisunu" style="font-size:15px;font-weight:700" oninput="previewHeaderName()">
        </div>
        <div class="form-group"><label class="form-label">Propietario</label>
          <input class="form-input" id="cfg-propietario" placeholder="Nombre completo" oninput="previewHeaderName()">
        </div>
      </div>
      <div style="display:flex;gap:10px;align-items:center">
        <button class="btn btn-primary" onclick="saveEstanciaIdentity()">💾 Guardar identidad</button>
        <span style="font-size:11px;color:var(--muted)">Se actualiza el encabezado y se sincroniza al servidor</span>
      </div>
    </div>
  </div>

  <!-- Sync status card -->
  <div class="card" style="margin-bottom:20px">
    <div class="card-hd"><div class="card-title">🔄 Estado de sincronizacion</div><span id="cfg-status-badge" class="bdg bdg-amber">Sin configurar</span></div>
    <div class="card-body">
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;margin-bottom:16px">
        <div style="background:var(--sur2);border-radius:10px;padding:14px;text-align:center">
          <div style="font-size:22px;font-weight:800" id="cfg-pending-count">-</div>
          <div style="font-family:DM Mono,monospace;font-size:10px;color:var(--muted);margin-top:4px">CAMBIOS PENDIENTES</div>
        </div>
        <div style="background:var(--sur2);border-radius:10px;padding:14px;text-align:center">
          <div style="font-size:14px;font-weight:600;color:var(--muted)" id="cfg-last-sync">Nunca</div>
          <div style="font-family:DM Mono,monospace;font-size:10px;color:var(--muted);margin-top:4px">ÚLTIMO SYNC</div>
        </div>
        <div style="background:var(--sur2);border-radius:10px;padding:14px;text-align:center">
          <div style="font-size:14px;font-weight:600" id="cfg-connection">-</div>
          <div style="font-family:DM Mono,monospace;font-size:10px;color:var(--muted);margin-top:4px">CONEXIÓN</div>
        </div>
      </div>
      <button class="btn btn-primary" onclick="manualSync()" style="width:100%">↑↓ Sincronizar ahora</button>
    </div>
  </div>

  <!-- Server config card -->
  <div class="card" style="margin-bottom:20px">
    <div class="card-hd"><div class="card-title">🎨 Personalización</div></div>
    <div class="card-body">
      <div class="form-group" style="margin-bottom:14px">
        <label class="form-label">Nombre de la estancia</label>
        <input type="text" class="form-input" id="brand-name" placeholder="Ej: Estancia San Pedro">
        <div style="font-size:10px;color:var(--muted);margin-top:4px">Se mostrará en el encabezado de la app</div>
      </div>
      <div class="form-group" style="margin-bottom:14px">
        <label class="form-label">Logo de la estancia</label>
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:8px">
          <div id="brand-logo-preview" style="width:56px;height:56px;border-radius:10px;border:1px solid var(--bor);background:var(--sur2);display:flex;align-items:center;justify-content:center;font-size:24px;overflow:hidden">🐄</div>
          <div>
            <button class="btn btn-ghost btn-sm" onclick="document.getElementById('brand-logo-input').click()">📁 Seleccionar imagen</button>
            <button class="btn btn-ghost btn-sm" style="margin-top:4px" onclick="removeLogo()">✕ Quitar logo</button>
          </div>
        </div>
        <input type="file" id="brand-logo-input" accept="image/*" style="display:none" onchange="previewLogo(this)">
        <div style="font-size:10px;color:var(--muted)">PNG o JPG recomendado. Se sincroniza con la PWA del capataz.</div>
      </div>
      <button class="btn btn-primary" onclick="saveBranding()" style="width:100%">💾 Guardar personalización</button>
    </div>
  </div>
  <div class="card" style="margin-bottom:20px">
    <div class="card-hd"><div class="card-title">🌐 Servidor API</div></div>
    <div class="card-body">
      <div style="background:rgba(88,166,255,.06);border:1px solid rgba(88,166,255,.2);border-radius:8px;padding:12px;margin-bottom:16px;font-family:DM Mono,monospace;font-size:11px;color:var(--blue);line-height:1.6">
        Configura la URL de tu servidor Railway para habilitar la sincronizacion entre la app de escritorio y la app del capataz en Android.
      </div>
      <div class="form-group" style="margin-bottom:14px">
        <label class="form-label">URL del servidor</label>
        <input type="url" class="form-input" id="cfg-url" placeholder="https://estancia5m-api-production.up.railway.app/api">
        <div style="font-family:DM Mono,monospace;font-size:10px;color:var(--muted);margin-top:4px">Inclui /api al final de la URL</div>
      </div>
      <div class="form-group" style="margin-bottom:14px">
        <label class="form-label">Token de acceso</label>
        <input type="password" class="form-input" id="cfg-token" placeholder="Tu token secreto de Railway">
        <div style="font-family:DM Mono,monospace;font-size:10px;color:var(--muted);margin-top:4px">El mismo que configuraste en las variables de Railway</div>
      </div>
      <div style="display:flex;gap:10px;flex-wrap:wrap">
        <button class="btn btn-primary" onclick="saveServerConfig()" style="flex:1;min-width:200px">💾 Guardar configuracion</button>
        <button class="btn btn-ghost" onclick="testConnection()">🔍 Probar conexion</button>
        <button class="btn btn-ghost" style="color:var(--amber2)" onclick="forcePullFromToken()">⬇️ Forzar carga</button>
        <button class="btn btn-ghost" style="color:var(--red)" onclick="forcePushToServer()">⬆️ Forzar push a server</button>
      </div>
      <div id="cfg-test-result" style="margin-top:12px;font-family:DM Mono,monospace;font-size:11px;display:none"></div>
    </div>
  </div>

  <!-- Dispositivos (Device Pairing v1.8.65) -->
  <div class="card" style="margin-bottom:20px">
    <div class="card-hd"><div class="card-title">📱 Dispositivos</div></div>
    <div class="card-body">
      <div style="color:var(--muted);font-size:12.5px;margin-bottom:14px">Vinculá celulares de capataces con un código de un solo uso. Cada uno tiene su propio acceso; revocar uno no afecta a los demás ni a este equipo.</div>

      <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:flex-end;margin-bottom:14px">
        <div class="form-group" style="flex:1;min-width:220px;margin:0">
          <label class="form-label">Nombre del dispositivo nuevo</label>
          <input class="form-input" id="dev-name" placeholder="Ej: Celular de Juan" maxlength="60" onkeydown="if(event.key==='Enter')generarCodigoDispositivo()">
        </div>
        <button class="btn btn-primary" onclick="generarCodigoDispositivo()" style="min-width:190px">➕ Vincular dispositivo</button>
      </div>

      <div id="dev-code-panel" style="display:none;background:var(--sur2);border:1px solid var(--bor);border-radius:10px;padding:14px 16px;margin-bottom:16px">
        <div style="font-size:10.5px;font-weight:700;letter-spacing:1.2px;color:var(--amber);margin-bottom:6px" id="dev-code-label">CÓDIGO</div>
        <div style="font-family:'DM Mono',monospace;font-size:32px;font-weight:600;letter-spacing:4px" id="dev-code-num">— — —</div>
        <div style="color:var(--muted);font-size:11.5px;margin-top:6px" id="dev-code-exp"></div>
        <div style="display:flex;gap:8px;margin-top:10px;flex-wrap:wrap">
          <button class="btn btn-ghost" style="font-size:12.5px" onclick="copiarLinkWhatsapp()">🔗 Copiar link de WhatsApp</button>
          <button class="btn btn-ghost" style="font-size:12.5px" onclick="copiarCodigoDispositivo()">📋 Copiar código</button>
        </div>
      </div>

      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px">
        <div class="form-label" style="margin:0">Dispositivos vinculados</div>
        <button class="btn btn-ghost" style="padding:4px 10px;font-size:12px" onclick="renderDispositivos()">↻ Actualizar</button>
      </div>
      <div id="dev-list"><div style="color:var(--muted);font-size:12px;padding:8px 0">Abrí esta pantalla con internet para ver los dispositivos.</div></div>
    </div>
  </div>

  <!-- Onboarding inicial -->
  <div class="card" style="margin-bottom:20px">
    <div class="card-hd">
      <div class="card-title">📥 Onboarding Inicial</div>
      <span style="font-family:DM Mono,monospace;font-size:10px;color:var(--muted)" id="onboarding-status">Cargá datos masivamente desde Excel</span>
    </div>
    <div class="card-body">
      <div style="background:rgba(57,211,83,.06);border:1px solid rgba(57,211,83,.2);border-radius:8px;padding:12px;margin-bottom:16px;font-family:DM Mono,monospace;font-size:11px;color:var(--green);line-height:1.6">
        Descargá la plantilla Excel, llená los datos de tu estancia (lotes, animales, potreros, stock, maquinaria, personal, etc.) y subila para cargar todo de una vez. <strong>Solo agrega lo nuevo</strong> — si un lote o animal ya existe, esa fila se ignora.
      </div>
      <div style="display:flex;gap:10px;flex-wrap:wrap">
        <button class="btn btn-primary" onclick="downloadOnboardingTemplate()" style="flex:1;min-width:200px;background:var(--green);color:#000">📄 Descargar plantilla Excel</button>
        <button class="btn btn-ghost" onclick="document.getElementById('onboarding-file-input').click()">📂 Importar archivo completado</button>
        <input type="file" id="onboarding-file-input" accept=".xlsx,.xls" style="display:none" onchange="handleOnboardingFile(event)">
      </div>
      <div id="onboarding-result" style="margin-top:12px;font-family:DM Mono,monospace;font-size:11px;display:none"></div>
    </div>
  </div>

  <!-- Backup y restauracion -->
  <div class="card" style="margin-bottom:20px">
    <div class="card-hd">
      <div class="card-title">💾 Backup y Restauracion</div>
      <span style="font-family:DM Mono,monospace;font-size:10px;color:var(--muted)" id="cfg-last-backup">Sin backup reciente</span>
    </div>
    <div class="card-body">
      <div style="background:rgba(88,166,255,.06);border:1px solid rgba(88,166,255,.2);border-radius:8px;padding:12px;margin-bottom:16px;font-family:DM Mono,monospace;font-size:11px;color:var(--blue);line-height:1.6">
        El backup exporta TODOS los datos: lotes, animales, compras, ventas, curaciones, mantenimiento, personal y configuracion.
      </div>

      <!-- Backup manual -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px">
        <button class="btn btn-primary" onclick="exportBackup()" style="display:flex;align-items:center;justify-content:center;gap:8px">
          ⬇ Exportar backup ahora
        </button>
        <label class="btn btn-ghost" style="display:flex;align-items:center;justify-content:center;gap:8px;cursor:pointer">
          ⬆ Restaurar desde backup
          <input type="file" id="restore-file-input" accept=".json" style="display:none" onchange="importBackup(this)">
        </label>
      </div>

      <!-- Backup automatico -->
      <div style="background:var(--sur2);border:1px solid var(--bor);border-radius:10px;padding:14px;margin-bottom:10px">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
          <div>
            <div style="font-size:13px;font-weight:600">Backup automático local</div>
            <div style="font-size:11px;color:var(--muted);margin-top:2px">Al arrancar y al cerrar la app · Documentos/EstanciaPro_Backups · Últimos 30</div>
          </div>
          <label style="display:flex;align-items:center;gap:8px;cursor:pointer">
            <input type="checkbox" id="auto-backup-enabled" onchange="toggleAutoBackup(this.checked)" style="width:16px;height:16px;cursor:pointer">
            <span style="font-size:12px;color:var(--muted)" id="auto-backup-status-lbl">Desactivado</span>
          </label>
        </div>
        <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap">
          <div style="display:flex;align-items:center;gap:8px">
            <span style="font-size:12px;color:var(--muted)">Backup adicional cada</span>
            <select id="auto-backup-freq" class="form-select" style="width:100px;padding:5px 8px;font-size:12px" onchange="saveAutoBackupConfig()">
              <option value="1">1 dia</option>
              <option value="3">3 dias</option>
              <option value="7" selected>7 dias</option>
              <option value="14">14 dias</option>
              <option value="30">30 dias</option>
            </select>
          </div>
          <div style="font-family:DM Mono,monospace;font-size:11px;color:var(--muted)" id="auto-backup-next">-</div>
        </div>
      </div>

      <div style="display:flex;justify-content:space-between;align-items:center">
        <div style="font-family:DM Mono,monospace;font-size:11px;color:var(--muted)" id="cfg-last-backup">Sin backup reciente</div>
        <button class="btn btn-ghost btn-sm" onclick="openBackupFolder()" style="font-size:11px">Abrir carpeta</button>
      </div>
      <div id="backup-status" style="font-family:DM Mono,monospace;font-size:11px;color:var(--muted);display:none;margin-top:8px;padding:8px 12px;border-radius:6px;background:var(--sur2)"></div>
    </div>
  </div>

  <!-- Mantenimiento de datos -->
  <div class="card" style="margin-bottom:20px">
    <div class="card-hd">
      <div class="card-title">🧹 Mantenimiento de datos</div>
    </div>
    <div class="card-body">
      <div style="background:rgba(212,160,23,.06);border:1px solid rgba(212,160,23,.2);border-radius:8px;padding:12px;margin-bottom:16px;font-family:DM Mono,monospace;font-size:11px;color:var(--amber2);line-height:1.6">
        Limpia lotes huérfanos: lotes vendidos con animales fantasmas, lotes que el servidor ya borró pero quedaron localmente, y referencias a animales sin lote padre. Antes de aplicar, te muestra exactamente qué va a borrar.
      </div>
      <div style="display:flex;gap:8px;flex-wrap:wrap">
        <button class="btn btn-ghost" onclick="cleanupOrphanLots()" style="font-size:12px">🧹 Limpiar lotes huérfanos</button>
      </div>
      <div id="cleanup-result" style="font-family:DM Mono,monospace;font-size:11px;color:var(--muted);display:none;margin-top:10px;padding:10px;border-radius:6px;background:var(--sur2);white-space:pre-wrap"></div>
    </div>
  </div>

  <!-- Backup en la nube -->
  <div class="card" style="margin-bottom:20px">
    <div class="card-hd">
      <div class="card-title">☁️ Backup en la Nube (Railway)</div>
      <span id="cloud-backup-last" style="font-family:DM Mono,monospace;font-size:10px;color:var(--muted)">Sin snapshots</span>
    </div>
    <div class="card-body">
      <div style="background:rgba(88,166,255,.06);border:1px solid rgba(88,166,255,.2);border-radius:8px;padding:12px;margin-bottom:16px;font-family:DM Mono,monospace;font-size:11px;color:var(--blue);line-height:1.6">
        Los snapshots se guardan en Railway (PostgreSQL). Se generan automaticamente cada 24 horas cuando el servidor esta activo. Maximo 30 snapshots guardados.
      </div>
      <div style="display:flex;gap:8px;margin-bottom:14px;flex-wrap:wrap">
        <button class="btn btn-primary" onclick="triggerCloudBackup()" style="font-size:12px">☁️ Crear snapshot ahora</button>
        <button class="btn btn-ghost" onclick="listCloudBackups()" style="font-size:12px">🔄 Ver snapshots</button>
      </div>
      <div id="cloud-backup-list" style="font-size:12px"></div>
    </div>
  </div>

  <!-- App info -->
  <div class="card">
    <div class="card-hd"><div class="card-title">📱 Informacion</div></div>
    <div class="card-body" style="padding:0">
      <div style="display:flex;justify-content:space-between;padding:10px 18px;border-bottom:1px solid rgba(48,54,61,.4);font-size:13px"><span style="color:var(--muted)">Version</span><span style="font-family:DM Mono,monospace" id="app-version">—</span></div>
      <div style="display:flex;justify-content:space-between;padding:10px 18px;border-bottom:1px solid rgba(48,54,61,.4);font-size:13px"><span style="color:var(--muted)">Base de datos</span><span style="font-family:DM Mono,monospace;color:var(--green)">SQLite local ✓</span></div>
      <div style="display:flex;justify-content:space-between;padding:10px 18px;border-bottom:1px solid rgba(48,54,61,.4);font-size:13px"><span style="color:var(--muted)">App Android (PWA)</span><span style="font-family:DM Mono,monospace;color:var(--blue)" id="cfg-pwa-url">-</span></div>
      <div style="padding:10px 18px;border-bottom:1px solid rgba(48,54,61,.4)">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px">
          <span style="color:var(--muted);font-size:13px">GitHub Token (actualizaciones)</span>
          <button class="btn btn-ghost btn-sm" onclick="guardarGhToken()" style="font-size:11px">Guardar</button>
        </div>
        <input type="password" class="form-input" id="cfg-gh-token" placeholder="ghp_xxxxxxxxxxxx" style="font-size:12px;font-family:DM Mono,monospace">
        <div style="font-size:10px;color:var(--muted);margin-top:3px">Necesario para recibir actualizaciones automaticas desde el repositorio privado</div>
      </div>
      <div style="padding:10px 18px;border-bottom:1px solid rgba(48,54,61,.4)">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px">
          <span style="color:var(--muted);font-size:13px">🤖 Gemini API Key (Asistente IA)</span>
          <button class="btn btn-ghost btn-sm" onclick="guardarGeminiKey()" style="font-size:11px">Guardar</button>
        </div>
        <input type="password" class="form-input" id="cfg-gemini-key" placeholder="AIzaSy..." style="font-size:12px;font-family:DM Mono,monospace">
        <div style="font-size:10px;color:var(--muted);margin-top:3px">Para el asistente IA integrado. Obtener en <a href="#" style="color:var(--blue)" onclick="require('electron').shell.openExternal('https://aistudio.google.com/apikey')">aistudio.google.com</a></div>
      </div>
      <!-- ACTUALIZACIONES -->
      <div style="padding:14px 18px;border-bottom:1px solid rgba(48,54,61,.4)">
        <div style="font-size:13px;font-weight:700;margin-bottom:10px">🔄 Actualizaciones</div>
        <div id="update-status" style="font-size:12px;color:var(--muted);margin-bottom:10px;padding:8px 12px;background:var(--sur2);border-radius:6px;border:1px solid var(--bor)">
          Estado: No verificado
        </div>
        <div style="display:flex;gap:8px;flex-wrap:wrap">
          <button class="btn btn-ghost" onclick="checkForAppUpdate()" style="font-size:12px;padding:8px 16px" id="btn-check-update">🔍 Verificar actualizaciones</button>
          <button class="btn btn-ghost" onclick="forceAppUpdate()" style="font-size:12px;padding:8px 16px" id="btn-force-update">⬇️ Actualizar ahora</button>
          <button class="btn btn-ghost" onclick="quitAndInstallUpdate()" style="font-size:12px;padding:8px 16px;display:none;color:var(--green)" id="btn-install-update">🚀 Instalar y reiniciar</button>
          <button class="btn btn-ghost" onclick="restartApp()" style="font-size:12px;padding:8px 16px;color:var(--blue)">🔄 Reiniciar app</button>
        </div>
        <div style="font-size:10px;color:var(--muted);margin-top:6px">Si el auto-updater no funciona, usa "Actualizar ahora" para forzar la descarga desde GitHub</div>
      </div>
      <div style="display:flex;justify-content:space-between;padding:10px 18px;font-size:13px"><span style="color:var(--muted)">SG Bolivia</span><span style="font-family:DM Mono,monospace;color:var(--muted)">sgbolivia.com</span></div>
    </div>
  </div>
</div>

<!-- ═══ TAREAS ═══ -->
<div id="page-tareas" class="page">
  <div class="ph">
    <div><div class="pt">📋 Tareas del Equipo</div><div class="ps">Gestion de actividades por responsable</div></div>
    <button class="btn btn-primary" id="btn-new-task">+ Nueva tarea</button>
    <button class="btn btn-ghost" onclick="publishTasksToPWA()" title="Sincronizar tareas al celular del capataz" style="font-size:12px">📡 Publicar a PWA</button>
  </div>

  <!-- Filtros -->
  <div style="display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap">
    <select id="filter-status" class="form-select" style="width:160px;padding:6px 10px;font-size:12px">
      <option value="">Todos los estados</option>
      <option value="pendiente">Pendiente</option>
      <option value="en_progreso">En progreso</option>
      <option value="revision">En revision</option>
      <option value="completada">Completada</option>
    </select>
    <select id="filter-assignee" class="form-select" style="width:180px;padding:6px 10px;font-size:12px">
      <option value="">Todos los responsables</option>
    </select>
    <select id="filter-priority" class="form-select" style="width:140px;padding:6px 10px;font-size:12px">
      <option value="">Toda prioridad</option>
      <option value="alta">Alta</option>
      <option value="media">Media</option>
      <option value="baja">Baja</option>
    </select>
  </div>

  <!-- Task list -->
