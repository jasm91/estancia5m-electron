function esc(s){return escH(s);}
function escH(str) { return String(str||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

// v1.4.109: normalizar valor de scope para tratamientos. Bot WhatsApp inconsistentemente
// generaba "lote" (español) o "lot" (inglés). Esta función devuelve siempre el valor canónico.
function _normalizeTreatmentScope(t) {
  if (!t) return '';
  var s = String(t.scope || '').toLowerCase();
  if (s === 'lot' || s === 'lote' || s === 'completo' || s === 'lote completo' || s === 'group' || s === 'grupo') return 'lot';
  if (s === 'individual' || s === 'animal' || s === 'single') return 'individual';
  // Inferir si falta scope pero hay pista
  if (!s && t.lot_code && !t.animal_id) return 'lot';
  if (!s && t.animal_id && !t.lot_code) return 'individual';
  return s;
}

// Helper para matchear lote (acepta multi-lote separado por comas)
// Si record.lot_code === "C-02,C-04" y filtro === "C-02", devuelve true
function lotMatches(recordLot, filterLot) {
  if (!filterLot) return true;
  if (!recordLot) return false;
  var s = String(recordLot);
  if (s === filterLot) return true;
  if (s.indexOf(',') >= 0) {
    return s.split(',').map(function(x){return x.trim();}).indexOf(filterLot) >= 0;
  }
  return false;
}

