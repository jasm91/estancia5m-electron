  var rec = {
    nombre: nombre,
    tipo: (document.getElementById('maq-tipo')||{}).value || 'otro',
    modelo: ((document.getElementById('maq-modelo')||{}).value||'').trim(),
    anio: parseInt((document.getElementById('maq-anio')||{}).value) || '',
    valor: parseFloat((document.getElementById('maq-valor')||{}).value) || 0,
    horometro: parseFloat((document.getElementById('maq-horometro')||{}).value) || 0,
    estado: (document.getElementById('maq-estado')||{}).value || 'operativo',
    notas: ((document.getElementById('maq-notas')||{}).value||'').trim(),
  };

  window._maqRenameMig = 0;
  if (editId) {
    var existing = db.maquinaria.find(function(m){return m.id===editId;});
    if (existing) {
      var _oldMaqName = String(existing.nombre||'').trim();   // v1.8.68: nombre previo
      Object.keys(rec).forEach(function(k){ existing[k] = rec[k]; });
      existing.updated_at = new Date().toISOString();
      if (_maqPhotoBase64) existing.photo_url = _maqPhotoBase64;
      // v1.8.68: el historial (diésel/aceite/mantenimiento) se vincula por NOMBRE del equipo,
      // no por id → al renombrar hay que reescribirlo o se huerfana todo el historial.
      if (_oldMaqName && _oldMaqName !== nombre) {
        (db.diesel||[]).forEach(function(r){ if(String(r.vehiculo||'').trim()===_oldMaqName){ r.vehiculo=nombre; window._maqRenameMig++; } });
        (db.aceite||[]).forEach(function(r){ if(String(r.vehiculo||'').trim()===_oldMaqName){ r.vehiculo=nombre; window._maqRenameMig++; } if(String(r.equipo||'').trim()===_oldMaqName){ r.equipo=nombre; window._maqRenameMig++; } });
        (db.maintenance||[]).forEach(function(r){ if(String(r.equipo||'').trim()===_oldMaqName){ r.equipo=nombre; window._maqRenameMig++; } if(String(r.vehiculo||'').trim()===_oldMaqName){ r.vehiculo=nombre; window._maqRenameMig++; } });
      }
      toast(window._maqRenameMig ? ('Equipo actualizado: '+nombre+' · '+window._maqRenameMig+' registro(s) de historial migrados') : ('Equipo actualizado: '+nombre),'success');
    }
  } else {
    rec.id = 'maq_' + Date.now();
    rec.created_at = new Date().toISOString();
    if (_maqPhotoBase64) rec.photo_url = _maqPhotoBase64;
    db.maquinaria.push(rec);
    toast('Equipo registrado: '+nombre,'success');
  }

  saveDB();
  replaceTableInRailway('maquinaria', db.maquinaria || []);
  // v1.8.68: si hubo rename, sincronizar también el historial migrado
  if (window._maqRenameMig) {
    try { replaceTableInRailway('diesel', db.diesel || []); } catch(e){}
    try { replaceTableInRailway('aceite', db.aceite || []); } catch(e){}
    try { replaceTableInRailway('maintenance', db.maintenance || []); } catch(e){}
    window._maqRenameMig = 0;
  }
  closeModal('modal-maquinaria');
  renderMaquinaria();
}

function deleteMaq(id) {
  var _mq = (db.maquinaria||[]).find(function(m){return m.id===id;}); var _mn = _mq ? String(_mq.nombre||'').trim() : '';   // v1.8.75
  var _depM = _mn ? ((db.diesel||[]).filter(function(r){return String(r.vehiculo||'').trim()===_mn;}).length
                   + (db.aceite||[]).filter(function(r){return String(r.vehiculo||'').trim()===_mn||String(r.equipo||'').trim()===_mn;}).length
                   + (db.maintenance||[]).filter(function(r){return String(r.equipo||'').trim()===_mn||String(r.vehiculo||'').trim()===_mn;}).length) : 0;
  if (!confirm('¿Eliminar este equipo?' + (_depM ? '\n\nTiene ' + _depM + ' registro(s) de historial (diésel/aceite/mantenimiento) que quedarán sin equipo.' : ''))) return;
  
  // FIX v1.4.35: audit log para deleteMaq
  var _delRec_deleteMaq = (db.maquinaria || []).find(function(r){ return String(r.id) === String(id); });
  var _delSummary_deleteMaq = _delRec_deleteMaq ? _summarizeRecord('maquinaria', _delRec_deleteMaq) : 'Maquinaria #' + id;
  try { auditLog('delete', 'maquinaria', id, _delSummary_deleteMaq); } catch(e){}
  trackDeletion(id, 'maquinaria');
  db.maquinaria = (db.maquinaria||[]).filter(function(m){return m.id!==id;});
  saveDB();
  replaceTableInRailway('maquinaria', db.maquinaria || []);
  renderMaquinaria();
  toast('Equipo eliminado','success');
}

function viewMaqHistorial(maqId) {
