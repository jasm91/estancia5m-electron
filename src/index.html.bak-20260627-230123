function restoreCloudSnapshot(snapshotId, dateLabel) {
  if (!confirm('⚠️ RESTAURAR SNAPSHOT del ' + dateLabel + '?\nEsto reemplazará TODOS los datos en Railway Y en esta app.\nSe creará un snapshot de seguridad antes de restaurar.\n\n¿Continuar?')) return;
  if (!confirm('SEGUNDA CONFIRMACIÓN: ¿Estás seguro? Los datos actuales serán reemplazados.')) return;
  var apiUrl = getApiUrl();
  var token = localStorage.getItem('e5m_api_token') || '';
  toast('Restaurando snapshot del ' + dateLabel + '...', 'info');

  // CRÍTICO: marcar restore en progreso para que ningún push automático se dispare
  window._restoreInProgress = true;

  fetch(apiUrl + '/cloud-backup/' + snapshotId + '/restore', {
    method: 'POST',
    headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' }
  })
  .then(function(r) { return r.json(); })
  .then(function(d) {
    if (!d.ok) {
      window._restoreInProgress = false;
      toast('Error: ' + (d.error || 'desconocido'), 'error');
      return;
    }
    toast('Server restaurado (' + d.restored_tables + ' tablas). Limpiando local...', 'success');

    // Esperar 1 segundo para que el server termine de escribir todas las tablas
    setTimeout(function() {
      try {
        // Wipear TODO localStorage relevante.
        // Al recargar, sync-pull traerá los datos del server (que ya está restaurado).
        // Preservamos solo cosas que NO son datos: token API, preferencias UI, etc.
        var preserveKeys = {};
        var keysToPreserve = ['e5m_api_token', 'e5m_dark_mode', 'e5m_active_tenant', 'e5m_settings'];
        keysToPreserve.forEach(function(k) {
          var v = localStorage.getItem(k);
          if (v !== null) preserveKeys[k] = v;
        });

        // Limpiar todo
        localStorage.clear();

        // Restaurar las claves que preservamos
        Object.keys(preserveKeys).forEach(function(k) {
          localStorage.setItem(k, preserveKeys[k]);
        });

        console.log('[Restore] localStorage wipeado. Token preservado:', !!preserveKeys.e5m_api_token);
      } catch(err) {
        console.error('[Restore] Error limpiando localStorage:', err);
      }

      toast('Recargando para sincronizar desde server...', 'success');
      // Marcador para que al iniciar haga pull forzado y NO push
      sessionStorage.setItem('_post_restore', '1');
      setTimeout(function() { location.reload(); }, 1500);
    }, 1000);
  })
  .catch(function(err) {
    window._restoreInProgress = false;
    console.error('[Restore] Error de red:', err);
    toast('Error de conexión al restaurar', 'error');
  });
}

// Auto-backup local al iniciar (guarda últimos 3 días en localStorage)
(function autoLocalBackupOnStart() {
  try {
    var backup = getBackupData();
    var key = 'e5m_startup_backup_' + localDate();
    var allKeys = [];
    for (var i = 0; i < localStorage.length; i++) {
      var k = localStorage.key(i);
      if (k && k.indexOf('e5m_startup_backup_') === 0) allKeys.push(k);
    }
    allKeys.sort().reverse();
    for (var j = 2; j < allKeys.length; j++) localStorage.removeItem(allKeys[j]);
    localStorage.setItem(key, JSON.stringify(backup));
    // console.log('[Backup] Startup backup:', key, Math.round(JSON.stringify(backup).length/1024) + 'KB');
  } catch(e) { console.warn('[Backup] Startup backup error:', e); }
})();

