function switchTab(prefix,btnOrId,targetId) {
  var btn = typeof btnOrId === 'string' ? document.getElementById(btnOrId) : btnOrId;
  if (!btn) return;
  var tabs = btn.closest('.tabs');
  if (tabs) tabs.querySelectorAll('.tab-btn').forEach(function(b){b.classList.remove('active');});
